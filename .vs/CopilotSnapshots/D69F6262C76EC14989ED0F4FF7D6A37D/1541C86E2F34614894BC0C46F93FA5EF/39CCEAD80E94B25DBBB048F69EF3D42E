@page
@model TechNova_IT_Solutions.Pages.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechNova</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #0f1219;
            color: #e5e7eb;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 270px;
            background: #1a1d2e;
            border-right: 1px solid #2d3548;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
        }

        .logo {
            padding: 24px 20px;
            border-bottom: 1px solid #2d3548;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-icon {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            width: 48px;
            height: 48px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
        }

        .logo-icon img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .logo-text h1 {
            font-size: 18px;
            font-weight: 600;
            color: white;
        }

        .logo-text p {
            font-size: 12px;
            color: #9ca3af;
        }

        .nav-menu {
            padding: 20px 16px;
            flex: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #9ca3af;
            text-decoration: none;
            border-radius: 8px;
            margin-bottom: 4px;
            transition: all 0.2s;
        }

        .nav-item:hover {
            background: #252940;
            color: white;
        }

        .nav-item.active {
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            color: white;
        }

        .nav-item svg {
            width: 20px;
            height: 20px;
        }

        .user-profile {
            padding: 20px;
            border-top: 1px solid #2d3548;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 16px;
        }

        .user-info h4 {
            font-size: 14px;
            font-weight: 600;
        }

        .user-info p {
            font-size: 12px;
            color: #9ca3af;
        }

        /* Main Content */
        .main-content {
            margin-left: 270px;
            flex: 1;
            padding: 32px;
            overflow-y: auto;
        }

        .page-header {
            margin-bottom: 32px;
        }

        .page-header h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .page-header p {
            color: #9ca3af;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .card {
            background: #1a1d2e;
            border: 1px solid #2d3548;
            border-radius: 12px;
            padding: 24px;
            transition: transform 0.2s;
        }

        .card:hover {
            transform: translateY(-2px);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

        .card-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-icon svg {
            width: 24px;
            height: 24px;
        }

        .card-icon.blue {
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
        }

        .card-icon.green {
            background: rgba(34, 197, 94, 0.1);
            color: #22c55e;
        }

        .card-icon.purple {
            background: rgba(168, 85, 247, 0.1);
            color: #a855f7;
        }

        .card-icon.orange {
            background: rgba(249, 115, 22, 0.1);
            color: #f97316;
        }

        .card-icon.red {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

        .card-value {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .card-label {
            font-size: 14px;
            color: #9ca3af;
        }

        /* Two Column Layout */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        /* Chart */
        .chart-container {
            background: #1a1d2e;
            border: 1px solid #2d3548;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .compliance-bars {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-top: 20px;
        }

        .bar-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .bar-label {
            width: 100px;
            font-size: 14px;
            color: #9ca3af;
        }

        .bar-container {
            flex: 1;
            height: 32px;
            background: #252940;
            border-radius: 8px;
            overflow: hidden;
            position: relative;
        }

        .bar-fill {
            height: 100%;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 12px;
            font-size: 14px;
            font-weight: 600;
            transition: width 0.3s;
        }

        .bar-fill.green {
            background: linear-gradient(90deg, #22c55e, #16a34a);
        }

        .bar-fill.yellow {
            background: linear-gradient(90deg, #eab308, #ca8a04);
        }

        .bar-fill.red {
            background: linear-gradient(90deg, #ef4444, #dc2626);
        }

        /* Tables */
        .table-container {
            background: #1a1d2e;
            border: 1px solid #2d3548;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .table-header {
            padding: 20px 24px;
            border-bottom: 1px solid #2d3548;
        }

        .table-header h3 {
            font-size: 16px;
            font-weight: 600;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #252940;
        }

        th {
            text-align: left;
            padding: 12px 24px;
            font-size: 12px;
            font-weight: 600;
            color: #9ca3af;
            text-transform: uppercase;
        }

        td {
            padding: 16px 24px;
            border-top: 1px solid #2d3548;
            font-size: 14px;
        }

        tbody tr:hover {
            background: #252940;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.success {
            background: rgba(34, 197, 94, 0.1);
            color: #22c55e;
        }

        .status-badge.warning {
            background: rgba(234, 179, 8, 0.1);
            color: #eab308;
        }

        .status-badge.danger {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

        /* Supplier Summary */
        .supplier-summary {
            background: #1a1d2e;
            border: 1px solid #2d3548;
            border-radius: 12px;
            padding: 24px;
        }

        .summary-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid #2d3548;
        }

        .summary-item:last-child {
            border-bottom: none;
        }

        .summary-label {
            font-size: 14px;
            color: #9ca3af;
        }

        .summary-value {
            font-size: 24px;
            font-weight: 700;
        }

        /* Quick Actions */
        .quick-actions {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 32px;
        }

        .btn-action {
            padding: 12px 24px;
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-action:hover {
            opacity: 0.9;
        }

        .btn-action svg {
            width: 18px;
            height: 18px;
        }

        /* Responsive */
        @@media (max-width: 1200px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .main-content {
                margin-left: 0;
                padding: 20px;
            }

            .summary-cards {
                grid-template-columns: 1fr;
            }

            .quick-actions {
                flex-direction: column;
            }

            .btn-action {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="logo">
            <div class="logo-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
            </div>
            <div class="logo-text">
                <h1>TechNova</h1>
                <p>Admin Portal</p>
            </div>
        </div>

        <nav class="nav-menu">
            <a href="/Dashboard" class="nav-item active">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"></rect>
                    <rect x="14" y="3" width="7" height="7"></rect>
                    <rect x="14" y="14" width="7" height="7"></rect>
                    <rect x="3" y="14" width="7" height="7"></rect>
                </svg>
                Dashboard
            </a>
            <a href="#" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                User Management
            </a>
            <a href="#" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                </svg>
                Policy Management
            </a>
            <a href="#" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                Compliance Monitoring
            </a>
            <a href="#" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
                Audit Logs
            </a>
            <a href="#" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                    <line x1="1" y1="10" x2="23" y2="10"></line>
                </svg>
                Procurement & Suppliers
            </a>
            <a href="#" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                Regulatory Reports
            </a>
            <a href="/Account/Logout" class="nav-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                Logout
            </a>
        </nav>

        <div class="user-profile">
            <div class="user-avatar">@Model.UserName.Substring(0, Math.Min(2, Model.UserName.Length)).ToUpper()</div>
            <div class="user-info">
                <h4>@Model.UserName</h4>
                <p>@Model.UserEmail</p>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1>Admin Dashboard</h1>
            <p>Compliance and Procurement Management System Overview</p>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <button class="btn-action">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Add User
            </button>
            <button class="btn-action">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="17 8 12 3 7 8"></polyline>
                    <line x1="12" y1="3" x2="12" y2="15"></line>
                </svg>
                Upload Policy
            </button>
            <button class="btn-action">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                Add Supplier
            </button>
            <button class="btn-action">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"></circle>
                    <circle cx="20" cy="21" r="1"></circle>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                Add Procurement
            </button>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="card">
                <div class="card-header">
                    <div class="card-icon blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                </div>
                <div class="card-value">@Model.TotalUsers</div>
                <div class="card-label">Total Users</div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                        </svg>
                    </div>
                </div>
                <div class="card-value">@Model.TotalPolicies</div>
                <div class="card-label">Total Policies</div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon purple">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                </div>
                <div class="card-value">@Model.TotalSuppliers</div>
                <div class="card-label">Total Suppliers</div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon orange">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                    </div>
                </div>
                <div class="card-value">@Model.TotalProcurementRecords</div>
                <div class="card-label">Procurement Records</div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                    </div>
                </div>
                <div class="card-value">@Model.PendingCompliance</div>
                <div class="card-label">Pending Compliance</div>
            </div>
        </div>

        <!-- Two Column Grid -->
        <div class="dashboard-grid">
            <!-- Left Column -->
            <div>
                <!-- Compliance Status Chart -->
                <div class="chart-container">
                    <h3 class="section-title">Compliance Status Summary</h3>
                    <div class="compliance-bars">
                        <div class="bar-item">
                            <div class="bar-label">Complied</div>
                            <div class="bar-container">
                                <div class="bar-fill green" style="width: @((Model.CompliedCount * 100.0 / (Model.CompliedCount + Model.PendingCount + Model.OverdueCount)).ToString("F0"))%">
                                    @Model.CompliedCount
                                </div>
                            </div>
                        </div>
                        <div class="bar-item">
                            <div class="bar-label">Pending</div>
                            <div class="bar-container">
                                <div class="bar-fill yellow" style="width: @((Model.PendingCount * 100.0 / (Model.CompliedCount + Model.PendingCount + Model.OverdueCount)).ToString("F0"))%">
                                    @Model.PendingCount
                                </div>
                            </div>
                        </div>
                        <div class="bar-item">
                            <div class="bar-label">Overdue</div>
                            <div class="bar-container">
                                <div class="bar-fill red" style="width: @((Model.OverdueCount * 100.0 / (Model.CompliedCount + Model.PendingCount + Model.OverdueCount)).ToString("F0"))%">
                                    @Model.OverdueCount
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Policy Activities -->
                <div class="table-container">
                    <div class="table-header">
                        <h3>Recent Policy Activities</h3>
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>Policy Title</th>
                                <th>Action</th>
                                <th>Performed By</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Data Privacy Policy</td>
                                <td><span class="status-badge success">Updated</span></td>
                                <td>John Smith</td>
                                <td>2024-01-15</td>
                            </tr>
                            <tr>
                                <td>Security Compliance</td>
                                <td><span class="status-badge success">Approved</span></td>
                                <td>Sarah Johnson</td>
                                <td>2024-01-14</td>
                            </tr>
                            <tr>
                                <td>Vendor Code of Conduct</td>
                                <td><span class="status-badge warning">Under Review</span></td>
                                <td>Mike Davis</td>
                                <td>2024-01-13</td>
                            </tr>
                            <tr>
                                <td>Financial Compliance</td>
                                <td><span class="status-badge success">Published</span></td>
                                <td>Emily Brown</td>
                                <td>2024-01-12</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right Column -->
            <div>
                <!-- Recent Procurement -->
                <div class="table-container">
                    <div class="table-header">
                        <h3>Recent Procurement</h3>
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>Item Name</th>
                                <th>Supplier</th>
                                <th>Quantity</th>
                                <th>Purchase Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Office Supplies</td>
                                <td>ABC Corp</td>
                                <td>250</td>
                                <td>2024-01-15</td>
                            </tr>
                            <tr>
                                <td>IT Equipment</td>
                                <td>Tech Solutions</td>
