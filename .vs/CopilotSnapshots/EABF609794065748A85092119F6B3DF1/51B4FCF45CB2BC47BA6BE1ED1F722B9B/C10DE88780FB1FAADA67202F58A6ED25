@page
@model TechNova_IT_Solutions.Pages.Supplier.InventoryModel
@{
    ViewData["Title"] = "Inventory";
    Layout = "_Layout";
}

@section Styles {
<style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f8f9fa; }
    .main-content { margin-left: 260px; min-height: 100vh; }
    .content-wrapper { padding: 24px; max-width: 1260px; margin: 0 auto; }

    /* Summary cards */
    .summary-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 16px; margin-bottom: 20px; }
    .summary-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 18px 20px; }
    .summary-label { color: #6b7280; font-size: 12px; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; font-weight: 700; }
    .summary-value { color: #1f2937; font-size: 28px; font-weight: 700; line-height: 1; }

    /* Alerts */
    .stock-alerts { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
    .stock-alert { border-radius: 10px; padding: 10px 14px; font-size: 13px; font-weight: 600; border: 1px solid; }
    .stock-alert.low { color: #92400e; background: #fffbeb; border-color: #fcd34d; }
    .stock-alert.out { color: #991b1b; background: #fef2f2; border-color: #fca5a5; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 9px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: background .15s, transform .1s; }
    .btn:hover { transform: translateY(-1px); }
    .btn-primary { background: #1e40af; color: #fff; }
    .btn-primary:hover { background: #1e3a8a; }
    .btn-sm { padding: 5px 10px; font-size: 12px; }
    .btn-outline { background: transparent; border: 1px solid #d1d5db; color: #374151; }
    .btn-outline:hover { background: #f1f5f9; }
    .btn-teal { background: #0f766e; color: #fff; }
    .btn-teal:hover { background: #0d6b63; }

    /* Table card */
    .table-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
    .table-header { padding: 16px 20px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
    .table-header-info h3 { margin: 0 0 2px; font-size: 18px; font-weight: 700; color: #1e293b; }
    .table-header-info p { margin: 0; font-size: 13px; color: #64748b; }
    table { width: 100%; border-collapse: collapse; }
    th { background: #f8fafc; padding: 11px 16px; text-align: left; font-size: 12px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: .04em; }
    td { padding: 13px 16px; border-top: 1px solid #f1f5f9; font-size: 13px; color: #1e293b; vertical-align: middle; }
    tr:hover td { background: #fafbff; }
    .empty-state { text-align: center; padding: 56px 24px; }
    .empty-state p { margin: 0; color: #94a3b8; font-size: 14px; }

    /* Badges */
    .badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .badge-green { color: #16a34a; border: 1.5px solid #16a34a; }
    .badge-amber { color: #d97706; border: 1.5px solid #d97706; }
    .badge-red { color: #dc2626; border: 1.5px solid #dc2626; }

    /* Modal */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,.5); z-index: 1000; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .inv-modal-card { background: #fff; border-radius: 14px; width: 500px; max-width: 95vw; overflow: hidden; box-shadow: 0 20px 48px rgba(15,23,42,.2); }
    .inv-modal-head { padding: 18px 20px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
    .inv-modal-head h3 { margin: 0; font-size: 18px; font-weight: 700; color: #1e293b; }
    .inv-modal-close-btn { background: #f1f5f9; border: none; width: 34px; height: 34px; border-radius: 8px; font-size: 18px; color: #334155; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .inv-modal-close-btn:hover { background: #e2e8f0; }
    .inv-modal-body { padding: 20px; display: grid; gap: 14px; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group label { font-size: 13px; font-weight: 600; color: #374151; }
    .form-group input, .form-group select { width: 100%; padding: 9px 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 13px; color: #1f2937; box-sizing: border-box; }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: #1e40af; box-shadow: 0 0 0 3px rgba(30,64,175,.08); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .inv-modal-actions { border-top: 1px solid #e5e7eb; padding: 16px 20px; display: flex; justify-content: flex-end; gap: 10px; }

    /* Alert strip */
    .alert-strip { padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 14px; display: none; }
    .alert-strip.success { background: #d1fae5; color: #065f46; display: block; }
    .alert-strip.error { background: #fee2e2; color: #991b1b; display: block; }

    @@media (max-width: 991px) { .main-content { margin-left: 0; } .summary-grid { grid-template-columns: 1fr; } .stock-alerts { grid-template-columns: 1fr; } .form-row { grid-template-columns: 1fr; } }
    .loading-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,42,.6); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:16px; }
    .loading-overlay.active { display:flex; }
    .loading-spinner { width:48px; height:48px; border:4px solid rgba(255,255,255,.3); border-top:4px solid #fff; border-radius:50%; animation:spin .8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>
}

<div class="loading-overlay" id="loadingOverlay"><div class="loading-spinner"></div><div id="loadingText" style="color:#fff;font-size:16px;font-weight:500;">Processing...</div></div>
@await Html.PartialAsync("_SupplierSidebar", "Inventory")

<div class="main-content">
    @await Html.PartialAsync("_SupplierTopBar", (Title: "Inventory", Description: "Manage your product catalogue and stock levels"))

    <div class="content-wrapper">
        <div class="summary-grid">
            <div class="summary-card">
                <div class="summary-label">Total Items</div>
                <div class="summary-value">@Model.Items.Count</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Low Stock</div>
                <div class="summary-value" style="color:#d97706;">@Model.Items.Count(i => i.QuantityAvailable > 0 && i.QuantityAvailable <= 10)</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Out of Stock</div>
                <div class="summary-value" style="color:#dc2626;">@Model.Items.Count(i => i.Status == "OutOfStock" || i.QuantityAvailable <= 0)</div>
            </div>
        </div>

        @if (Model.Items.Any(i => i.QuantityAvailable > 0 && i.QuantityAvailable <= 10) || Model.Items.Any(i => i.Status == "OutOfStock" || i.QuantityAvailable <= 0))
        {
            <div class="stock-alerts">
                @if (Model.Items.Any(i => i.QuantityAvailable > 0 && i.QuantityAvailable <= 10))
                {
                    <div class="stock-alert low">Low stock warning: @Model.Items.Count(i => i.QuantityAvailable > 0 && i.QuantityAvailable <= 10) item(s) are at or below 10 units.</div>
                }
                @if (Model.Items.Any(i => i.Status == "OutOfStock" || i.QuantityAvailable <= 0))
                {
                    <div class="stock-alert out">Out of stock alert: @Model.Items.Count(i => i.Status == "OutOfStock" || i.QuantityAvailable <= 0) item(s) need replenishment.</div>
                }
            </div>
        }

        <div id="alertBox" class="alert-strip"></div>

        <div class="table-card">
            <div class="table-header">
                <div class="table-header-info">
                    <h3>Your Items (@Model.Items.Count)</h3>
                    <p>@(string.IsNullOrEmpty(Model.SupplierName) ? "Manage items, prices, and stock quantities" : Model.SupplierName + " — manage your items, prices, and stock quantities")</p>
                </div>
                <button class="btn btn-primary" onclick="openAddModal()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add Item
                </button>
            </div>

            @if (Model.Items.Count == 0)
            {
                <div class="empty-state">
                    <p>No inventory items yet. Click <strong>Add Item</strong> to get started.</p>
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th>Category</th>
                            <th>Unit Price</th>
                            <th>Qty Available</th>
                            <th>Status</th>
                            <th>Last Updated</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var badgeClass = item.Status == "Available" ? "badge-green"
                                           : (item.QuantityAvailable > 0 && item.QuantityAvailable <= 10 ? "badge-amber" : "badge-red");
                            <tr>
                                <td style="font-weight:600;">@item.ItemName</td>
                                <td style="color:#64748b;">@(item.Category ?? "—")</td>
                                <td>@item.CurrencyCode @item.UnitPrice.ToString("F2")</td>
                                <td>@item.QuantityAvailable</td>
                                <td><span class="badge @badgeClass">@item.Status</span></td>
                                <td style="color:#64748b;">@item.LastUpdated.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div style="display:flex;gap:6px;">
                                        <button class="btn btn-sm btn-outline"
                                            onclick="openEditModal(@item.SupplierItemId, '@Html.Raw(item.ItemName.Replace("'","\\\'"))', '@(item.Category ?? "")', @item.UnitPrice, '@item.CurrencyCode', @item.QuantityAvailable)">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm btn-teal"
                                            onclick="openStockModal(@item.SupplierItemId, '@Html.Raw(item.ItemName.Replace("'","\\\'"))')">
                                            + Stock
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<!-- Add / Edit Modal -->
<div class="modal-overlay" id="itemModal">
    <div class="inv-modal-card">
        <div class="inv-modal-head">
            <h3 id="itemModalTitle">Add Item</h3>
            <button class="inv-modal-close-btn" onclick="closeItemModal()">&times;</button>
        </div>
        <div class="inv-modal-body">
            <input type="hidden" id="editItemId" value="0" />
            <div class="form-group">
                <label>Item Name *</label>
                <input type="text" id="itemName" placeholder="e.g. Office Chair" maxlength="255" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Category</label>
                    <input type="text" id="itemCategory" placeholder="e.g. Furniture" maxlength="100" />
                </div>
                <div class="form-group">
                    <label>Currency</label>
                    <select id="itemCurrency">
                        <option value="PHP">PHP – Philippine Peso</option>
                        <option value="USD">USD – US Dollar</option>
                        <option value="EUR">EUR – Euro</option>
                        <option value="JPY">JPY – Japanese Yen</option>
                        <option value="GBP">GBP – British Pound</option>
                        <option value="AUD">AUD – Australian Dollar</option>
                        <option value="CAD">CAD – Canadian Dollar</option>
                        <option value="SGD">SGD – Singapore Dollar</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="grid-column:1/-1;">
                    <label>Unit Price *</label>
                    <input type="number" id="itemPrice" min="0.01" step="0.01" placeholder="0.00" />
                </div>
            </div>
            <input type="hidden" id="itemQty" value="0" />
        </div>
        <div class="inv-modal-actions">
            <button class="btn btn-outline" onclick="closeItemModal()">Cancel</button>
            <button class="btn btn-primary" onclick="saveItem()">Save Item</button>
        </div>
    </div>
</div>

<!-- Add Stock Modal -->
<div class="modal-overlay" id="stockModal">
    <div class="inv-modal-card">
        <div class="inv-modal-head">
            <h3>Add Stock</h3>
            <button class="inv-modal-close-btn" onclick="closeStockModal()">&times;</button>
        </div>
        <div class="inv-modal-body">
            <input type="hidden" id="stockItemId" value="0" />
            <div class="form-group">
                <label>Item</label>
                <input type="text" id="stockItemLabel" readonly style="background:#f8fafc;color:#64748b;" />
            </div>
            <div class="form-group">
                <label>Quantity to Add *</label>
                <input type="number" id="stockQty" min="1" step="1" placeholder="e.g. 50" />
            </div>
        </div>
        <div class="inv-modal-actions">
            <button class="btn btn-outline" onclick="closeStockModal()">Cancel</button>
            <button class="btn btn-teal" onclick="addStock()">Add Stock</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showLoading(msg) { document.getElementById('loadingText').textContent = msg || 'Processing...'; document.getElementById('loadingOverlay').classList.add('active'); }
    function hideLoading() { document.getElementById('loadingOverlay').classList.remove('active'); }

    function showAlert(msg, type) {
        const box = document.getElementById('alertBox');
        box.textContent = msg;
        box.className = 'alert-strip ' + type;
        setTimeout(() => { box.className = 'alert-strip'; box.textContent = ''; }, 4000);
    }

    function openAddModal() {
        document.getElementById('itemModalTitle').textContent = 'Add Item';
        document.getElementById('editItemId').value = '0';
        document.getElementById('itemName').value = '';
        document.getElementById('itemCategory').value = '';
        document.getElementById('itemCurrency').value = 'PHP';
        document.getElementById('itemPrice').value = '';
        document.getElementById('itemQty').value = '0';
        document.getElementById('itemModal').classList.add('open');
    }

    function openEditModal(id, name, category, price, currency, qty) {
        document.getElementById('itemModalTitle').textContent = 'Edit Item';
        document.getElementById('editItemId').value = id;
        document.getElementById('itemName').value = name;
        document.getElementById('itemCategory').value = category;
        document.getElementById('itemCurrency').value = currency;
        document.getElementById('itemPrice').value = price;
        document.getElementById('itemQty').value = qty;
        document.getElementById('itemModal').classList.add('open');
    }

    function closeItemModal() { document.getElementById('itemModal').classList.remove('open'); }

    function openStockModal(id, name) {
        document.getElementById('stockItemId').value = id;
        document.getElementById('stockItemLabel').value = name;
        document.getElementById('stockQty').value = '';
        document.getElementById('stockModal').classList.add('open');
    }

    function closeStockModal() { document.getElementById('stockModal').classList.remove('open'); }

    document.getElementById('itemModal').addEventListener('click', e => { if (e.target === document.getElementById('itemModal')) closeItemModal(); });
    document.getElementById('stockModal').addEventListener('click', e => { if (e.target === document.getElementById('stockModal')) closeStockModal(); });

    async function saveItem() {
        const itemId = parseInt(document.getElementById('editItemId').value);
        const itemName = document.getElementById('itemName').value.trim();
        const category = document.getElementById('itemCategory').value.trim();
        const price = parseFloat(document.getElementById('itemPrice').value);
        const currency = document.getElementById('itemCurrency').value;
        const qty = parseInt(document.getElementById('itemQty').value) || 0;

        if (!itemName) { showAlert('Item name is required.', 'error'); return; }
        if (!price || price <= 0) { showAlert('Unit price must be greater than zero.', 'error'); return; }

        const _t = setTimeout(() => showLoading('Saving item...'), 300);
        try {
            const resp = await fetch('/Supplier/UpsertInventoryItem', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ supplierItemId: itemId, itemName, category, unitPrice: price, currencyCode: currency, quantityAvailable: qty })
            });
            const data = await resp.json();
            clearTimeout(_t); hideLoading();
            if (data.success) {
                closeItemModal();
                showAlert('Item saved successfully.', 'success');
                setTimeout(() => location.reload(), 1200);
            } else {
                showAlert(data.message || 'Failed to save item.', 'error');
            }
        } catch { clearTimeout(_t); hideLoading(); showAlert('Error saving item.', 'error'); }
    }

    async function addStock() {
        const itemId = parseInt(document.getElementById('stockItemId').value);
        const qty = parseInt(document.getElementById('stockQty').value);
        if (!qty || qty <= 0) { showAlert('Quantity must be greater than zero.', 'error'); return; }

        const _t = setTimeout(() => showLoading('Updating stock...'), 300);
        try {
            const resp = await fetch('/Supplier/AddInventoryStock', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ supplierItemId: itemId, addQuantity: qty })
            });
            const data = await resp.json();
            clearTimeout(_t); hideLoading();
            if (data.success) {
                closeStockModal();
                showAlert('Stock updated successfully.', 'success');
                setTimeout(() => location.reload(), 1200);
            } else {
                showAlert(data.message || 'Failed to update stock.', 'error');
            }
        } catch { clearTimeout(_t); hideLoading(); showAlert('Error updating stock.', 'error'); }
    }
</script>
}
