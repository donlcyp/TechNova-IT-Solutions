    /* ── JS Escape for inline strings ──────────────── */
    function escJs(s) { return (s || '').replace(/'/g, "\\'").replace(/"/g, '&quot;'); }

    /* ── Create Violation ──────────────────────────── */
    function openCreateViolation() {
        document.getElementById('cvType').value = 'Employee';
        document.getElementById('cvAssignmentId').value = '';
        document.getElementById('cvSupplierPolicyId').value = '';
        document.getElementById('cvDescription').value = '';
        document.getElementById('cvNotes').value = '';
        onViolationTypeChange();
        document.getElementById('createViolationModal').classList.add('active');
    }
    function closeCreateViolation() { document.getElementById('createViolationModal').classList.remove('active'); }

    function raiseViolationFor(type, assignmentId, supplierPolicyId, name, policy) {
        document.getElementById('cvType').value = type;
        onViolationTypeChange();
        if (type === 'Employee') document.getElementById('cvAssignmentId').value = assignmentId || '';
        else document.getElementById('cvSupplierPolicyId').value = supplierPolicyId || '';
        document.getElementById('cvDescription').value = `Non-compliance violation for ${name} regarding policy: ${policy}`;
        document.getElementById('cvNotes').value = '';
        document.getElementById('createViolationModal').classList.add('active');
    }

    function onViolationTypeChange() {
        const isEmp = document.getElementById('cvType').value === 'Employee';
        document.getElementById('cvAssignmentGroup').style.display = isEmp ? '' : 'none';
        document.getElementById('cvSupplierPolicyGroup').style.display = isEmp ? 'none' : '';
    }

    async function submitCreateViolation() {
        const type = document.getElementById('cvType').value;
        const desc = document.getElementById('cvDescription').value.trim();
        if (!desc) { await window.showAppMessage('Description is required.', 'Validation'); return; }

        const body = {
            violationType: type,
            policyAssignmentId: type === 'Employee' ? (parseInt(document.getElementById('cvAssignmentId').value) || null) : null,
            supplierPolicyId: type === 'Supplier' ? (parseInt(document.getElementById('cvSupplierPolicyId').value) || null) : null,
            description: desc,
            notes: document.getElementById('cvNotes').value.trim() || null
        };

        const _t = setTimeout(() => showLoading('Creating violation...'), 300);
        fetch(API + '/CreateViolation', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
            .then(r => r.json())
            .then(async res => {
                clearTimeout(_t); hideLoading();
                if (res.success) { await window.showAppMessage(res.message, 'Success'); closeCreateViolation(); location.reload(); }
                else { await window.showAppMessage(res.message || 'Failed', 'Error'); }
            }).catch(async () => { clearTimeout(_t); hideLoading(); await window.showAppMessage('Error creating violation', 'Error'); });
    }

    /* ── Timeline helpers ─────────────────────────── */
    const statusColors = { Open: '#d97706', UnderReview: '#2563eb', Escalated: '#dc2626', Resolved: '#16a34a' };
    function parseTimeline(notes) {
        if (!notes) return [];
        const items = [], re = /^\[TIMELINE:([^:]+):([^\]]+)\] (.+)$/;
        notes.split('\n').forEach(line => { const m = line.trim().match(re); if (m) items.push({ status: m[1], date: m[2], event: m[3] }); });
        return items;
    }
    function parseNotes(notes) {
        if (!notes) return '';
        return notes.split('\n').filter(l => !l.trim().match(/^\[TIMELINE:/)).join('\n').trim();
    }
    function renderTimeline(items) {
        if (!items.length) return '';
        let html = '<div style="margin-bottom:18px;"><div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;">Timeline</div>';
        items.forEach((item, i) => {
            const color = statusColors[item.status] || '#6b7280';
            const isLast = i === items.length - 1;
            html += '<div style="display:flex;gap:12px;">'
                + '<div style="display:flex;flex-direction:column;align-items:center;">'
                + '<div style="width:12px;height:12px;border-radius:50%;background:' + color + ';flex-shrink:0;margin-top:3px;"></div>'
                + (!isLast ? '<div style="width:2px;flex:1;background:#e5e7eb;min-height:22px;margin:3px 0;"></div>' : '')
                + '</div>'
                + '<div style="padding-bottom:' + (isLast ? '0' : '14px') + ';"><div style="font-size:13px;font-weight:600;color:#1f2937;">' + item.event + '</div><div style="font-size:11px;color:#9ca3af;margin-top:1px;">' + item.date + ' UTC</div></div>'
                + '</div>';
        });
        html += '</div>';
        return html;
    }

    /* ── Update Violation Status ───────────────────── */
    function openUpdateViolation(v) {
        currentViolationId = v.violationId;
        document.getElementById('updateModalTitle').textContent = `Violation #${v.violationId}`;
        document.getElementById('violationDetailGrid').innerHTML = `
            <div class="detail-item"><div class="label">Type</div><div class="value">${v.violationType}</div></div>
            <div class="detail-item"><div class="label">Subject</div><div class="value">${v.subjectName}</div></div>
            <div class="detail-item"><div class="label">Policy</div><div class="value">${v.policyName}</div></div>
            <div class="detail-item"><div class="label">Status</div><div class="value"><span class="status-badge ${v.status.toLowerCase().replace(/\\s+/g,'')}">${formatStatus(v.status)}</span></div></div>
            <div class="detail-item"><div class="label">Raised</div><div class="value">${v.raisedDate}</div></div>
            <div class="detail-item"><div class="label">Raised By</div><div class="value">${v.raisedBy}</div></div>
            ${v.resolvedDate ? `<div class="detail-item"><div class="label">Resolved</div><div class="value">${v.resolvedDate}</div></div>` : ''}
            ${v.resolution ? `<div class="detail-item"><div class="label">Resolution</div><div class="value">${v.resolution}</div></div>` : ''}
        `;
        // Timeline
        const timelineItems = parseTimeline(v.notes);
        const timelineEl = document.getElementById('violationTimeline');
        if (timelineItems.length) { timelineEl.innerHTML = renderTimeline(timelineItems); timelineEl.style.display = ''; }
        else { timelineEl.style.display = 'none'; }
        // Notes (strip internal TIMELINE marker lines)
        const cleanNotes = parseNotes(v.notes);
        const notesEl = document.getElementById('violationNotesHistory');
        if (cleanNotes) { notesEl.textContent = cleanNotes; notesEl.style.display = ''; }
        else { notesEl.style.display = 'none'; }
        const isResolved = v.status === 'Resolved';
        document.getElementById('uvUpdateSection').style.display = isResolved ? 'none' : '';
        document.getElementById('uvUpdateBtn').style.display = isResolved ? 'none' : '';
        if (!isResolved) {
            document.getElementById('uvStatus').value = v.status;
            document.getElementById('uvNotes').value = '';
            document.getElementById('uvResolution').value = '';
            checkResolutionVisibility();
        }
        document.getElementById('updateViolationModal').classList.add('active');
    }
    function closeUpdateViolation() { document.getElementById('updateViolationModal').classList.remove('active'); currentViolationId = null; }

    document.getElementById('uvStatus').addEventListener('change', checkResolutionVisibility);
    function checkResolutionVisibility() {
        document.getElementById('uvResolutionGroup').style.display = document.getElementById('uvStatus').value === 'Resolved' ? '' : 'none';
    }

    async function submitUpdateViolation() {
        if (!currentViolationId) return;
        const body = {
            status: document.getElementById('uvStatus').value,
            notes: document.getElementById('uvNotes').value.trim() || null,
            resolution: document.getElementById('uvResolution').value.trim() || null
        };

        const _t = setTimeout(() => showLoading('Updating violation status...'), 300);
        fetch(`${API}/UpdateViolationStatus?violationId=${currentViolationId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
            .then(r => r.json())
            .then(async res => {
                clearTimeout(_t); hideLoading();
                if (res.success) { await window.showAppMessage('Violation updated', 'Success'); closeUpdateViolation(); location.reload(); }
                else { await window.showAppMessage(res.message || 'Failed', 'Error'); }
            }).catch(async () => { clearTimeout(_t); hideLoading(); await window.showAppMessage('Error updating violation', 'Error'); });
    }

    /* ── Suspend / Unsuspend Employee ──────────────── */
    async function suspendEmployee(id, name) {
        const ok = await window.showAppConfirm(`Suspend employee "${name}"?`);
        if (!ok) return;
        const _t = setTimeout(() => showLoading('Suspending employee...'), 300);
        fetch(`${API}/SuspendEmployee?userId=${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: 'Suspended' }) })
            .then(r => r.json())
            .then(async res => { clearTimeout(_t); hideLoading(); if (res.success) { await window.showAppMessage(res.message, 'Success'); loadCompliantEmployees(); } else { await window.showAppMessage(res.message, 'Error'); } })
            .catch(async () => { clearTimeout(_t); hideLoading(); await window.showAppMessage('Error suspending employee', 'Error'); });
    }

    async function unsuspendEmployee(id, name) {
        const ok = await window.showAppConfirm(`Reactivate employee "${name}"?`);
        if (!ok) return;
        const _t = setTimeout(() => showLoading('Reactivating employee...'), 300);
        fetch(`${API}/UnsuspendEmployee?userId=${id}`, { method: 'POST' })
            .then(r => r.json())
            .then(async res => { clearTimeout(_t); hideLoading(); if (res.success) { await window.showAppMessage(res.message, 'Success'); loadCompliantEmployees(); } else { await window.showAppMessage(res.message, 'Error'); } })
            .catch(async () => { clearTimeout(_t); hideLoading(); await window.showAppMessage('Error reactivating employee', 'Error'); });
    }

    /* ── Suspend / Unsuspend Supplier ──────────────── */
    async function suspendSupplier(id, name) {
        const ok = await window.showAppConfirm(`Suspend supplier "${name}" for non-compliance?`);
        if (!ok) return;
        const _t = setTimeout(() => showLoading('Suspending supplier...'), 300);
        fetch(`${API}/SuspendSupplier?supplierId=${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: 'Suspended for non-compliance' }) })
            .then(r => r.json())
            .then(async res => { clearTimeout(_t); hideLoading(); if (res.success) { await window.showAppMessage(res.message, 'Success'); loadNonCompliantSuppliers(); } else { await window.showAppMessage(res.message, 'Error'); } })
            .catch(async () => { clearTimeout(_t); hideLoading(); await window.showAppMessage('Error suspending supplier', 'Error'); });
    }

    async function unsuspendSupplier(id, name) {
        const ok = await window.showAppConfirm(`Re-activate supplier "${name}"?`);
        if (!ok) return;
        const _t = setTimeout(() => showLoading('Reactivating supplier...'), 300);
        fetch(`${API}/UnsuspendSupplier?supplierId=${id}`, { method: 'POST' })
            .then(r => r.json())
            .then(async res => { clearTimeout(_t); hideLoading(); if (res.success) { await window.showAppMessage(res.message, 'Success'); loadNonCompliantSuppliers(); } else { await window.showAppMessage(res.message, 'Error'); } })
            .catch(async () => { clearTimeout(_t); hideLoading(); await window.showAppMessage('Error unsuspending supplier', 'Error'); });
    }

    /* ── Close modal on backdrop ───────────────────── */
    document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('active'); }));

    /* ── Initial load ──────────────────────────────── */
    document.addEventListener('DOMContentLoaded', () => loadViolations());
</script>
