@model (string Title, string Description)
@{
    var sessionRole = Context.Session.GetString("UserRole") ?? string.Empty;
    var showReturnToSuperAdmin =
        sessionRole.Equals("SuperAdmin", StringComparison.OrdinalIgnoreCase) &&
        !Context.Request.Path.StartsWithSegments("/SuperAdmin", StringComparison.OrdinalIgnoreCase);
}

<div class="top-bar">
    <div class="page-header">
        <h1>@Model.Title</h1>
        <p>@Model.Description</p>
    </div>
    <div class="account-section">
    @if (showReturnToSuperAdmin)
    {
        <a class="return-super-admin-btn" href="/SuperAdmin/Dashboard">Back to Super Admin</a>
    }
    <!-- Notification Bell -->
    <div class="notif-wrap" id="supNotifWrap">
        <button class="notif-btn" id="supNotifBtn" onclick="toggleSupNotif()" aria-label="Notifications">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span class="notif-badge" id="supNotifBadge" style="display:none;">0</span>
        </button>
        <div class="notif-dropdown" id="supNotifDropdown">
            <div class="notif-header">Notifications</div>
            <div id="supNotifItems"><div class="notif-loading">Loading…</div></div>
        </div>
    </div>
    <div class="account-info">
            <h4>@Context.Session.GetString("UserName")</h4>
            <p>@(sessionRole.Equals("SuperAdmin", StringComparison.OrdinalIgnoreCase) ? "Super Administrator" : "Supplier")</p>
        </div>
        <div class="account-avatar">
            @{
                var userName = Context.Session.GetString("UserName") ?? "User";
                var nameParts = userName.Split(' ');
                var initials = nameParts.Length >= 2 
                    ? $"{nameParts[0][0]}{nameParts[1][0]}" 
                    : userName.Length >= 2 ? userName.Substring(0, 2).ToUpper() : userName[0].ToString().ToUpper();
            }
            @initials
        </div>
    </div>
</div>

<style>
    .top-bar {
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
        padding: 24px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 10;
        width: 100%;
        margin: 0;
        box-sizing: border-box;
    }

    .page-header {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .page-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
        line-height: 1.2;
    }

    .page-header p {
        color: #6b7280;
        font-size: 15px;
        margin: 0;
        line-height: 1.5;
    }

    .account-section {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-shrink: 0;
    }

    .return-super-admin-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 38px;
        padding: 0 14px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        background: #f8fafc;
        color: #1e3a8a;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
    }

    .return-super-admin-btn:hover {
        background: #eff6ff;
        border-color: #93c5fd;
    }

    .account-info {
        text-align: right;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 2px;
    }

    .account-info h4 {
        font-size: 14px;
        font-weight: 600;
        color: #1f2937;
        margin: 0;
        line-height: 1.3;
    }

    .account-info p {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
        line-height: 1.3;
    }

    .account-avatar {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 18px;
        color: white;
        flex-shrink: 0;
    }

    .content-wrapper {
        padding: 32px;
    }

    @@media (max-width: 991px) {
        .top-bar {
            padding: 16px 20px 16px 70px;
        }

        .page-header h1 {
            font-size: 22px;
        }

        .page-header p {
            font-size: 13px;
        }

        .account-info {
            display: none;
        }

        .return-super-admin-btn {
            height: 34px;
            padding: 0 10px;
            font-size: 12px;
        }

        .account-avatar {
            width: 38px;
            height: 38px;
            font-size: 14px;
        }

        .content-wrapper {
            padding: 20px;
        }
    }

    @@media (max-width: 576px) {
        .top-bar {
            padding: 12px 16px 12px 60px;
        }

        .page-header h1 {
            font-size: 18px;
        }

        .page-header p {
            font-size: 12px;
        }

        .content-wrapper {
            padding: 16px;
        }
    }
</style>
