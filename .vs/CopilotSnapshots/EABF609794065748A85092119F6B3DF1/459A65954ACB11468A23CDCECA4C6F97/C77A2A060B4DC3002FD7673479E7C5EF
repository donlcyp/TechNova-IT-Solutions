@page
@model TechNova_IT_Solutions.Pages.SystemAdmin.SupplierReportModel
@{
    ViewData["Title"] = "Supplier Report";
}

@section Styles {
<style>
    .main-content {
        margin-left: 260px;
        min-height: 100vh;
        overflow-y: auto;
        background: linear-gradient(135deg, #f0f4ff 0%, #f8fafc 50%, #f0fdf4 100%);
    }

    .reports-shell { padding: 28px; max-width: 1400px; margin: 0 auto; }

    .report-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: 0 1px 3px rgba(15,23,42,.04), 0 4px 12px rgba(15,23,42,.03);
        transition: box-shadow .2s;
    }
    .report-card:hover { box-shadow: 0 4px 16px rgba(15,23,42,.07); }

    /* Section label */
    .section-label { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
    .sl-num { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; font-size: 0.7rem; font-weight: 700; padding: 3px 9px; border-radius: 6px; letter-spacing: 0.05em; }
    .sl-text { font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.06em; }

    /* Filter bar */
    .filters { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr auto; gap: 14px; align-items: end; }
    .filters label { font-size: 0.78rem; font-weight: 600; color: #475569; display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em; }
    .filters input, .filters select {
        width: 100%; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: 10px 12px; font-size: 0.9rem; color: #1e293b;
        background: #f8fafc; transition: border-color .2s, box-shadow .2s;
    }
    .filters input:focus, .filters select:focus {
        outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12);
    }

    /* Action buttons */
    .actions { display: flex; gap: 8px; flex-wrap: nowrap; align-items: center; }
    .btn {
        display: inline-flex; align-items: center; justify-content: center;
        white-space: nowrap; border-radius: 10px;
        font-weight: 600; font-size: 0.875rem; padding: 10px 18px;
        transition: all .2s; gap: 6px; cursor: pointer; border: none;
    }
    .btn-primary { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; box-shadow: 0 2px 8px rgba(37,99,235,.25); }
    .btn-primary:hover { box-shadow: 0 4px 14px rgba(37,99,235,.35); transform: translateY(-1px); }
    .btn-secondary { background: #fff; color: #2563eb; border: 1.5px solid #bfdbfe !important; }
    .btn-secondary:hover { background: #eff6ff; border-color: #93c5fd !important; }
    .btn-success { background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff; box-shadow: 0 2px 8px rgba(22,163,74,.2); }
    .btn-success:hover { box-shadow: 0 4px 14px rgba(22,163,74,.3); transform: translateY(-1px); }

    /* KPI cards */
    .kpis-grid { display: grid; grid-template-columns: repeat(6, minmax(120px, 1fr)); gap: 14px; margin-bottom: 20px; }
    .kpi {
        border-radius: 14px; padding: 18px; position: relative; overflow: hidden;
        border: 1px solid #e2e8f0; background: linear-gradient(135deg, #f8fafc 0%, #fff 100%);
        transition: transform .2s, box-shadow .2s;
    }
    .kpi:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(15,23,42,.06); }
    .kpi::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; border-radius: 4px 0 0 4px; }
    .kpi.blue::before { background: linear-gradient(180deg,#3b82f6,#2563eb); }
    .kpi.green::before { background: linear-gradient(180deg,#22c55e,#16a34a); }
    .kpi.amber::before { background: linear-gradient(180deg,#f59e0b,#d97706); }
    .kpi.red::before { background: linear-gradient(180deg,#ef4444,#dc2626); }
    .kpi.purple::before { background: linear-gradient(180deg,#8b5cf6,#7c3aed); }
    .kpi.slate::before { background: linear-gradient(180deg,#64748b,#475569); }
    .kpi .kpi-label { font-size: 0.74rem; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
    .kpi .kpi-value { font-size: 1.65rem; font-weight: 800; color: #0f172a; letter-spacing: -0.02em; }
    .kpi .kpi-sub { font-size: 0.75rem; color: #94a3b8; margin-top: 2px; }

    /* Report header info */
    .report-meta { display: flex; flex-direction: column; gap: 4px; }
    .report-meta h3 { margin: 0; font-size: 1.1rem; font-weight: 700; color: #0f172a; }
    .meta-row { color: #64748b; font-size: 0.84rem; display: flex; align-items: center; gap: 6px; margin-top: 4px; }
    .meta-row svg { width: 13px; height: 13px; flex-shrink: 0; }

    /* Table */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: separate; border-spacing: 0; }
    thead th {
        padding: 12px 14px; text-align: left; font-size: 0.72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.06em; color: #64748b;
        background: #f8fafc; border-bottom: 2px solid #e2e8f0;
    }
    thead th:first-child { border-radius: 10px 0 0 0; }
    thead th:last-child { border-radius: 0 10px 0 0; }
    tbody td {
        padding: 12px 14px; font-size: 0.9rem; color: #334155;
        border-bottom: 1px solid #f1f5f9; transition: background .15s;
    }
    tbody tr:hover td { background: #f8fafc; }
    tbody tr:last-child td { border-bottom: none; }
    .empty-row td { text-align: center; color: #9ca3af; padding: 40px 14px; }

    /* Status badges */
    .badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 20px;
        font-size: 0.77rem; font-weight: 600;
    }
    .badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .badge-compliant, .badge-approved, .badge-active { background: #f0fdf4; color: #15803d; }
    .badge-compliant::before, .badge-approved::before, .badge-active::before { background: #22c55e; }
    .badge-pending { background: #fffbeb; color: #b45309; }
    .badge-pending::before { background: #f59e0b; }
    .badge-non-compliant, .badge-rejected, .badge-terminated { background: #fef2f2; color: #dc2626; }
    .badge-non-compliant::before, .badge-rejected::before, .badge-terminated::before { background: #ef4444; }
    .badge-inactive { background: #f1f5f9; color: #475569; }
    .badge-inactive::before { background: #94a3b8; }

    /* Print-only header */
    .print-header { display: none; }

    @@media (max-width: 991px) { .main-content { margin-left: 0; } }
    @@media (max-width: 1100px) {
        .kpis-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 900px) {
        .filters { grid-template-columns: 1fr 1fr; }
        .kpis-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 576px) {
        .reports-shell { padding: 16px; }
        .report-card { padding: 16px; }
        .filters { grid-template-columns: 1fr; }
        .kpis-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
        .kpi { padding: 14px; }
        .kpi .kpi-value { font-size: 1.4rem; }
        .actions { flex-wrap: wrap; }
        .btn { flex: 1 1 auto; }
    }

    @@media print {
        .sidebar, .top-bar { display: none !important; }
        main.main-content { margin-left: 0 !important; background: #fff !important; }
        .reports-shell { padding: 0 !important; }
        .report-card { box-shadow: none !important; border: 1px solid #d1d5db !important; break-inside: avoid; margin-bottom: 12px !important; }
        .report-card:hover, .kpi:hover { transform: none !important; box-shadow: none !important; }
        .actions { display: none !important; }
        .section-label { display: flex !important; }
        .print-header { display: block !important; text-align: center; padding-bottom: 16px; border-bottom: 2px solid #1e40af; margin-bottom: 20px; }
        @@page { margin: 1.5cm; }
    }
</style>
}

@await Html.PartialAsync("_SystemAdminSidebar", "SupplierReport")

<div class="main-content">
    @await Html.PartialAsync("_AdminTopBar", (Title: "Supplier Report", Description: "Comprehensive report on supplier compliance, procurement, and status"))

    <div class="reports-shell">

        <!-- Print header (only shown on print) -->
        <div class="print-header">
            <div style="font-size:1.1rem;font-weight:800;color:#1e40af;">TechNova IT Solutions</div>
            <div style="font-size:1.45rem;font-weight:700;color:#0f172a;margin:6px 0;">
                Supplier Report &mdash;
                @(Model.ReportType == "overview" ? "Overview" : Model.ReportType == "procurement" ? "Procurement" : "Compliance")
            </div>
            <div style="font-size:0.85rem;color:#64748b;">
                Period: @Model.FromDate?.ToString("MMM dd, yyyy") &ndash; @Model.ToDate?.ToString("MMM dd, yyyy") &nbsp;|&nbsp;
                Generated by: @Model.UserName on @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
            </div>
        </div>

        <!-- ── Section 01: Global KPIs ── -->
        <div class="section-label"><span class="sl-num">01</span><span class="sl-text">Supplier Overview</span></div>
        <div class="kpis-grid">
            <div class="kpi blue">
                <div class="kpi-label">Total Suppliers</div>
                <div class="kpi-value">@Model.TotalSuppliers</div>
            </div>
            <div class="kpi green">
                <div class="kpi-label">Active</div>
                <div class="kpi-value">@Model.ActiveSuppliers</div>
            </div>
            <div class="kpi amber">
                <div class="kpi-label">Inactive</div>
                <div class="kpi-value">@Model.InactiveSuppliers</div>
            </div>
            <div class="kpi red">
                <div class="kpi-label">Terminated</div>
                <div class="kpi-value">@Model.TerminatedSuppliers</div>
            </div>
            <div class="kpi green">
                <div class="kpi-label">Compliant Suppliers</div>
                <div class="kpi-value">@Model.CompliantSuppliers</div>
            </div>
            <div class="kpi red">
                <div class="kpi-label">Non-Compliant</div>
                <div class="kpi-value">@Model.NonCompliantSuppliers</div>
            </div>
        </div>

        <!-- ── Section 02: Filters ── -->
        <div class="section-label"><span class="sl-num">02</span><span class="sl-text">Report Filters</span></div>
        <div class="report-card">
            <form method="get" class="filters">
                <div>
                    <label for="reportType">Report Type</label>
                    <select id="reportType" name="reportType">
                        @if (Model.ReportType == "compliance") { <option value="compliance" selected>Policy Compliance</option> } else { <option value="compliance">Policy Compliance</option> }
                        @if (Model.ReportType == "procurement") { <option value="procurement" selected>Procurement</option> } else { <option value="procurement">Procurement</option> }
                        @if (Model.ReportType == "overview") { <option value="overview" selected>Full Overview</option> } else { <option value="overview">Full Overview</option> }
                    </select>
                </div>
                <div>
                    <label for="fromDate">From Date</label>
                    <input id="fromDate" type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label for="toDate">To Date</label>
                    <input id="toDate" type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label for="statusFilter">Supplier Status</label>
                    <select id="statusFilter" name="statusFilter">
                        @if (Model.StatusFilter == "all") { <option value="all" selected>All Statuses</option> } else { <option value="all">All Statuses</option> }
                        @if (Model.StatusFilter == "active") { <option value="active" selected>Active</option> } else { <option value="active">Active</option> }
                        @if (Model.StatusFilter == "inactive") { <option value="inactive" selected>Inactive</option> } else { <option value="inactive">Inactive</option> }
                        @if (Model.StatusFilter == "terminated") { <option value="terminated" selected>Terminated</option> } else { <option value="terminated">Terminated</option> }
                    </select>
                </div>
                <div class="actions">
                    <button type="submit" class="btn btn-primary">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        Generate
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="exportPdf()">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        PDF
                    </button>
                    <a class="btn btn-success"
                       href="/SystemAdmin/SupplierReport?handler=ExportCsv&reportType=@Model.ReportType&fromDate=@Model.FromDate?.ToString("yyyy-MM-dd")&toDate=@Model.ToDate?.ToString("yyyy-MM-dd")&statusFilter=@Model.StatusFilter">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        CSV
                    </a>
                </div>
            </form>
        </div>

        <!-- ── Section 03: Summary Metrics ── -->
        <div class="section-label"><span class="sl-num">03</span><span class="sl-text">Summary Metrics</span></div>
        <div class="report-card">
            <div class="report-meta">
                <h3>
                    @(Model.ReportType == "overview" ? "Full Overview Report" :
                      Model.ReportType == "procurement" ? "Procurement Report" : "Policy Compliance Report")
                </h3>
                <div class="meta-row">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    Period: @Model.FromDate?.ToString("MMM dd, yyyy") &mdash; @Model.ToDate?.ToString("MMM dd, yyyy")
                </div>
                <div class="meta-row">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Generated by: @Model.UserName &nbsp;on&nbsp; @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                </div>
            </div>

            <div class="kpis-grid" style="margin-top:18px;">
                <div class="kpi blue">
                    <div class="kpi-label">Total Records</div>
                    <div class="kpi-value">@Model.TotalRecords</div>
                </div>
                @if (Model.ReportType == "procurement")
                {
                    <div class="kpi green">
                        <div class="kpi-label">Approved</div>
                        <div class="kpi-value">@Model.ApprovedProcurements</div>
                    </div>
                    <div class="kpi amber">
                        <div class="kpi-label">Pending</div>
                        <div class="kpi-value">@Model.PendingCount</div>
                    </div>
                    <div class="kpi green">
                        <div class="kpi-label">Total Value</div>
                        <div class="kpi-value">@Model.TotalProcurementValue.ToString("C")</div>
                    </div>
                }
                else
                {
                    <div class="kpi green">
                        <div class="kpi-label">Compliant</div>
                        <div class="kpi-value">@Model.CompliantCount</div>
                    </div>
                    <div class="kpi amber">
                        <div class="kpi-label">Pending</div>
                        <div class="kpi-value">@Model.PendingCount</div>
                    </div>
                    <div class="kpi red">
                        <div class="kpi-label">Non-Compliant</div>
                        <div class="kpi-value">@Model.NonCompliantCount</div>
                    </div>
                }
                <div class="kpi purple">
                    <div class="kpi-label">@(Model.ReportType == "procurement" ? "Approval Rate" : "Compliance Rate")</div>
                    <div class="kpi-value">@Model.ComplianceRate%</div>
                </div>
            </div>
        </div>

        <!-- ── Section 04: Detailed Data ── -->
        <div class="section-label"><span class="sl-num">04</span><span class="sl-text">Detailed Data</span></div>
        <div class="report-card table-wrap">

            @if (Model.ReportType == "overview")
            {
                <table>
                    <thead>
                        <tr>
                            <th>Supplier ID</th>
                            <th>Supplier Name</th>
                            <th>Status</th>
                            <th>Policies</th>
                            <th>Compliance</th>
                            <th>Total Procurement</th>
                            <th>Terminated At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.OverviewData.Any())
                        {
                            <tr class="empty-row"><td colspan="7">No supplier data found.</td></tr>
                        }
                        @foreach (var row in Model.OverviewData)
                        {
                            <tr>
                                <td style="font-family:monospace;color:#475569;">@row.SupplierId</td>
                                <td style="font-weight:600;color:#0f172a;">@row.SupplierName</td>
                                <td>
                                    <span class="badge badge-@row.Status.ToLower()">@row.Status</span>
                                </td>
                                <td>@row.PolicyCount</td>
                                <td>
                                    @{
                                        var cCss = row.ComplianceStatus switch {
                                            "Compliant" => "badge-compliant",
                                            "Non-Compliant" => "badge-non-compliant",
                                            _ => "badge-pending"
                                        };
                                    }
                                    <span class="badge @cCss">@row.ComplianceStatus</span>
                                </td>
                                <td>@row.TotalProcurement.ToString("C")</td>
                                <td style="color:#94a3b8;font-size:0.83rem;">
                                    @(row.TerminatedAt.HasValue ? row.TerminatedAt.Value.ToString("MMM dd, yyyy") : "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (Model.ReportType == "procurement")
            {
                <table>
                    <thead>
                        <tr>
                            <th>Procurement ID</th>
                            <th>Supplier</th>
                            <th>Supplier Status</th>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th>Total Cost</th>
                            <th>Status</th>
                            <th>Purchase Date</th>
                            <th>Linked Policy</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ProcurementData.Any())
                        {
                            <tr class="empty-row"><td colspan="10">No procurement records found for the selected period.</td></tr>
                        }
                        @foreach (var row in Model.ProcurementData)
                        {
                            var sCss = row.ApprovalStatus switch {
                                "Approved" => "badge-approved",
                                "Rejected" => "badge-rejected",
                                _ => "badge-pending"
                            };
                            var ssCss = "badge-" + row.SupplierStatus.ToLower();
                            <tr>
                                <td style="font-family:monospace;color:#475569;">@row.ProcurementId</td>
                                <td style="font-weight:600;color:#0f172a;">@row.SupplierName</td>
                                <td><span class="badge @ssCss">@row.SupplierStatus</span></td>
                                <td>@row.ItemName</td>
                                <td>@row.Quantity</td>
                                <td>@row.UnitPrice.ToString("C")</td>
                                <td style="font-weight:600;">@row.TotalCost.ToString("C")</td>
                                <td><span class="badge @sCss">@row.ApprovalStatus</span></td>
                                <td style="white-space:nowrap;">@row.PurchaseDate?.ToString("MMM dd, yyyy")</td>
                                <td style="color:#64748b;font-size:0.83rem;">@row.LinkedPolicy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Supplier ID</th>
                            <th>Supplier Name</th>
                            <th>Supplier Status</th>
                            <th>Policy</th>
                            <th>Compliance Status</th>
                            <th>Assigned Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ComplianceData.Any())
                        {
                            <tr class="empty-row"><td colspan="6">No compliance records found for the selected period.</td></tr>
                        }
                        @foreach (var row in Model.ComplianceData)
                        {
                            var cCss2 = row.ComplianceStatus switch {
                                "Compliant" => "badge-compliant",
                                "Non-Compliant" => "badge-non-compliant",
                                _ => "badge-pending"
                            };
                            var ssCss2 = "badge-" + row.SupplierStatus.ToLower();
                            <tr>
                                <td style="font-family:monospace;color:#475569;">@row.SupplierId</td>
                                <td style="font-weight:600;color:#0f172a;">@row.SupplierName</td>
                                <td><span class="badge @ssCss2">@row.SupplierStatus</span></td>
                                <td>@row.PolicyTitle</td>
                                <td><span class="badge @cCss2">@row.ComplianceStatus</span></td>
                                <td style="white-space:nowrap;">@row.AssignedDate?.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function exportPdf() {
            window.print();
        }
    </script>
}
