@model string
@* Current page name for active state *@

<!-- Mobile Hamburger Button -->
<button class="mobile-menu-btn" id="chiefMobileMenuBtn" onclick="toggleChiefMobileSidebar()" aria-label="Toggle Menu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
</button>

<!-- Mobile Overlay -->
<div class="mobile-overlay" id="chiefMobileOverlay" onclick="closeChiefMobileSidebar()"></div>

<!-- Sidebar -->
<div class="sidebar" id="chiefComplianceManagerSidebar">
    <div class="logo">
        <img src="/images/logo2.png" alt="TechNova Logo" class="logo-image" />
        <span class="logo-text">TechNova</span>
    </div>

    <button class="toggle-btn" onclick="toggleChiefSidebar()" title="Toggle Sidebar" aria-label="Toggle Sidebar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
    </button>

    <nav class="nav-menu">
        <a href="/ChiefComplianceManager/ComplianceDashboard" class="nav-item @(Model == "ComplianceDashboard" ? "active" : "")" title="Compliance Dashboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            <span class="nav-text">Compliance Dashboard</span>
        </a>
        <a href="/ChiefComplianceManager/PolicyManagement" class="nav-item @(Model == "PolicyManagement" ? "active" : "")" title="Policy Management">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            <span class="nav-text">Policy Management</span>
        </a>

        <a href="/ChiefComplianceManager/SupplierCompliance" class="nav-item @(Model == "SupplierCompliance" ? "active" : "")" title="Supplier Compliance">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"></path>
                <path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z"></path>
            </svg>
            <span class="nav-text">Supplier Compliance</span>
        </a>
        <a href="/ChiefComplianceManager/PolicyReview" class="nav-item @(Model == "PolicyReview" ? "active" : "")" title="Policy Review">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            <span class="nav-text">Policy Review</span>
        </a>
        <a href="/ChiefComplianceManager/ViolationManagement" class="nav-item @(Model == "ViolationManagement" ? "active" : "")" title="Violation Management">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <span class="nav-text">Violation Management</span>
        </a>
        <a href="/ComplianceManager/ExternalPolicyReferences" class="nav-item @(Model == "ExternalPolicyReferences" ? "active" : "")" title="External Policy API">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="17 8 12 3 7 8"></polyline>
                <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
            <span class="nav-text">External Policy API</span>
        </a>
        <a href="/ChiefComplianceManager/ComplianceReports" class="nav-item @(Model == "ComplianceReports" ? "active" : "")" title="Compliance Reports">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <span class="nav-text">Compliance Reports</span>
        </a>
        <a href="/ChiefComplianceManager/AuditTrail" class="nav-item @(Model == "AuditTrail" ? "active" : "")" title="Audit Trail">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                <line x1="1" y1="10" x2="23" y2="10"></line>
            </svg>
            <span class="nav-text">Audit Trail</span>
        </a>
        <a href="/ChiefComplianceManager/PolicyArchives" class="nav-item @(Model == "PolicyArchives" ? "active" : "")" title="Policy Archives">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="21 8 21 21 3 21 3 8"></polyline>
                <rect x="1" y="3" width="22" height="5"></rect>
                <line x1="10" y1="12" x2="14" y2="12"></line>
            </svg>
            <span class="nav-text">Policy Archives</span>
        </a>


    </nav>

    <button type="button" class="logout-btn js-logout-trigger" title="Logout" aria-label="Logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        <span class="logout-text">Logout</span>
    </button>
</div>
@await Html.PartialAsync("_LogoutModal")

<style>
    .sidebar {
        width: 260px;
        background: #ffffff;
        border-right: 1px solid #e5e7eb;
        display: flex;
        flex-direction: column;
        position: fixed;
        height: 100vh;
        transition: width 0.3s ease;
    }

    .sidebar.collapsed {
        width: 70px;
    }

    .logo {
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 8px;
    }

    .logo-text {
        font-size: 18px;
        font-weight: 700;
        color: #1e40af;
        white-space: nowrap;
    }

    .sidebar.collapsed .logo-text {
        display: none;
    }

    .toggle-btn {
        background: #f3f4f6;
        border: none;
        color: #6b7280;
        padding: 12px;
        margin: 8px 16px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .toggle-btn svg {
        width: 24px;
        height: 24px;
    }

    .toggle-btn:hover {
        background: #e5e7eb;
        color: #1e40af;
    }

    .logo-image {
        height: 45px;
        width: auto;
        object-fit: contain;
    }

    .sidebar.collapsed .logo-image {
        height: 32px;
    }

    .nav-menu {
        flex: 1;
        padding: 8px 0;
        overflow-y: auto;
    }

    .nav-item {
        padding: 14px 24px;
        color: #6b7280;
        text-decoration: none;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s;
        font-size: 14px;
        font-weight: 500;
        white-space: nowrap;
    }

    .nav-item:hover {
        background: rgba(30, 64, 175, 0.1);
        color: #1e40af;
    }

    .nav-item.active {
        background: linear-gradient(90deg, rgba(30, 64, 175, 0.15) 0%, transparent 100%);
        color: #1e40af;
        border-left: 3px solid #1e40af;
    }

    .nav-item svg {
        width: 24px;
        height: 24px;
        min-width: 24px;
    }

    .logout-btn {
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        padding: 16px 24px;
        border-top: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #ef4444;
        text-decoration: none;
        transition: all 0.3s;
        margin-top: auto;
        white-space: nowrap;
        font-size: 15px;
        font-weight: 500;
    }

    .logout-btn:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .logout-btn svg {
        width: 24px;
        height: 24px;
        min-width: 24px;
    }

    .sidebar.collapsed .nav-text,
    .sidebar.collapsed .logout-text {
        display: none;
    }

    .sidebar.collapsed .logo {
        justify-content: center;
    }

    .sidebar.collapsed .nav-item {
        justify-content: center;
        padding: 12px;
    }

    .sidebar.collapsed .logout-btn {
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        justify-content: center;
        padding: 16px;
    }

    /* Update main content margin based on sidebar state */
    body:has(.sidebar.collapsed) .main-content {
        margin-left: 70px !important;
    }

    /* Mobile Menu Button */
    .mobile-menu-btn {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 1001;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: none;
    }

    .mobile-menu-btn svg {
        width: 24px;
        height: 24px;
        color: #1f2937;
    }

    /* Mobile Overlay */
    .mobile-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 998;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s;
        display: none;
    }

    .mobile-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    @@media (max-width: 991px) {
        .mobile-overlay {
            display: block;
        }
    }

    /* Mobile Responsive Styles */
    @@media (max-width: 991px) {
        .mobile-menu-btn {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sidebar {
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            z-index: 999;
            width: 280px;
        }

        .sidebar.mobile-open {
            transform: translateX(0);
        }

        .sidebar.collapsed {
            width: 280px;
        }

        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .logout-text {
            display: inline;
        }

        .toggle-btn {
            display: none;
        }

        body:has(.sidebar.collapsed) .main-content {
            margin-left: 0 !important;
        }
    }

    @@media (max-width: 576px) {
        .sidebar {
            width: 260px;
        }

        .sidebar.collapsed {
            width: 260px;
        }
    }
</style>

<script>
    function toggleChiefSidebar() {
        const sidebar = document.getElementById('chiefComplianceManagerSidebar');
        sidebar.classList.toggle('collapsed');

        // Save state to localStorage
        const isCollapsed = sidebar.classList.contains('collapsed');
        localStorage.setItem('chiefCMSidebarCollapsed', isCollapsed);
    }

    // Restore sidebar state on page load
    document.addEventListener('DOMContentLoaded', function () {
        const sidebar = document.getElementById('chiefComplianceManagerSidebar');
        const isCollapsed = localStorage.getItem('chiefCMSidebarCollapsed') === 'true';

        if (isCollapsed) {
            sidebar.classList.add('collapsed');
        }
    });

    // Mobile sidebar functions
    function toggleChiefMobileSidebar() {
        const sidebar = document.getElementById('chiefComplianceManagerSidebar');
        const overlay = document.getElementById('chiefMobileOverlay');
        sidebar.classList.toggle('mobile-open');
        overlay.classList.toggle('active');
        document.body.style.overflow = sidebar.classList.contains('mobile-open') ? 'hidden' : '';
    }

    function closeChiefMobileSidebar() {
        const sidebar = document.getElementById('chiefComplianceManagerSidebar');
        const overlay = document.getElementById('chiefMobileOverlay');
        sidebar.classList.remove('mobile-open');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Close mobile sidebar when clicking on a nav link
    document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', function () {
            if (window.innerWidth <= 991) {
                closeChiefMobileSidebar();
            }
        });
    });

    // Close mobile sidebar on window resize to desktop
    window.addEventListener('resize', function () {
        if (window.innerWidth > 991) {
            closeChiefMobileSidebar();
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeChiefMobileSidebar();
        }
    });
</script>
