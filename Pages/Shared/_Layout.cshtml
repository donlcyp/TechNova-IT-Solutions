<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechNova IT Solutions</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    @RenderSection("Styles", required: false)
</head>
<body>
    @RenderBody()

    @{
        var mustChangePassword = Context.Session.GetString("MustChangePassword") == "true";
    }

    @if (mustChangePassword)
    {
        <div id="forceChangePwdOverlay" style="position:fixed;inset:0;background:rgba(15,23,42,.7);z-index:5000;display:flex;align-items:center;justify-content:center;padding:16px;">
            <div style="width:100%;max-width:480px;background:#fff;border-radius:12px;border:1px solid #e5e7eb;overflow:hidden;box-shadow:0 20px 40px rgba(15,23,42,.25);">
                <div style="padding:18px 20px;border-bottom:1px solid #e5e7eb;">
                    <h3 style="margin:0;font-size:18px;font-weight:700;color:#111827;">Change Your Password</h3>
                    <p style="margin:6px 0 0;font-size:13px;color:#6b7280;line-height:1.4;">Your account is using a default password. Please set a new secure password to continue.</p>
                </div>
                <div style="padding:20px;display:grid;gap:14px;">
                    <div>
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;">New Password</label>
                        <div style="position:relative;">
                            <input id="forceNewPwd" type="password" placeholder="Min. 8 characters" style="width:100%;padding:10px 44px 10px 14px;border:1px solid #e5e7eb;border-radius:8px;font-size:14px;" />
                            <button type="button" id="toggleForceNewPwd" aria-label="Show password" title="Show password" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);border:none;background:transparent;padding:0;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#6b7280;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path id="toggleForceNewPwdEyeOpen" d="M2 12C3.8 8.5 7.4 6 12 6C16.6 6 20.2 8.5 22 12C20.2 15.5 16.6 18 12 18C7.4 18 3.8 15.5 2 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                                    <circle id="toggleForceNewPwdPupilOpen" cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"></circle>
                                    <path id="toggleForceNewPwdEyeClosed" d="M4 4L20 20M9.9 9.9C9.4 10.4 9 11.2 9 12C9 13.7 10.3 15 12 15C12.8 15 13.6 14.6 14.1 14.1M6.5 6.5C5 7.7 3.7 9.4 2.9 12C4.7 15.5 8 18 12 18C13.9 18 15.6 17.5 17.1 16.6M9.1 6.3C10 6.1 11 6 12 6C16.6 6 20.2 8.5 22 12C21.4 13.2 20.7 14.2 19.8 15.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none;"></path>
                                </svg>
                            </button>
                        </div>
                        <div style="margin-top:6px;">
                            <div style="display:flex;gap:4px;margin-bottom:4px;" id="forcePwdBar">
                                <div class="fseg" style="flex:1;height:5px;border-radius:3px;background:#e5e7eb;transition:background .25s;"></div>
                                <div class="fseg" style="flex:1;height:5px;border-radius:3px;background:#e5e7eb;transition:background .25s;"></div>
                                <div class="fseg" style="flex:1;height:5px;border-radius:3px;background:#e5e7eb;transition:background .25s;"></div>
                                <div class="fseg" style="flex:1;height:5px;border-radius:3px;background:#e5e7eb;transition:background .25s;"></div>
                            </div>
                            <div id="forcePwdLabel" style="font-size:12px;font-weight:600;color:#6b7280;transition:color .25s;"></div>
                        </div>
                    </div>
                    <div>
                        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;">Confirm Password</label>
                        <div style="position:relative;">
                            <input id="forceConfirmPwd" type="password" placeholder="Re-enter password" style="width:100%;padding:10px 44px 10px 14px;border:1px solid #e5e7eb;border-radius:8px;font-size:14px;" />
                            <button type="button" id="toggleForceConfirmPwd" aria-label="Show password" title="Show password" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);border:none;background:transparent;padding:0;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#6b7280;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path id="toggleForceConfirmPwdEyeOpen" d="M2 12C3.8 8.5 7.4 6 12 6C16.6 6 20.2 8.5 22 12C20.2 15.5 16.6 18 12 18C7.4 18 3.8 15.5 2 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                                    <circle id="toggleForceConfirmPwdPupilOpen" cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.8"></circle>
                                    <path id="toggleForceConfirmPwdEyeClosed" d="M4 4L20 20M9.9 9.9C9.4 10.4 9 11.2 9 12C9 13.7 10.3 15 12 15C12.8 15 13.6 14.6 14.1 14.1M6.5 6.5C5 7.7 3.7 9.4 2.9 12C4.7 15.5 8 18 12 18C13.9 18 15.6 17.5 17.1 16.6M9.1 6.3C10 6.1 11 6 12 6C16.6 6 20.2 8.5 22 12C21.4 13.2 20.7 14.2 19.8 15.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none;"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div id="forceChangePwdError" style="display:none;background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:10px 14px;border-radius:8px;font-size:13px;"></div>
                    <button id="forceChangePwdBtn" type="button" style="width:100%;padding:12px;background:linear-gradient(135deg,#1e3a8a 0%,#1e40af 100%);border:none;border-radius:8px;color:#fff;font-size:14px;font-weight:600;cursor:pointer;transition:opacity .2s;">
                        Update Password
                    </button>
                </div>
            </div>
        </div>
    }

    <div id="globalAppModal" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:3000;align-items:center;justify-content:center;padding:16px;">
        <div style="width:100%;max-width:420px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;box-shadow:0 20px 40px rgba(15,23,42,.2);">
            <div id="globalAppModalTitle" style="padding:16px 18px 12px;border-bottom:1px solid #e5e7eb;font-size:18px;font-weight:700;color:#111827;">Notice</div>
            <div id="globalAppModalBody" style="padding:14px 18px;font-size:14px;color:#374151;line-height:1.5;white-space:pre-wrap;"></div>
            <div id="globalAppModalFooter" style="padding:14px 18px;border-top:1px solid #e5e7eb;display:flex;justify-content:flex-end;gap:10px;"></div>
        </div>
    </div>
    
    <!-- Bootstrap JS Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script>
        (function () {
            // Normalize label "for" targets to element ids.
            // If a label references a field name instead of id, map it to the field id.
            function normalizeLabelTargets() {
                const labels = document.querySelectorAll('label[for]');
                labels.forEach((label, index) => {
                    const key = label.getAttribute('for');
                    if (!key) return;

                    if (document.getElementById(key)) {
                        return;
                    }

                    const byName = document.querySelector(`[name="${CSS.escape(key)}"]`);
                    if (!byName) return;

                    if (!byName.id) {
                        byName.id = `auto_field_${index}`;
                    }

                    label.setAttribute('for', byName.id);
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', normalizeLabelTargets);
            } else {
                normalizeLabelTargets();
            }

            const modal = document.getElementById('globalAppModal');
            const titleEl = document.getElementById('globalAppModalTitle');
            const bodyEl = document.getElementById('globalAppModalBody');
            const footerEl = document.getElementById('globalAppModalFooter');

            function makeButton(text, primary, onClick) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.textContent = text;
                btn.style.border = '1px solid ' + (primary ? '#1e40af' : '#d1d5db');
                btn.style.background = primary ? '#1e40af' : '#ffffff';
                btn.style.color = primary ? '#ffffff' : '#1f2937';
                btn.style.borderRadius = '8px';
                btn.style.padding = '8px 14px';
                btn.style.fontSize = '14px';
                btn.style.fontWeight = '600';
                btn.style.cursor = 'pointer';
                btn.addEventListener('click', onClick);
                return btn;
            }

            function closeModal() {
                modal.style.display = 'none';
            }

            window.showAppMessage = function (message, title) {
                return new Promise(resolve => {
                    titleEl.textContent = title || 'Notice';
                    bodyEl.textContent = message || '';
                    footerEl.innerHTML = '';

                    const okBtn = makeButton('OK', true, () => {
                        closeModal();
                        resolve();
                    });
                    footerEl.appendChild(okBtn);

                    const onOverlay = (e) => {
                        if (e.target === modal) {
                            modal.removeEventListener('click', onOverlay);
                            closeModal();
                            resolve();
                        }
                    };

                    modal.addEventListener('click', onOverlay);
                    modal.style.display = 'flex';
                });
            };

            window.showAppConfirm = function (message, title) {
                return new Promise(resolve => {
                    titleEl.textContent = title || 'Confirm Action';
                    bodyEl.textContent = message || '';
                    footerEl.innerHTML = '';

                    const cancelBtn = makeButton('Cancel', false, () => {
                        closeModal();
                        resolve(false);
                    });
                    const continueBtn = makeButton('Continue', true, () => {
                        closeModal();
                        resolve(true);
                    });

                    footerEl.appendChild(cancelBtn);
                    footerEl.appendChild(continueBtn);

                    const onOverlay = (e) => {
                        if (e.target === modal) {
                            modal.removeEventListener('click', onOverlay);
                            closeModal();
                            resolve(false);
                        }
                    };

                    modal.addEventListener('click', onOverlay);
                    modal.style.display = 'flex';
                });
            };

            window.appConfirmNavigate = function (event, message, href) {
                if (event && typeof event.preventDefault === 'function') {
                    event.preventDefault();
                }
                const targetHref = href || (event && event.currentTarget ? event.currentTarget.getAttribute('href') : null);
                window.showAppConfirm(message || 'Are you sure?').then(ok => {
                    if (ok && targetHref) {
                        window.location.href = targetHref;
                    }
                });
                return false;
            };

            window.alert = function (message) {
                window.showAppMessage(message, 'Notice');
            };
        })();

        /* ── Force Change Password ── */
        (function () {
            const overlay = document.getElementById('forceChangePwdOverlay');
            if (!overlay) return;

            function evalStrength(pwd) {
                let s = 0;
                if (pwd.length >= 8) s++;
                if (pwd.length >= 12) s++;
                if (/[a-z]/.test(pwd)) s++;
                if (/[A-Z]/.test(pwd)) s++;
                if (/[0-9]/.test(pwd)) s++;
                if (/[^a-zA-Z0-9]/.test(pwd)) s++;
                if (s <= 1) return { level: 0, label: 'Weak', color: '#ef4444' };
                if (s <= 3) return { level: 1, label: 'Fair', color: '#f59e0b' };
                if (s <= 4) return { level: 2, label: 'Good', color: '#3b82f6' };
                return { level: 3, label: 'Strong', color: '#22c55e' };
            }

            const inp = document.getElementById('forceNewPwd');
            const segs = document.querySelectorAll('#forcePwdBar .fseg');
            const lbl = document.getElementById('forcePwdLabel');
            const errBox = document.getElementById('forceChangePwdError');
            const confirmInp = document.getElementById('forceConfirmPwd');

            function wirePwdToggle(btnId, inputEl) {
                const btn = document.getElementById(btnId);
                if (!btn || !inputEl) return;

                const eyeOpen = document.getElementById(`${btnId}EyeOpen`);
                const pupilOpen = document.getElementById(`${btnId}PupilOpen`);
                const eyeClosed = document.getElementById(`${btnId}EyeClosed`);

                btn.addEventListener('click', function () {
                    const isMasked = inputEl.type === 'password';
                    inputEl.type = isMasked ? 'text' : 'password';

                    if (eyeOpen) eyeOpen.style.display = isMasked ? 'none' : '';
                    if (pupilOpen) pupilOpen.style.display = isMasked ? 'none' : '';
                    if (eyeClosed) eyeClosed.style.display = isMasked ? '' : 'none';

                    const label = isMasked ? 'Hide password' : 'Show password';
                    btn.setAttribute('aria-label', label);
                    btn.setAttribute('title', label);
                });
            }

            wirePwdToggle('toggleForceNewPwd', inp);
            wirePwdToggle('toggleForceConfirmPwd', confirmInp);

            inp.addEventListener('input', function () {
                if (!this.value) { segs.forEach(s => s.style.background = '#e5e7eb'); lbl.textContent = ''; return; }
                const r = evalStrength(this.value);
                segs.forEach((s, i) => s.style.background = i <= r.level ? r.color : '#e5e7eb');
                lbl.textContent = r.label;
                lbl.style.color = r.color;
            });

            document.getElementById('forceChangePwdBtn').addEventListener('click', async function () {
                const newPwd = inp.value;
                const confirmPwd = document.getElementById('forceConfirmPwd').value;

                errBox.style.display = 'none';

                if (!newPwd || newPwd.length < 8) {
                    errBox.textContent = 'Password must be at least 8 characters.';
                    errBox.style.display = 'block';
                    return;
                }
                if (newPwd !== confirmPwd) {
                    errBox.textContent = 'Passwords do not match.';
                    errBox.style.display = 'block';
                    return;
                }

                this.disabled = true;
                this.textContent = 'Updating...';

                try {
                    const response = await fetch('/Account/ChangePassword', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ newPassword: newPwd })
                    });
                    const result = await response.json();

                    if (response.ok && result.success) {
                        overlay.remove();
                    } else {
                        errBox.textContent = result.message || 'Failed to update password.';
                        errBox.style.display = 'block';
                        this.disabled = false;
                        this.textContent = 'Update Password';
                    }
                } catch {
                    errBox.textContent = 'An error occurred. Please try again.';
                    errBox.style.display = 'block';
                    this.disabled = false;
                    this.textContent = 'Update Password';
                }
            });
        })();
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
