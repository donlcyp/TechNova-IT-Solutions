@model (string Title, string Description)
@* Top bar with page header and account section — Branch Admin variant *@
@{
    var sessionRole = Context.Session.GetString("UserRole") ?? string.Empty;
    var showReturnToSuperAdmin =
        sessionRole.Equals("SuperAdmin", StringComparison.OrdinalIgnoreCase) &&
        !Context.Request.Path.StartsWithSegments("/SuperAdmin", StringComparison.OrdinalIgnoreCase);
    var branchName = Context.Session.GetString("BranchName");
}

<div class="top-bar">
    <div class="page-header">
        <h1>@Model.Title</h1>
        <p>@Model.Description</p>
    </div>
    <div class="account-section">
        @if (showReturnToSuperAdmin)
        {
            <a class="return-super-admin-btn" href="/SuperAdmin/Dashboard">Back to Super Admin</a>
        }
        <div class="account-info">
            <h4>@Context.Session.GetString("UserName")</h4>
            <p>Branch Administrator</p>
            @if (!string.IsNullOrEmpty(branchName))
            {
                <div class="branch-indicator">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px;flex-shrink:0;">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                    <span>@branchName</span>
                </div>
            }
        </div>
        <div class="account-avatar branch-avatar">
            @{
                var userName = Context.Session.GetString("UserName") ?? "User";
                var nameParts = userName.Split(' ');
                var initials = nameParts.Length >= 2 
                    ? $"{nameParts[0][0]}{nameParts[1][0]}" 
                    : userName.Length >= 2 ? userName.Substring(0, 2).ToUpper() : userName[0].ToString().ToUpper();
            }
            @initials
        </div>
    </div>
</div>

<style>
    .top-bar {
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
        padding: 24px 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 10;
        width: 100%;
        margin: 0;
        box-sizing: border-box;
    }

    .page-header {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .page-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
        line-height: 1.2;
    }

    .page-header p {
        color: #6b7280;
        font-size: 15px;
        margin: 0;
        line-height: 1.5;
    }

    .account-section {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-shrink: 0;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .return-super-admin-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 38px;
        padding: 0 14px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        background: #f8fafc;
        color: #1e3a8a;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
    }

    .return-super-admin-btn:hover {
        background: #eff6ff;
        border-color: #93c5fd;
    }

    .branch-indicator {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: #1e40af;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
        margin-top: 1px;
    }

    .branch-indicator i {
        font-size: 11px;
        flex-shrink: 0;
    }

    .account-info {
        text-align: right;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 2px;
    }

    .account-info h4 {
        font-size: 14px;
        font-weight: 600;
        color: #1f2937;
        margin: 0;
        line-height: 1.3;
    }

    .account-info p {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
        line-height: 1.3;
    }

    .account-avatar {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 18px;
        color: white;
        flex-shrink: 0;
    }

    .account-avatar.branch-avatar {
        background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
    }

    .content-wrapper {
        padding: 32px;
    }

    /* Mobile Responsive Styles */
    @@media (max-width: 991px) {
        .top-bar {
            padding: 16px 20px 16px 70px;
        }

        .page-header h1 {
            font-size: 24px;
        }

        .page-header p {
            font-size: 14px;
        }

        .account-info {
            display: none;
        }

        .branch-indicator {
            font-size: 11px;
            height: 30px;
            padding: 0 8px;
        }

        .return-super-admin-btn {
            height: 34px;
            padding: 0 10px;
            font-size: 12px;
        }

        .account-avatar {
            width: 40px;
            height: 40px;
            font-size: 16px;
            border-radius: 10px;
        }
    }

    @@media (max-width: 576px) {
        .top-bar {
            padding: 10px 10px 10px 66px;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            column-gap: 8px;
            row-gap: 6px;
            align-items: center;
        }

        .page-header h1 {
            font-size: 18px;
            line-height: 1.25;
            overflow-wrap: anywhere;
        }

        .page-header p {
            font-size: 12px;
            display: none;
        }

        .account-section {
            grid-column: 1 / -1;
            justify-content: flex-end;
            gap: 8px;
        }

        .return-super-admin-btn {
            height: 30px;
            padding: 0 8px;
            font-size: 11px;
            border-radius: 8px;
            max-width: 55vw;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .account-avatar {
            width: 32px;
            height: 32px;
            font-size: 12px;
            border-radius: 8px;
        }
    }

    @@media (max-width: 400px) {
        .top-bar {
            padding: 8px 8px 8px 58px;
        }

        .page-header h1 {
            font-size: 16px;
        }
    }

    @@media (max-width: 390px) and (min-height: 800px) {
        .top-bar {
            padding: 8px 8px 8px 60px;
            row-gap: 4px;
        }

        .page-header h1 {
            font-size: 16px;
            line-height: 1.2;
        }

        .account-section {
            gap: 6px;
        }

        .return-super-admin-btn {
            height: 28px;
            padding: 0 7px;
            font-size: 10px;
            max-width: 52vw;
        }

        .account-avatar {
            width: 30px;
            height: 30px;
            font-size: 11px;
        }
    }
</style>
