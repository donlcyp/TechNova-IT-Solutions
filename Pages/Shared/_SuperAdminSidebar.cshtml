@model string

<!-- Mobile Hamburger Button -->
<button class="mobile-menu-btn" id="mobileMenuBtn" onclick="toggleMobileSidebar()" aria-label="Toggle Menu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
</button>

<!-- Mobile Overlay -->
<div class="mobile-overlay" id="mobileOverlay" onclick="closeMobileSidebar()"></div>

<!-- Sidebar -->
<div class="sidebar" id="superAdminSidebar">
    <script>(function(){var s=document.currentScript.parentElement;if(localStorage.getItem('superAdminSidebarCollapsed')==='true')s.classList.add('collapsed','notransition');})()</script>
    <div class="logo">
        <img src="/images/logo2.png" alt="TechNova Logo" class="logo-image" />
        <span class="logo-text">TechNova</span>
    </div>

    <button class="toggle-btn" onclick="toggleSidebar()" title="Toggle Sidebar" aria-label="Toggle Sidebar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
    </button>

    <nav class="nav-menu" id="superAdminNav">

        <!-- ── Overview ── -->
        <a href="/SuperAdmin/Dashboard" class="nav-item @(Model == "Dashboard" ? "active" : "")" title="Dashboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            <span class="nav-text">Dashboard</span>
        </a>

        <!-- ── Organization ── -->
        <div class="nav-group @(new[]{"ManageAdminAccounts","ManageBranches","ManageBranchAccounts"}.Contains(Model) ? "open" : "")">
            <button class="nav-group-header" onclick="toggleNavGroup(this)" title="Organization">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <span class="nav-text">Organization</span>
                <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            <div class="nav-group-items">
                <a href="/SuperAdmin/ManageAdminAccounts" class="nav-item nav-sub-item @(Model == "ManageAdminAccounts" ? "active" : "")" title="Global Accounts">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span class="nav-text">Global Accounts</span>
                </a>
                <a href="/SuperAdmin/ManageBranches" class="nav-item nav-sub-item @(Model == "ManageBranches" ? "active" : "")" title="Manage Branches">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9.5L12 4l9 5.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
                        <path d="M9 21V12h6v9"/>
                    </svg>
                    <span class="nav-text">Manage Branches</span>
                </a>
                <a href="/SuperAdmin/ManageBranchAccounts" class="nav-item nav-sub-item @(Model == "ManageBranchAccounts" ? "active" : "")" title="Branch Accounts">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    <span class="nav-text">Branch Accounts</span>
                </a>
            </div>
        </div>

        <!-- ── Policies ── -->
        <div class="nav-group @(new[]{"SystemSettingsPolicies","PolicyManagement"}.Contains(Model) ? "open" : "")">
            <button class="nav-group-header" onclick="toggleNavGroup(this)" title="Policies">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                </svg>
                <span class="nav-text">Policies</span>
                <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            <div class="nav-group-items">
                <a href="/SuperAdmin/SystemSettingsPolicies" class="nav-item nav-sub-item @(Model == "SystemSettingsPolicies" ? "active" : "")" title="System Settings">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                    <span class="nav-text">System Settings</span>
                </a>
                <a href="/SuperAdmin/PolicyManagement" class="nav-item nav-sub-item @(Model == "PolicyManagement" ? "active" : "")" title="Policy Management">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <line x1="9" y1="9" x2="8" y2="9"></line>
                    </svg>
                    <span class="nav-text">Policy Management</span>
                </a>
            </div>
        </div>

        <!-- ── Monitoring & Reports ── -->
        <div class="nav-group @(new[]{"AllReports","ComplianceMonitoring","FullAuditLogs","DetailedReports"}.Contains(Model) ? "open" : "")">
            <button class="nav-group-header" onclick="toggleNavGroup(this)" title="Monitoring & Reports">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
                <span class="nav-text">Monitoring & Reports</span>
                <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            <div class="nav-group-items">
                <a href="/SuperAdmin/ComplianceMonitoring" class="nav-item nav-sub-item @(Model == "ComplianceMonitoring" ? "active" : "")" title="Compliance Monitoring">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                    <span class="nav-text">Compliance Monitoring</span>
                </a>
                <a href="/SuperAdmin/AllReports" class="nav-item nav-sub-item @(Model == "AllReports" ? "active" : "")" title="System Reports">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span class="nav-text">System Reports</span>
                </a>
                <a href="/SuperAdmin/FullAuditLogs" class="nav-item nav-sub-item @(Model == "FullAuditLogs" ? "active" : "")" title="Full Audit Logs">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
                    </svg>
                    <span class="nav-text">Full Audit Logs</span>
                </a>
            </div>
        </div>

    </nav>

    <button type="button" class="logout-btn js-logout-trigger" title="Logout" aria-label="Logout">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        <span class="logout-text">Logout</span>
    </button>
</div>
@await Html.PartialAsync("_LogoutModal")

<style>
    .sidebar {
        width: 260px;
        background: #ffffff;
        border-right: 1px solid #e5e7eb;
        display: flex;
        flex-direction: column;
        position: fixed;
        height: 100vh;
        transition: width 0.3s ease;
    }

    .sidebar.collapsed {
        width: 70px;
    }

    .sidebar.notransition { transition: none !important; }

    .logo {
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 8px;
    }

    .logo-text {
        font-size: 18px;
        font-weight: 700;
        color: #1e40af;
        white-space: nowrap;
    }

    .sidebar.collapsed .logo-text {
        display: none;
    }

    .toggle-btn {
        background: #f3f4f6;
        border: none;
        color: #6b7280;
        padding: 12px;
        margin: 8px 16px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .toggle-btn:hover {
        background: #e5e7eb;
        color: #1e40af;
    }

    .toggle-btn svg {
        width: 24px;
        height: 24px;
    }

    .logo-image {
        height: 45px;
        width: auto;
        object-fit: contain;
    }

    .sidebar.collapsed .logo-image {
        height: 32px;
    }

    .nav-menu {
        flex: 1;
        padding: 8px 0;
        overflow-y: auto;
        min-height: 0;
        scrollbar-width: thin;
        scrollbar-color: #e2e8f0 transparent;
    }

    .nav-menu::-webkit-scrollbar { width: 4px; }
    .nav-menu::-webkit-scrollbar-track { background: transparent; }
    .nav-menu::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }

    /* ── Group header ── */
    .nav-group {
        overflow: hidden;
    }

    .nav-group-header {
        padding: 11px 24px;
        color: #374151;
        background: transparent;
        border: none;
        width: 100%;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.01em;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .nav-group-header:hover {
        background: rgba(30, 64, 175, 0.06);
        color: #1e40af;
    }

    .nav-group-header svg:first-child {
        width: 20px;
        height: 20px;
        min-width: 20px;
        color: #6b7280;
        display: none;
    }

    .nav-group-header:hover svg:first-child {
        color: #1e40af;
    }

    .nav-group-header .chevron {
        width: 14px;
        height: 14px;
        min-width: 14px;
        margin-left: auto;
        transition: transform 0.25s ease;
        color: #9ca3af;
    }

    .nav-group.open > .nav-group-header .chevron {
        transform: rotate(180deg);
    }

    /* ── Collapsible items ── */
    .nav-group-items {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.25s ease;
    }

    .nav-group.open > .nav-group-items {
        max-height: 300px;
    }

    /* ── Sub-items ── */
    .nav-sub-item {
        padding-left: 44px !important;
    }

    /* ── Collapsed sidebar: flatten groups & center all icons ── */
    .sidebar.collapsed .nav-group-items {
        max-height: none;
    }

    .sidebar.collapsed .nav-item,
    .sidebar.collapsed .nav-group-header {
        justify-content: center;
        padding: 10px !important;
    }

    .sidebar.collapsed .nav-group-header {
        display: none;
    }

    .sidebar.collapsed .nav-group-header .nav-text,
    .sidebar.collapsed .nav-group-header .chevron {
        display: none;
    }

    .nav-item {
        padding: 11px 24px;
        color: #6b7280;
        text-decoration: none;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s;
        font-size: 14px;
        font-weight: 500;
        white-space: nowrap;
    }

    .nav-item:hover {
        background: rgba(30, 64, 175, 0.1);
        color: #1e40af;
    }

    .nav-item.active {
        background: rgba(30, 64, 175, 0.15);
        color: #1e40af;
        border-left: 3px solid #1e40af;
    }

    .nav-item svg {
        width: 24px;
        height: 24px;
        min-width: 24px;
    }

    .logout-btn {
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        padding: 16px 24px;
        border-top: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #ef4444;
        text-decoration: none;
        transition: all 0.3s;
        margin-top: auto;
        white-space: nowrap;
        font-size: 15px;
        font-weight: 500;
    }

    .logout-btn:hover {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .logout-btn svg {
        width: 24px;
        height: 24px;
        min-width: 24px;
    }

    .sidebar.collapsed .nav-text,
    .sidebar.collapsed .logout-text {
        display: none;
    }

    .sidebar.collapsed .logo {
        justify-content: center;
    }

    .sidebar.collapsed .nav-item {
        justify-content: center;
        padding: 12px;
    }

    .sidebar.collapsed .logout-btn {
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        justify-content: center;
        padding: 16px;
    }

    body:has(.sidebar.collapsed) .main-content {
        margin-left: 70px !important;
    }

    .mobile-menu-btn {
        position: fixed;
        top: 16px;
        left: 16px;
        z-index: 1001;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 12px;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        display: none;
    }

    .mobile-menu-btn svg {
        width: 24px;
        height: 24px;
        color: #1f2937;
    }

    .mobile-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 998;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s;
        display: none;
    }

    .mobile-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    @@media (max-width: 991px) {
        .mobile-overlay {
            display: block;
        }
    }

    @@media (max-width: 991px) {
        .mobile-menu-btn {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sidebar {
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            z-index: 999;
            width: 280px;
        }

        .sidebar.mobile-open {
            transform: translateX(0);
        }

        .sidebar.collapsed {
            width: 280px;
        }

        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .logout-text {
            display: inline;
        }

        .toggle-btn {
            display: none;
        }

        body:has(.sidebar.collapsed) .main-content {
            margin-left: 0 !important;
        }
    }

    @@media (max-width: 576px) {
        .sidebar {
            width: 260px;
        }

        .sidebar.collapsed {
            width: 260px;
        }
    }
</style>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('superAdminSidebar');
        sidebar.classList.toggle('collapsed');

        const isCollapsed = sidebar.classList.contains('collapsed');
        localStorage.setItem('superAdminSidebarCollapsed', isCollapsed);
    }

    document.addEventListener('DOMContentLoaded', function () {
        const sidebar = document.getElementById('superAdminSidebar');
        sidebar.classList.remove('notransition');
        document.querySelectorAll('#superAdminNav .nav-group').forEach(function (group, i) {
            var saved = localStorage.getItem('superAdminNavGroup_' + i);
            if (saved === 'true') group.classList.add('open');
            else if (saved === 'false') group.classList.remove('open');
        });
    });

    function toggleMobileSidebar() {
        const sidebar = document.getElementById('superAdminSidebar');
        const overlay = document.getElementById('mobileOverlay');
        sidebar.classList.toggle('mobile-open');
        overlay.classList.toggle('active');
        document.body.style.overflow = sidebar.classList.contains('mobile-open') ? 'hidden' : '';
    }

    function closeMobileSidebar() {
        const sidebar = document.getElementById('superAdminSidebar');
        const overlay = document.getElementById('mobileOverlay');
        sidebar.classList.remove('mobile-open');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    function toggleNavGroup(btn) {
        const sidebar = document.getElementById('superAdminSidebar');
        if (sidebar.classList.contains('collapsed')) return;
        const group = btn.closest('.nav-group');
        group.classList.toggle('open');
        const i = Array.from(document.querySelectorAll('#superAdminNav .nav-group')).indexOf(group);
        if (i >= 0) localStorage.setItem('superAdminNavGroup_' + i, group.classList.contains('open'));
    }

    document.querySelectorAll('.nav-item').forEach(item => {
        item.addEventListener('click', function () {
            if (window.innerWidth <= 991) {
                closeMobileSidebar();
            }
        });
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 991) {
            closeMobileSidebar();
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeMobileSidebar();
        }
    });
</script>






