@page
@model TechNova_IT_Solutions.Pages.ChiefComplianceManager.PolicyReviewModel
@{
    ViewData["Title"] = "Policy Review";
}

@section Styles {
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f8f9fa; color: #1f2937; display: flex; min-height: 100vh; }

        .main-content { margin-left: 260px; flex: 1; overflow-y: auto; }

        .content-area { padding: 28px 40px; }

        /* ── Summary Cards ──────────────── */
        .summary-cards { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 28px; }
        .summary-card { background: #fff; border-radius: 12px; padding: 20px 22px; box-shadow: 0 1px 4px rgba(0,0,0,.06); border-left: 4px solid #64748b; transition: transform .15s; }
        .summary-card:hover { transform: translateY(-2px); }
        .summary-card.pending-review { border-left-color: #f59e0b; }
        .summary-card.pending-update { border-left-color: #8b5cf6; }
        .summary-card.approved { border-left-color: #10b981; }
        .summary-card.rejected { border-left-color: #ef4444; }
        .summary-card.archived { border-left-color: #6b7280; }
        .summary-card .card-count { font-size: 32px; font-weight: 700; line-height: 1; }
        .summary-card .card-label { font-size: 13px; color: #64748b; margin-top: 4px; }

        /* ── Filters ──────────────────── */
        .filter-section { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; align-items: center; }
        .filter-section input, .filter-section select { padding: 9px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; background: #fff; }
        .filter-section input { flex: 1; min-width: 220px; }

        /* ── Table ────────────────────── */
        .policy-table-wrapper { background: #fff; border-radius: 12px; box-shadow: 0 1px 4px rgba(0,0,0,.06); overflow: hidden; }
        .policy-table { width: 100%; border-collapse: collapse; }
        .policy-table th { background: #f1f5f9; padding: 12px 16px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; color: #64748b; font-weight: 600; }
        .policy-table td { padding: 14px 16px; border-top: 1px solid #e5e7eb; font-size: 14px; vertical-align: middle; }
        .policy-table tr:hover td { background: #f9fafb; }

        /* Status badges */
        .badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
        .badge-pending-review { background: #fef3c7; color: #92400e; }
        .badge-pending-update { background: #ede9fe; color: #5b21b6; }
        .badge-approved { background: #d1fae5; color: #065f46; }
        .badge-rejected { background: #fee2e2; color: #991b1b; }
        .badge-archived { background: #f3f4f6; color: #374151; }

        .badge::before { content: ''; width: 7px; height: 7px; border-radius: 50%; }
        .badge-pending-review::before { background: #f59e0b; }
        .badge-pending-update::before { background: #8b5cf6; }
        .badge-approved::before { background: #10b981; }
        .badge-rejected::before { background: #ef4444; }
        .badge-archived::before { background: #6b7280; }

        /* ── Action Buttons ───────────── */
        .btn-sm { padding: 6px 14px; border-radius: 6px; font-size: 13px; font-weight: 500; border: none; cursor: pointer; transition: background .15s, transform .1s; }
        .btn-sm:active { transform: scale(.96); }
        .btn-review { background: #1d4ed8; color: #fff; }
        .btn-review:hover { background: #1e40af; }
        .btn-view { background: #f1f5f9; color: #334155; }
        .btn-view:hover { background: #e2e8f0; }
        .btn-approved-tag { background: #d1fae5; color: #065f46; cursor: default; }
        .btn-archived-tag { background: #f3f4f6; color: #6b7280; }
        .btn-archived-tag:hover { background: #e5e7eb; }
        .btn-rejected-tag { background: #fee2e2; color: #991b1b; }
        .btn-rejected-tag:hover { background: #fecaca; }

        /* ── Icon Buttons ─────────────── */
        .btn-icon { width: 34px; height: 34px; border-radius: 8px; border: 1.5px solid; background: transparent; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: all .15s; padding: 0; }
        .btn-icon svg { width: 16px; height: 16px; }
        .btn-icon.review { color: #1d4ed8; border-color: #93c5fd; background: #eff6ff; }
        .btn-icon.review:hover { background: #dbeafe; }
        .btn-icon.approved { color: #059669; border-color: #6ee7b7; background: #ecfdf5; }
        .btn-icon.approved:hover { background: #d1fae5; }
        .btn-icon.archived { color: #6b7280; border-color: #d1d5db; background: #f9fafb; }
        .btn-icon.archived:hover { background: #f3f4f6; }
        .btn-icon.rejected { color: #dc2626; border-color: #fca5a5; background: #fef2f2; }
        .btn-icon.rejected:hover { background: #fee2e2; }

        /* ── Modal ────────────────────── */
        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,23,42,.55); z-index: 1000; justify-content: center; align-items: center; }
        .modal-overlay.active { display: flex; }
        .modal-panel { background: #fff; border-radius: 16px; width: 680px; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,.2); }

        .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 22px 28px; border-bottom: 1px solid #e5e7eb; }
        .modal-header h2 { font-size: 18px; font-weight: 700; }
        .modal-close { background: none; border: none; font-size: 22px; cursor: pointer; color: #64748b; padding: 4px 8px; border-radius: 6px; }
        .modal-close:hover { background: #f1f5f9; color: #1f2937; }

        .modal-body { padding: 28px; }

        .review-section { margin-bottom: 22px; }
        .review-section h3 { font-size: 13px; text-transform: uppercase; letter-spacing: .06em; color: #64748b; margin-bottom: 8px; }
        .review-section .value { font-size: 15px; color: #1f2937; line-height: 1.6; }

        .diff-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 12px; }
        .diff-old { background: #fee2e2; border-radius: 8px; padding: 12px 16px; }
        .diff-new { background: #d1fae5; border-radius: 8px; padding: 12px 16px; }
        .diff-label { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #64748b; margin-bottom: 4px; }

        .review-notes-input { width: 100%; padding: 12px 16px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; min-height: 80px; resize: vertical; font-family: inherit; }
        .review-notes-input:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.15); }

        .modal-actions { display: flex; gap: 12px; justify-content: flex-end; padding: 18px 28px; border-top: 1px solid #e5e7eb; }
        .btn-approve { background: #10b981; color: #fff; padding: 10px 28px; border-radius: 8px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; }
        .btn-approve:hover { background: #059669; }
        .btn-reject { background: #ef4444; color: #fff; padding: 10px 28px; border-radius: 8px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; }
        .btn-reject:hover { background: #dc2626; }
        .btn-cancel { background: #f1f5f9; color: #334155; padding: 10px 28px; border-radius: 8px; border: none; font-size: 14px; font-weight: 500; cursor: pointer; }
        .btn-cancel:hover { background: #e2e8f0; }

        /* File preview */
        .file-preview { margin-top: 12px; }
        .file-preview iframe { width: 100%; height: 320px; border: 1px solid #e5e7eb; border-radius: 8px; }
        .file-link { display: inline-flex; align-items: center; gap: 6px; color: #1d4ed8; text-decoration: none; font-size: 14px; }
        .file-link:hover { text-decoration: underline; }

        /* ── Toast ────────────────────── */
        .toast { position: fixed; top: 24px; right: 24px; padding: 14px 24px; border-radius: 10px; font-size: 14px; font-weight: 500; color: #fff; z-index: 2000; box-shadow: 0 8px 24px rgba(0,0,0,.15); animation: slideIn .3s; }
        .toast-success { background: #10b981; }
        .toast-error { background: #ef4444; }
        @@keyframes slideIn { from { transform: translateX(80px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

        /* ── Branch tag ───────────────── */
        .branch-tag { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; background: #e0f2fe; color: #0369a1; }
        .branch-tag.global { background: #dbeafe; color: #1e40af; }

        /* ── Responsive ───────────────── */
        @@media (max-width: 1100px) { .summary-cards { grid-template-columns: repeat(3, 1fr); } }
        @@media (max-width: 768px) {
            .main-content { margin-left: 0; }
            .summary-cards { grid-template-columns: 1fr 1fr; }
            .diff-row { grid-template-columns: 1fr; }
            .modal-panel { width: 95%; }
        }

        .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; }
        .empty-state svg { width: 64px; height: 64px; margin-bottom: 16px; opacity: .5; }

        /* ── Detail grid in view modal ── */
        .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 20px; }
        .detail-item .detail-label { font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: #64748b; font-weight: 600; margin-bottom: 4px; }
        .detail-item .detail-value { font-size: 14px; color: #1f2937; line-height: 1.5; }
        .detail-full { grid-column: 1 / -1; }
        .detail-desc { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 14px 16px; font-size: 14px; line-height: 1.65; color: #1f2937; }
        .review-info-card { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 14px 16px; margin-top: 8px; }
        .review-info-card.rejected { background: #fef2f2; border-color: #fecaca; }
        .review-info-card .ri-label { font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #64748b; font-weight: 600; }
        .review-info-card .ri-value { font-size: 14px; color: #1f2937; margin-top: 2px; }

        /* Status banners */
        .status-banner-approved { background: #f0fdf4; color: #166534; border-bottom: 1px solid #bbf7d0; }
        .status-banner-rejected { background: #fef2f2; color: #991b1b; border-bottom: 1px solid #fecaca; }
        .status-banner-archived { background: #f3f4f6; color: #374151; border-bottom: 1px solid #d1d5db; }
        .status-banner-pending { background: #fffbeb; color: #92400e; border-bottom: 1px solid #fde68a; }
    </style>
}

<!-- Toast notifications -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="toast toast-success" id="toast">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="toast toast-error" id="toast">@TempData["ErrorMessage"]</div>
}

@await Html.PartialAsync("_ChiefComplianceManagerSidebar", "PolicyReview")

<div class="main-content">
    @await Html.PartialAsync("_ComplianceManagerTopBar", (Title: "Policy Review", Description: "Review, approve, or reject branch-submitted policies and updates"))

    <div class="content-area">
        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="summary-card pending-review">
                <div class="card-count">@Model.PendingReviewCount</div>
                <div class="card-label">Pending Review</div>
            </div>
            <div class="summary-card pending-update">
                <div class="card-count">@Model.PendingUpdateCount</div>
                <div class="card-label">Pending Update</div>
            </div>
            <div class="summary-card approved">
                <div class="card-count">@Model.ApprovedCount</div>
                <div class="card-label">Approved</div>
            </div>
            <div class="summary-card rejected">
                <div class="card-count">@Model.RejectedCount</div>
                <div class="card-label">Rejected</div>
            </div>
            <div class="summary-card archived">
                <div class="card-count">@Model.ArchivedCount</div>
                <div class="card-label">Archived</div>
            </div>
        </div>

        <!-- Filters -->
        <form method="get" class="filter-section">
            <input type="text" name="SearchQuery" placeholder="Search policies..." value="@Model.SearchQuery" />
            <select name="CategoryFilter">
                <option value="All">All Categories</option>
                @foreach (var cat in Model.AvailableCategories)
                {
                    <option value="@cat" selected="@(Model.CategoryFilter == cat)">@cat</option>
                }
            </select>
            <select name="StatusFilter">
                <option value="All">All Statuses</option>
                <option value="PendingReview" selected="@(Model.StatusFilter == "PendingReview")">Pending Review</option>
                <option value="PendingUpdate" selected="@(Model.StatusFilter == "PendingUpdate")">Pending Update</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
                <option value="Archived" selected="@(Model.StatusFilter == "Archived")">Archived</option>
            </select>
            <button type="submit" class="btn-sm btn-view">Filter</button>
        </form>

        <!-- Policy Table -->
        <div class="policy-table-wrapper">
            @if (Model.Policies.Count == 0)
            {
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <p>No policies match the current filters.</p>
                </div>
            }
            else
            {
                <table class="policy-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Policy Title</th>
                            <th>Category</th>
                            <th>Branch</th>
                            <th>Uploaded By</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Policies)
                        {
                            var badgeClass = p.ReviewStatus switch
                            {
                                "PendingReview" => "badge-pending-review",
                                "PendingUpdate" => "badge-pending-update",
                                "Approved" => "badge-approved",
                                "Rejected" => "badge-rejected",
                                "Archived" => "badge-archived",
                                _ => "badge-approved"
                            };
                            var statusLabel = p.ReviewStatus switch
                            {
                                "PendingReview" => "Pending Review",
                                "PendingUpdate" => "Pending Update",
                                _ => p.ReviewStatus
                            };
                            <tr>
                                <td>#@p.PolicyId</td>
                                <td><strong>@p.Title</strong></td>
                                <td>@p.Category</td>
                                <td>
                                    <span class="branch-tag @(p.BranchName == "Company-wide" ? "global" : "")">
                                        @p.BranchName
                                    </span>
                                </td>
                                <td>@p.UploadedBy</td>
                                <td>@p.DateUploaded.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge @badgeClass">@statusLabel</span></td>
                                <td>
                                    @if (p.ReviewStatus is "PendingReview" or "PendingUpdate")
                                    {
                                        <button class="btn-icon review" onclick="openReviewModal(@p.PolicyId)" title="Review Policy">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                        </button>
                                    }
                                    else if (p.ReviewStatus == "Approved")
                                    {
                                        <button class="btn-icon approved" onclick="openViewModal(@p.PolicyId)" title="View Approved Policy">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                        </button>
                                    }
                                    else if (p.ReviewStatus == "Archived")
                                    {
                                        <button class="btn-icon archived" onclick="openViewModal(@p.PolicyId)" title="View Archived Policy">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
                                        </button>
                                    }
                                    else if (p.ReviewStatus == "Rejected")
                                    {
                                        <button class="btn-icon rejected" onclick="openViewModal(@p.PolicyId)" title="View Rejected Policy">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn-icon archived" onclick="openViewModal(@p.PolicyId)" title="View Policy">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<!-- ═══════ Review Modal ═══════ -->
<div class="modal-overlay" id="reviewModal">
    <div class="modal-panel">
        <div class="modal-header">
            <h2 id="reviewModalTitle">Policy Review</h2>
            <button class="modal-close" onclick="closeModal('reviewModal')">&times;</button>
        </div>
        <div class="modal-body" id="reviewModalBody">
            <!-- Populated by JS -->
        </div>
        <div class="modal-actions" id="reviewModalActions">
            <!-- Populated by JS -->
        </div>
    </div>
</div>

<!-- ═══════ View / Review Detail Modal ═══════ -->
<div class="modal-overlay" id="viewModal">
    <div class="modal-panel" style="width:760px;">
        <div class="modal-header" style="background:linear-gradient(135deg,#0f172a,#1e3a5f);border-radius:16px 16px 0 0;border-bottom:none;">
            <div>
                <h2 id="viewModalTitle" style="color:#fff;font-size:18px;">Policy Details</h2>
                <div id="viewModalSubtitle" style="color:#94a3b8;font-size:13px;margin-top:2px;"></div>
            </div>
            <button class="modal-close" onclick="closeModal('viewModal')" style="color:#94a3b8;">&times;</button>
        </div>

        <!-- Status Banner -->
        <div id="viewStatusBanner" style="padding:12px 28px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;"></div>

        <div class="modal-body" id="viewModalBody" style="padding:24px 28px;">
            <!-- Populated by JS -->
        </div>
        <div class="modal-actions" id="viewModalActions">
            <button class="btn-cancel" onclick="closeModal('viewModal')">Close</button>
        </div>
    </div>
</div>

<!-- Hidden forms for approve/reject -->
<form id="approveForm" method="post" asp-page-handler="Approve" style="display:none;">
    <input type="hidden" name="policyId" id="approvePolicyId" />
    <input type="hidden" name="reviewNotes" id="approveNotes" />
</form>
<form id="rejectForm" method="post" asp-page-handler="Reject" style="display:none;">
    <input type="hidden" name="policyId" id="rejectPolicyId" />
    <input type="hidden" name="reviewNotes" id="rejectNotes" />
</form>

@section Scripts {
    <script>
        // Policy data from server
        const policiesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Policies, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        function getPolicy(id) {
            return policiesData.find(p => p.policyId === id);
        }

        function escHtml(str) {
            if (!str) return '';
            const d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        function openReviewModal(id) {
            const p = getPolicy(id);
            if (!p) return;

            const isPendingUpdate = p.reviewStatus === 'PendingUpdate';
            document.getElementById('reviewModalTitle').textContent =
                isPendingUpdate ? 'Review Policy Update' : 'Review New Policy';

            let body = '';

            if (isPendingUpdate) {
                // Show diff between current and pending values
                body += '<div class="review-section"><h3>Update Comparison</h3></div>';

                if (p.pendingTitle && p.pendingTitle !== p.title) {
                    body += `<div class="diff-row">
                        <div class="diff-old"><div class="diff-label">Current Title</div>${escHtml(p.title)}</div>
                        <div class="diff-new"><div class="diff-label">Proposed Title</div>${escHtml(p.pendingTitle)}</div>
                    </div>`;
                }
                if (p.pendingCategory && p.pendingCategory !== p.category) {
                    body += `<div class="diff-row">
                        <div class="diff-old"><div class="diff-label">Current Category</div>${escHtml(p.category)}</div>
                        <div class="diff-new"><div class="diff-label">Proposed Category</div>${escHtml(p.pendingCategory)}</div>
                    </div>`;
                }
                if (p.pendingDescription && p.pendingDescription !== p.description) {
                    body += `<div class="diff-row">
                        <div class="diff-old"><div class="diff-label">Current Description</div>${escHtml(p.description)}</div>
                        <div class="diff-new"><div class="diff-label">Proposed Description</div>${escHtml(p.pendingDescription)}</div>
                    </div>`;
                }
                if (p.pendingFilePath) {
                    body += `<div class="review-section"><h3>New Attached File</h3>
                        <a class="file-link" href="${escHtml(p.pendingFilePath)}" target="_blank">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            View proposed file
                        </a></div>`;
                }
                if (p.pendingUpdatedAt) {
                    body += `<div class="review-section"><h3>Update Submitted</h3><div class="value">${new Date(p.pendingUpdatedAt).toLocaleString()}</div></div>`;
                }
            } else {
                // New policy review
                body += `<div class="review-section"><h3>Title</h3><div class="value">${escHtml(p.title)}</div></div>`;
                body += `<div class="review-section"><h3>Category</h3><div class="value">${escHtml(p.category)}</div></div>`;
                body += `<div class="review-section"><h3>Branch</h3><div class="value"><span class="branch-tag">${escHtml(p.branchName)}</span></div></div>`;
                body += `<div class="review-section"><h3>Description</h3><div class="value">${escHtml(p.description) || '<em>No description provided.</em>'}</div></div>`;
                body += `<div class="review-section"><h3>Uploaded By</h3><div class="value">${escHtml(p.uploadedBy)} &mdash; ${new Date(p.dateUploaded).toLocaleDateString()}</div></div>`;

                if (p.fileName) {
                    const ext = p.fileName.split('.').pop()?.toLowerCase();
                    if (ext === 'pdf') {
                        body += `<div class="review-section"><h3>Attached Document</h3><div class="file-preview"><iframe src="${escHtml(p.fileName)}" title="Document preview"></iframe></div></div>`;
                    } else {
                        body += `<div class="review-section"><h3>Attached Document</h3>
                            <a class="file-link" href="${escHtml(p.fileName)}" target="_blank">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                Download / view file
                            </a></div>`;
                    }
                }
            }

            // Review notes input
            body += `<div class="review-section" style="margin-top:20px;">
                <h3>Review Notes (optional)</h3>
                <textarea class="review-notes-input" id="reviewNotesInput" placeholder="Add notes for the branch about this decision..."></textarea>
            </div>`;

            document.getElementById('reviewModalBody').innerHTML = body;

            // Actions
            const label = isPendingUpdate ? 'Approve Update' : 'Approve Policy';
            document.getElementById('reviewModalActions').innerHTML = `
                <button class="btn-cancel" onclick="closeModal('reviewModal')">Cancel</button>
                <button class="btn-reject" onclick="submitReject(${p.policyId})">Reject</button>
                <button class="btn-approve" onclick="submitApprove(${p.policyId})">${label}</button>
            `;

            document.getElementById('reviewModal').classList.add('active');
        }

        function openViewModal(id) {
            const p = getPolicy(id);
            if (!p) return;

            document.getElementById('viewModalTitle').textContent = p.title;
            document.getElementById('viewModalSubtitle').textContent = `POL-${String(p.policyId).padStart(3,'0')} • ${escHtml(p.branchName)}`;

            // Status banner
            const banner = document.getElementById('viewStatusBanner');
            const statusMap = {
                'Approved':      { cls: 'status-banner-approved',  icon: '✓', label: 'Approved' },
                'Rejected':      { cls: 'status-banner-rejected',  icon: '✕', label: 'Rejected' },
                'Archived':      { cls: 'status-banner-archived',  icon: '◉', label: 'Archived by Branch' },
                'PendingReview': { cls: 'status-banner-pending',   icon: '◷', label: 'Pending Review' },
                'PendingUpdate': { cls: 'status-banner-pending',   icon: '◷', label: 'Pending Update' }
            };
            const st = statusMap[p.reviewStatus] || statusMap['Approved'];
            banner.className = st.cls;
            banner.innerHTML = `<span style="font-size:16px;">${st.icon}</span> ${st.label}`;

            let body = '';

            // Main details grid
            body += `<div class="detail-grid">
                <div class="detail-item">
                    <div class="detail-label">Category</div>
                    <div class="detail-value">${escHtml(p.category)}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Branch</div>
                    <div class="detail-value"><span class="branch-tag ${p.branchName === 'Company-wide' ? 'global' : ''}">${escHtml(p.branchName)}</span></div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Uploaded By</div>
                    <div class="detail-value">${escHtml(p.uploadedBy)}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Date Submitted</div>
                    <div class="detail-value">${new Date(p.dateUploaded).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
                </div>
            </div>`;

            // Description
            body += `<div class="detail-item detail-full" style="margin-bottom:18px;">
                <div class="detail-label">Description</div>
                <div class="detail-desc">${escHtml(p.description) || '<em style="color:#94a3b8;">No description provided.</em>'}</div>
            </div>`;

            // Document
            if (p.fileName) {
                const ext = p.fileName.split('.').pop()?.toLowerCase();
                body += `<div class="detail-item detail-full" style="margin-bottom:18px;">
                    <div class="detail-label">Attached Document</div>`;
                if (ext === 'pdf') {
                    body += `<div class="file-preview" style="margin-top:8px;"><iframe src="${escHtml(p.fileName)}" title="Document preview"></iframe></div>`;
                } else {
                    body += `<div style="margin-top:8px;"><a class="file-link" href="${escHtml(p.fileName)}" target="_blank">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        Download / View File</a></div>`;
                }
                body += `</div>`;
            }

            // Review history
            if (p.reviewedBy) {
                const isRejected = p.reviewStatus === 'Rejected';
                body += `<div class="review-info-card ${isRejected ? 'rejected' : ''}">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div><div class="ri-label">Reviewed By</div><div class="ri-value">${escHtml(p.reviewedBy)}</div></div>
                        <div><div class="ri-label">Reviewed On</div><div class="ri-value">${p.reviewedAt ? new Date(p.reviewedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A'}</div></div>
                    </div>`;
                if (p.reviewNotes) {
                    body += `<div style="margin-top:10px;"><div class="ri-label">Review Notes</div><div class="ri-value">${escHtml(p.reviewNotes)}</div></div>`;
                }
                body += `</div>`;
            }

            document.getElementById('viewModalBody').innerHTML = body;

            // Actions — show approve button for approved policies (no action needed), but show nothing extra for archived/rejected
            let actions = `<button class="btn-cancel" onclick="closeModal('viewModal')">Close</button>`;
            document.getElementById('viewModalActions').innerHTML = actions;

            document.getElementById('viewModal').classList.add('active');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        function submitApprove(policyId) {
            const notes = document.getElementById('reviewNotesInput')?.value || '';
            document.getElementById('approvePolicyId').value = policyId;
            document.getElementById('approveNotes').value = notes;
            document.getElementById('approveForm').submit();
        }

        function submitReject(policyId) {
            const notes = document.getElementById('reviewNotesInput')?.value || '';
            if (!notes.trim()) {
                if (!confirm('No rejection reason provided. Continue anyway?')) return;
            }
            document.getElementById('rejectPolicyId').value = policyId;
            document.getElementById('rejectNotes').value = notes;
            document.getElementById('rejectForm').submit();
        }

        // Close modal on overlay click
        document.querySelectorAll('.modal-overlay').forEach(m => {
            m.addEventListener('click', e => { if (e.target === m) closeModal(m.id); });
        });

        // Auto-dismiss toast
        const toast = document.getElementById('toast');
        if (toast) setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity .4s'; setTimeout(() => toast.remove(), 400); }, 4000);
    </script>
}

