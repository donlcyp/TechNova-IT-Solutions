@page
@model TechNova_IT_Solutions.Pages.ChiefComplianceManager.ViolationManagementModel
@{
    ViewData["Title"] = "Violation Management";
}

@section Styles {
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif; background: #f8f9fa; color: #1f2937; display: flex; min-height: 100vh; }
        .main-content { margin-left: 260px; flex: 1; overflow-y: auto; }
        .content-wrapper { padding: 24px; max-width: 1400px; margin: 0 auto; }

        /* Buttons */
        .btn-primary { padding: 12px 24px; background: linear-gradient(135deg,#1e40af 0%,#1e3a8a 100%); border: none; border-radius: 8px; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; transition: opacity .2s; }
        .btn-primary:hover { opacity: .9; }
        .btn-secondary { padding: 10px 20px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #6b7280; font-size: 14px; font-weight: 600; cursor: pointer; transition: all .2s; }
        .btn-secondary:hover { border-color: #1e40af; color: #1e40af; }
        .btn-action { padding: 6px 12px; border: 1px solid #e5e7eb; border-radius: 6px; background: #f8f9fa; color: #6b7280; font-size: 12px; cursor: pointer; transition: all .2s; white-space: nowrap; }
        .btn-action:hover { border-color: #1e40af; color: #1e40af; }
        .btn-action.danger { color: #e53e3e; }
        .btn-action.danger:hover { border-color: #e53e3e; }
        .btn-action.success { color: #38a169; }
        .btn-action.success:hover { border-color: #38a169; }

        /* Summary Cards */
        .summary-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 24px; }
        .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px 20px; transition: transform .2s; display: grid; grid-template-columns: auto 1fr; grid-template-rows: auto auto; gap: 0 12px; align-items: center; }

        .card-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; grid-row: 1/3; }
        .card-icon svg { width: 22px; height: 22px; }
        .card-value { font-size: 26px; font-weight: 700; color: #1f2937; margin-bottom: 4px; }
        .card-label { font-size: 14px; color: #6b7280; font-weight: 500; }

        /* Tabs */
        .tab-bar { display: flex; gap: 0; margin-bottom: 24px; border-bottom: 2px solid #e5e7eb; }
        .tab-btn { padding: 12px 24px; background: none; border: none; border-bottom: 2px solid transparent; margin-bottom: -2px; font-size: 14px; font-weight: 600; color: #6b7280; cursor: pointer; transition: all .2s; }
        .tab-btn.active { color: #1e40af; border-bottom-color: #1e40af; }
        .tab-btn:hover { color: #1e40af; }
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* Filter */
        .filter-section { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; margin-bottom: 20px; display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }
        .search-box { flex: 1; min-width: 200px; position: relative; }
        .search-box input { width: 100%; padding: 10px 14px 10px 40px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #1f2937; font-size: 14px; }
        .search-box input:focus { outline: none; border-color: #1e40af; }
        .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #6b7280; width: 18px; height: 18px; }
        select { padding: 10px 14px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #1f2937; font-size: 14px; cursor: pointer; }
        select:focus { outline: none; border-color: #1e40af; }

        /* Table */
        .table-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
        .table-scroll { width: 100%; overflow-x: auto; }
        .table-scroll table { min-width: 900px; }
        table { width: 100%; border-collapse: collapse; }
        thead { background: #f3f4f6; }
        th { text-align: left; padding: 12px 16px; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; border-bottom: 2px solid #e5e7eb; }
        td { padding: 14px 16px; border-bottom: 1px solid #e5e7eb; font-size: 14px; color: #1f2937; }
        tbody tr { transition: background .2s; }
        tbody tr:hover { background: #f3f4f6; }
        .status-badge { display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600; }
        .status-badge.open { color: #d97706; background: #fffbeb; }
        .status-badge.underreview { color: #2563eb; background: #eff6ff; }
        .status-badge.escalated { color: #dc2626; background: #fef2f2; }
        .status-badge.resolved { color: #16a34a; background: #f0fdf4; }
        .empty-state { text-align: center; padding: 60px 20px; color: #6b7280; }
        .empty-state svg { width: 48px; height: 48px; margin-bottom: 12px; opacity: .5; }
        .actions { display: flex; gap: 6px; flex-wrap: wrap; }

        /* Modal */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,.7); z-index: 1000; align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        .modal-content { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
        .modal-header { padding: 24px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
        .modal-header h2 { font-size: 20px; font-weight: 600; color: #1f2937; }
        .btn-close { background: none; border: none; font-size: 24px; color: #6b7280; cursor: pointer; }
        .btn-close:hover { color: #1f2937; }
        .modal-body { padding: 24px; }
        .modal-footer { padding: 24px; border-top: 1px solid #e5e7eb; display: flex; justify-content: flex-end; gap: 12px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-size: 14px; font-weight: 600; color: #1f2937; }
        .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 10px 14px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #1f2937; font-size: 14px; font-family: inherit; }
        .form-group textarea { min-height: 100px; resize: vertical; }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: #1e40af; }

        /* Detail panel for updating status */
        .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
        .detail-item { }
        .detail-item .label { font-size: 12px; color: #6b7280; font-weight: 600; text-transform: uppercase; margin-bottom: 4px; }
        .detail-item .value { font-size: 14px; color: #1f2937; }
        .notes-history { background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; max-height: 200px; overflow-y: auto; white-space: pre-wrap; font-size: 13px; color: #374151; margin-bottom: 16px; }

        @@media (max-width: 991px) { .main-content { margin-left: 0; } .content-wrapper { padding: 20px; } }
        @@media (max-width: 768px) { .filter-section { flex-direction: column; } .search-box { min-width: 100%; } .tab-btn { padding: 10px 16px; font-size: 13px; } }
        @@media (max-width: 576px) { .summary-cards { grid-template-columns: 1fr; } .detail-grid { grid-template-columns: 1fr; } }
    </style>
}

@await Html.PartialAsync("_ChiefComplianceManagerSidebar", "ViolationManagement")

<!-- Main Content -->
<div class="main-content">
    @await Html.PartialAsync("_ComplianceManagerTopBar", (Title: "Violation Management", Description: "Track, escalate and resolve compliance violations"))

    <div class="content-wrapper">
        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="card">
                <div class="card-icon" style="color: #d97706;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div class="card-value">@Model.OpenViolations</div>
                <div class="card-label">Open</div>
            </div>
            <div class="card">
                <div class="card-icon" style="color: #2563eb;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div class="card-value">@Model.UnderReviewViolations</div>
                <div class="card-label">Under Review</div>
            </div>
            <div class="card">
                <div class="card-icon" style="color: #dc2626;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <div class="card-value">@Model.EscalatedViolations</div>
                <div class="card-label">Escalated</div>
            </div>
            <div class="card">
                <div class="card-icon" style="color: #16a34a;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div class="card-value">@Model.ResolvedViolations</div>
                <div class="card-label">Resolved</div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="tab-bar">
            <button class="tab-btn active" data-tab="violations" onclick="switchTab('violations')">All Violations</button>
            <button class="tab-btn" data-tab="employees" onclick="switchTab('employees')">Non-Compliant Employees</button>
            <button class="tab-btn" data-tab="suppliers" onclick="switchTab('suppliers')">Non-Compliant Suppliers</button>
        </div>

        <!-- Violations Tab -->
        <div class="tab-panel active" id="panel-violations">
            <div class="filter-section">
                <div class="search-box">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input type="text" id="violationSearch" placeholder="Search violations..." oninput="filterViolationTable()" />
                </div>
                <select id="typeFilter" onchange="loadViolations()">
                    <option value="All">All Types</option>
                    <option value="Employee">Employee</option>
                    <option value="Supplier">Supplier</option>
                </select>
                <select id="statusFilterV" onchange="loadViolations()">
                    <option value="All">All Statuses</option>
                    <option value="Open">Open</option>
                    <option value="UnderReview">Under Review</option>
                    <option value="Escalated">Escalated</option>
                    <option value="Resolved">Resolved</option>
                </select>
                <button class="btn-primary" onclick="openCreateViolation()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Raise Violation
                </button>
            </div>
            <div class="table-card">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Type</th>
                                <th>Subject</th>
                                <th>Policy</th>
                                <th>Status</th>
                                <th>Raised</th>
                                <th>Raised By</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="violationsBody">
                            <tr><td colspan="8" class="empty-state">Loading violations...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Non-Compliant Employees Tab -->
        <div class="tab-panel" id="panel-employees">
            <div class="filter-section">
                <div class="search-box">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input type="text" id="empSearch" placeholder="Search employees..." oninput="filterEmpTable()" />
                </div>
            </div>
            <div class="table-card">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Email</th>
                                <th>Policy</th>
                                <th>Assigned</th>
                                <th>Status</th>
                                <th>Violation</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="empBody">
                            <tr><td colspan="7" class="empty-state">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Non-Compliant Suppliers Tab -->
        <div class="tab-panel" id="panel-suppliers">
            <div class="filter-section">
                <div class="search-box">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input type="text" id="supSearch" placeholder="Search suppliers..." oninput="filterSupTable()" />
                </div>
            </div>
            <div class="table-card">
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Supplier</th>
                                <th>Account Status</th>
                                <th>Policy</th>
                                <th>Assigned</th>
                                <th>Compliance</th>
                                <th>Violation</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="supBody">
                            <tr><td colspan="7" class="empty-state">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Violation Modal -->
<div class="modal" id="createViolationModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Raise Compliance Violation</h2>
            <button class="btn-close" onclick="closeCreateViolation()">&times;</button>
        </div>
        <div class="modal-body">
            <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px 14px;margin-bottom:18px;font-size:13px;color:#1e3a8a;display:flex;gap:10px;align-items:flex-start;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div><strong>Tip:</strong> For easier entry, go to the <strong>Non-Compliant Employees</strong> or <strong>Non-Compliant Suppliers</strong> tab and click <em>"Raise Violation"</em> on a specific row — the form will auto-fill.</div>
            </div>
            <div class="form-group">
                <label for="cvType">Violation Type</label>
                <select id="cvType" onchange="onViolationTypeChange()">
                    <option value="Employee">Employee Violation</option>
                    <option value="Supplier">Supplier Violation</option>
                </select>
            </div>
            <div class="form-group" id="cvAssignmentGroup">
                <label for="cvAssignmentId">Policy Assignment ID</label>
                <input type="number" id="cvAssignmentId" placeholder="Enter policy assignment ID" />
                <small style="color: #6b7280; font-size: 12px;">Find from Non-Compliant Employees tab</small>
            </div>
            <div class="form-group" id="cvSupplierPolicyGroup" style="display:none;">
                <label for="cvSupplierPolicyId">Supplier Policy ID</label>
                <input type="number" id="cvSupplierPolicyId" placeholder="Enter supplier policy ID" />
                <small style="color: #6b7280; font-size: 12px;">Find from Non-Compliant Suppliers tab</small>
            </div>
            <div class="form-group">
                <label for="cvDescription">Description</label>
                <textarea id="cvDescription" placeholder="Describe the compliance violation..."></textarea>
            </div>
            <div class="form-group">
                <label for="cvNotes">Notes (optional)</label>
                <textarea id="cvNotes" placeholder="Additional notes..." style="min-height: 60px;"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeCreateViolation()">Cancel</button>
            <button class="btn-primary" onclick="submitCreateViolation()">Raise Violation</button>
        </div>
    </div>
</div>

<!-- Update Violation Status Modal -->
<div class="modal" id="updateViolationModal">
    <div class="modal-content" style="max-width: 650px;">
        <div class="modal-header">
            <h2 id="updateModalTitle">Violation Details</h2>
            <button class="btn-close" onclick="closeUpdateViolation()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="detail-grid" id="violationDetailGrid"></div>
            <div id="violationNotesHistory" class="notes-history" style="display:none;"></div>
            <div class="form-group">
                <label for="uvStatus">Update Status</label>
                <select id="uvStatus">
                    <option value="Open">Open</option>
                    <option value="UnderReview">Under Review</option>
                    <option value="Escalated">Escalated</option>
                    <option value="Resolved">Resolved</option>
                </select>
            </div>
            <div class="form-group">
                <label for="uvNotes">Add Notes</label>
                <textarea id="uvNotes" placeholder="Add a note about this status change..." style="min-height:60px;"></textarea>
            </div>
            <div class="form-group" id="uvResolutionGroup" style="display:none;">
                <label for="uvResolution">Resolution</label>
                <textarea id="uvResolution" placeholder="Describe how the violation was resolved..." style="min-height:60px;"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeUpdateViolation()">Cancel</button>
            <button class="btn-primary" onclick="submitUpdateViolation()">Update</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const API = '/ComplianceManagerPolicy';
    let currentViolationId = null;

    /* ── Tab switching ─────────────────────────────── */
    function switchTab(tab) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id === 'panel-' + tab));
        if (tab === 'violations') loadViolations();
        else if (tab === 'employees') loadNonCompliantEmployees();
        else if (tab === 'suppliers') loadNonCompliantSuppliers();
    }

    /* ── Load Violations ───────────────────────────── */
    function loadViolations() {
        const type = document.getElementById('typeFilter').value;
        const status = document.getElementById('statusFilterV').value;
        const url = `${API}/GetViolations?type=${encodeURIComponent(type)}&status=${encodeURIComponent(status)}`;
        document.getElementById('violationsBody').innerHTML = '<tr><td colspan="8" class="empty-state">Loading...</td></tr>';

        fetch(url).then(r => r.json()).then(res => {
            if (!res.success || !res.violations.length) {
                document.getElementById('violationsBody').innerHTML = '<tr><td colspan="8" class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M16 16s-1.5-2-4-2-4 2-4 2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg><div>No violations found</div></td></tr>';
                return;
            }
            let html = '';
            res.violations.forEach(v => {
                const statusClass = v.status.toLowerCase().replace(/\s+/g, '');
                html += `<tr>
                    <td>#${v.violationId}</td>
                    <td>${v.violationType}</td>
                    <td>${v.subjectName}</td>
                    <td>${v.policyName}</td>
                    <td><span class="status-badge ${statusClass}">${formatStatus(v.status)}</span></td>
                    <td>${v.raisedDate}</td>
                    <td>${v.raisedBy}</td>
                    <td><div class="actions">
                        <button class="btn-action" onclick='openUpdateViolation(${JSON.stringify(v)})'>Manage</button>
                    </div></td>
                </tr>`;
            });
            document.getElementById('violationsBody').innerHTML = html;
        }).catch(() => {
            document.getElementById('violationsBody').innerHTML = '<tr><td colspan="8" class="empty-state" style="color:#e53e3e;">Error loading violations</td></tr>';
        });
    }

    function formatStatus(s) {
        if (s === 'UnderReview') return 'Under Review';
        return s;
    }

    function filterViolationTable() {
        const q = document.getElementById('violationSearch').value.toLowerCase();
        document.querySelectorAll('#violationsBody tr').forEach(r => {
            r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }

    /* ── Non-Compliant Employees ───────────────────── */
    function loadNonCompliantEmployees() {
        document.getElementById('empBody').innerHTML = '<tr><td colspan="7" class="empty-state">Loading...</td></tr>';
        fetch(API + '/GetNonCompliantEmployees').then(r => r.json()).then(res => {
            if (!res.success || !res.employees.length) {
                document.getElementById('empBody').innerHTML = '<tr><td colspan="7" class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><div>All employees are compliant!</div></td></tr>';
                return;
            }
            let html = '';
            res.employees.forEach(e => {
                const violBadge = e.hasViolation
                    ? '<span class="status-badge escalated">Active Violation</span>'
                    : '<span style="color:#6b7280;font-size:12px;">None</span>';
                html += `<tr>
                    <td>${e.employeeName}</td>
                    <td>${e.email}</td>
                    <td>${e.policyTitle}</td>
                    <td>${e.assignedDate}</td>
                    <td><span class="status-badge open">${e.status}</span></td>
                    <td>${violBadge}</td>
                    <td><div class="actions">
                        ${!e.hasViolation ? `<button class="btn-action danger" onclick="raiseViolationFor('Employee', ${e.assignmentId}, null, '${escJs(e.employeeName)}', '${escJs(e.policyTitle)}')">Raise Violation</button>` : ''}
                    </div></td>
                </tr>`;
            });
            document.getElementById('empBody').innerHTML = html;
        }).catch(() => {
            document.getElementById('empBody').innerHTML = '<tr><td colspan="7" class="empty-state" style="color:#e53e3e;">Error loading data</td></tr>';
        });
    }

    function filterEmpTable() {
        const q = document.getElementById('empSearch').value.toLowerCase();
        document.querySelectorAll('#empBody tr').forEach(r => r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none');
    }

    /* ── Non-Compliant Suppliers ───────────────────── */
    function loadNonCompliantSuppliers() {
        document.getElementById('supBody').innerHTML = '<tr><td colspan="7" class="empty-state">Loading...</td></tr>';
        fetch(API + '/GetNonCompliantSuppliers').then(r => r.json()).then(res => {
            if (!res.success || !res.suppliers.length) {
                document.getElementById('supBody').innerHTML = '<tr><td colspan="7" class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><div>All suppliers are compliant!</div></td></tr>';
                return;
            }
            let html = '';
            res.suppliers.forEach(s => {
                const violBadge = s.hasViolation
                    ? '<span class="status-badge escalated">Active Violation</span>'
                    : '<span style="color:#6b7280;font-size:12px;">None</span>';
                const acctBadge = s.supplierStatus === 'Suspended'
                    ? '<span class="status-badge escalated">Suspended</span>'
                    : `<span class="status-badge resolved">${s.supplierStatus}</span>`;
                html += `<tr>
                    <td>${s.supplierName}</td>
                    <td>${acctBadge}</td>
                    <td>${s.policyTitle}</td>
                    <td>${s.assignedDate}</td>
                    <td><span class="status-badge open">${s.complianceStatus}</span></td>
                    <td>${violBadge}</td>
                    <td><div class="actions">
                        ${!s.hasViolation ? `<button class="btn-action danger" onclick="raiseViolationFor('Supplier', null, ${s.supplierPolicyId}, '${escJs(s.supplierName)}', '${escJs(s.policyTitle)}')">Raise Violation</button>` : ''}
                        ${s.supplierStatus !== 'Suspended' ? `<button class="btn-action danger" onclick="suspendSupplier(${s.supplierId}, '${escJs(s.supplierName)}')">Suspend</button>` : `<button class="btn-action success" onclick="unsuspendSupplier(${s.supplierId}, '${escJs(s.supplierName)}')">Unsuspend</button>`}
                    </div></td>
                </tr>`;
            });
            document.getElementById('supBody').innerHTML = html;
        }).catch(() => {
            document.getElementById('supBody').innerHTML = '<tr><td colspan="7" class="empty-state" style="color:#e53e3e;">Error loading data</td></tr>';
        });
    }

    function filterSupTable() {
        const q = document.getElementById('supSearch').value.toLowerCase();
        document.querySelectorAll('#supBody tr').forEach(r => r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none');
    }

    /* ── JS Escape for inline strings ──────────────── */
    function escJs(s) { return (s || '').replace(/'/g, "\\'").replace(/"/g, '&quot;'); }

    /* ── Create Violation ──────────────────────────── */
    function openCreateViolation() {
        document.getElementById('cvType').value = 'Employee';
        document.getElementById('cvAssignmentId').value = '';
        document.getElementById('cvSupplierPolicyId').value = '';
        document.getElementById('cvDescription').value = '';
        document.getElementById('cvNotes').value = '';
        onViolationTypeChange();
        document.getElementById('createViolationModal').classList.add('active');
    }
    function closeCreateViolation() { document.getElementById('createViolationModal').classList.remove('active'); }

    function raiseViolationFor(type, assignmentId, supplierPolicyId, name, policy) {
        document.getElementById('cvType').value = type;
        onViolationTypeChange();
        if (type === 'Employee') document.getElementById('cvAssignmentId').value = assignmentId || '';
        else document.getElementById('cvSupplierPolicyId').value = supplierPolicyId || '';
        document.getElementById('cvDescription').value = `Non-compliance violation for ${name} regarding policy: ${policy}`;
        document.getElementById('cvNotes').value = '';
        document.getElementById('createViolationModal').classList.add('active');
    }

    function onViolationTypeChange() {
        const isEmp = document.getElementById('cvType').value === 'Employee';
        document.getElementById('cvAssignmentGroup').style.display = isEmp ? '' : 'none';
        document.getElementById('cvSupplierPolicyGroup').style.display = isEmp ? 'none' : '';
    }

    async function submitCreateViolation() {
        const type = document.getElementById('cvType').value;
        const desc = document.getElementById('cvDescription').value.trim();
        if (!desc) { await window.showAppMessage('Description is required.', 'Validation'); return; }

        const body = {
            violationType: type,
            policyAssignmentId: type === 'Employee' ? (parseInt(document.getElementById('cvAssignmentId').value) || null) : null,
            supplierPolicyId: type === 'Supplier' ? (parseInt(document.getElementById('cvSupplierPolicyId').value) || null) : null,
            description: desc,
            notes: document.getElementById('cvNotes').value.trim() || null
        };

        fetch(API + '/CreateViolation', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
            .then(r => r.json())
            .then(async res => {
                if (res.success) { await window.showAppMessage(res.message, 'Success'); closeCreateViolation(); location.reload(); }
                else { await window.showAppMessage(res.message || 'Failed', 'Error'); }
            }).catch(async () => await window.showAppMessage('Error creating violation', 'Error'));
    }

    /* ── Update Violation Status ───────────────────── */
    function openUpdateViolation(v) {
        currentViolationId = v.violationId;
        document.getElementById('updateModalTitle').textContent = `Violation #${v.violationId}`;
        document.getElementById('violationDetailGrid').innerHTML = `
            <div class="detail-item"><div class="label">Type</div><div class="value">${v.violationType}</div></div>
            <div class="detail-item"><div class="label">Subject</div><div class="value">${v.subjectName}</div></div>
            <div class="detail-item"><div class="label">Policy</div><div class="value">${v.policyName}</div></div>
            <div class="detail-item"><div class="label">Status</div><div class="value"><span class="status-badge ${v.status.toLowerCase().replace(/\\s+/g,'')}">${formatStatus(v.status)}</span></div></div>
            <div class="detail-item"><div class="label">Raised</div><div class="value">${v.raisedDate}</div></div>
            <div class="detail-item"><div class="label">Raised By</div><div class="value">${v.raisedBy}</div></div>
            ${v.resolvedDate ? `<div class="detail-item"><div class="label">Resolved</div><div class="value">${v.resolvedDate}</div></div>` : ''}
            ${v.resolution ? `<div class="detail-item"><div class="label">Resolution</div><div class="value">${v.resolution}</div></div>` : ''}
        `;
        const notesEl = document.getElementById('violationNotesHistory');
        if (v.notes) { notesEl.textContent = v.notes; notesEl.style.display = ''; }
        else { notesEl.style.display = 'none'; }
        document.getElementById('uvStatus').value = v.status;
        document.getElementById('uvNotes').value = '';
        document.getElementById('uvResolution').value = '';
        checkResolutionVisibility();
        document.getElementById('updateViolationModal').classList.add('active');
    }
    function closeUpdateViolation() { document.getElementById('updateViolationModal').classList.remove('active'); currentViolationId = null; }

    document.getElementById('uvStatus').addEventListener('change', checkResolutionVisibility);
    function checkResolutionVisibility() {
        document.getElementById('uvResolutionGroup').style.display = document.getElementById('uvStatus').value === 'Resolved' ? '' : 'none';
    }

    async function submitUpdateViolation() {
        if (!currentViolationId) return;
        const body = {
            status: document.getElementById('uvStatus').value,
            notes: document.getElementById('uvNotes').value.trim() || null,
            resolution: document.getElementById('uvResolution').value.trim() || null
        };

        fetch(`${API}/UpdateViolationStatus?violationId=${currentViolationId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
            .then(r => r.json())
            .then(async res => {
                if (res.success) { await window.showAppMessage('Violation updated', 'Success'); closeUpdateViolation(); location.reload(); }
                else { await window.showAppMessage(res.message || 'Failed', 'Error'); }
            }).catch(async () => await window.showAppMessage('Error updating violation', 'Error'));
    }

    /* ── Suspend / Unsuspend ───────────────────────── */
    async function suspendSupplier(id, name) {
        const ok = await window.showAppConfirm(`Suspend supplier "${name}" for non-compliance?`);
        if (!ok) return;
        fetch(`${API}/SuspendSupplier?supplierId=${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: 'Suspended for non-compliance' }) })
            .then(r => r.json())
            .then(async res => { if (res.success) { await window.showAppMessage(res.message, 'Success'); loadNonCompliantSuppliers(); } else { await window.showAppMessage(res.message, 'Error'); } })
            .catch(async () => await window.showAppMessage('Error suspending supplier', 'Error'));
    }

    async function unsuspendSupplier(id, name) {
        const ok = await window.showAppConfirm(`Re-activate supplier "${name}"?`);
        if (!ok) return;
        fetch(`${API}/UnsuspendSupplier?supplierId=${id}`, { method: 'POST' })
            .then(r => r.json())
            .then(async res => { if (res.success) { await window.showAppMessage(res.message, 'Success'); loadNonCompliantSuppliers(); } else { await window.showAppMessage(res.message, 'Error'); } })
            .catch(async () => await window.showAppMessage('Error unsuspending supplier', 'Error'));
    }

    /* ── Close modal on backdrop ───────────────────── */
    document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('active'); }));

    /* ── Initial load ──────────────────────────────── */
    document.addEventListener('DOMContentLoaded', () => loadViolations());
</script>
}
