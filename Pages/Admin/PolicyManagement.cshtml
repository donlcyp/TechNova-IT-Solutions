@page
@model TechNova_IT_Solutions.Pages.PolicyManagementModel
@{
    ViewData["Title"] = "Policy Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechNova</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
        }

        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            padding: 28px 20px;
            border-bottom: 1px solid #e5e7eb;
        }

        .logo-icon {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            width: 48px;
            height: 48px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 24px;
            color: white;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
        }

        .nav-menu {
            padding: 20px 16px;
            flex: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #6b7280;
            text-decoration: none;
            border-radius: 8px;
            margin-bottom: 4px;
            transition: all 0.2s;
            font-size: 15px;
            font-weight: 500;
        }

        .nav-item:hover {
            background: #f3f4f6;
            color: #1f2937;
        }

        .nav-item.active {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
        }

        .nav-item svg {
            width: 20px;
            height: 20px;
        }

        .user-profile {
            padding: 20px;
            border-top: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 16px;
            color: white;
        }

        .user-info h4 {
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
        }

        .user-info p {
            font-size: 12px;
            color: #6b7280;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }



        .btn-primary {
            padding: 12px 24px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: opacity 0.2s;
        }

        .btn-primary:hover {
            opacity: 0.9;
        }

        .btn-primary svg {
            width: 18px;
            height: 18px;
        }

        /* Filter Section */
        .filter-section {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .search-box {
            flex: 1;
            min-width: 250px;
            position: relative;
        }

        .search-box input {
            width: 100%;
            padding: 10px 14px 10px 40px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
        }

        .search-box input:focus {
            outline: none;
            border-color: #1e40af;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #6b7280;
            width: 18px;
            height: 18px;
        }

        .filter-group {
            display: flex;
            gap: 12px;
        }

        select {
            padding: 10px 14px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
            cursor: pointer;
        }

        select:focus {
            outline: none;
            border-color: #1e40af;
        }

        /* Table Section */
        .table-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 32px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f3f4f6;
        }

        th {
            text-align: left;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            border-bottom: 2px solid #e5e7eb;
        }

        td {
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
            color: #1f2937;
        }

        tbody tr {
            transition: background 0.2s;
        }

        tbody tr:hover {
            background: #f3f4f6;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.draft {
            color: #9ca3af;
        }

        .status-badge.approved {
            color: #f6ad55;
        }

        .status-badge.active {
            color: #48bb78;
        }

        .actions {
            display: flex;
            gap: 8px;
        }

        .btn-action {
            padding: 6px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #f8f9fa;
            color: #6b7280;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-action:hover {
            border-color: #1e40af;
            color: #1e40af;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
        }

        .card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px 20px;
            transition: transform 0.2s;
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: auto auto;
            gap: 0 12px;
            align-items: center;
        }

        .card:hover {
            transform: translateY(-2px);
        }

        .card-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            grid-row: 1 / 3;
        }

        .card-icon svg {
            width: 22px;
            height: 22px;
        }

        .card-icon.blue {
            color: #1e40af;
        }

        .card-icon.green {
            color: #48bb78;
        }

        .card-icon.purple {
            color: #9f7aea;
        }

        .card-value {
            font-size: 26px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .card-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            width: 90%;
            max-width: 600px;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            padding: 24px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: #1f2937;
        }

        .btn-close {
            background: none;
            border: none;
            font-size: 24px;
            color: #6b7280;
            cursor: pointer;
        }

        .btn-close:hover {
            color: #1f2937;
        }

        .modal-body {
            padding: 24px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
            font-family: inherit;
        }

        .form-group textarea {
            min-height: 100px;
            resize: vertical;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #1e40af;
        }

        .form-group input[type="file"] {
            padding: 8px;
        }

        .multi-select {
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 12px;
            max-height: 200px;
            overflow-y: auto;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            padding: 8px;
            margin-bottom: 4px;
            border-radius: 6px;
            transition: background 0.2s;
        }

        .checkbox-item:hover {
            background: #f3f4f6;
        }

        .checkbox-item input[type="checkbox"] {
            width: auto;
            margin-right: 10px;
        }

        .checkbox-item label {
            margin: 0;
            font-weight: normal;
            cursor: pointer;
        }

        .modal-footer {
            padding: 24px;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .btn-secondary {
            padding: 10px 20px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #6b7280;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-secondary:hover {
            border-color: #1e40af;
            color: #1e40af;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .filter-section {
                flex-direction: column;
            }

            .search-box {
                min-width: 100%;
            }
        }

        @@media (max-width: 768px) {
            .sidebar {
                width: 200px;
            }

            .main-content {
                margin-left: 200px;
                padding: 20px;
            }

            table {
                font-size: 12px;
            }

            th, td {
                padding: 8px 10px;
            }

            .actions {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    @await Html.PartialAsync("_AdminSidebar", "PolicyManagement")

    <!-- Main Content -->
    <div class="main-content">
        @await Html.PartialAsync("_AdminTopBar", (Title: "Policy Management", Description: "Manage compliance policies and procedures"))

        <div class="content-wrapper">
            <!-- Summary Cards -->
            <div class="summary-cards">
                <div class="card">
                        <div class="card-icon blue">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                            </svg>
                        </div>
                    <div class="card-value">@Model.TotalPolicies</div>
                    <div class="card-label">Total Policies</div>
                </div>

                <div class="card">
                        <div class="card-icon green">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                        </div>
                    <div class="card-value">@Model.ActivePolicies</div>
                    <div class="card-label">Active Policies</div>
                </div>

                <div class="card">
                        <div class="card-icon purple">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </div>
                    <div class="card-value">@Model.RecentlyUploaded</div>
                    <div class="card-label">Recently Uploaded</div>
                </div>
            </div>

            <!-- Filter Section -->
            <div class="filter-section" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; flex: 1;">
            <div class="search-box">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input type="text" placeholder="Search by policy title..." />
            </div>
            <div class="filter-group">
                <select>
                    <option>All Categories</option>
                    <option>Data Privacy</option>
                    <option>Cybersecurity</option>
                    <option>Financial Compliance</option>
                    <option>HR Policies</option>
                    <option>Environmental</option>
                </select>
                <select>
                    <option>All Status</option>
                    <option>Draft</option>
                    <option>Approved</option>
                    <option>Active</option>
                </select>
            </div>
            </div>
            <button onclick="openUploadModal()" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%); color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; white-space: nowrap;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Add Policy
            </button>
        </div>

        <!-- Policies Table -->
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Policy ID</th>
                        <th>Policy Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Date Uploaded</th>
                        <th>Uploaded By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var policy in Model.Policies)
                    {
                        <tr>
                            <td>@policy.PolicyId</td>
                            <td>@policy.Title</td>
                            <td>@policy.Category</td>
                            <td>
                                <span class="status-badge @policy.Status.ToLower()">
                                    @policy.Status
                                </span>
                            </td>
                            <td>@policy.DateUploaded.ToString("MMM dd, yyyy")</td>
                            <td>@policy.UploadedBy</td>
                            <td>
                                <div class="actions">
                                    <button class="btn-action" onclick="viewPolicy('@policy.PolicyId')">View</button>
                                    <button class="btn-action" onclick="editPolicy('@policy.PolicyId', '@policy.Title', '@policy.Category', '@policy.Status')">Edit</button>
                                    <button class="btn-action" onclick="openAssignModal('@policy.PolicyId', '@policy.Title')">Assign</button>
                                    <button class="btn-action" onclick="archivePolicy('@policy.PolicyId')">Archive</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        </div>
    </div>

    <!-- Upload/Edit Policy Modal -->
    <div class="modal" id="uploadModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="uploadModalTitle">Upload New Policy</h2>
                <button class="btn-close" onclick="closeUploadModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="policyForm">
                    <div class="form-group">
                        <label for="policyTitle">Policy Title</label>
                        <input type="text" id="policyTitle" placeholder="Enter policy title" required />
                    </div>
                    <div class="form-group">
                        <label for="policyDescription">Description</label>
                        <textarea id="policyDescription" placeholder="Enter policy description" required></textarea>
                    </div>
                    <div class="form-group">
                        <label for="policyCategory">Category</label>
                        <select id="policyCategory" required>
                            <option value="">Select category</option>
                            <option>Data Privacy</option>
                            <option>Cybersecurity</option>
                            <option>Financial Compliance</option>
                            <option>HR Policies</option>
                            <option>Environmental</option>
                            <option>Health & Safety</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="policyFile">Upload File</label>
                        <input type="file" id="policyFile" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.png,.jpg,.jpeg" />
                    </div>
                    <div class="form-group">
                        <label for="policyStatus">Status</label>
                        <select id="policyStatus" required>
                            <option>Draft</option>
                            <option>Approved</option>
                            <option>Active</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeUploadModal()">Cancel</button>
                <button class="btn-primary" onclick="savePolicy()">Save Policy</button>
            </div>
        </div>
    </div>

    <!-- Assign Policy Modal -->
    <div class="modal" id="assignModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="assignModalTitle">Assign Policy</h2>
                <button class="btn-close" onclick="closeAssignModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Assign to Employees</label>
                    <div class="multi-select" id="employeeList">
                        @foreach (var emp in Model.Employees)
                        {
                            <div class="checkbox-item">
                                <input type="checkbox" id="emp_@emp.Id" value="@emp.Id" />
                                <label for="emp_@emp.Id">@emp.Name</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="form-group">
                    <label>Assign to Suppliers</label>
                    <div class="multi-select" id="supplierList">
                        @foreach (var supplier in Model.Suppliers)
                        {
                            <div class="checkbox-item">
                                <input type="checkbox" id="sup_@supplier.Id" value="@supplier.Id" />
                                <label for="sup_@supplier.Id">@supplier.Name</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="form-group">
                    <label for="assignDate">Assign Date</label>
                    <input type="date" id="assignDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeAssignModal()">Cancel</button>
                <button class="btn-primary" onclick="assignPolicy()">Assign Policy</button>
            </div>
        </div>
    </div>

    <script>
        let currentPolicyId = null;
        let currentPolicyDbId = null;

        function openUploadModal() {
            document.getElementById('uploadModalTitle').textContent = 'Upload New Policy';
            document.getElementById('policyForm').reset();
            currentPolicyId = null;
            currentPolicyDbId = null;
            document.getElementById('uploadModal').classList.add('active');
        }

        function closeUploadModal() {
            document.getElementById('uploadModal').classList.remove('active');
            currentPolicyId = null;
            currentPolicyDbId = null;
        }

        function editPolicy(id, title, category, status) {
            currentPolicyId = id;
            // Extract numeric DB ID from "POL-001" format
            currentPolicyDbId = parseInt(id.replace('POL-', ''));
            document.getElementById('uploadModalTitle').textContent = 'Edit Policy';
            document.getElementById('policyTitle').value = title;
            document.getElementById('policyCategory').value = category;
            document.getElementById('policyStatus').value = status;
            document.getElementById('uploadModal').classList.add('active');
        }

        function savePolicy() {
            const title = document.getElementById('policyTitle').value.trim();
            const description = document.getElementById('policyDescription').value.trim();
            const category = document.getElementById('policyCategory').value;
            const status = document.getElementById('policyStatus').value;
            const fileInput = document.getElementById('policyFile');

            if (!title || !category) {
                alert('Please fill in all required fields');
                return;
            }

            const formData = new FormData();
            formData.append('policyTitle', title);
            formData.append('description', description);
            formData.append('category', category);
            formData.append('status', status);

            if (fileInput.files.length > 0) {
                formData.append('policyFile', fileInput.files[0]);
            }

            if (currentPolicyDbId) {
                formData.append('policyId', currentPolicyDbId);
            }

            fetch('/Admin/UploadPolicy', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    closeUploadModal();
                    location.reload();
                } else {
                    alert(result.message || 'Failed to save policy');
                }
            })
            .catch(() => alert('Error saving policy'));
        }

        function viewPolicy(id) {
            alert('Viewing policy: ' + id);
        }

        function archivePolicy(id) {
            if (!confirm('Are you sure you want to delete this policy?')) return;
            const dbId = parseInt(id.replace('POL-', ''));

            fetch('/Admin/DeletePolicy?policyId=' + dbId, { method: 'POST' })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    location.reload();
                } else {
                    alert(result.message || 'Failed to delete policy');
                }
            })
            .catch(() => alert('Error deleting policy'));
        }

        function openAssignModal(id, title) {
            currentPolicyId = id;
            currentPolicyDbId = parseInt(id.replace('POL-', ''));
            document.getElementById('assignModalTitle').textContent = 'Assign Policy: ' + title;
            // Uncheck all checkboxes
            document.querySelectorAll('#employeeList input, #supplierList input').forEach(cb => cb.checked = false);
            document.getElementById('assignModal').classList.add('active');
        }

        function closeAssignModal() {
            document.getElementById('assignModal').classList.remove('active');
            currentPolicyId = null;
            currentPolicyDbId = null;
        }

        function assignPolicy() {
            const selectedEmployees = Array.from(document.querySelectorAll('#employeeList input:checked')).map(cb => parseInt(cb.value));
            const selectedSuppliers = Array.from(document.querySelectorAll('#supplierList input:checked')).map(cb => parseInt(cb.value));

            if (selectedEmployees.length === 0 && selectedSuppliers.length === 0) {
                alert('Please select at least one employee or supplier');
                return;
            }

            fetch('/Admin/AssignPolicy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    policyId: currentPolicyDbId,
                    employeeIds: selectedEmployees,
                    supplierIds: selectedSuppliers
                })
            })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    alert('Policy assigned successfully!');
                    closeAssignModal();
                } else {
                    alert(result.message || 'Failed to assign policy');
                }
            })
            .catch(() => alert('Error assigning policy'));
        }

        // Close modals when clicking outside
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.remove('active');
                }
            });
        });
    </script>
</body>
</html>
