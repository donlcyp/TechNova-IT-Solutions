@page
@model TechNova_IT_Solutions.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<style>
    .reports-shell { padding: 24px; }
    .report-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
    .report-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap; }
    .meta { color: #4b5563; font-size: 0.9rem; margin-top: 6px; }
    .filters { display: grid; grid-template-columns: repeat(4, minmax(150px, 1fr)); gap: 12px; align-items: end; }
    .filters label { font-size: 0.85rem; color: #374151; display: block; margin-bottom: 6px; }
    .filters input, .filters select { width: 100%; border: 1px solid #d1d5db; border-radius: 8px; padding: 8px 10px; }
    .kpis { display: grid; grid-template-columns: repeat(4, minmax(140px, 1fr)); gap: 12px; margin-top: 12px; }
    .kpi { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 12px; }
    .kpi .label { font-size: 0.8rem; color: #64748b; }
    .kpi .value { font-size: 1.4rem; font-weight: 700; color: #0f172a; }
    .actions { display: flex; gap: 8px; }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #e5e7eb; padding: 10px 8px; text-align: left; font-size: 0.9rem; }
    .status { padding: 0; border-radius: 0; font-size: 0.9rem; font-weight: 600; background: transparent; }
    .status.compliant, .status.approved { color: #166534; }
    .status.pending { color: #92400e; }
    .status.rejected, .status.non-compliant { color: #991b1b; }
    @@media (max-width: 900px) {
        .filters { grid-template-columns: 1fr 1fr; }
        .kpis { grid-template-columns: 1fr 1fr; }
    }
</style>

@await Html.PartialAsync("_AdminSidebar", "Reports")

<main class="main-content">
    @await Html.PartialAsync("_AdminTopBar", (Title: "Reports", Description: "Operational reports with server-side filtering and export"))

    <div class="reports-shell">
        <div class="report-card">
            <form method="get" class="filters">
                <div>
                    <label for="reportType">Report Type</label>
                    <select id="reportType" name="reportType">
                        @if (Model.ReportType == "compliance")
                        {
                            <option value="compliance" selected>Employee Compliance</option>
                        }
                        else
                        {
                            <option value="compliance">Employee Compliance</option>
                        }
                        @if (Model.ReportType == "supplier")
                        {
                            <option value="supplier" selected>Supplier Compliance</option>
                        }
                        else
                        {
                            <option value="supplier">Supplier Compliance</option>
                        }
                        @if (Model.ReportType == "procurement")
                        {
                            <option value="procurement" selected>Procurement</option>
                        }
                        else
                        {
                            <option value="procurement">Procurement</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="fromDate">From Date</label>
                    <input id="fromDate" type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label for="toDate">To Date</label>
                    <input id="toDate" type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="actions">
                    <button type="submit" class="btn btn-primary">Generate</button>
                    <a class="btn btn-secondary"
                       asp-page-handler="ExportCsv"
                       asp-route-reportType="@Model.ReportType"
                       asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")">
                        Export CSV
                    </a>
                </div>
            </form>
        </div>

        <div class="report-card">
            <div class="report-header">
                <div>
                    <h3>
                        @if (Model.ReportType == "supplier")
                        {
                            <text>Supplier Compliance Report</text>
                        }
                        else if (Model.ReportType == "procurement")
                        {
                            <text>Procurement Report</text>
                        }
                        else
                        {
                            <text>Employee Compliance Report</text>
                        }
                    </h3>
                    <div class="meta">Period: @Model.FromDate?.ToString("MMM dd, yyyy") to @Model.ToDate?.ToString("MMM dd, yyyy")</div>
                    <div class="meta">Generated by: @Model.UserName (@Model.GeneratedByRole) on @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</div>
                </div>
            </div>

            <div class="kpis">
                <div class="kpi"><div class="label">Total Records</div><div class="value">@Model.TotalRecords</div></div>
                <div class="kpi"><div class="label">Compliant/Approved</div><div class="value">@Model.CompliantCount</div></div>
                <div class="kpi"><div class="label">Pending</div><div class="value">@Model.PendingCount</div></div>
                <div class="kpi">
                    <div class="label">@((Model.ReportType == "procurement") ? "Total Quantity" : "Compliance Rate")</div>
                    <div class="value">@((Model.ReportType == "procurement") ? Model.TotalQuantity.ToString() : $"{Model.ComplianceRate}%")</div>
                </div>
            </div>
        </div>

        <div class="report-card table-wrap">
            @if (Model.ReportType == "supplier")
            {
                <table>
                    <thead>
                        <tr>
                            <th>Supplier</th>
                            <th>Policy</th>
                            <th>Status</th>
                            <th>Assigned Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.SupplierReportData)
                        {
                            var statusCss = item.ComplianceStatus.ToLowerInvariant();
                            <tr>
                                <td>@item.SupplierName</td>
                                <td>@item.AssignedPolicy</td>
                                <td><span class="status @statusCss">@item.ComplianceStatus</span></td>
                                <td>@item.AssignedDate?.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (Model.ReportType == "procurement")
            {
                <table>
                    <thead>
                        <tr>
                            <th>Procurement ID</th>
                            <th>Item</th>
                            <th>Supplier</th>
                            <th>Policy</th>
                            <th>Quantity</th>
                            <th>Status</th>
                            <th>Purchase Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ProcurementReportData)
                        {
                            var statusCss = item.ApprovalStatus.ToLowerInvariant();
                            <tr>
                                <td>@item.ProcurementId</td>
                                <td>@item.ItemName</td>
                                <td>@item.Supplier</td>
                                <td>@item.LinkedPolicy</td>
                                <td>@item.Quantity</td>
                                <td><span class="status @statusCss">@item.ApprovalStatus</span></td>
                                <td>@item.PurchaseDate?.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Policy</th>
                            <th>Status</th>
                            <th>Assigned Date</th>
                            <th>Acknowledged Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ComplianceReportData)
                        {
                            var statusCss = item.ComplianceStatus.ToLowerInvariant();
                            <tr>
                                <td>@item.EmployeeName</td>
                                <td>@item.AssignedPolicy</td>
                                <td><span class="status @statusCss">@item.ComplianceStatus</span></td>
                                <td>@item.AssignedDate?.ToString("MMM dd, yyyy")</td>
                                <td>@(item.AcknowledgedDate.HasValue ? item.AcknowledgedDate.Value.ToString("MMM dd, yyyy") : "N/A")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</main>
