@page
@model TechNova_IT_Solutions.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<style>
    .main-content {
        margin-left: 260px;
        min-height: 100vh;
        overflow-y: auto;
        background: linear-gradient(135deg, #f0f4ff 0%, #f8fafc 50%, #f0fdf4 100%);
    }

    .reports-shell { padding: 28px; max-width: 1400px; margin: 0 auto; }

    .report-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: 0 1px 3px rgba(15,23,42,.04), 0 4px 12px rgba(15,23,42,.03);
        transition: box-shadow .2s;
    }
    .report-card:hover { box-shadow: 0 4px 16px rgba(15,23,42,.07); }

    .report-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap; }
    .report-header h3 { margin: 0; font-size: 1.15rem; font-weight: 700; color: #0f172a; letter-spacing: -0.01em; }

    .meta { color: #64748b; font-size: 0.85rem; margin-top: 6px; display: flex; align-items: center; gap: 6px; }
    .meta svg { width: 14px; height: 14px; flex-shrink: 0; }

    .filters { display: grid; grid-template-columns: repeat(4, minmax(160px, 1fr)); gap: 16px; align-items: end; }
    .filters label {
        font-size: 0.78rem; font-weight: 600; color: #475569; display: block;
        margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .filters input, .filters select {
        width: 100%; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: 10px 12px; font-size: 0.9rem; color: #1e293b;
        background: #f8fafc; transition: border-color .2s, box-shadow .2s;
    }
    .filters input:focus, .filters select:focus {
        outline: none; border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59,130,246,.12);
    }

    .kpis { display: grid; grid-template-columns: repeat(4, minmax(150px, 1fr)); gap: 14px; margin-top: 18px; }
    .kpi {
        border-radius: 14px; padding: 18px; position: relative; overflow: hidden;
        border: 1px solid #e2e8f0; background: linear-gradient(135deg, #f8fafc 0%, #fff 100%);
        transition: transform .2s, box-shadow .2s;
    }
    .kpi:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(15,23,42,.06); }
    .kpi::before {
        content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%;
        border-radius: 4px 0 0 4px;
    }
    .kpi:nth-child(1)::before { background: linear-gradient(180deg, #3b82f6, #2563eb); }
    .kpi:nth-child(2)::before { background: linear-gradient(180deg, #22c55e, #16a34a); }
    .kpi:nth-child(3)::before { background: linear-gradient(180deg, #f59e0b, #d97706); }
    .kpi:nth-child(4)::before { background: linear-gradient(180deg, #8b5cf6, #7c3aed); }
    .kpi .label { font-size: 0.75rem; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
    .kpi .value { font-size: 1.6rem; font-weight: 800; color: #0f172a; letter-spacing: -0.02em; }

    .actions { display: flex; gap: 10px; }
    .actions .btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 0; white-space: nowrap; border-radius: 10px;
        font-weight: 600; font-size: 0.875rem; padding: 10px 18px;
        transition: all .2s; gap: 6px;
    }
    .actions .btn-primary {
        background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff;
        border: none; box-shadow: 0 2px 8px rgba(37,99,235,.25);
    }
    .actions .btn-primary:hover { box-shadow: 0 4px 14px rgba(37,99,235,.35); transform: translateY(-1px); }
    .actions .btn-secondary {
        background: #fff; color: #2563eb; border: 1.5px solid #bfdbfe;
    }
    .actions .btn-secondary:hover { background: #eff6ff; border-color: #93c5fd; }

    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: separate; border-spacing: 0; }
    thead th {
        padding: 12px 14px; text-align: left; font-size: 0.72rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.06em; color: #64748b;
        background: #f8fafc; border-bottom: 2px solid #e2e8f0;
        position: sticky; top: 0; z-index: 1;
    }
    thead th:first-child { border-radius: 10px 0 0 0; }
    thead th:last-child { border-radius: 0 10px 0 0; }
    tbody td {
        padding: 12px 14px; font-size: 0.9rem; color: #334155;
        border-bottom: 1px solid #f1f5f9; transition: background .15s;
    }
    tbody tr:hover td { background: #f8fafc; }
    tbody tr:last-child td { border-bottom: none; }

    .status {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 20px;
        font-size: 0.78rem; font-weight: 600; letter-spacing: 0.01em;
    }
    .status::before {
        content: ''; width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    }
    .status.compliant, .status.approved { background: #f0fdf4; color: #15803d; }
    .status.compliant::before, .status.approved::before { background: #22c55e; }
    .status.pending { background: #fffbeb; color: #b45309; }
    .status.pending::before { background: #f59e0b; }
    .status.rejected, .status.non-compliant { background: #fef2f2; color: #dc2626; }
    .status.rejected::before, .status.non-compliant::before { background: #ef4444; }

    @@media (max-width: 991px) {
        .main-content { margin-left: 0; }
    }
    @@media (max-width: 900px) {
        .filters { grid-template-columns: 1fr 1fr; }
        .kpis { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 576px) {
        .reports-shell { padding: 16px; }
        .report-card { padding: 16px; border-radius: 14px; }
        .filters { grid-template-columns: 1fr; gap: 12px; }
        .actions { display: grid; grid-template-columns: 1fr 1fr; width: 100%; }
        .actions .btn { width: 100%; padding: 12px 10px; font-size: .85rem; }
        .kpis { grid-template-columns: 1fr 1fr; gap: 12px; }
        .kpi { padding: 14px; }
        .kpi .value { font-size: 1.5rem; }
    }
    @@media (max-width: 380px) {
        .actions { grid-template-columns: 1fr; }
        .kpis { grid-template-columns: 1fr; }
    }
</style>

@await Html.PartialAsync("_AdminSidebar", "Reports")

<main class="main-content">
    @await Html.PartialAsync("_AdminTopBar", (Title: "Reports", Description: "Operational reports with server-side filtering and export"))

    <div class="reports-shell">
        <div class="report-card">
            <form method="get" class="filters">
                <div>
                    <label for="reportType">Report Type</label>
                    <select id="reportType" name="reportType">
                        @if (Model.ReportType == "compliance")
                        {
                            <option value="compliance" selected>Employee Compliance</option>
                        }
                        else
                        {
                            <option value="compliance">Employee Compliance</option>
                        }
                        @if (Model.ReportType == "supplier")
                        {
                            <option value="supplier" selected>Supplier Compliance</option>
                        }
                        else
                        {
                            <option value="supplier">Supplier Compliance</option>
                        }
                        @if (Model.ReportType == "procurement")
                        {
                            <option value="procurement" selected>Procurement</option>
                        }
                        else
                        {
                            <option value="procurement">Procurement</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="fromDate">From Date</label>
                    <input id="fromDate" type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label for="toDate">To Date</label>
                    <input id="toDate" type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="actions">
                    <button type="submit" class="btn btn-primary">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        Generate
                    </button>
                    <a class="btn btn-secondary"
                       asp-page-handler="ExportCsv"
                       asp-route-reportType="@Model.ReportType"
                       asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export CSV
                    </a>
                </div>
            </form>
        </div>

        <div class="report-card">
            <div class="report-header">
                <div>
                    <h3>
                        @if (Model.ReportType == "supplier")
                        {
                            <text>Supplier Compliance Report</text>
                        }
                        else if (Model.ReportType == "procurement")
                        {
                            <text>Procurement Report</text>
                        }
                        else
                        {
                            <text>Employee Compliance Report</text>
                        }
                    </h3>
                    <div class="meta">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Period: @Model.FromDate?.ToString("MMM dd, yyyy") &mdash; @Model.ToDate?.ToString("MMM dd, yyyy")
                    </div>
                    <div class="meta">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Generated by: @Model.UserName (@Model.GeneratedByRole) on @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                    </div>
                </div>
            </div>

            <div class="kpis">
                <div class="kpi"><div class="label">Total Records</div><div class="value">@Model.TotalRecords</div></div>
                <div class="kpi"><div class="label">Compliant / Approved</div><div class="value">@Model.CompliantCount</div></div>
                <div class="kpi"><div class="label">Pending</div><div class="value">@Model.PendingCount</div></div>
                <div class="kpi">
                    <div class="label">@((Model.ReportType == "procurement") ? "Total Quantity" : "Compliance Rate")</div>
                    <div class="value">@((Model.ReportType == "procurement") ? Model.TotalQuantity.ToString() : $"{Model.ComplianceRate}%")</div>
                </div>
            </div>
        </div>

        <div class="report-card table-wrap">
            @if (Model.ReportType == "supplier")
            {
                <table>
                    <thead>
                        <tr>
                            <th>Supplier</th>
                            <th>Policy</th>
                            <th>Status</th>
                            <th>Assigned Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.SupplierReportData)
                        {
                            var statusCss = item.ComplianceStatus.ToLowerInvariant();
                            <tr>
                                <td style="font-weight:600;color:#1e293b;">@item.SupplierName</td>
                                <td>@item.AssignedPolicy</td>
                                <td><span class="status @statusCss">@item.ComplianceStatus</span></td>
                                <td>@item.AssignedDate?.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else if (Model.ReportType == "procurement")
            {
                <table>
                    <thead>
                        <tr>
                            <th>Procurement ID</th>
                            <th>Item</th>
                            <th>Supplier</th>
                            <th>Policy</th>
                            <th>Quantity</th>
                            <th>Status</th>
                            <th>Purchase Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ProcurementReportData)
                        {
                            var statusCss = item.ApprovalStatus.ToLowerInvariant();
                            <tr>
                                <td style="font-weight:600;color:#3b82f6;">@item.ProcurementId</td>
                                <td style="font-weight:600;color:#1e293b;">@item.ItemName</td>
                                <td>@item.Supplier</td>
                                <td>@item.LinkedPolicy</td>
                                <td>@item.Quantity</td>
                                <td><span class="status @statusCss">@item.ApprovalStatus</span></td>
                                <td>@item.PurchaseDate?.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Policy</th>
                            <th>Status</th>
                            <th>Assigned Date</th>
                            <th>Acknowledged Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.ComplianceReportData)
                        {
                            var statusCss = item.ComplianceStatus.ToLowerInvariant();
                            <tr>
                                <td style="font-weight:600;color:#1e293b;">@item.EmployeeName</td>
                                <td>@item.AssignedPolicy</td>
                                <td><span class="status @statusCss">@item.ComplianceStatus</span></td>
                                <td>@item.AssignedDate?.ToString("MMM dd, yyyy")</td>
                                <td>@(item.AcknowledgedDate.HasValue ? item.AcknowledgedDate.Value.ToString("MMM dd, yyyy") : "N/A")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</main>

