@page
@model TechNova_IT_Solutions.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .report-controls {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .controls-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr auto;
            gap: 16px;
            align-items: end;
        }

        .control-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .control-group label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
        }

        .control-group select,
        .control-group input {
            padding: 10px 14px;
            background: #f3f4f6;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
        }

        .control-group select:focus,
        .control-group input:focus {
            outline: none;
            border-color: #1e40af;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-secondary {
            background: #f3f4f6;
            color: #1f2937;
            border: 1px solid #e5e7eb;
        }

        .btn-secondary:hover {
            background: #e5e7eb;
        }

        .report-actions {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 24px;
            display: none;
            align-items: center;
            justify-content: space-between;
        }

        .report-actions.active {
            display: flex;
        }

        .report-title {
            font-size: 18px;
            font-weight: 600;
            color: #1f2937;
        }

        .action-buttons {
            display: flex;
            gap: 12px;
        }

        .table-container {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            display: none;
        }

        .table-container.active {
            display: block;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f3f4f6;
        }

        th {
            padding: 16px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        td {
            padding: 16px;
            border-top: 1px solid #e5e7eb;
            font-size: 14px;
            color: #1f2937;
        }

        tbody tr:hover {
            background: #f3f4f6;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
        }

        .status-compliant,
        .status-approved {
            color: #48bb78;
        }

        .status-non-compliant,
        .status-pending {
            color: #f6ad55;
        }

        .empty-state {
            text-align: center;
            padding: 80px 20px;
            color: #6b7280;
        }

        .empty-state svg {
            width: 80px;
            height: 80px;
            margin-bottom: 20px;
            opacity: 0.3;
        }

        .empty-state h3 {
            font-size: 20px;
            margin-bottom: 8px;
            color: #1f2937;
        }

        .empty-state p {
            font-size: 14px;
        }

        @@media print {
            .sidebar,
            .report-controls,
            .report-actions {
                display: none !important;
            }

            .main-content {
                margin-left: 0;
                padding: 20px;
            }

            .table-container {
                display: block !important;
            }

            body {
                background: white;
                color: black;
            }

            .table-container,
            table,
            th,
            td {
                background: white !important;
                color: black !important;
                border-color: #ddd !important;
            }
        }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }

            .controls-grid {
                grid-template-columns: 1fr 1fr;
            }

            .report-actions {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }

            .table-container {
                overflow-x: auto;
            }
        }

        @@media (max-width: 576px) {
            .controls-grid {
                grid-template-columns: 1fr;
            }

            .report-controls {
                padding: 16px;
            }

            table {
                min-width: 800px;
            }
        }
    </style>
}

@await Html.PartialAsync("_AdminSidebar", "Reports")

    <main class="main-content">
        @await Html.PartialAsync("_AdminTopBar", (Title: "Reports", Description: "Generate and view system reports"))

        <div class="content-wrapper">
            <div class="report-controls">
            <div class="controls-grid">
                <div class="control-group">
                    <label>Report Type</label>
                    <select id="reportType">
                        <option value="">Select Report Type</option>
                        <option value="compliance">Compliance Report</option>
                        <option value="supplier">Supplier Compliance Report</option>
                        <option value="procurement">Procurement Report</option>
                    </select>
                </div>
                <div class="control-group">
                    <label>From Date</label>
                    <input type="date" id="fromDate" />
                </div>
                <div class="control-group">
                    <label>To Date</label>
                    <input type="date" id="toDate" />
                </div>
                <div class="control-group">
                    <button class="btn btn-primary" onclick="generateReport()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 18px; height: 18px;">
                            <polyline points="6 9 6 2 18 2 18 9"></polyline>
                            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                            <rect x="6" y="14" width="12" height="8"></rect>
                        </svg>
                        Generate Report
                    </button>
                </div>
            </div>
        </div>

        <div id="reportActions" class="report-actions">
            <div class="report-title" id="reportTitleText"></div>
            <div class="action-buttons">
                <button class="btn btn-secondary" onclick="exportPDF()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 18px; height: 18px;">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                    Export PDF
                </button>
                <button class="btn btn-secondary" onclick="exportExcel()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 18px; height: 18px;">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                    </svg>
                    Export Excel
                </button>
                <button class="btn btn-secondary" onclick="window.print()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 18px; height: 18px;">
                        <polyline points="6 9 6 2 18 2 18 9"></polyline>
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                        <rect x="6" y="14" width="12" height="8"></rect>
                    </svg>
                    Print
                </button>
            </div>
        </div>

        <!-- Compliance Report Table -->
        <div id="complianceReport" class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Employee Name</th>
                        <th>Assigned Policy</th>
                        <th>Compliance Status</th>
                        <th>Acknowledged Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ComplianceReportData)
                    {
                        <tr>
                            <td>@item.EmployeeName</td>
                            <td>@item.AssignedPolicy</td>
                            <td>
                                <span class="status-badge status-@item.ComplianceStatus.ToLower().Replace(" ", "-")">
                                    @item.ComplianceStatus
                                </span>
                            </td>
                            <td>@item.AcknowledgedDate</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Supplier Compliance Report Table -->
        <div id="supplierReport" class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Supplier Name</th>
                        <th>Assigned Policy</th>
                        <th>Compliance Status</th>
                        <th>Assigned Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.SupplierReportData)
                    {
                        <tr>
                            <td>@item.SupplierName</td>
                            <td>@item.AssignedPolicy</td>
                            <td>
                                <span class="status-badge status-@item.ComplianceStatus.ToLower().Replace(" ", "-")">
                                    @item.ComplianceStatus
                                </span>
                            </td>
                            <td>@item.AssignedDate</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Procurement Report Table -->
        <div id="procurementReport" class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Procurement ID</th>
                        <th>Item Name</th>
                        <th>Supplier</th>
                        <th>Linked Policy</th>
                        <th>Purchase Date</th>
                        <th>Approval Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ProcurementReportData)
                    {
                        <tr>
                            <td>@item.ProcurementId</td>
                            <td>@item.ItemName</td>
                            <td>@item.Supplier</td>
                            <td>@item.LinkedPolicy</td>
                            <td>@item.PurchaseDate</td>
                            <td>
                                <span class="status-badge status-@item.ApprovalStatus.ToLower()">
                                    @item.ApprovalStatus
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="table-container active">
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                <h3>No Report Generated</h3>
                <p>Select a report type and date range, then click "Generate Report" to view data</p>
            </div>
        </div>
    </main>

@section Scripts {
    <script>
        function generateReport() {
            const reportType = document.getElementById('reportType').value;
            const fromDate = document.getElementById('fromDate').value;
            const toDate = document.getElementById('toDate').value;

            if (!reportType) {
                alert('Please select a report type');
                return;
            }

            // Hide all reports
            document.getElementById('emptyState').classList.remove('active');
            document.getElementById('complianceReport').classList.remove('active');
            document.getElementById('supplierReport').classList.remove('active');
            document.getElementById('procurementReport').classList.remove('active');

            // Show report actions
            document.getElementById('reportActions').classList.add('active');

            // Show selected report
            let reportTitle = '';
            if (reportType === 'compliance') {
                document.getElementById('complianceReport').classList.add('active');
                reportTitle = 'Compliance Report';
            } else if (reportType === 'supplier') {
                document.getElementById('supplierReport').classList.add('active');
                reportTitle = 'Supplier Compliance Report';
            } else if (reportType === 'procurement') {
                document.getElementById('procurementReport').classList.add('active');
                reportTitle = 'Procurement Report';
            }

            if (fromDate && toDate) {
                reportTitle += ` (${fromDate} to ${toDate})`;
            }

            document.getElementById('reportTitleText').textContent = reportTitle;
        }

        function exportPDF() {
            alert('PDF export functionality would be implemented here.\nIn production, this would use a library like jsPDF or a server-side PDF generator.');
        }

        function exportExcel() {
            alert('Excel export functionality would be implemented here.\nIn production, this would use a library like SheetJS (xlsx) or ExcelJS.');
        }
    </script>
}
