@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.ComplianceMonitoringModel
@{
    ViewData["Title"] = "Compliance Monitoring";
}

@section Styles {
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f8f9fa; }
        .main-content { margin-left: 260px; min-height: 100vh; }
        .content-wrapper { padding: 24px; max-width: 1200px; margin: 0 auto; }
        .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
        .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; }
        .value { font-size: 30px; font-weight: 700; color: #0f172a; }
        .label { font-size: 13px; color: #6b7280; }
        .tab-panel { margin-top: 18px; background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
        .tab-bar { display: flex; border-bottom: 1px solid #e5e7eb; background: #f8fafc; }
        .tab-btn { flex: 1; padding: 12px 10px; border: none; background: transparent; font-size: 13px; font-weight: 600; color: #6b7280; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; white-space: nowrap; }
        .tab-btn:hover { color: #1e40af; background: #eff6ff; }
        .tab-btn.active { color: #1e40af; border-bottom-color: #1e40af; background: #fff; }
        .tab-content { display: none; padding: 16px; }
        .tab-content.active { display: block; }
        .section-subtitle { margin: 0 0 14px; color: #64748b; font-size: 12px; }
        .table-wrap { overflow-x: auto; border: 1px solid #e5e7eb; border-radius: 10px; }
        table { width: 100%; border-collapse: collapse; min-width: 740px; }
        th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #f1f5f9; font-size: 13px; color: #334155; }
        th { background: #f8fafc; color: #475569; font-size: 12px; text-transform: uppercase; letter-spacing: 0.03em; }
        tbody tr:last-child td { border-bottom: none; }
        tbody tr:hover td { background: #f8fafc; }
        .status-badge { display: inline-block; border-radius: 999px; padding: 4px 10px; font-size: 11px; font-weight: 700; }
        .status-badge.acknowledged, .status-badge.compliant { background: #dcfce7; color: #166534; }
        .status-badge.pending { background: #fef3c7; color: #92400e; }
        .status-badge.overdue, .status-badge.non-compliant { background: #fee2e2; color: #991b1b; }
        .muted { color: #64748b; }
        .empty-state { padding: 14px; color: #64748b; font-size: 13px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 10px; }
        @@media (max-width: 991px) { .main-content { margin-left: 0; } .tab-btn { font-size: 12px; padding: 10px 6px; } }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "ComplianceMonitoring")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "Compliance Monitoring", Description: "Super Admin-owned compliance overview"))
    <div class="content-wrapper">
        <div class="cards">
            <div class="card"><div class="value">@Model.TotalAssignments</div><div class="label">Total Policy Assignments</div></div>
            <div class="card"><div class="value">@Model.CompliantEmployees</div><div class="label">Compliant Employees</div></div>
            <div class="card"><div class="value">@Model.NonCompliantEmployees</div><div class="label">Not Compliant Employees</div></div>
            <div class="card"><div class="value">@Model.CompliantSuppliers</div><div class="label">Compliant Suppliers</div></div>
        </div>
        <div class="tab-panel">
            <div class="tab-bar">
                <button class="tab-btn active" onclick="switchTab('employees', this)">Employee Compliance Exceptions</button>
                <button class="tab-btn" onclick="switchTab('suppliers', this)">Supplier Compliance Exceptions</button>
                <button class="tab-btn" onclick="switchTab('activity', this)">Latest Assignment Activity</button>
            </div>

            <!-- Employee Compliance Exceptions -->
            <div id="tab-employees" class="tab-content active">
                <p class="section-subtitle">Recent employee assignments that are still pending or overdue.</p>
                @if (Model.NonCompliantEmployeeRows.Any())
                {
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Employee</th>
                                    <th>Policy</th>
                                    <th>Status</th>
                                    <th>Assigned</th>
                                    <th>Acknowledged</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.NonCompliantEmployeeRows)
                                {
                                    var statusClass = (row.Status ?? string.Empty).ToLowerInvariant().Replace(" ", "-");
                                    <tr>
                                        <td>@row.EmployeeName</td>
                                        <td>@row.PolicyTitle</td>
                                        <td><span class="status-badge @statusClass">@row.Status</span></td>
                                        <td>@(row.AssignedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                        <td>@(row.AcknowledgedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">No pending or overdue employee compliance records found.</div>
                }
            </div>

            <!-- Supplier Compliance Exceptions -->
            <div id="tab-suppliers" class="tab-content">
                <p class="section-subtitle">Recent supplier policy assignments that require follow-up.</p>
                @if (Model.SupplierExceptionRows.Any())
                {
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Supplier</th>
                                    <th>Policy</th>
                                    <th>Status</th>
                                    <th>Assigned</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.SupplierExceptionRows)
                                {
                                    var statusClass = (row.ComplianceStatus ?? string.Empty).ToLowerInvariant().Replace(" ", "-");
                                    <tr>
                                        <td>@row.SupplierName</td>
                                        <td>@row.PolicyTitle</td>
                                        <td><span class="status-badge @statusClass">@row.ComplianceStatus</span></td>
                                        <td>@(row.AssignedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">No supplier exceptions found for the latest assignments.</div>
                }
            </div>

            <!-- Latest Policy Assignment Activity -->
            <div id="tab-activity" class="tab-content">
                <p class="section-subtitle">Combined employee and supplier assignments for recent monitoring.</p>
                @if (Model.RecentAssignmentRows.Any())
                {
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Assignee</th>
                                    <th>Policy</th>
                                    <th>Status</th>
                                    <th>Assigned</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.RecentAssignmentRows)
                                {
                                    var statusClass = (row.Status ?? string.Empty).ToLowerInvariant().Replace(" ", "-");
                                    <tr>
                                        <td class="muted">@row.AssigneeType</td>
                                        <td>@row.AssigneeName</td>
                                        <td>@row.PolicyTitle</td>
                                        <td><span class="status-badge @statusClass">@row.Status</span></td>
                                        <td>@(row.AssignedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">No assignment activity is available yet.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(name, btn) {
            document.querySelectorAll('.tab-content').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            btn.classList.add('active');
        }
    </script>
}
