@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.AdminDashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@section Styles {
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f8f9fa; }
        .main-content { margin-left: 260px; min-height: 100vh; }
        .content-wrapper { padding: 24px; max-width: 1280px; margin: 0 auto; }
        .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 14px; }
        .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 14px; }
        .value { font-size: 26px; font-weight: 700; color: #0f172a; }
        .label { font-size: 13px; color: #6b7280; }
        .links { display: flex; gap: 10px; flex-wrap: wrap; }
        .btn { border: 1px solid #1e40af; background: #fff; color: #1e40af; border-radius: 8px; padding: 9px 12px; text-decoration: none; font-size: 13px; font-weight: 600; }
        .btn:hover { background: #eff6ff; }
        @@media (max-width: 991px) { .main-content { margin-left: 0; } }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "Dashboard")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "Admin Dashboard", Description: "Super Admin-owned admin operations dashboard"))
    <div class="content-wrapper">
        <div class="cards">
            <div class="card"><div class="value">@Model.TotalUsers</div><div class="label">Total Users</div></div>
            <div class="card"><div class="value">@Model.TotalPolicies</div><div class="label">Total Policies</div></div>
            <div class="card"><div class="value">@Model.PendingCompliance</div><div class="label">Pending Compliance</div></div>
            <div class="card"><div class="value">@Model.TotalSuppliers</div><div class="label">Total Suppliers</div></div>
            <div class="card"><div class="value">@Model.RecentProcurements</div><div class="label">Procurements (30d)</div></div>
            <div class="card"><div class="value">@Model.AuditLogsToday</div><div class="label">Audit Logs Today</div></div>
        </div>

        <div class="links">
            <a class="btn" href="/SuperAdmin/SystemSettingsPolicies">Open System Settings & Policies</a>
            <a class="btn" href="/SuperAdmin/AllReports">Open Reports</a>
        </div>
    </div>
</div>
