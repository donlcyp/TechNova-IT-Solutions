@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.ResetDeactivateAccountsModel
@{
    ViewData["Title"] = "Reset / Deactivate Accounts";
}

@section Styles {
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f8f9fa;
        }

        .main-content {
            margin-left: 260px;
            min-height: 100vh;
        }

        .content-wrapper {
            padding: 24px;
            max-width: 1280px;
            margin: 0 auto;
        }

        .table-container {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 780px;
        }

        th, td {
            text-align: left;
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
        }

        th {
            font-size: 12px;
            color: #6b7280;
            text-transform: uppercase;
            background: #f9fafb;
        }

        tbody tr:hover {
            background: #f9fafb;
        }

        .role-badge {
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
        }

        .status-badge {
            font-size: 14px;
            font-weight: 600;
        }

        .status-badge.active { color: #166534; }
        .status-badge.inactive { color: #991b1b; }

        .btn {
            border: 1px solid #d1d5db;
            border-radius: 8px;
            padding: 7px 10px;
            font-size: 13px;
            font-weight: 600;
            background: #fff;
            cursor: pointer;
        }

        .btn-danger { border-color: #ef4444; color: #ef4444; }
        .btn-success { border-color: #059669; color: #059669; }
        .btn-secondary { color: #1e40af; border-color: #1e40af; }

        .btn:hover { background: #f3f4f6; }

        .action-row {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .action-protected {
            color: #6b7280;
            font-size: 13px;
            font-weight: 600;
        }

        .helper {
            margin-bottom: 16px;
            color: #475569;
            font-size: 14px;
        }

        @@media (max-width: 991px) {
            .main-content { margin-left: 0; }
        }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "ResetDeactivateAccounts")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "Reset / Deactivate Accounts", Description: "Manage access lifecycle and account recovery"))

    <div class="content-wrapper">
        <p class="helper">Deactivate immediately blocks login. Reactivate restores access. Reset Password now applies role defaults: <strong>compliance123</strong> for compliance roles, <strong>employee123</strong> for employee roles, and <strong>supplier123</strong> for supplier roles.</p>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td><span class="role-badge">@user.Role</span></td>
                            <td><span class="status-badge @user.Status.ToLower()">@user.Status</span></td>
                            <td>
                                <div class="action-row">
                                    @if (string.Equals(user.Role, "SuperAdmin", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="action-protected">Protected</span>
                                    }
                                    else if (user.Status == "Active")
                                    {
                                        <button class="btn btn-danger" onclick="toggleUserStatus('@user.UserId', 'deactivate')">Deactivate</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-success" onclick="toggleUserStatus('@user.UserId', 'reactivate')">Reactivate</button>
                                    }
                                    @if (!string.Equals(user.Role, "SuperAdmin", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button class="btn btn-secondary" onclick="resetPasswordByRole('@user.UserId', '@user.Role')">Reset Password</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function toggleUserStatus(userId, action) {
            const endpoint = action === 'deactivate' ? '/SuperAdmin/DeactivateUser' : '/SuperAdmin/ReactivateUser';
            const confirmed = await window.showAppConfirm(`Are you sure you want to ${action} this account?`);
            if (!confirmed) return;

            const response = await fetch(`${endpoint}?userId=${userId}`, { method: 'POST' });
            const result = await response.json();
            if (response.ok && result.success) {
                await window.showAppMessage(result.message, 'Success');
                window.location.reload();
                return;
            }

            await window.showAppMessage(result.message || `Failed to ${action} account.`, 'Error');
        }

        async function resetPasswordByRole(userId, role) {
            const roleLabel = role || 'this';
            const confirmed = await window.showAppConfirm(`Reset password for ${roleLabel} account to its default value?`);
            if (!confirmed) return;

            const response = await fetch(`/SuperAdmin/ResetUserPassword?userId=${userId}`, { method: 'POST' });
            const result = await response.json();

            if (response.ok && result.success) {
                await window.showAppMessage(result.message, 'Success');
                return;
            }

            await window.showAppMessage(result.message || 'Failed to reset password.', 'Error');
        }
    </script>
}
