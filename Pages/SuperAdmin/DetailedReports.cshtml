@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.DetailedReportsModel
@{
    ViewData["Title"] = "Operational Drilldown Reports";
}

@section Styles {
    <style>
        .main-content { margin-left: 260px; min-height: 100vh; background: linear-gradient(135deg, #f0f4ff 0%, #f8fafc 50%, #f0fdf4 100%); }
        .content-wrapper { padding: 28px; max-width: 1400px; margin: 0 auto; }

        .panel {
            background: #fff; border: 1px solid #e2e8f0; border-radius: 16px;
            padding: 24px; margin-bottom: 18px;
            box-shadow: 0 1px 3px rgba(15,23,42,.04), 0 4px 12px rgba(15,23,42,.03);
            transition: box-shadow .2s;
        }
        .panel:hover { box-shadow: 0 4px 16px rgba(15,23,42,.07); }

        .panel-title {
            margin: 0 0 14px; color: #0f172a; font-size: 1.05rem; font-weight: 700;
            display: flex; align-items: center; gap: 8px; letter-spacing: -0.01em;
        }
        .panel-title .icon {
            width: 28px; height: 28px; border-radius: 8px;
            display: inline-flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, #eff6ff, #dbeafe); color: #2563eb;
        }
        .panel-title .icon svg { width: 16px; height: 16px; }

        .meta { font-size: 0.85rem; color: #64748b; display: flex; align-items: center; gap: 6px; }
        .meta svg { width: 14px; height: 14px; flex-shrink: 0; }

        .toolbar { display: grid; grid-template-columns: repeat(6, minmax(120px, 1fr)); gap: 14px; align-items: end; }
        .toolbar label {
            display: block; font-size: 0.72rem; font-weight: 600; color: #475569;
            margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.04em;
        }
        .toolbar select, .toolbar input {
            width: 100%; border: 1px solid #e2e8f0; border-radius: 10px;
            padding: 10px 12px; font-size: 0.9rem; color: #1e293b;
            background: #f8fafc; transition: border-color .2s, box-shadow .2s;
        }
        .toolbar select:focus, .toolbar input:focus {
            outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12);
        }
        .toolbar .actions { display: flex; gap: 10px; align-items: end; }

        .btn {
            border: none; background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff;
            border-radius: 10px; padding: 10px 16px; text-decoration: none;
            font-size: 0.82rem; font-weight: 600; cursor: pointer;
            display: inline-flex; align-items: center; gap: 6px;
            transition: all .2s; box-shadow: 0 2px 8px rgba(37,99,235,.2);
        }
        .btn:hover { box-shadow: 0 4px 14px rgba(37,99,235,.3); transform: translateY(-1px); }
        .btn.secondary {
            background: #fff; color: #2563eb; border: 1.5px solid #bfdbfe; box-shadow: none;
        }
        .btn.secondary:hover { background: #eff6ff; border-color: #93c5fd; transform: translateY(-1px); }

        .cards { display: grid; grid-template-columns: repeat(4, minmax(130px, 1fr)); gap: 14px; }
        .card {
            border-radius: 14px; padding: 18px; position: relative; overflow: hidden;
            border: 1px solid #e2e8f0; background: linear-gradient(135deg, #f8fafc 0%, #fff 100%);
            transition: transform .2s, box-shadow .2s;
        }

        .card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%;
            border-radius: 4px 0 0 4px;
        }
        .card:nth-child(1)::before { background: linear-gradient(180deg, #3b82f6, #2563eb); }
        .card:nth-child(2)::before { background: linear-gradient(180deg, #22c55e, #16a34a); }
        .card:nth-child(3)::before { background: linear-gradient(180deg, #f59e0b, #d97706); }
        .card:nth-child(4)::before { background: linear-gradient(180deg, #ef4444, #dc2626); }
        .card .label { font-size: 0.72rem; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
        .card .value { font-size: 1.6rem; font-weight: 800; color: #0f172a; letter-spacing: -0.02em; }

        table { width: 100%; border-collapse: separate; border-spacing: 0; }
        thead th {
            padding: 12px 14px; text-align: left; font-size: 0.72rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.06em; color: #64748b;
            background: #f8fafc; border-bottom: 2px solid #e2e8f0;
            position: sticky; top: 0; z-index: 1;
        }
        thead th:first-child { border-radius: 10px 0 0 0; }
        thead th:last-child { border-radius: 0 10px 0 0; }
        tbody td {
            padding: 12px 14px; font-size: 0.9rem; color: #334155;
            border-bottom: 1px solid #f1f5f9; transition: background .15s;
        }
        tbody tr:hover td { background: #f8fafc; }
        tbody tr:last-child td { border-bottom: none; }

        .status {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 12px; border-radius: 20px;
            font-size: 0.78rem; font-weight: 600; letter-spacing: 0.01em;
        }
        .status::before {
            content: ''; width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
        }
        .status.compliant { background: #f0fdf4; color: #15803d; }
        .status.compliant::before { background: #22c55e; }
        .status.pending { background: #fffbeb; color: #b45309; }
        .status.pending::before { background: #f59e0b; }
        .status.non-compliant { background: #fef2f2; color: #dc2626; }
        .status.non-compliant::before { background: #ef4444; }

        .pager { display: flex; justify-content: space-between; align-items: center; margin-top: 16px; padding-top: 14px; border-top: 1px solid #f1f5f9; }
        .pager-links { display: flex; gap: 8px; }

        @@media (max-width: 991px) {
            .main-content { margin-left: 0; }
            .toolbar { grid-template-columns: 1fr 1fr; }
            .cards { grid-template-columns: 1fr 1fr; }
        }
        @@media (max-width: 576px) {
            .content-wrapper { padding: 16px; }
            .panel { padding: 16px; border-radius: 14px; }
            .toolbar { grid-template-columns: 1fr; }
            .cards { grid-template-columns: 1fr 1fr; }
            .card .value { font-size: 1.4rem; }
        }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "AllReports")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "Operational Drilldown Reports", Description: "Investigative, record-level view for exceptions and audit tracing"))

    <div class="content-wrapper">
        <div class="panel">
            <h3 class="panel-title">
                <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg></span>
                Drilldown Filters
            </h3>
            <form method="get" class="toolbar">
                <div>
                    <label for="moduleType">Module</label>
                    <select id="moduleType" name="moduleType">
                        @if (Model.ModuleType == "all") { <option value="all" selected>All</option> } else { <option value="all">All</option> }
                        @if (Model.ModuleType == "employee") { <option value="employee" selected>Employee</option> } else { <option value="employee">Employee</option> }
                        @if (Model.ModuleType == "supplier") { <option value="supplier" selected>Supplier</option> } else { <option value="supplier">Supplier</option> }
                    </select>
                </div>
                <div>
                    <label for="status">Status</label>
                    <select id="status" name="status">
                        @if (Model.Status == "all") { <option value="all" selected>All</option> } else { <option value="all">All</option> }
                        @if (Model.Status == "compliant") { <option value="compliant" selected>Compliant</option> } else { <option value="compliant">Compliant</option> }
                        @if (Model.Status == "pending") { <option value="pending" selected>Pending</option> } else { <option value="pending">Pending</option> }
                        @if (Model.Status == "non-compliant") { <option value="non-compliant" selected>Non-Compliant</option> } else { <option value="non-compliant">Non-Compliant</option> }
                    </select>
                </div>
                <div>
                    <label for="fromDate">From Date</label>
                    <input id="fromDate" name="fromDate" type="date" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label for="toDate">To Date</label>
                    <input id="toDate" name="toDate" type="date" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label for="pageSize">Page Size</label>
                    <select id="pageSize" name="pageSize">
                        @if (Model.PageSize == 10) { <option value="10" selected>10</option> } else { <option value="10">10</option> }
                        @if (Model.PageSize == 25) { <option value="25" selected>25</option> } else { <option value="25">25</option> }
                        @if (Model.PageSize == 50) { <option value="50" selected>50</option> } else { <option value="50">50</option> }
                    </select>
                </div>
                <div class="actions">
                    <input type="hidden" name="pageNumber" value="1" />
                    <button type="submit" class="btn">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                        Apply
                    </button>
                    <a class="btn secondary"
                       asp-page-handler="ExportCsv"
                       asp-route-moduleType="@Model.ModuleType"
                       asp-route-status="@Model.Status"
                       asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export CSV
                    </a>
                </div>
            </form>
            <div class="meta" style="margin-top:12px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                Strategic summary remains in
                <a href="/SuperAdmin/AllReports" style="color:#2563eb;font-weight:600;text-decoration:none;">System Oversight Reports</a>.
                This page is record-level drilldown for investigation.
            </div>
        </div>

        <div class="panel">
            <h3 class="panel-title">
                <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span>
                Filtered Summary
            </h3>
            <div class="cards">
                <div class="card"><div class="label">Total Records</div><div class="value">@Model.TotalRecords</div></div>
                <div class="card"><div class="label">Compliant</div><div class="value">@Model.CompliantCount</div></div>
                <div class="card"><div class="label">Pending</div><div class="value">@Model.PendingCount</div></div>
                <div class="card"><div class="label">Non-Compliant</div><div class="value">@Model.NonCompliantCount</div></div>
            </div>
        </div>

        <div class="panel">
            <h3 class="panel-title">
                <span class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></span>
                Record-Level Evidence
            </h3>
            <table>
                <thead>
                    <tr>
                        <th>Module</th>
                        <th>Entity</th>
                        <th>Policy</th>
                        <th>Status</th>
                        <th>Assigned Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="5" style="text-align:center;padding:32px 14px;color:#94a3b8;font-size:0.9rem;">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:block;margin:0 auto 8px;color:#cbd5e1;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                                No records found for selected filters.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in Model.Rows)
                        {
                            var statusCss = row.Status.ToLowerInvariant();
                            <tr>
                                <td style="font-weight:600;color:#1e293b;">@row.Module</td>
                                <td>@row.EntityName</td>
                                <td>@row.Policy</td>
                                <td><span class="status @statusCss">@row.Status</span></td>
                                <td>@row.AssignedDate?.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="pager">
                <div class="meta">Page @Model.PageNumber of @Model.TotalPages</div>
                <div class="pager-links">
                    @if (Model.PageNumber > 1)
                    {
                        <a class="btn secondary"
                           asp-route-moduleType="@Model.ModuleType"
                           asp-route-status="@Model.Status"
                           asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                           asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-pageNumber="@(Model.PageNumber - 1)">
                            Previous
                        </a>
                    }
                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a class="btn secondary"
                           asp-route-moduleType="@Model.ModuleType"
                           asp-route-status="@Model.Status"
                           asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                           asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-pageNumber="@(Model.PageNumber + 1)">
                            Next
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
