@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.SystemSettingsPoliciesModel
@{
    ViewData["Title"] = "System Settings";
}

@section Styles {
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f1f5f9; }
        .main-content { margin-left: 260px; min-height: 100vh; }
        .content-wrapper { padding: 28px; max-width: 1100px; }

        .settings-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .settings-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,.04);
        }

        .settings-card.full-width {
            grid-column: span 2;
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            padding-bottom: 14px;
            border-bottom: 1px solid #f1f5f9;
        }

        .card-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .card-icon svg { width: 20px; height: 20px; }

        .card-header-text h3 {
            margin: 0;
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
        }

        .card-header-text p {
            margin: 2px 0 0;
            font-size: 12px;
            color: #64748b;
        }

        .setting-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f8fafc;
            gap: 12px;
        }

        .setting-row:last-child { border-bottom: none; }

        .setting-key {
            font-size: 13px;
            color: #475569;
            font-weight: 500;
            min-width: 160px;
        }

        .setting-val {
            font-size: 13px;
            color: #0f172a;
            font-weight: 600;
            word-break: break-all;
            text-align: right;
        }

        .setting-val.masked {
            color: #94a3b8;
            letter-spacing: 2px;
        }

        .badge-on  { display:inline-block; padding:3px 10px; border-radius:99px; font-size:12px; font-weight:600; background:#dcfce7; color:#16a34a; }
        .badge-off { display:inline-block; padding:3px 10px; border-radius:99px; font-size:12px; font-weight:600; background:#f1f5f9; color:#64748b; }

        @@media (max-width: 991px) {
            .main-content { margin-left: 0; }
            .settings-grid { grid-template-columns: 1fr; }
            .settings-card.full-width { grid-column: span 1; }
        }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "SystemSettingsPolicies")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "System Settings", Description: "Read-only view of platform configuration"))

    <div class="content-wrapper">
        <div class="settings-grid">

            @* Email Settings *@
            <div class="settings-card">
                <div class="card-header">
                    <div class="card-icon" style="background:#eff6ff;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                    </div>
                    <div class="card-header-text">
                        <h3>Email Settings</h3>
                        <p>SMTP configuration used for system notifications</p>
                    </div>
                </div>
                <div class="setting-row">
                    <span class="setting-key">SMTP Host</span>
                    <span class="setting-val">@Model.EmailHost</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Port</span>
                    <span class="setting-val">@Model.EmailPort</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Username</span>
                    <span class="setting-val">@Model.EmailUsername</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">From Address</span>
                    <span class="setting-val">@Model.EmailFrom</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Password</span>
                    <span class="setting-val masked">&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Use SSL</span>
                    <span class="setting-val">
                        @if (Model.EmailUseSsl)
                        { <span class="badge-on">Enabled</span> }
                        else
                        { <span class="badge-off">Disabled</span> }
                    </span>
                </div>
            </div>

            @* Database Settings *@
            <div class="settings-card">
                <div class="card-header">
                    <div class="card-icon" style="background:#f0fdf4;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <ellipse cx="12" cy="5" rx="9" ry="3"/>
                            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                        </svg>
                    </div>
                    <div class="card-header-text">
                        <h3>Database</h3>
                        <p>Connection and migration configuration</p>
                    </div>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Connection</span>
                    <span class="setting-val masked">&bull;&bull;&bull;&bull;&bull; configured &bull;&bull;&bull;&bull;&bull;</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Auto-Migrate on Startup</span>
                    <span class="setting-val">
                        @if (Model.AutoMigrateOnStartup)
                        { <span class="badge-on">Enabled</span> }
                        else
                        { <span class="badge-off">Disabled</span> }
                    </span>
                </div>
            </div>

            @* Federal Register API *@
            <div class="settings-card">
                <div class="card-header">
                    <div class="card-icon" style="background:#fdf4ff;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#a21caf" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="2" y1="12" x2="22" y2="12"/>
                            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                        </svg>
                    </div>
                    <div class="card-header-text">
                        <h3>Federal Register API</h3>
                        <p>External policy reference source</p>
                    </div>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Base URL</span>
                    <span class="setting-val">@Model.FederalRegisterBaseUrl</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Results Per Page</span>
                    <span class="setting-val">@Model.FederalRegisterPerPage</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Timeout (s)</span>
                    <span class="setting-val">@Model.FederalRegisterTimeout</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Default Search Term</span>
                    <span class="setting-val">@Model.FederalRegisterSearchTerm</span>
                </div>
            </div>

            @* Exchange Rate API *@
            <div class="settings-card">
                <div class="card-header">
                    <div class="card-icon" style="background:#fff7ed;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="1" x2="12" y2="23"/>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                        </svg>
                    </div>
                    <div class="card-header-text">
                        <h3>Exchange Rate API</h3>
                        <p>Currency conversion service for procurement</p>
                    </div>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Base URL</span>
                    <span class="setting-val">@Model.ExchangeRateBaseUrl</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">API Key</span>
                    <span class="setting-val masked">&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Base Currency</span>
                    <span class="setting-val">@Model.ExchangeRateBaseCurrency</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Timeout (s)</span>
                    <span class="setting-val">@Model.ExchangeRateTimeout</span>
                </div>
            </div>

            @* Bootstrap Super Admin *@
            <div class="settings-card full-width">
                <div class="card-header">
                    <div class="card-icon" style="background:#fff1f2;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#e11d48" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                    </div>
                    <div class="card-header-text">
                        <h3>Bootstrap Super Admin</h3>
                        <p>One-time super admin seeding configuration — should remain disabled in production</p>
                    </div>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Bootstrap Enabled</span>
                    <span class="setting-val">
                        @if (Model.BootstrapEnabled)
                        { <span class="badge-on">Enabled</span> }
                        else
                        { <span class="badge-off">Disabled</span> }
                    </span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Bootstrap Email</span>
                    <span class="setting-val">@(string.IsNullOrWhiteSpace(Model.BootstrapEmail) ? "—" : Model.BootstrapEmail)</span>
                </div>
                <div class="setting-row">
                    <span class="setting-key">Bootstrap Password</span>
                    <span class="setting-val masked">&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;</span>
                </div>
            </div>

        </div>
    </div>
</div>
