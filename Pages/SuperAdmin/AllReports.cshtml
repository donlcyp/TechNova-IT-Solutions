@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.AllReportsModel
@{
    ViewData["Title"] = "System Oversight Reports";
}

@section Styles {
    <style>
        .main-content { margin-left: 260px; min-height: 100vh; background: linear-gradient(135deg, #f0f4ff 0%, #f8fafc 50%, #f0fdf4 100%); }
        .content-wrapper { padding: 28px; max-width: 1400px; margin: 0 auto; }

        .panel {
            background: #fff; border: 1px solid #e2e8f0; border-radius: 16px;
            padding: 24px; margin-bottom: 18px;
            box-shadow: 0 1px 3px rgba(15,23,42,.04), 0 4px 12px rgba(15,23,42,.03);
            transition: box-shadow .2s;
        }
        .panel:hover { box-shadow: 0 4px 16px rgba(15,23,42,.07); }

        .header-grid { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; align-items: flex-start; }
        .header-grid h3 { margin: 0; font-size: 1.15rem; font-weight: 700; color: #0f172a; letter-spacing: -0.01em; }

        .meta { color: #64748b; font-size: 0.85rem; margin-top: 5px; display: flex; align-items: center; gap: 6px; }
        .meta svg { width: 14px; height: 14px; flex-shrink: 0; }

        .controls { display: flex; gap: 10px; align-items: end; flex-wrap: wrap; }
        .controls label {
            display: block; font-size: 0.72rem; font-weight: 600; color: #475569;
            margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.04em;
        }
        .controls select {
            border: 1px solid #e2e8f0; border-radius: 10px; padding: 10px 12px;
            font-size: 0.9rem; color: #1e293b; background: #f8fafc;
            transition: border-color .2s, box-shadow .2s;
        }
        .controls select:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12); }

        .btn {
            border: none; background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff;
            border-radius: 10px; padding: 10px 16px; text-decoration: none;
            font-size: 0.82rem; font-weight: 600; cursor: pointer;
            display: inline-flex; align-items: center; gap: 6px;
            transition: all .2s; box-shadow: 0 2px 8px rgba(37,99,235,.2);
        }
        .btn:hover { box-shadow: 0 4px 14px rgba(37,99,235,.3); transform: translateY(-1px); }
        .btn.secondary {
            background: #fff; color: #2563eb; border: 1.5px solid #bfdbfe;
            box-shadow: none;
        }
        .btn.secondary:hover { background: #eff6ff; border-color: #93c5fd; transform: translateY(-1px); }

        .section-title {
            font-size: 1rem; font-weight: 700; margin: 0 0 14px; color: #0f172a;
            display: flex; align-items: center; gap: 8px; letter-spacing: -0.01em;
        }
        .section-title .badge {
            background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff;
            font-size: 0.7rem; font-weight: 700; padding: 3px 9px; border-radius: 20px;
        }

        .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 12px; }
        .kpi {
            border-radius: 14px; padding: 18px; position: relative; overflow: hidden;
            border: 1px solid #e2e8f0; background: linear-gradient(135deg, #f8fafc 0%, #fff 100%);
            transition: transform .2s, box-shadow .2s;
        }
        .kpi:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(15,23,42,.06); }
        .kpi::before {
            content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%;
            border-radius: 4px 0 0 4px; background: linear-gradient(180deg, #3b82f6, #2563eb);
        }
        .kpi:nth-child(2)::before { background: linear-gradient(180deg, #22c55e, #16a34a); }
        .kpi:nth-child(3)::before { background: linear-gradient(180deg, #8b5cf6, #7c3aed); }
        .kpi:nth-child(4)::before { background: linear-gradient(180deg, #f59e0b, #d97706); }
        .kpi:nth-child(5)::before { background: linear-gradient(180deg, #ec4899, #db2777); }
        .kpi:nth-child(6)::before { background: linear-gradient(180deg, #06b6d4, #0891b2); }
        .kpi .label { color: #64748b; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
        .kpi .value { color: #0f172a; font-weight: 800; font-size: 1.6rem; letter-spacing: -0.02em; }

        .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }

        .risk-up { color: #dc2626; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; }
        .risk-up::before { content: ''; border-left: 5px solid transparent; border-right: 5px solid transparent; border-bottom: 7px solid #dc2626; }
        .risk-down { color: #16a34a; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; }
        .risk-down::before { content: ''; border-left: 5px solid transparent; border-right: 5px solid transparent; border-top: 7px solid #16a34a; }

        table { width: 100%; border-collapse: separate; border-spacing: 0; }
        thead th {
            padding: 12px 14px; text-align: left; font-size: 0.72rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.06em; color: #64748b;
            background: #f8fafc; border-bottom: 2px solid #e2e8f0;
        }
        thead th:first-child { border-radius: 10px 0 0 0; }
        thead th:last-child { border-radius: 0 10px 0 0; }
        tbody td {
            padding: 12px 14px; font-size: 0.9rem; color: #334155;
            border-bottom: 1px solid #f1f5f9; transition: background .15s;
        }
        tbody tr:hover td { background: #f8fafc; }
        tbody tr:last-child td { border-bottom: none; }

        @@media (max-width: 991px) {
            .main-content { margin-left: 0; }
            .two-col { grid-template-columns: 1fr; }
            .controls { flex-direction: column; align-items: stretch; }
        }
        @@media (max-width: 576px) {
            .content-wrapper { padding: 16px; }
            .panel { padding: 16px; border-radius: 14px; }
            .kpis { grid-template-columns: 1fr 1fr; }
            .kpi .value { font-size: 1.4rem; }
        }
        @@media print {
            .sidebar, .top-bar { display: none !important; }
            .main-content { margin-left: 0 !important; background: #fff !important; }
            .content-wrapper { padding: 0 !important; max-width: 100% !important; }
            .panel { box-shadow: none !important; border: 1px solid #d1d5db !important; break-inside: avoid; margin-bottom: 12px !important; }
            .panel:hover { box-shadow: none !important; transform: none !important; }
            .kpi:hover { transform: none !important; box-shadow: none !important; }
            .btn { display: none !important; }
            body { background: #fff !important; }
            .two-col { grid-template-columns: 1fr 1fr !important; }
            .print-header { display: block !important; text-align: center; padding-bottom: 16px; border-bottom: 2px solid #1e40af; margin-bottom: 20px; }
            @@page { margin: 1.5cm; }
        }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "AllReports")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "System Oversight Reports", Description: "Strategic, cross-module governance view for Super Admin"))

    <div class="content-wrapper">
        <div class="print-header" style="display:none;">
            <div style="font-size:1.1rem;font-weight:800;color:#1e40af;">TechNova IT Solutions</div>
            <div style="font-size:1.45rem;font-weight:700;color:#0f172a;margin:6px 0;">System Oversight Report</div>
            <div style="font-size:0.85rem;color:#64748b;">
                Reporting Period: Last @Model.PeriodDays days &nbsp;|&nbsp;
                Generated by: @Model.GeneratedBy on @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
            </div>
        </div>
        <div class="panel">
            <div class="header-grid">
                <div>
                    <h3>System Overview Report</h3>
                    <div class="meta">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Reporting Period: Last @Model.PeriodDays days
                    </div>
                    <div class="meta">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Generated By: @Model.GeneratedBy
                    </div>
                    <div class="meta">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Generated On: @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")
                    </div>
                </div>

                <form method="get" class="controls">
                    <div>
                        <label for="periodDays">Cross-Module Filter</label>
                        <select id="periodDays" name="periodDays">
                            @if (Model.PeriodDays == 7) { <option value="7" selected>Last 7 days</option> } else { <option value="7">Last 7 days</option> }
                            @if (Model.PeriodDays == 30) { <option value="30" selected>Last 30 days</option> } else { <option value="30">Last 30 days</option> }
                            @if (Model.PeriodDays == 90) { <option value="90" selected>Last 90 days</option> } else { <option value="90">Last 90 days</option> }
                        </select>
                    </div>
                    <button type="submit" class="btn">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                        Apply
                    </button>
                    <button type="button" class="btn secondary" onclick="window.print()">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                        Export PDF
                    </button>
                    <a class="btn secondary" href="/SuperAdmin/FullAuditLogs">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                        Audit Logs
                    </a>
                </form>
            </div>
        </div>

        <div class="panel">
            <h4 class="section-title"><span class="badge">1</span> System-Wide Overview</h4>
            <div class="kpis">
                <div class="kpi"><div class="label">Total Users</div><div class="value">@Model.TotalUsers</div></div>
                <div class="kpi"><div class="label">Active Users</div><div class="value">@Model.TotalActiveUsers</div></div>
                <div class="kpi"><div class="label">Total Policies</div><div class="value">@Model.TotalPolicies</div></div>
                <div class="kpi"><div class="label">Total Suppliers</div><div class="value">@Model.TotalSuppliers</div></div>
                <div class="kpi"><div class="label">Procurement Txns</div><div class="value">@Model.TotalProcurementTransactions</div></div>
                <div class="kpi"><div class="label">Compliance Rate</div><div class="value">@($"{Model.SystemComplianceRate}%")</div></div>
            </div>
        </div>

        <div class="two-col">
            <div class="panel">
                <h4 class="section-title"><span class="badge">2</span> Compliance Overview</h4>
                <div class="kpis">
                    <div class="kpi"><div class="label">Employee Compliance</div><div class="value">@($"{Model.EmployeeComplianceRate}%")</div></div>
                    <div class="kpi"><div class="label">Supplier Compliance</div><div class="value">@($"{Model.SupplierComplianceRate}%")</div></div>
                    <div class="kpi"><div class="label">Overdue Policies</div><div class="value">@Model.OverduePolicies</div></div>
                    <div class="kpi"><div class="label">Current Month</div><div class="value">@($"{Model.CurrentMonthComplianceRate}%")</div></div>
                    <div class="kpi"><div class="label">Previous Month</div><div class="value">@($"{Model.PreviousMonthComplianceRate}%")</div></div>
                </div>
                <div class="meta" style="margin-top:12px;">
                    Trend:
                    @if (Model.CurrentMonthComplianceRate >= Model.PreviousMonthComplianceRate)
                    {
                        <span class="risk-down">Improving (+@Math.Round(Model.CurrentMonthComplianceRate - Model.PreviousMonthComplianceRate, 1)%)</span>
                    }
                    else
                    {
                        <span class="risk-up">Declining (@Math.Round(Model.CurrentMonthComplianceRate - Model.PreviousMonthComplianceRate, 1)%)</span>
                    }
                </div>
            </div>

            <div class="panel">
                <h4 class="section-title"><span class="badge">3</span> Security &amp; Audit</h4>
                <div class="kpis">
                    <div class="kpi"><div class="label">Login Attempts (@Model.PeriodDays d)</div><div class="value">@Model.TotalLoginAttempts</div></div>
                    <div class="kpi"><div class="label">Failed Logins (@Model.PeriodDays d)</div><div class="value">@Model.FailedLoginAttempts</div></div>
                    <div class="kpi"><div class="label">Locked Accounts</div><div class="value">@Model.LockedAccounts</div></div>
                    <div class="kpi"><div class="label">System Errors (@Model.PeriodDays d)</div><div class="value">@Model.SystemErrorsLogged</div></div>
                </div>
                <div class="meta" style="margin-top:10px;">Most Active User: <strong style="color:#1e293b;">@Model.MostActiveUser</strong></div>
                <div class="meta">Most Accessed Module: <strong style="color:#1e293b;">@Model.MostAccessedModule</strong></div>
            </div>
        </div>

        <div class="panel">
            <h4 class="section-title"><span class="badge">4</span> Procurement Overview</h4>
            <div class="kpis" style="margin-bottom:16px;">
                <div class="kpi"><div class="label">Approved Orders</div><div class="value">@Model.ApprovedOrders</div></div>
                <div class="kpi"><div class="label">Rejected Orders</div><div class="value">@Model.RejectedOrders</div></div>
                <div class="kpi"><div class="label">Pending Orders</div><div class="value">@Model.PendingOrders</div></div>
                <div class="kpi"><div class="label">Total Quantity</div><div class="value">@Model.TotalProcurementQuantity</div></div>
                <div class="kpi"><div class="label">Delayed Shipments</div><div class="value">@Model.DelayedShipments</div></div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Top Supplier</th>
                        <th>Total Quantity</th>
                        <th>Transactions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in Model.TopSuppliersByVolume)
                    {
                        <tr>
                            <td style="font-weight:600;color:#1e293b;">@supplier.SupplierName</td>
                            <td>@supplier.TotalQuantity</td>
                            <td>@supplier.TransactionCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
