@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.AllReportsModel
@{
    ViewData["Title"] = "System Oversight Reports";
}

@section Styles {
    <style>
        .main-content { margin-left: 260px; min-height: 100vh; background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%); }
        .content-wrapper { padding: 24px; max-width: 1360px; margin: 0 auto; }
        .panel { background: #fff; border: 1px solid #dbe3ef; border-radius: 14px; padding: 16px; margin-bottom: 14px; }
        .header-grid { display: flex; justify-content: space-between; gap: 14px; flex-wrap: wrap; }
        .meta { color: #475569; font-size: 0.9rem; margin-top: 4px; }
        .controls { display: flex; gap: 8px; align-items: end; }
        .controls label { display: block; font-size: 12px; color: #475569; margin-bottom: 5px; }
        .controls select { border: 1px solid #cbd5e1; border-radius: 8px; padding: 8px 10px; }
        .btn { border: 1px solid #2563eb; background: #2563eb; color: #fff; border-radius: 8px; padding: 9px 12px; text-decoration: none; font-size: 13px; font-weight: 600; }
        .btn.secondary { background: #fff; color: #2563eb; border-color: #2563eb; }
        .section-title { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: #0f172a; }
        .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; }
        .kpi { background: #f8fafc; border: 1px solid #dbeafe; border-radius: 10px; padding: 12px; }
        .kpi .label { color: #64748b; font-size: 12px; }
        .kpi .value { color: #0f172a; font-weight: 700; font-size: 1.4rem; }
        .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .risk-up { color: #b45309; font-weight: 700; }
        .risk-down { color: #15803d; font-weight: 700; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border-bottom: 1px solid #e2e8f0; padding: 10px 8px; text-align: left; font-size: 0.9rem; }
        th { color: #475569; font-size: 0.75rem; text-transform: uppercase; }
        @@media (max-width: 991px) {
            .main-content { margin-left: 0; }
            .two-col { grid-template-columns: 1fr; }
        }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "AllReports")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "System Oversight Reports", Description: "Strategic, cross-module governance view for Super Admin"))

    <div class="content-wrapper">
        <div class="panel">
            <div class="header-grid">
                <div>
                    <h3 style="margin:0;">System Overview Report</h3>
                    <div class="meta">Reporting Period: Last @Model.PeriodDays days</div>
                    <div class="meta">Generated By: @Model.GeneratedBy</div>
                    <div class="meta">Generated On: @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</div>
                </div>

                <form method="get" class="controls">
                    <div>
                        <label for="periodDays">Cross-Module Filter</label>
                        <select id="periodDays" name="periodDays">
                            @if (Model.PeriodDays == 7) { <option value="7" selected>Last 7 days</option> } else { <option value="7">Last 7 days</option> }
                            @if (Model.PeriodDays == 30) { <option value="30" selected>Last 30 days</option> } else { <option value="30">Last 30 days</option> }
                            @if (Model.PeriodDays == 90) { <option value="90" selected>Last 90 days</option> } else { <option value="90">Last 90 days</option> }
                        </select>
                    </div>
                    <button type="submit" class="btn">Apply</button>
                    <a class="btn secondary" asp-page-handler="ExportSystemCsv" asp-route-periodDays="@Model.PeriodDays">Export Full System Report (CSV)</a>
                    <a class="btn secondary" href="/SuperAdmin/FullAuditLogs">Full Audit Logs</a>
                </form>
            </div>
        </div>

        <div class="panel">
            <h4 class="section-title">1. System-Wide Overview</h4>
            <div class="kpis">
                <div class="kpi"><div class="label">Total Users</div><div class="value">@Model.TotalUsers</div></div>
                <div class="kpi"><div class="label">Active Users</div><div class="value">@Model.TotalActiveUsers</div></div>
                <div class="kpi"><div class="label">Total Policies</div><div class="value">@Model.TotalPolicies</div></div>
                <div class="kpi"><div class="label">Total Suppliers</div><div class="value">@Model.TotalSuppliers</div></div>
                <div class="kpi"><div class="label">Procurement Transactions</div><div class="value">@Model.TotalProcurementTransactions</div></div>
                <div class="kpi"><div class="label">System Compliance Rate</div><div class="value">@($"{Model.SystemComplianceRate}%")</div></div>
            </div>
        </div>

        <div class="two-col">
            <div class="panel">
                <h4 class="section-title">2. Compliance Overview</h4>
                <div class="kpis">
                    <div class="kpi"><div class="label">Employee Compliance</div><div class="value">@($"{Model.EmployeeComplianceRate}%")</div></div>
                    <div class="kpi"><div class="label">Supplier Compliance</div><div class="value">@($"{Model.SupplierComplianceRate}%")</div></div>
                    <div class="kpi"><div class="label">Overdue Policies</div><div class="value">@Model.OverduePolicies</div></div>
                    <div class="kpi"><div class="label">Current Month</div><div class="value">@($"{Model.CurrentMonthComplianceRate}%")</div></div>
                    <div class="kpi"><div class="label">Previous Month</div><div class="value">@($"{Model.PreviousMonthComplianceRate}%")</div></div>
                </div>
                <div class="meta" style="margin-top:8px;">
                    Trend:
                    @if (Model.CurrentMonthComplianceRate >= Model.PreviousMonthComplianceRate)
                    {
                        <span class="risk-down">Improving (+@Math.Round(Model.CurrentMonthComplianceRate - Model.PreviousMonthComplianceRate, 1)%)</span>
                    }
                    else
                    {
                        <span class="risk-up">Declining (@Math.Round(Model.CurrentMonthComplianceRate - Model.PreviousMonthComplianceRate, 1)%)</span>
                    }
                </div>
            </div>

            <div class="panel">
                <h4 class="section-title">3. Security and Audit Overview</h4>
                <div class="kpis">
                    <div class="kpi"><div class="label">Login Attempts (@Model.PeriodDays d)</div><div class="value">@Model.TotalLoginAttempts</div></div>
                    <div class="kpi"><div class="label">Failed Login (@Model.PeriodDays d)</div><div class="value">@Model.FailedLoginAttempts</div></div>
                    <div class="kpi"><div class="label">Locked Accounts</div><div class="value">@Model.LockedAccounts</div></div>
                    <div class="kpi"><div class="label">System Errors (@Model.PeriodDays d)</div><div class="value">@Model.SystemErrorsLogged</div></div>
                </div>
                <div class="meta">Most Active User: <strong>@Model.MostActiveUser</strong></div>
                <div class="meta">Most Accessed Module: <strong>@Model.MostAccessedModule</strong></div>
            </div>
        </div>

        <div class="panel">
            <h4 class="section-title">4. Procurement Overview</h4>
            <div class="kpis" style="margin-bottom:10px;">
                <div class="kpi"><div class="label">Approved Orders</div><div class="value">@Model.ApprovedOrders</div></div>
                <div class="kpi"><div class="label">Rejected Orders</div><div class="value">@Model.RejectedOrders</div></div>
                <div class="kpi"><div class="label">Pending Orders</div><div class="value">@Model.PendingOrders</div></div>
                <div class="kpi"><div class="label">Total Quantity</div><div class="value">@Model.TotalProcurementQuantity</div></div>
                <div class="kpi"><div class="label">Delayed Shipments</div><div class="value">@Model.DelayedShipments</div></div>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Top Supplier</th>
                        <th>Total Quantity</th>
                        <th>Transactions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in Model.TopSuppliersByVolume)
                    {
                        <tr>
                            <td>@supplier.SupplierName</td>
                            <td>@supplier.TotalQuantity</td>
                            <td>@supplier.TransactionCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="panel">
            <h4 class="section-title">5. Drilldown Access</h4>
            <div class="meta">For operational-level detail, open the subordinate drilldown report page.</div>
            <div style="margin-top:10px;">
                <a class="btn secondary" href="/SuperAdmin/DetailedReports">Open Detailed Reports</a>
            </div>
        </div>
    </div>
</div>
