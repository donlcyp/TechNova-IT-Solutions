@page
@model TechNova_IT_Solutions.Pages.SuperAdmin.PolicyManagementModel
@{
    ViewData["Title"] = "Policy Management";
}

@section Styles {
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f8f9fa; }
        .main-content { margin-left: 260px; min-height: 100vh; }
        .content-wrapper { padding: 24px; max-width: 1280px; margin: 0 auto; }
        .table-container { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 760px; }
        th, td { text-align: left; padding: 14px 16px; border-bottom: 1px solid #e5e7eb; font-size: 14px; }
        th { font-size: 12px; color: #6b7280; text-transform: uppercase; background: #f9fafb; }
        .btn { border: 1px solid #1e40af; background: #fff; color: #1e40af; border-radius: 8px; padding: 8px 10px; text-decoration: none; font-size: 13px; font-weight: 600; }
        .btn:hover { background: #eff6ff; }
        .actions { margin-bottom: 14px; display: flex; gap: 10px; }
        .filters { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; align-items: center; }
        .filters input[type=text] { flex: 1; min-width: 200px; padding: 9px 14px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; background: #f9fafb; }
        .filters input[type=text]:focus { outline: none; border-color: #1e40af; }
        .filters select { padding: 9px 14px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; background: #f9fafb; cursor: pointer; }
        .filters select:focus { outline: none; border-color: #1e40af; }
        @@media (max-width: 991px) { .main-content { margin-left: 0; } .filters { flex-direction: column; } .filters input[type=text], .filters select { min-width: 100%; } }
    </style>
}

@await Html.PartialAsync("_SuperAdminSidebar", "SystemSettingsPolicies")

<div class="main-content">
    @await Html.PartialAsync("_SuperAdminTopBar", (Title: "Policy Management", Description: "Super Admin-owned policy listing and controls"))
    <div class="content-wrapper">
        <div class="actions">
            <a class="btn" href="/SuperAdmin/SystemSettingsPolicies">Back to Settings & Policies</a>
        </div>
        <!-- Filters -->
        <div class="filters">
            <input type="text" id="searchInput" placeholder="Search by policy title..." oninput="filterPolicies()" />
            <select id="categoryFilter" onchange="filterPolicies()">
                <option value="">All Categories</option>
                <option>Supplier Management</option>
                <option>Procurement Policy</option>
                <option>IT Governance</option>
                <option>Contract Management</option>
                <option>Quality Assurance</option>
                <option>Compliance &amp; Regulatory</option>
                <option>Code of Conduct</option>
                <option>Risk Management</option>
            </select>
            <select id="statusFilter" onchange="filterPolicies()">
                <option value="">All Status</option>
                <option>Active</option>
                <option>Archived</option>
            </select>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Policy Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Date Uploaded</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Policies)
                    {
                        <tr>
                            <td>@p.PolicyTitle</td>
                            <td>@p.Category</td>
                            <td>@(p.IsArchived ? "Archived" : "Active")</td>
                            <td>@(p.DateUploaded?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function filterPolicies() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const category = document.getElementById('categoryFilter').value;
            const status = document.getElementById('statusFilter').value;

            document.querySelectorAll('tbody tr').forEach(row => {
                const tds = row.querySelectorAll('td');
                if (tds.length < 3) return;

                const title = tds[0].textContent.toLowerCase();
                const rowCategory = tds[1].textContent.trim();
                const rowStatus = tds[2].textContent.trim();

                const matchesSearch = !search || title.includes(search);
                const matchesCategory = !category || rowCategory === category;
                const matchesStatus = !status || rowStatus === status;

                row.style.display = (matchesSearch && matchesCategory && matchesStatus) ? '' : 'none';
            });
        }
    </script>
}