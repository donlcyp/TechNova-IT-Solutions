    @section Scripts {
        <script>
            function showLoading(msg) { document.getElementById('loadingText').textContent = msg || 'Processing...'; document.getElementById('loadingOverlay').classList.add('active'); }
            function hideLoading() { document.getElementById('loadingOverlay').classList.remove('active'); }

            // Filter functionality
            const searchInput = document.getElementById('searchInput');
            const supplierFilter = document.getElementById('supplierFilter');
            const statusFilter = document.getElementById('statusFilter');
            const deliveryFilter = document.getElementById('deliveryFilter');
            const branchFilter = document.getElementById('branchFilter');
            const tableRows = document.querySelectorAll('#procurementTable tr');

            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase();
                const supplierValue = supplierFilter.value;
                const statusValue = statusFilter.value;
                const deliveryValue = deliveryFilter.value;
                const branchValue = branchFilter.value;

                tableRows.forEach(row => {
                    const itemName = row.cells[1]?.textContent.toLowerCase() || '';
                    const supplier = row.dataset.supplier || '';
                    const approvalStatus = row.dataset.approvalStatus || '';
                    const deliveryStatus = row.dataset.deliveryStatus || '';
                    const branch = row.dataset.branch || '';

                    const matchSearch = itemName.includes(searchTerm) || supplier.toLowerCase().includes(searchTerm);
                    const matchSupplier = !supplierValue || supplier === supplierValue;
                    const matchStatus = !statusValue || approvalStatus === statusValue;
                    const matchDelivery = !deliveryValue || deliveryStatus === deliveryValue;
                    const matchBranch = !branchValue || branch === branchValue;

                    row.style.display = (matchSearch && matchSupplier && matchStatus && matchDelivery && matchBranch) ? '' : 'none';
                });
            }

        searchInput.addEventListener('input', filterTable);
        supplierFilter.addEventListener('change', filterTable);
        statusFilter.addEventListener('change', filterTable);
        deliveryFilter.addEventListener('change', filterTable);
        branchFilter.addEventListener('change', filterTable);

        // Modal functions
        function openModal() {
            editingProcurementId = null;
            document.getElementById('modalTitle').textContent = 'Add Procurement Record';
            document.getElementById('procurementForm').reset();
            categoryInput.value = '';
            document.getElementById('derivedCurrencyCode').value = 'Auto from item';
            document.getElementById('derivedOriginalAmount').value = 'Auto from unit price x quantity';
            supplierItemSelect.innerHTML = '<option value="">Select Supplier First</option>';
            supplierItemSelect.disabled = true;
            policySelect.innerHTML = '<option value="">Select Supplier First</option>';
            policySelect.disabled = true;
            document.getElementById('procurementModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('procurementModal').classList.remove('active');
        }

        function showErrorModal(message, title = 'Action Required') {
            document.getElementById('errorModalTitle').textContent = title;
            document.getElementById('errorModalMessage').textContent = message;
            document.getElementById('errorModal').classList.add('active');
        }

        function closeErrorModal() {
            document.getElementById('errorModal').classList.remove('active');
        }

        function showToast(message, type = 'error', title = null) {
            if (type !== 'success') {
                showErrorModal(message, title || 'Action Required');
                return;
            }
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const resolvedTitle = title || (type === 'success' ? 'Success' : 'Action Required');
            toast.innerHTML = `
                <div class="toast-title">${resolvedTitle}</div>
                <div class="toast-message">${message}</div>
            `;
            container.appendChild(toast);
            requestAnimationFrame(() => toast.classList.add('show'));
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    if (toast.parentNode) {
                        toast.parentNode.removeChild(toast);
                    }
                }, 220);
            }, 3000);
        }

        function viewRecord(id) {
            // Find the table row matching this procurement ID
            const rows = document.querySelectorAll('#procurementTable tr');
            let targetRow = null;
            rows.forEach(row => {
                if (row.cells[0] && row.cells[0].textContent.trim() === id) {
                    targetRow = row;
                }
            });

            if (!targetRow) {
                showToast('Record not found.');
                return;
            }

            document.getElementById('viewId').textContent = targetRow.cells[0].textContent.trim();
            document.getElementById('viewItem').textContent = targetRow.cells[1].textContent.trim();
            document.getElementById('viewCategory').textContent = targetRow.cells[2].textContent.trim();
            document.getElementById('viewQuantity').textContent = targetRow.cells[3].textContent.trim();
            document.getElementById('viewSupplier').textContent = targetRow.cells[4].textContent.trim();
            document.getElementById('viewBranch').textContent = targetRow.cells[5].textContent.trim();
            document.getElementById('viewPolicy').textContent = targetRow.cells[6].textContent.trim();
            document.getElementById('viewDate').textContent = targetRow.cells[7].textContent.trim();
            document.getElementById('viewCurrency').textContent = targetRow.cells[8].textContent.trim();
            document.getElementById('viewOriginalAmount').textContent = targetRow.cells[9].textContent.trim();
            document.getElementById('viewConvertedAmount').textContent = targetRow.cells[10].textContent.trim();
            document.getElementById('viewExchangeRate').textContent = targetRow.dataset.exchangeRate || 'N/A';
            document.getElementById('viewDeliveryBegin').textContent = targetRow.cells[11].textContent.trim();
            document.getElementById('viewPossibleArrival').textContent = targetRow.cells[12].textContent.trim();
            document.getElementById('viewRevisedDelivery').textContent = targetRow.dataset.revisedDelivery || 'N/A';
            document.getElementById('viewDelayReason').textContent = targetRow.dataset.delayReason || 'N/A';

            const approvalStatus = targetRow.cells[13].textContent.trim();
            const deliveryStatus = targetRow.cells[14].textContent.trim();
            const approvalStatusEl = document.getElementById('viewApprovalStatus');
            const deliveryStatusEl = document.getElementById('viewDeliveryStatus');
            approvalStatusEl.textContent = approvalStatus;
            deliveryStatusEl.textContent = deliveryStatus;

            if (approvalStatus === 'SupplierRejected') approvalStatusEl.style.color = '#dc2626';
            else if (approvalStatus === 'Submitted' || approvalStatus === 'Draft') approvalStatusEl.style.color = '#d97706';
            else approvalStatusEl.style.color = '#16a34a';

            if (deliveryStatus === 'Late' || deliveryStatus === 'Rejected') deliveryStatusEl.style.color = '#dc2626';
            else if (deliveryStatus === 'PendingSupplier' || deliveryStatus === 'NotStarted') deliveryStatusEl.style.color = '#64748b';
            else deliveryStatusEl.style.color = '#16a34a';

            document.getElementById('viewModal').classList.add('active');
        }

        function closeViewModal() {
            document.getElementById('viewModal').classList.remove('active');
        }

        function editRecord(id) {
            const rows = document.querySelectorAll('#procurementTable tr');
            let targetRow = null;
            rows.forEach(row => {
                if (row.cells[0] && row.cells[0].textContent.trim() === id) {
                    targetRow = row;
                }
            });

            if (!targetRow) {
                showToast('Record not found.');
                return;
            }

            const status = (targetRow.dataset.workflowStatus || '').trim();
            if (status !== 'Draft' && status !== 'Submitted') {
                showToast('Only Draft or Submitted records can be edited.');
                return;
            }

            // Extract numeric DB ID from "PROC-001" format
            editingProcurementId = parseInt(id.replace('PROC-', ''));
            document.getElementById('modalTitle').textContent = 'Edit Procurement Record';
            document.getElementById('procurementModal').classList.add('active');
        }

        function markDeliveryArrived(id) {
            const procurementId = parseInt(id.replace('PROC-', ''));
            if (!Number.isFinite(procurementId) || procurementId <= 0) {
                showToast('Invalid procurement id.');
                return;
            }

            const _t = setTimeout(() => showLoading('Marking delivery as arrived...'), 300);
            fetch(`/AdminProcurement/MarkDeliveryArrived?procurementId=${procurementId}`, {
                method: 'POST'
            })
            .then(async res => {
                let payload = null;
                try {
                    payload = await res.json();
                } catch {
                    payload = null;
                }
                return { ok: res.ok, payload };
            })
            .then(result => {
                clearTimeout(_t); hideLoading();
                if (result.ok && result.payload?.success) {
                    showToast(result.payload?.message || 'Delivery marked as arrived.', 'success', 'Updated');
                    location.reload();
                } else {
                    showToast(result.payload?.message || 'Failed to mark delivery as arrived.');
                }
            })
            .catch(() => { clearTimeout(_t); hideLoading(); showToast('Error updating delivery status.'); });
        }

        let editingProcurementId = null;

        function saveProcurement() {
            const supplierIdValue = parseInt(document.getElementById('supplierId').value);
            const supplierItemIdValue = parseInt(document.getElementById('supplierItemId').value);
            const quantityValue = parseInt(document.getElementById('quantity').value);
            if (isNaN(supplierIdValue)) {
                showToast('Please select a supplier.');
                return;
            }
            if (isNaN(supplierItemIdValue)) {
                showToast('Please select an available supplier item.');
                return;
            }
            if (!Number.isFinite(quantityValue) || quantityValue <= 0) {
                showToast('Quantity must be greater than zero.');
                return;
            }
            const maxStock = supplierItemStock[supplierItemIdValue] || 0;
            if (maxStock > 0 && quantityValue > maxStock) {
                showToast(`Only ${maxStock} item(s) available for this supplier item.`);
                return;
            }
            const policyIdValue = parseInt(document.getElementById('policyId').value);
            if (isNaN(policyIdValue)) {
                showToast('Please select a compliant linked policy for this supplier.');
                return;
            }
            const data = {
                procurementId: editingProcurementId || 0,
                supplierId: supplierIdValue,
                supplierItemId: supplierItemIdValue,
                itemName: document.getElementById('supplierItemId').selectedOptions[0]?.text?.split(' (')[0] || '',
                category: document.getElementById('category').value,
                quantity: quantityValue,
                procurementDate: new Date().toISOString(),
                policyId: policyIdValue
            };

            const url = editingProcurementId ? '/AdminProcurement/UpdateProcurement' : '/AdminProcurement/CreateProcurement';

            const _t = setTimeout(() => showLoading('Saving procurement...'), 300);
            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(async res => {
                let payload = null;
                try {
                    payload = await res.json();
                } catch {
                    payload = null;
                }
                return { ok: res.ok, payload };
            })
            .then(result => {
                clearTimeout(_t); hideLoading();
                const success = result.payload?.success === true;
                if (result.ok && success) {
                    showToast(result.payload?.message || 'Procurement saved successfully.', 'success', 'Saved');
                    closeModal();
                    location.reload();
                } else {
                    showToast(result.payload?.message || 'Failed to save procurement.');
                }
            })
            .catch(() => { clearTimeout(_t); hideLoading(); showToast('Error saving procurement.'); });
        }

        // Close modal when clicking outside
        document.getElementById('procurementModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
        document.getElementById('viewModal').addEventListener('click', function(e) {
            if (e.target === this) closeViewModal();
        });
        document.getElementById('errorModal').addEventListener('click', function(e) {
            if (e.target === this) closeErrorModal();
        });
        document.getElementById('deleteModal').addEventListener('click', function(e) {
            if (e.target === this) closeDeleteModal();
        });

        let deletingProcurementId = null;

        function confirmDeleteProcurement(id) {
            deletingProcurementId = parseInt(id.replace('PROC-', ''));
            document.getElementById('deleteTargetId').textContent = id;
            document.getElementById('deleteModal').classList.add('active');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('active');
            deletingProcurementId = null;
        }

        function executeDelete() {
            if (!Number.isFinite(deletingProcurementId) || deletingProcurementId <= 0) {
                showToast('Invalid procurement id.');
                closeDeleteModal();
                return;
            }
            closeDeleteModal();
            const _t = setTimeout(() => showLoading('Deleting procurement...'), 300);
            fetch(`/AdminProcurement/DeleteProcurement?procurementId=${deletingProcurementId}`, { method: 'POST' })
                .then(async res => {
                    let payload = null;
                    try { payload = await res.json(); } catch { payload = null; }
                    return { ok: res.ok, payload };
                })
                .then(result => {
                    clearTimeout(_t); hideLoading();
                    if (result.ok && result.payload?.success) {
                        showToast(result.payload?.message || 'Procurement deleted.', 'success', 'Deleted');
                        location.reload();
                    } else {
                        showToast(result.payload?.message || 'Failed to delete procurement.');
                    }
                })
                .catch(() => { clearTimeout(_t); hideLoading(); showToast('Error deleting procurement.'); });
        }

        const supplierSelect = document.getElementById('supplierId');
        const supplierItemSelect = document.getElementById('supplierItemId');
        const policySelect = document.getElementById('policyId');
        const categoryInput = document.getElementById('category');
        let supplierItemStock = {};
        let supplierItemPricing = {};

        function updatePricingPreview() {
            const selectedItemId = parseInt(supplierItemSelect.value);
            const qty = parseInt(document.getElementById('quantity').value || '0');
            const pricing = supplierItemPricing[selectedItemId];

            if (!pricing) {
                document.getElementById('derivedCurrencyCode').value = 'Auto from item';
                document.getElementById('derivedOriginalAmount').value = 'Auto from unit price x quantity';
                return;
            }

            document.getElementById('derivedCurrencyCode').value = pricing.currencyCode;
            if (Number.isFinite(qty) && qty > 0) {
                document.getElementById('derivedOriginalAmount').value = (pricing.unitPrice * qty).toFixed(2);
            } else {
                document.getElementById('derivedOriginalAmount').value = 'Enter quantity to compute';
            }
        }

        async function reloadSupplierItems() {
            const supplierId = parseInt(supplierSelect.value);
            supplierItemSelect.innerHTML = '';
            supplierItemStock = {};
            supplierItemPricing = {};
            document.getElementById('derivedCurrencyCode').value = 'Auto from item';
            document.getElementById('derivedOriginalAmount').value = 'Auto from unit price x quantity';

            if (isNaN(supplierId)) {
                supplierItemSelect.innerHTML = '<option value="">Select Supplier First</option>';
                categoryInput.value = '';
                supplierItemSelect.disabled = true;
                policySelect.innerHTML = '<option value="">Select Supplier First</option>';
                policySelect.disabled = true;
                return;

            }

            // Reset policy until supplier items and policies are loaded
            policySelect.innerHTML = '<option value="">Loading policies...</option>';
            policySelect.disabled = true;

            supplierItemSelect.innerHTML = '<option value="">Loading items...</option>';
            supplierItemSelect.disabled = true;
            categoryInput.value = '';

            // Load all policies for the dropdown
            try {
                const policyResponse = await fetch(`/AdminProcurement/GetSupplierCompliantPoliciesByItemCategory?supplierId=${supplierId}&supplierItemId=0`);
                const policyPayload = await policyResponse.json();
                const policies = policyPayload.policies || [];
                if (policies.length) {
                    policySelect.innerHTML = '<option value="">Select Policy</option>';
                    policies.forEach(policy => {
                        const option = document.createElement('option');
                        option.value = policy.id;
                        option.textContent = policy.title;
                        policySelect.appendChild(option);
                    });
                    policySelect.disabled = false;
                } else {
                    policySelect.innerHTML = '<option value="">No policies available</option>';
                }
            } catch {
                policySelect.innerHTML = '<option value="">Failed to load policies</option>';
            }

            let items = [];
            try {
                const response = await fetch(`/AdminProcurement/GetSupplierItems?supplierId=${supplierId}`);
                const payload = await response.json();
                if (!payload.success) {
                    supplierItemSelect.innerHTML = '<option value="">Failed to load items</option>';
                    policySelect.innerHTML = '<option value="">Failed to load policies</option>';
                    policySelect.disabled = true;
                    return;
                }
                items = (payload.items || [])
                    .filter(i => i.status === 'Available' && i.quantityAvailable > 0);
            } catch {
                supplierItemSelect.innerHTML = '<option value="">Failed to load items</option>';
                return;
            }

            if (!items.length) {
                supplierItemSelect.innerHTML = '<option value="">No available items</option>';
                categoryInput.value = '';
                supplierItemSelect.disabled = true;
            } else {
                supplierItemSelect.innerHTML = '<option value="">Select Item</option>';
                items.forEach(item => {
                    const option = document.createElement('option');
                    option.value = item.supplierItemId;
                    option.textContent = `${item.itemName} (${item.currencyCode} ${Number(item.unitPrice).toFixed(2)} / unit, Stock: ${item.quantityAvailable})`;
                    option.dataset.category = item.category || '';
                    supplierItemSelect.appendChild(option);
                    supplierItemStock[item.supplierItemId] = item.quantityAvailable;
                    supplierItemPricing[item.supplierItemId] = {
                        unitPrice: Number(item.unitPrice || 0),
                        currencyCode: item.currencyCode || 'PHP'
                    };
                });
                supplierItemSelect.disabled = false;
            }
        }

        supplierSelect.addEventListener('change', reloadSupplierItems);
        supplierItemSelect.addEventListener('change', function () {
            const selected = supplierItemSelect.selectedOptions[0];
            categoryInput.value = selected?.dataset?.category || '';
            updatePricingPreview();
        });

        document.getElementById('quantity').addEventListener('input', function () {
            // No native custom validity bubble; validation is handled with custom modal on save.
            updatePricingPreview();
        });
    </script>
}
