@page
@model TechNova_IT_Solutions.Pages.SystemAdmin.ProcurementModel
@{
    ViewData["Title"] = "Procurement Management";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
        }

        .nav-menu {
            padding: 20px 16px;
            flex: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #6b7280;
            text-decoration: none;
            border-radius: 8px;
            margin-bottom: 4px;
            transition: all 0.2s;
            font-size: 15px;
            font-weight: 500;
        }

        .nav-item:hover {
            background: #f3f4f6;
            color: #1e40af;
        }

        .nav-item.active {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
        }

        .nav-item svg {
            width: 20px;
            height: 20px;
        }

        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Header Section */
        .page-header-section {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .header-title {
            font-size: 24px;
            font-weight: 700;
            color: #1f2937;
        }

        .btn-add {
            padding: 12px 20px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-add:hover {
            opacity: 0.9;
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(30, 64, 175, 0.3);
        }

        .btn-add svg {
            width: 18px;
            height: 18px;
        }

        /* Filters */
        .filters-row {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 16px;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .filter-label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
        }

        .filter-input {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            color: #1f2937;
            font-family: inherit;
            transition: all 0.2s;
        }

        .filter-input:focus {
            outline: none;
            border-color: #1e40af;
            box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1);
        }

        /* Table */
        .table-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 800px;
        }

        .view-detail-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 18px;
        }

        thead {
            background: #f3f4f6;
        }

        th {
            padding: 14px 16px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        td {
            padding: 16px;
            border-top: 1px solid #e5e7eb;
            font-size: 14px;
            color: #1f2937;
        }

        tbody tr {
            transition: background 0.2s;
        }

        tbody tr:hover {
            background: #f8f9fa;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
        }

        .status-pending {
            color: #d97706;
        }

        .status-approved {
            color: #48bb78;
        }

        .status-submitted {
            color: #d97706;
        }

        .status-supplierapproved,
        .status-shipped,
        .status-received,
        .status-closed {
            color: #16a34a;
        }

        .status-supplierrejected {
            color: #dc2626;
        }

        .status-late {
            color: #dc2626;
        }

        .status-draft {
            color: #64748b;
        }

        .status-notstarted,
        .status-pendingsupplier {
            color: #64748b;
        }

        .status-ontheway,
        .status-arrived {
            color: #16a34a;
        }

        .status-rejected {
            color: #dc2626;
        }

        /* Action Buttons */
        .action-btns {
            display: flex;
            gap: 8px;
        }

        .btn-action {
            padding: 6px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #f8f9fa;
            color: #6b7280;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-action:hover {
            border-color: #1e40af;
            color: #1e40af;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 20px;
        }

        .summary-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px 20px;
            transition: all 0.2s;
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: auto auto;
            gap: 0 12px;
            align-items: center;
        }

        .card-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            grid-row: 1 / 3;
        }

        .card-icon svg {
            width: 22px;
            height: 22px;
        }

        .card-value {
            font-size: 26px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .card-label {
            font-size: 14px;
            color: #6b7280;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: white;
            border-radius: 16px;
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            padding: 24px 28px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-title {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
        }

        .modal-close {
            background: #f3f4f6;
            border: none;
            font-size: 20px;
            color: #6b7280;
            cursor: pointer;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .modal-close:hover {
            background: #e5e7eb;
        }

        .modal-body {
            padding: 28px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group.full-width {
            grid-column: span 2;
        }

        .form-label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 8px;
        }

        .form-input {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            color: #1f2937;
            font-family: inherit;
            transition: all 0.2s;
        }

        .form-input:focus {
            outline: none;
            border-color: #1e40af;
            box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1);
        }

        .modal-footer {
            padding: 20px 28px;
            border-top: 1px solid #e5e7eb;
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }

        .btn {
            padding: 10px 18px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }

        .btn-secondary {
            background: #f3f4f6;
            color: #1f2937;
        }

        .btn-secondary:hover {
            background: #e5e7eb;
        }

        .btn-primary {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .toast-container {
            position: fixed;
            right: 20px;
            bottom: 20px;
            z-index: 3000;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 380px;
        }

        .toast {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-left: 4px solid #1e40af;
            border-radius: 10px;
            box-shadow: 0 10px 22px rgba(0, 0, 0, 0.15);
            padding: 12px 14px;
            transform: translateX(120%);
            opacity: 0;
            transition: all 0.25s ease;
        }

        .toast.show {
            transform: translateX(0);
            opacity: 1;
        }

        .toast.success {
            border-left-color: #16a34a;
        }

        .toast.error {
            border-left-color: #dc2626;
        }

        .toast-title {
            font-size: 13px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 2px;
        }

        .toast-message {
            font-size: 13px;
            color: #374151;
        }

        @@media (max-width: 1024px) {
            .filters-row {
                grid-template-columns: 1fr;
            }

            .summary-cards {
                grid-template-columns: 1fr;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .form-group.full-width {
                grid-column: span 1;
            }
        }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }

            .content-wrapper {
                padding: 20px;
            }

            .header-top {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }

            .table-container {
                overflow-x: auto;
            }

            .summary-cards {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 576px) {
            .page-header-section {
                padding: 16px;
            }

            .modal-header {
                padding: 16px 20px;
            }

            .modal-body {
                padding: 20px;
            }

            .modal-footer {
                padding: 16px 20px;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .form-group.full-width {
                grid-column: span 1;
            }

            .modal-content {
                width: 95%;
                margin: 10px;
            }

            .view-detail-grid {
                grid-template-columns: 1fr;
            }

            th, td {
                padding: 10px;
                font-size: 13px;
            }
        }
    .loading-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,42,.6); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:16px; }
    .loading-overlay.active { display:flex; }
    .loading-spinner { width:48px; height:48px; border:4px solid rgba(255,255,255,.3); border-top:4px solid #fff; border-radius:50%; animation:spin .8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
}
<div class="loading-overlay" id="loadingOverlay"><div class="loading-spinner"></div><div id="loadingText" style="color:#fff;font-size:16px;font-weight:500;">Processing...</div></div>
@await Html.PartialAsync("_SystemAdminSidebar", "Procurement")
<div id="toastContainer" class="toast-container"></div>

<!-- Main Content -->
<div class="main-content">
    @await Html.PartialAsync("_AdminTopBar", (Title: "Procurement Management", Description: "Manage procurement records and approvals"))

    <div class="content-wrapper">
        <!-- Header Section -->
        <div class="page-header-section">
            <div class="header-top">
                <h1 class="header-title">Procurement Management</h1>
                <button class="btn-add" onclick="openModal()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Add Procurement Record
                </button>
            </div>

            <div class="filters-row">
                    <div class="filter-group">
                        <label class="filter-label">Search</label>
                        <input type="text" class="filter-input" placeholder="Search by item name or supplier..." id="searchInput">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label">Supplier</label>
                        <select class="filter-input" id="supplierFilter">
                            <option value="">All Suppliers</option>
                            @foreach (var supplier in Model.Suppliers)
                            {
                                <option value="@supplier.Name">@supplier.Name</option>
                            }
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label">Approval Status</label>
                        <select class="filter-input" id="statusFilter">
                            <option value="">All Status</option>
                            <option value="Draft">Draft</option>
                            <option value="Submitted">Submitted</option>
                            <option value="SupplierApproved">SupplierApproved</option>
                            <option value="SupplierRejected">SupplierRejected</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label">Delivery Status</label>
                        <select class="filter-input" id="deliveryFilter">
                            <option value="">All Delivery</option>
                            <option value="NotStarted">NotStarted</option>
                            <option value="PendingSupplier">PendingSupplier</option>
                            <option value="OnTheWay">OnTheWay</option>
                            <option value="Late">Late</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Arrived">Arrived</option>
                            <option value="Closed">Closed</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label">Branch</label>
                        <select class="filter-input" id="branchFilter">
                            <option value="">All Branches</option>
                            <option value="Company-Wide">Company-Wide</option>
                            @foreach (var branch in Model.Branches)
                            {
                                <option value="@branch.Name">@branch.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Summary Cards -->
            <div class="summary-cards" style="grid-template-columns: repeat(4, 1fr);">
                <div class="summary-card">
                    <div class="card-icon" style="color: #1e40af;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                            <line x1="1" y1="10" x2="23" y2="10"></line>
                        </svg>
                    </div>
                    <div class="card-value">@Model.TotalProcurements</div>
                    <div class="card-label">Total Procurement Records</div>
                </div>
                <div class="summary-card">
                    <div class="card-icon" style="color: #d97706;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                    </div>
                    <div class="card-value">@Model.PendingApprovals</div>
                    <div class="card-label">Pending Approvals</div>
                </div>
                <div class="summary-card">
                    <div class="card-icon" style="color: #48bb78;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                    </div>
                    <div class="card-value">@Model.ProcurementsThisMonth</div>
                    <div class="card-label">Procurements This Month</div>
                </div>
                <div class="summary-card">
                    <div class="card-icon" style="color: #7c3aed;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                    </div>
                    <div class="card-value">₱@Model.TotalValue.ToString("N2")</div>
                    <div class="card-label">Total Procurement Value</div>
                </div>
            </div>

            <!-- Main Table -->
            <div class="table-card">
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Procurement ID</th>
                                <th>Item Name</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Supplier Name</th>
                                <th>Branch</th>
                                <th>Linked Policy</th>
                                <th>Order Date</th>
                                <th>Currency</th>
                                <th>Original Amount</th>
                                <th>Converted Amount (PHP)</th>
                                <th>Delivery Begin</th>
                                <th>Possible Arrival</th>
                                <th>Approval Status</th>
                                <th>Delivery Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="procurementTable">
                            @foreach (var record in Model.ProcurementRecords)
                            {
                            <tr data-supplier="@record.SupplierName"
                                data-approval-status="@record.ApprovalStatus"
                                data-delivery-status="@record.DeliveryStatus"
                                data-workflow-status="@record.WorkflowStatus"
                                data-branch="@record.BranchName"
                                data-db-id="@record.ProcurementId.Replace("PROC-", "")"
                                data-exchange-rate="@(record.ExchangeRate?.ToString("0.000000") ?? "N/A")"
                                data-delay-reason="@(record.DelayReason ?? string.Empty)"
                                data-revised-delivery="@(record.RevisedDeliveryDate?.ToString("MMM d, yyyy") ?? "N/A")">
                                <td>@record.ProcurementId</td>
                                <td>@record.ItemName</td>
                                <td>@record.Category</td>
                                <td>@record.Quantity</td>
                                <td>@record.SupplierName</td>
                                <td>@record.BranchName</td>
                                <td>@record.LinkedPolicy</td>
                                <td>@record.PurchaseDate.ToString("MMM d, yyyy")</td>
                                <td>@record.CurrencyCode</td>
                                <td>@(record.OriginalAmount.HasValue ? record.OriginalAmount.Value.ToString("N2") : "N/A")</td>
                                <td>@(record.ConvertedAmount.HasValue ? record.ConvertedAmount.Value.ToString("N2") : "N/A")</td>
                                <td>@(record.DeliveryBegin.HasValue ? record.DeliveryBegin.Value.ToString("MMM d, yyyy") : "TBD")</td>
                                <td>@(record.PossibleArrival.HasValue ? record.PossibleArrival.Value.ToString("MMM d, yyyy") : "TBD")</td>
                                <td><span class="status-badge status-@record.ApprovalStatus.ToLower()">@record.ApprovalStatus</span></td>
                                <td><span class="status-badge status-@record.DeliveryStatus.ToLower()">@record.DeliveryStatus</span></td>
                                <td>
                                    <div class="action-btns">
                                        <button class="btn-action" onclick="viewRecord('@record.ProcurementId')">View</button>
                                        @if (record.CanMarkDeliveryArrived)
                                        {
                                            <button class="btn-action" onclick="markDeliveryArrived('@record.ProcurementId')">Delivery Arrived</button>
                                        }
                                        else if (record.CanEdit)
                                        {
                                            <button class="btn-action" onclick="editRecord('@record.ProcurementId')">Edit</button>
                                        }
                                        @if (record.CanDelete)
                                        {
                                            <button class="btn-action" style="color:#dc2626;border-color:#fca5a5;" onclick="confirmDeleteProcurement('@record.ProcurementId')">Delete</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

    <!-- Add/Edit Procurement Modal -->
    <div class="modal" id="procurementModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="modalTitle">Add Procurement Record</h2>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="procurementForm">
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Supplier *</label>
                            <select id="supplierId" class="form-input" required>
                                <option value="">Select Supplier</option>
                                @foreach (var supplier in Model.Suppliers)
                                {
                                    <option value="@supplier.Id">@supplier.Name</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Available Supplier Item *</label>
                            <select id="supplierItemId" class="form-input" required disabled>
                                <option value="">Select Supplier First</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Category</label>
                            <input type="text" id="category" class="form-input" readonly>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Quantity *</label>
                            <input type="number" id="quantity" class="form-input" placeholder="0" min="1" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Linked Policy *</label>
                            <select id="policyId" class="form-input" required disabled>
                                <option value="">Select Supplier First</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Supplier Currency</label>
                            <input type="text" id="derivedCurrencyCode" class="form-input" value="Auto from item" readonly>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Original Amount</label>
                            <input type="text" id="derivedOriginalAmount" class="form-input" value="Auto from unit price x quantity" readonly>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Order Date</label>
                            <input type="text" class="form-input" value="Auto-set on save" readonly>
                        </div>
                        <div class="form-group full-width">
                            <small style="color:#64748b;">Currency and original amount are derived from selected supplier item price. Converted amount in PHP is computed on save using the latest exchange rate API quote.</small>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
                <button class="btn btn-primary" onclick="saveProcurement()">Save</button>
            </div>
        </div>
    </div>

