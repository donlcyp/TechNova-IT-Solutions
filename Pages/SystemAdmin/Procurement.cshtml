    <!-- Delete Confirmation Modal -->
    <div class="modal" id="deleteModal">
        <div class="modal-content" style="max-width: 460px;">
            <div class="modal-header">
                <h2 class="modal-title" style="color:#dc2626;">Confirm Deletion</h2>
                <button class="modal-close" onclick="closeDeleteModal()">&times;</button>
            </div>
            <div class="modal-body" style="padding: 20px 24px;">
                <p style="color:#334155; font-size:14px; margin:0;">Are you sure you want to delete procurement <strong id="deleteTargetId"></strong>? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeDeleteModal()">Cancel</button>
                <button class="btn" style="background:#dc2626;color:#fff;" onclick="executeDelete()">Delete</button>
