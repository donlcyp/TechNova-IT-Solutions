@page
@model TechNova_IT_Solutions.Pages.SystemAdmin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            min-height: 100vh;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px 20px;
            transition: transform 0.2s, box-shadow 0.2s;
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: auto 1fr;
            gap: 0 12px;
            align-items: start;
        }

        a.card {
            text-decoration: none;
            color: inherit;
            cursor: pointer;
        }

        a.card:hover {
            border-color: #c7d2fe;
            box-shadow: 0 4px 16px rgba(99, 102, 241, 0.08);
        }

        .card-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            grid-row: 1 / 3;
        }

        .card-icon svg {
            width: 22px;
            height: 22px;
        }

        .card-icon.blue {
            color: #1e40af;
        }

        .card-icon.green {
            color: #48bb78;
        }

        .card-icon.purple {
            color: #9f7aea;
        }

        .card-icon.orange {
            color: #f6ad55;
        }

        .card-icon.red {
            color: #fc8181;
        }

        .card-icon.teal {
            color: #38b2ac;
        }

        .card-value {
            font-size: 26px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 2px;
            line-height: 1;
            min-height: 30px;
            display: flex;
            align-items: center;
        }

        .card-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
            line-height: 1.35;
            min-height: 38px;
        }

        /* Two Column Layout */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }

        .section-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 26px;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
            overflow: hidden;
            min-width: 0;
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            row-gap: 10px;
        }

        .section-title-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
        }

        .section-title-icon svg {
            width: 18px;
            height: 18px;
        }

        /* Compliance Overview */
        .compliance-percentage {
            text-align: center;
            margin-bottom: 24px;
            padding: 20px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            border-radius: 10px;
            color: white;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .compliance-percentage h2 {
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 4px;
            line-height: 1.05;
        }

        .compliance-percentage p {
            font-size: 14px;
            opacity: 0.9;
            line-height: 1.3;
            max-width: 22ch;
        }

        .policy-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-height: 400px;
            overflow-y: auto;
            padding-right: 4px;
        }

        .policy-list::-webkit-scrollbar {
            width: 6px;
        }

        .policy-list::-webkit-scrollbar-track {
            background: #f3f4f6;
            border-radius: 10px;
        }

        .policy-list::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }

        .policy-list::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .policy-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: #f3f4f6;
            border-radius: 8px;
            transition: background 0.2s;
            gap: 12px;
        }

        .policy-item > div {
            min-width: 0;
            flex: 1;
            overflow: hidden;
        }

        .policy-item:hover {
            background: #e5e7eb;
        }

        .policy-name {
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .policy-date {
            font-size: 12px;
            color: #6b7280;
            white-space: nowrap;
        }

        .policy-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            background: rgba(72, 187, 120, 0.1);
            color: #48bb78;
            white-space: nowrap;
            flex-shrink: 0;
        }

        /* Procurement Overview Table */
        .procurement-table {
            width: 100%;
            border-collapse: collapse;
        }

        .procurement-table thead {
            background: #f3f4f6;
        }

        .procurement-table th {
            text-align: left;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            border-bottom: 2px solid #e5e7eb;
        }

        .procurement-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
            color: #1f2937;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }

        .procurement-table tbody tr:hover {
            background: #f3f4f6;
        }

        .table-scroll {
            width: 100%;
            max-height: 400px;
            overflow-x: auto;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            margin-top: 4px;
        }

        .table-scroll::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        .table-scroll::-webkit-scrollbar-track {
            background: #f3f4f6;
            border-radius: 10px;
        }

        .table-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }

        .table-scroll::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .table-scroll .procurement-table {
            min-width: 500px;
        }

        .supplier-name {
            font-weight: 600;
            color: #1e40af;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Mobile scroll hint */
        @@media (max-width: 768px) {
            .table-scroll {
                position: relative;
            }

            .table-scroll::after {
                content: '← Scroll →';
                position: absolute;
                bottom: 8px;
                right: 8px;
                background: rgba(30, 64, 175, 0.9);
                color: white;
                padding: 4px 10px;
                border-radius: 6px;
                font-size: 10px;
                font-weight: 600;
                pointer-events: none;
                opacity: 0;
                animation: fadeInOut 3s ease-in-out;
                animation-delay: 0.5s;
            }

            @@keyframes fadeInOut {
                0% { opacity: 0; }
                20% { opacity: 1; }
                80% { opacity: 1; }
                100% { opacity: 0; }
            }

            .procurement-table td {
                max-width: 150px;
            }
        }

        /* Recent Activities */
        .activity-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .activity-item {
            display: flex;
            gap: 16px;
            padding: 16px;
            background: #f3f4f6;
            border-radius: 10px;
            transition: background 0.2s;
        }

        .activity-content {
            min-width: 0;
        }

        .activity-item:hover {
            background: #e5e7eb;
        }

        .activity-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .activity-icon svg {
            width: 20px;
            height: 20px;
        }

        .activity-icon.user {
            background: rgba(30, 64, 175, 0.1);
            color: #1e40af;
        }

        .activity-icon.policy {
            background: rgba(159, 122, 234, 0.1);
            color: #9f7aea;
        }

        .activity-icon.procurement {
            background: rgba(246, 173, 85, 0.1);
            color: #f6ad55;
        }

        .activity-content {
            flex: 1;
        }

        .activity-title {
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .activity-description {
            font-size: 13px;
            color: #6b7280;
        }

        .activity-time {
            font-size: 12px;
            color: #6b7280;
            white-space: nowrap;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 20px;
                margin-bottom: 24px;
            }

            .summary-cards {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }

            .content-wrapper {
                padding: 20px;
            }

            .summary-cards {
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }

            .card {
                padding: 14px 16px;
            }

            .card-value {
                font-size: 22px;
            }

            .card-label {
                font-size: 13px;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 18px;
                margin-bottom: 20px;
            }

            .section-card {
                padding: 20px;
            }

            .section-title {
                font-size: 18px;
            }

            .table-scroll {
                max-height: 350px;
            }

            .policy-list {
                max-height: 350px;
            }
        }

        @@media (max-width: 768px) {
            .dashboard-grid {
                gap: 16px;
                margin-bottom: 18px;
            }

            .section-card {
                padding: 18px;
            }

            .section-title {
                font-size: 17px;
            }
        }

        @@media (max-width: 576px) {
            .summary-cards {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .card {
                padding: 12px 16px;
                grid-template-columns: auto 1fr;
            }

            .card-icon {
                width: 32px;
                height: 32px;
            }

            .card-icon svg {
                width: 18px;
                height: 18px;
            }

            .card-value {
                font-size: 20px;
            }

            .card-label {
                font-size: 12px;
            }

            .content-wrapper {
                padding: 16px;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 14px;
                margin-bottom: 16px;
            }

            .section-card {
                padding: 16px;
            }

            .section-title {
                font-size: 16px;
                margin-bottom: 14px;
            }

            .section-title-icon {
                width: 28px;
                height: 28px;
            }

            .section-title-icon svg {
                width: 16px;
                height: 16px;
            }

            .compliance-percentage h2 {
                font-size: 32px;
            }

            .compliance-percentage {
                padding: 14px;
                margin-bottom: 16px;
            }

            .compliance-percentage p {
                max-width: none;
                font-size: 13px;
            }

            .policy-item {
                flex-direction: column;
                align-items: flex-start;
                padding: 12px;
                gap: 8px;
            }

            .policy-name {
                font-size: 13px;
                white-space: normal;
            }

            .policy-date {
                font-size: 11px;
            }

            .policy-badge {
                font-size: 10px;
                padding: 3px 8px;
            }

            .procurement-table th,
            .procurement-table td {
                padding: 10px 12px;
                font-size: 12px;
            }

            .procurement-table th {
                font-size: 10px;
            }

            .table-scroll {
                max-height: 300px;
            }

            .policy-list {
                max-height: 300px;
            }

            .activity-item {
                flex-direction: row;
                align-items: flex-start;
                padding: 12px;
                gap: 12px;
            }

            .activity-icon {
                width: 36px;
                height: 36px;
            }

            .activity-icon svg {
                width: 18px;
                height: 18px;
            }

            .activity-title {
                font-size: 13px;
            }

            .activity-description {
                font-size: 12px;
            }

            .activity-time {
                font-size: 11px;
                white-space: nowrap;
                margin-top: 4px;
                display: block;
            }
        }

        @@media (max-width: 480px) {
            .dashboard-grid {
                gap: 14px;
                margin-bottom: 16px;
            }

            .section-card {
                padding: 14px;
            }

            .section-title {
                font-size: 15px;
                gap: 8px;
            }

            .section-title-icon {
                width: 26px;
                height: 26px;
            }

            .section-title-icon svg {
                width: 14px;
                height: 14px;
            }

            .compliance-percentage {
                padding: 12px;
                margin-bottom: 14px;
                border-radius: 8px;
            }

            .compliance-percentage h2 {
                font-size: 28px;
            }

            .compliance-percentage p {
                font-size: 12px;
            }

            .policy-list {
                gap: 10px;
                max-height: 280px;
            }

            .policy-item {
                padding: 10px 12px;
                gap: 6px;
            }

            .policy-name {
                font-size: 12px;
            }

            .policy-date {
                font-size: 10px;
            }

            .policy-badge {
                font-size: 9px;
                padding: 3px 7px;
            }

            .table-scroll {
                border-radius: 8px;
                max-height: 280px;
            }

            .table-scroll .procurement-table {
                min-width: 420px;
            }

            .procurement-table th {
                padding: 8px 10px;
                font-size: 9px;
            }

            .procurement-table td {
                padding: 8px 10px;
                font-size: 11px;
                max-width: 120px;
            }
        }

        @@media (max-width: 400px) {
            .content-wrapper {
                padding: 10px;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 12px;
                margin-bottom: 14px;
            }

            .section-card {
                padding: 12px;
                border-radius: 10px;
            }

            .compliance-percentage h2 {
                font-size: 26px;
            }

            .compliance-percentage {
                padding: 10px;
                margin-bottom: 12px;
            }

            .card-value {
                font-size: 18px;
            }

            .summary-cards {
                gap: 10px;
            }

            .section-title {
                font-size: 14px;
                margin-bottom: 12px;
            }

            .table-scroll .procurement-table {
                min-width: 380px;
            }

            .procurement-table th {
                padding: 7px 8px;
                font-size: 9px;
            }

            .procurement-table td {
                padding: 7px 8px;
                font-size: 11px;
                max-width: 100px;
            }

            .policy-item {
                padding: 8px 10px;
            }

            .policy-name {
                font-size: 12px;
            }

            .policy-date {
                font-size: 10px;
            }
        }

        @@media (max-width: 360px) {
            .content-wrapper {
                padding: 8px;
            }

            .dashboard-grid {
                gap: 10px;
                margin-bottom: 12px;
            }

            .section-card {
                padding: 10px;
                border-radius: 8px;
            }

            .section-title {
                font-size: 13px;
                margin-bottom: 10px;
            }

            .compliance-percentage h2 {
                font-size: 24px;
            }

            .table-scroll .procurement-table {
                min-width: 340px;
            }
        }

        @@media (max-width: 320px) {
            .dashboard-grid {
                gap: 8px;
                margin-bottom: 10px;
            }

            .section-card {
                padding: 8px;
                border-radius: 6px;
            }

            .section-title {
                font-size: 12px;
                margin-bottom: 8px;
            }

            .compliance-percentage h2 {
                font-size: 22px;
            }

            .card-value {
                font-size: 16px;
            }
        }
    </style>
}

    @await Html.PartialAsync("_SystemAdminSidebar", "Dashboard")

    <!-- Main Content -->
    <div class="main-content flex-grow-1">
        @await Html.PartialAsync("_AdminTopBar", (Title: "Dashboard", Description: "System Administration Overview"))

        <div class="content-wrapper">

            <!-- Summary Cards -->
            <div class="summary-cards">
                <a href="/SystemAdmin/BranchManagement" class="card">
                    <div class="card-icon blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9.5L12 4l9 5.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
                            <path d="M9 21V12h6v9"/>
                        </svg>
                    </div>
                    <div class="card-value">@Model.TotalBranches</div>
                    <div class="card-label">Total Branches</div>
                </a>

                <a href="/SystemAdmin/BranchManagement" class="card">
                    <div class="card-icon green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="card-value">@Model.ActiveBranches</div>
                    <div class="card-label">Active Branches</div>
                </a>

                <a href="/SystemAdmin/BranchManagement" class="card">
                    <div class="card-icon red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                        </svg>
                    </div>
                    <div class="card-value">@Model.InactiveBranches</div>
                    <div class="card-label">Inactive Branches</div>
                </a>

                <a href="/SystemAdmin/BranchManagement" class="card">
                    <div class="card-icon orange">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                    </div>
                    <div class="card-value">@Model.UnassignedBranches</div>
                    <div class="card-label">Unassigned Branches</div>
                </a>

                <a href="/SystemAdmin/UserManagement" class="card">
                    <div class="card-icon purple">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <line x1="19" y1="8" x2="19" y2="14"></line>
                            <line x1="22" y1="11" x2="16" y2="11"></line>
                        </svg>
                    </div>
                    <div class="card-value">@Model.TotalBranchAdmins</div>
                    <div class="card-label">Branch Admins</div>
                </a>

                <a href="/SystemAdmin/SupplierManagement" class="card">
                    <div class="card-icon teal">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <div class="card-value">@Model.TotalSuppliers</div>
                    <div class="card-label">Total Suppliers</div>
                </a>
            </div>

            <!-- Two Column: Branch Overview + Recent Activities -->
            <div class="dashboard-grid">

                <!-- Branch Status Overview -->
                <div class="section-card">
                    <div class="section-title">
                        <div class="section-title-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 9.5L12 4l9 5.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
                                <path d="M9 21V12h6v9"/>
                            </svg>
                        </div>
                        Branch Status Overview
                    </div>

                    @if (!Model.Branches.Any())
                    {
                        <p style="color:#9ca3af;font-size:14px;text-align:center;padding:32px 0;">No branches found. Contact Super Admin to create branches.</p>
                    }
                    else
                    {
                        <div class="table-scroll">
                            <table class="procurement-table">
                                <thead>
                                    <tr>
                                        <th>Branch</th>
                                        <th>City</th>
                                        <th>Assigned Admin</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var branch in Model.Branches.Take(10))
                                    {
                                        <tr>
                                            <td style="font-weight:600;color:#1e40af;">@branch.BranchName</td>
                                            <td>@branch.City</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(branch.AssignedAdminName))
                                                {
                                                    <span style="color:#16a34a;font-weight:500;">@branch.AssignedAdminName</span>
                                                }
                                                else
                                                {
                                                    <span style="color:#ef4444;font-size:12px;font-weight:600;">Unassigned</span>
                                                }
                                            </td>
                                            <td>
                                                <span style="display:inline-block;padding:3px 10px;border-radius:12px;font-size:11px;font-weight:700;
                                                    background:@(branch.Status == "Active" ? "#d1fae5" : "#fee2e2");
                                                    color:@(branch.Status == "Active" ? "#065f46" : "#991b1b");">
                                                    @branch.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (Model.Branches.Count > 10)
                        {
                            <p style="font-size:13px;color:#6b7280;margin-top:10px;text-align:right;">
                                Showing 10 of @Model.Branches.Count branches —
                                <a href="/SystemAdmin/BranchManagement" style="color:#1e40af;text-decoration:none;font-weight:600;">View all</a>
                            </p>
                        }
                    }
                </div>

                <!-- Recent Activities -->
                <div class="section-card">
                    <div class="section-title">
                        <div class="section-title-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </div>
                        Recent Activities
                    </div>

                    <div class="activity-list">
                        @if (!Model.RecentActivities.Any())
                        {
                            <p style="color:#9ca3af;font-size:14px;text-align:center;padding:32px 0;">No recent activity.</p>
                        }
                        else
                        {
                            @foreach (var activity in Model.RecentActivities)
                            {
                                <div class="activity-item">
                                    <div class="activity-icon @activity.IconClass">
                                        @Html.Raw(activity.IconSvg)
                                    </div>
                                    <div class="activity-content">
                                        <div class="activity-title">@activity.Title</div>
                                        <div class="activity-description">@activity.Description</div>
                                    </div>
                                    <div class="activity-time">@activity.Time</div>
                                </div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>

@section Scripts {
    <script>
        if (window.innerWidth <= 768) {
            console.log('Mobile view initialized');
        }
    </script>
}
