@page
@model TechNova_IT_Solutions.Pages.SystemAdmin.InventoryModel
@{
    ViewData["Title"] = "Inventory";
}

@section Styles {
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            transition: margin-left 0.3s ease;
        }

        body:has(.sidebar.collapsed) .main-content { margin-left: 70px; }

        .content-wrapper { padding: 32px; }

        /* ── Stats cards ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: #fff;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .stat-icon svg { width: 24px; height: 24px; }

        .stat-icon.blue   { background: rgba(30,64,175,.1);  color: #1e40af; }
        .stat-icon.yellow { background: rgba(234,179,8,.1);  color: #ca8a04; }
        .stat-icon.red    { background: rgba(239,68,68,.1);  color: #dc2626; }
        .stat-icon.green  { background: rgba(5,150,105,.1);  color: #059669; }

        .stat-info h3 { font-size: 28px; font-weight: 700; color: #1f2937; }
        .stat-info p  { font-size: 13px; color: #6b7280; margin-top: 2px; }

        /* ── Table card ── */
        .table-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            overflow: hidden;
        }

        .table-header {
            padding: 20px 24px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }

        .table-header h2 { font-size: 18px; font-weight: 600; color: #1f2937; }

        .table-controls { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

        .search-input {
            padding: 8px 14px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            min-width: 220px;
            outline: none;
            transition: border-color .2s;
        }

        .search-input:focus { border-color: #1e40af; }

        .filter-select {
            padding: 8px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            background: #fff;
            color: #374151;
            cursor: pointer;
            outline: none;
        }

        .filter-select:focus { border-color: #1e40af; }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        thead tr { background: #f9fafb; }

        th {
            padding: 12px 16px;
            text-align: left;
            font-weight: 600;
            color: #6b7280;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .4px;
            border-bottom: 1px solid #e5e7eb;
        }

        td {
            padding: 14px 16px;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            vertical-align: middle;
        }

        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #f9fafb; }

        .item-name { font-weight: 600; color: #1f2937; }
        .supplier  { color: #6b7280; font-size: 13px; }

        .qty-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 32px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }

        .qty-ok     { background: rgba(5,150,105,.1);  color: #059669; }
        .qty-low    { background: rgba(234,179,8,.1);  color: #ca8a04; }
        .qty-zero   { background: rgba(239,68,68,.1);  color: #dc2626; }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-approved  { background: rgba(5,150,105,.1);  color: #059669; }
        .status-pending   { background: rgba(234,179,8,.1);  color: #ca8a04; }
        .status-rejected  { background: rgba(239,68,68,.1);  color: #dc2626; }
        .status-default   { background: #f3f4f6;              color: #6b7280; }

        .empty-state {
            text-align: center;
            padding: 60px 24px;
            color: #9ca3af;
        }

        .empty-state svg { width: 48px; height: 48px; margin-bottom: 12px; opacity: .4; }
        .empty-state p   { font-size: 15px; }

        .btn-action {
            padding: 6px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #f8f9fa;
            color: #6b7280;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-action:hover { border-color: #1e40af; color: #1e40af; }

        /* Modal */
        .modal { display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:2000; align-items:center; justify-content:center; }
        .modal.active { display:flex; }
        .modal-content { background:#fff; border-radius:16px; max-width:560px; width:90%; max-height:90vh; overflow-y:auto; }
        .modal-header { padding:24px 28px; border-bottom:1px solid #e5e7eb; display:flex; justify-content:space-between; align-items:center; }
        .modal-title { font-size:20px; font-weight:700; color:#1f2937; }
        .modal-close { background:#f3f4f6; border:none; font-size:20px; color:#6b7280; cursor:pointer; width:36px; height:36px; display:flex; align-items:center; justify-content:center; border-radius:8px; transition:all .2s; }
        .modal-close:hover { background:#e5e7eb; }
        .modal-body { padding:28px; }
        .modal-footer { padding:20px 28px; border-top:1px solid #e5e7eb; display:flex; gap:12px; justify-content:flex-end; }
        .btn { padding:10px 18px; border-radius:8px; font-size:14px; font-weight:500; cursor:pointer; transition:all .2s; border:none; }
        .btn-secondary { background:#f3f4f6; color:#1f2937; }
        .btn-secondary:hover { background:#e5e7eb; }
        .view-detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; }

        @@media (max-width: 991px) {
            .main-content { margin-left: 0; }
            .stats-grid   { grid-template-columns: repeat(2,1fr); }
        }

        @@media (max-width: 576px) {
            .content-wrapper { padding: 16px; }
            .stats-grid      { grid-template-columns: 1fr; }
            .view-detail-grid { grid-template-columns: 1fr; }
        }
    </style>
}

@await Html.PartialAsync("_SystemAdminSidebar", "Inventory")
@await Html.PartialAsync("_SystemAdminTopBar", ("Inventory", "Track and manage company-wide inventory"))

<div class="main-content">
    <div class="content-wrapper">

        <!-- Stats -->
        <div class="stats-grid" style="grid-template-columns: repeat(5, 1fr);">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    </svg>
                </div>
                <div class="stat-info">
                    <h3>@Model.TotalItems</h3>
                    <p>Unique Items</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon yellow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                </div>
                <div class="stat-info">
                    <h3>@Model.LowStockCount</h3>
                    <p>Low Stock Items</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                    </svg>
                </div>
                <div class="stat-info">
                    <h3>@Model.OutOfStockCount</h3>
                    <p>Out of Stock</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                        <line x1="1" y1="10" x2="23" y2="10"></line>
                    </svg>
                </div>
                <div class="stat-info">
                    <h3>@Model.TotalProcurements</h3>
                    <p>Total Procurements</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(124,58,237,.1);color:#7c3aed;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg>
                </div>
                <div class="stat-info">
                    <h3>₱@Model.TotalInventoryValue.ToString("N2")</h3>
                    <p>Total Inventory Value</p>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-header">
                <h2>Inventory Items</h2>
                <div class="table-controls">
                    <input type="text" class="search-input" id="searchInput" placeholder="Search items, suppliers, or branches..." oninput="filterTable()" />
                    <select class="filter-select" id="statusFilter" onchange="filterTable()">
                        <option value="">All Statuses</option>
                        <option value="Draft">Draft</option>
                        <option value="Submitted">Submitted</option>
                        <option value="SupplierApproved">SupplierApproved</option>
                        <option value="SupplierRejected">SupplierRejected</option>
                        <option value="Received">Received</option>
                        <option value="Closed">Closed</option>
                        <option value="Late">Late</option>
                    </select>
                    <select class="filter-select" id="categoryFilter" onchange="filterTable()">
                        <option value="">All Categories</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <select class="filter-select" id="branchFilter" onchange="filterTable()">
                        <option value="">All Branches</option>
                        <option value="Company-Wide">Company-Wide</option>
                        @foreach (var branch in Model.Branches)
                        {
                            <option value="@branch.Name">@branch.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div style="overflow-x:auto;">
                <table id="inventoryTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Item Name</th>
                            <th>Category</th>
                            <th>Supplier</th>
                            <th>Branch</th>
                            <th>Qty</th>
                            <th>Unit Price</th>
                            <th>Total Cost</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Linked Policy</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="inventoryBody">
                        @if (!Model.InventoryItems.Any())
                        {
                            <tr>
                                <td colspan="12">
                                    <div class="empty-state">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                                        </svg>
                                        <p>No inventory items found.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            int row = 1;
                            foreach (var item in Model.InventoryItems)
                            {
                                var qtyClass = item.Quantity == 0 ? "qty-zero" : item.Quantity <= 5 ? "qty-low" : "qty-ok";
                                var statusLower = item.Status.ToLower();
                                var statusClass = statusLower.Contains("approv") ? "status-approved"
                                               : statusLower.Contains("pend") || statusLower.Contains("submit") || statusLower.Contains("draft") ? "status-pending"
                                               : statusLower.Contains("reject") || statusLower.Contains("late") ? "status-rejected"
                                               : statusLower.Contains("receiv") || statusLower.Contains("closed") ? "status-approved"
                                               : "status-default";
                                <tr data-status="@item.Status" data-category="@item.Category" data-branch="@item.BranchName">
                                    <td>@(row++)</td>
                                    <td><span class="item-name">@item.ItemName</span></td>
                                    <td>@item.Category</td>
                                    <td><span class="supplier">@item.SupplierName</span></td>
                                    <td>@item.BranchName</td>
                                    <td><span class="qty-badge @qtyClass">@item.Quantity</span></td>
                                    <td>₱@item.UnitPrice.ToString("N2")</td>
                                    <td>₱@item.TotalCost.ToString("N2")</td>
                                    <td><span class="status-badge @statusClass">@item.Status</span></td>
                                    <td>@(item.ProcurementDate?.ToString("MMM d, yyyy") ?? "—")</td>
                                    <td>@item.LinkedPolicy</td>
                                    <td>
                                        <button class="btn-action" onclick="viewInventoryItem(this)">View</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- Inventory Detail Modal -->
<div class="modal" id="inventoryDetailModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title">Inventory Item Details</h2>
            <button class="modal-close" onclick="closeDetailModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="view-detail-grid">
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Item Name</div>
                    <div id="detailItemName" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Category</div>
                    <div id="detailCategory" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Supplier</div>
                    <div id="detailSupplier" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Branch</div>
                    <div id="detailBranch" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Quantity</div>
                    <div id="detailQuantity" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Unit Price</div>
                    <div id="detailUnitPrice" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Total Cost (PHP)</div>
                    <div id="detailTotalCost" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Status</div>
                    <div id="detailStatus" style="font-weight:600;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Procurement Date</div>
                    <div id="detailDate" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
                <div>
                    <div style="font-size:12px;color:#6b7280;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Linked Policy</div>
                    <div id="detailPolicy" style="font-weight:600;color:#1f2937;font-size:15px;"></div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeDetailModal()">Close</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const status = document.getElementById('statusFilter').value;
            const category = document.getElementById('categoryFilter').value;
            const branch = document.getElementById('branchFilter').value;
            const rows = document.querySelectorAll('#inventoryBody tr');

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                const rowStatus = row.dataset.status || '';
                const rowCategory = row.dataset.category || '';
                const rowBranch = row.dataset.branch || '';

                const matchSearch = !search || text.includes(search);
                const matchStatus = !status || rowStatus === status;
                const matchCategory = !category || rowCategory === category;
                const matchBranch = !branch || rowBranch === branch;

                row.style.display = (matchSearch && matchStatus && matchCategory && matchBranch) ? '' : 'none';
            });
        }

        function viewInventoryItem(btn) {
            const row = btn.closest('tr');
            if (!row) return;
            document.getElementById('detailItemName').textContent = row.cells[1].textContent.trim();
            document.getElementById('detailCategory').textContent = row.cells[2].textContent.trim();
            document.getElementById('detailSupplier').textContent = row.cells[3].textContent.trim();
            document.getElementById('detailBranch').textContent = row.cells[4].textContent.trim();
            document.getElementById('detailQuantity').textContent = row.cells[5].textContent.trim();
            document.getElementById('detailUnitPrice').textContent = row.cells[6].textContent.trim();
            document.getElementById('detailTotalCost').textContent = row.cells[7].textContent.trim();

            const statusText = row.cells[8].textContent.trim();
            const statusEl = document.getElementById('detailStatus');
            statusEl.textContent = statusText;
            const sl = statusText.toLowerCase();
            statusEl.style.color = sl.includes('approv') || sl.includes('receiv') || sl.includes('closed') ? '#059669'
                : sl.includes('reject') || sl.includes('late') ? '#dc2626'
                : sl.includes('submit') || sl.includes('draft') ? '#ca8a04' : '#6b7280';

            document.getElementById('detailDate').textContent = row.cells[9].textContent.trim();
            document.getElementById('detailPolicy').textContent = row.cells[10].textContent.trim();
            document.getElementById('inventoryDetailModal').classList.add('active');
        }

        function closeDetailModal() {
            document.getElementById('inventoryDetailModal').classList.remove('active');
        }

        document.getElementById('inventoryDetailModal').addEventListener('click', function(e) {
            if (e.target === this) closeDetailModal();
        });
    </script>
}
