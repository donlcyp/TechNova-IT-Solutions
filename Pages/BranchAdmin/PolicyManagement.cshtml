@page
@model TechNova_IT_Solutions.Pages.BranchAdmin.PolicyManagementModel
@{
    ViewData["Title"] = "Policy Management";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            display: flex;
            min-height: 100vh;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
            max-width: 1400px;
            margin: 0 auto;
        }

        .btn-primary {
            padding: 12px 24px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: opacity 0.2s;
        }

        .btn-primary:hover {
            opacity: 0.9;
        }

        .btn-primary svg {
            width: 18px;
            height: 18px;
        }

        /* Filter Section */
        .filter-section {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .search-box {
            flex: 1;
            min-width: 200px;
            max-width: 400px;
            position: relative;
        }

        .search-box input {
            width: 100%;
            padding: 10px 14px 10px 40px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
        }

        .search-box input:focus {
            outline: none;
            border-color: #1e40af;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #6b7280;
            width: 18px;
            height: 18px;
        }

        .filter-group {
            display: flex;
            gap: 12px;
        }

        .filter-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .filter-controls {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            flex: 1;
            min-width: 0;
        }

        .add-policy-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 20px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .add-policy-btn svg {
            width: 18px;
            height: 18px;
        }

        select {
            padding: 10px 14px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
            cursor: pointer;
        }

        select:focus {
            outline: none;
            border-color: #1e40af;
        }

        /* Table Section */
        .table-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 32px;
        }

        .table-scroll {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .table-scroll table {
            min-width: 1000px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #f3f4f6;
        }

        th {
            text-align: left;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            border-bottom: 2px solid #e5e7eb;
        }

        td {
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
            color: #1f2937;
        }

        tbody tr {
            transition: background 0.2s;
        }

        tbody tr:hover {
            background: #f3f4f6;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.archived {
            color: #e53e3e;
            background: #fff5f5;
        }

        .status-badge.draft {
            color: #9ca3af;
        }

        .status-badge.approved {
            color: #f6ad55;
        }

        .status-badge.active {
            color: #48bb78;
        }

        .actions {
            display: flex;
            gap: 8px;
        }

        .btn-action {
            padding: 6px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            background: #f8f9fa;
            color: #6b7280;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-action:hover {
            border-color: #1e40af;
            color: #1e40af;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 16px;
        }

        .card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px 20px;
            transition: transform 0.2s;
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: auto auto;
            gap: 0 12px;
            align-items: center;
        }

        .card-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            grid-row: 1 / 3;
        }

        .card-icon svg {
            width: 22px;
            height: 22px;
        }

        .card-icon.blue {
            color: #1e40af;
        }

        .card-icon.green {
            color: #48bb78;
        }

        .card-icon.purple {
            color: #9f7aea;
        }

        .card-value {
            font-size: 26px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .card-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            width: 90%;
            max-width: 600px;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            padding: 24px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: #1f2937;
        }

        .btn-close {
            background: none;
            border: none;
            font-size: 24px;
            color: #6b7280;
            cursor: pointer;
        }

        .btn-close:hover {
            color: #1f2937;
        }

        .modal-body {
            padding: 24px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
            font-family: inherit;
        }

        .form-group textarea {
            min-height: 100px;
            resize: vertical;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #1e40af;
        }

        .form-group input[type="file"] {
            padding: 8px;
        }

        .multi-select {
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 12px;
            max-height: 200px;
            overflow-y: auto;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            padding: 8px;
            margin-bottom: 4px;
            border-radius: 6px;
            transition: background 0.2s;
        }

        .checkbox-item:hover {
            background: #f3f4f6;
        }

        .checkbox-item input[type="checkbox"] {
            width: auto;
            margin-right: 10px;
        }

        .checkbox-item label {
            margin: 0;
            font-weight: normal;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .checkbox-item.already-assigned {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .checkbox-item.already-assigned label {
            color: #64748b;
            cursor: not-allowed;
        }

        .already-badge {
            display: inline-flex;
            align-items: center;
            padding: 2px 8px;
            border-radius: 999px;
            background: #dbeafe;
            color: #1e40af;
            font-size: 11px;
            font-weight: 600;
        }

        .assign-status-note {
            margin-bottom: 14px;
            padding: 10px 12px;
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            background: #eff6ff;
            color: #1e3a8a;
            font-size: 13px;
        }

        .modal-footer {
            padding: 24px;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .btn-secondary {
            padding: 10px 20px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #6b7280;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-secondary:hover {
            border-color: #1e40af;
            color: #1e40af;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .filter-section {
                flex-direction: column;
            }

            .search-box {
                min-width: 100%;
            }
        }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }

            .content-wrapper {
                padding: 20px;
            }

            .filter-section {
                flex-direction: column;
            }

            .search-box {
                min-width: 100%;
            }

            .filter-controls {
                width: 100%;
            }
        }

        @@media (max-width: 768px) {
            th, td {
                padding: 12px;
            }

            .actions {
                flex-direction: column;
                gap: 8px;
            }

            .btn-action {
                width: 100%;
                text-align: center;
            }
        }

        @@media (max-width: 576px) {
            .section-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            th, td {
                padding: 8px 10px;
                font-size: 13px;
            }

            .actions {
                flex-direction: column;
            }

            .modal-header,
            .modal-body,
            .modal-footer {
                padding: 16px;
            }

            .modal-content {
                width: 95%;
                margin: 10px;
            }

            .summary-cards {
                grid-template-columns: 1fr;
            }

            .filter-toolbar {
                align-items: stretch;
            }

            .filter-controls {
                width: 100%;
            }

            .filter-group {
                width: 100%;
                display: grid;
                grid-template-columns: 1fr 1fr;
            }

            .filter-group select {
                width: 100%;
                min-width: 0;
            }

            .add-policy-btn {
                width: 100%;
            }
        }

        /* ── Loading overlay ────────────────── */
        .loading-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,42,.6); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:16px; }
        .loading-overlay.active { display:flex; }
        .loading-spinner { width:48px; height:48px; border:4px solid rgba(255,255,255,.3); border-top:4px solid #fff; border-radius:50%; animation:spin .8s linear infinite; }
        .loading-text { color:#fff; font-size:15px; font-weight:600; text-align:center; max-width:280px; line-height:1.4; }
        @@keyframes spin { to { transform:rotate(360deg); } }
    </style>
}

@await Html.PartialAsync("_BranchAdminSidebar", "PolicyManagement")

    <!-- Main Content -->
    <div class="main-content">
        @await Html.PartialAsync("_BranchAdminTopBar", (Title: "Policy Management", Description: "Manage compliance policies and procedures"))

        <div class="content-wrapper">
            <!-- Summary Cards -->
            <div class="summary-cards">
                <div class="card">
                        <div class="card-icon blue">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                            </svg>
                        </div>
                    <div class="card-value">@Model.TotalPolicies</div>
                    <div class="card-label">Total Policies</div>
                </div>

                <div class="card">
                        <div class="card-icon green">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                        </div>
                    <div class="card-value">@Model.ActivePolicies</div>
                    <div class="card-label">Active Policies</div>
                </div>

                <div class="card">
                        <div class="card-icon" style="color: #e53e3e;">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 8v13H3V8"></path>
                                <path d="M1 3h22v5H1z"></path>
                                <path d="M10 12h4"></path>
                            </svg>
                        </div>
                    <div class="card-value">@Model.ArchivedPolicies</div>
                    <div class="card-label">Archived Policies</div>
                </div>

                <div class="card">
                        <div class="card-icon purple">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </div>
                    <div class="card-value">@Model.RecentlyUploaded</div>
                    <div class="card-label">Recently Uploaded</div>
                </div>
            </div>

            <!-- Filter Section -->
            <div class="filter-section filter-toolbar">
            <div class="filter-controls">
            <div class="search-box">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.35-4.35"></path>
                </svg>
                <input type="text" id="searchInput" placeholder="Search by policy title..." oninput="filterPolicies()" />
            </div>
            <div class="filter-group">
                <select id="categoryFilter" onchange="filterPolicies()">
                    <option value="">All Categories</option>
                    <option>Supplier Management</option>
                    <option>Procurement Policy</option>
                    <option>IT Governance</option>
                    <option>Contract Management</option>
                    <option>Quality Assurance</option>
                    <option>Compliance &amp; Regulatory</option>
                    <option>Code of Conduct</option>
                    <option>Risk Management</option>
                </select>
                <select id="statusFilter" onchange="filterPolicies()">
                    <option value="">All Status</option>
                    <option>Draft</option>
                    <option>Approved</option>
                    <option>Active</option>
                    <option>Archived</option>
                </select>
            </div>
            </div>

        </div>

        <!-- Policies Table -->
        <div class="table-card">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>Policy ID</th>
                            <th>Policy Title</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Date Uploaded</th>
                            <th>Uploaded By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var policy in Model.Policies)
                        {
                            <tr>
                                <td>@policy.PolicyId</td>
                                <td>@policy.Title</td>
                                <td>@policy.Category</td>
                                <td>
                                    <span class="status-badge @policy.Status.ToLower()">
                                        @policy.Status
                                    </span>
                                </td>
                                <td>@policy.DateUploaded.ToString("MMM dd, yyyy")</td>
                                <td>@policy.UploadedBy</td>
                                <td>
                                    <div class="actions">
                                        <button class="btn-action" onclick="viewPolicy(@policy.RawId)">View</button>
                                        @if (!policy.IsArchived)
                                        {
                                            <button class="btn-action" onclick="openAssignModal('@policy.PolicyId', '@policy.Title')">Assign</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        </div>
    </div>

    <!-- Assign Policy Modal -->
    <div class="modal" id="assignModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="assignModalTitle">Assign Policy</h2>
                <button class="btn-close" onclick="closeAssignModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div id="assignStatusNote" class="assign-status-note">Select users to assign. Recipients with an existing assignment are marked and disabled.</div>
                <div class="form-group">
                    <label>Assign to Employees</label>
                    <div class="multi-select" id="employeeList">
                        @foreach (var emp in Model.Employees)
                        {
                            <div class="checkbox-item">
                                <input type="checkbox" id="emp_@emp.Id" value="@emp.Id" />
                                <label for="emp_@emp.Id">
                                    <span class="recipient-name">@emp.Name</span>
                                    <span class="already-badge" style="display:none;">Already assigned</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div class="form-group">
                    <label>Assign to Suppliers</label>
                    <div class="multi-select" id="supplierList">
                        @foreach (var supplier in Model.Suppliers)
                        {
                            <div class="checkbox-item">
                                <input type="checkbox" id="sup_@supplier.Id" value="@supplier.Id" />
                                <label for="sup_@supplier.Id">
                                    <span class="recipient-name">@supplier.Name</span>
                                    <span class="already-badge" style="display:none;">Already assigned</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div class="form-group">
                    <label for="assignDate">Assign Date</label>
                    <input type="date" id="assignDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeAssignModal()">Cancel</button>
                <button class="btn-primary" onclick="assignPolicy()">Assign Policy</button>
            </div>
        </div>
    </div>

    <!-- View Policy Modal -->
    <div class="modal" id="viewModal">
        <div class="modal-content" style="max-width: 700px;">
            <div class="modal-header">
                <h2 id="viewModalTitle">Policy Details</h2>
                <button class="btn-close" onclick="closeViewModal()">&times;</button>
            </div>
            <div class="modal-body" id="viewModalBody">
                <div style="text-align: center; padding: 40px;">Loading...</div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeViewModal()">Close</button>
                <a id="viewDownloadBtn" href="#" target="_blank" class="btn-primary" style="display: none; text-decoration: none; padding: 10px 20px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    View / Download File
                </a>
            </div>
        </div>
    </div>

<!-- ── Loading Overlay ── -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <div class="loading-text" id="loadingText">Processing...</div>
</div>

@section Scripts {
    <script>
        let currentPolicyId = null;
        let currentPolicyDbId = null;

        function showLoading(msg = 'Processing...') { document.getElementById('loadingText').textContent = msg; document.getElementById('loadingOverlay').classList.add('active'); }
        function hideLoading() { document.getElementById('loadingOverlay').classList.remove('active'); }

        function viewPolicy(dbId) {
            document.getElementById('viewModalBody').innerHTML = '<div style="text-align:center;padding:40px;">Loading...</div>';
            document.getElementById('viewDownloadBtn').style.display = 'none';
            document.getElementById('viewModal').classList.add('active');

            fetch('/AdminPolicy/GetPolicyDetail?policyId=' + dbId)
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    const p = result.policy;
                    document.getElementById('viewModalTitle').textContent = p.policyTitle;

                    let statusColor = p.isArchived ? '#e53e3e' : '#48bb78';
                    let statusText = p.isArchived ? 'Archived' : 'Active';

                    let html = `
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
                            <div>
                                <div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Policy ID</div>
                                <div style="font-size:14px;color:#1f2937;">POL-${String(p.policyId).padStart(3, '0')}</div>
                            </div>
                            <div>
                                <div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Category</div>
                                <div style="font-size:14px;color:#1f2937;">${p.category || 'N/A'}</div>
                            </div>
                            <div>
                                <div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Status</div>
                                <div><span style="color:${statusColor};font-weight:600;font-size:14px;">${statusText}</span></div>
                            </div>
                            <div>
                                <div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Date Uploaded</div>
                                <div style="font-size:14px;color:#1f2937;">${p.dateUploaded || 'N/A'}</div>
                            </div>
                            <div>
                                <div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Uploaded By</div>
                                <div style="font-size:14px;color:#1f2937;">${p.uploadedBy}</div>
                            </div>
                            <div>
                                <div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Assigned To</div>
                                <div style="font-size:14px;color:#1f2937;">${p.assignedEmployees} employee(s), ${p.assignedSuppliers} supplier(s)</div>
                            </div>
                        </div>`;

                    if (p.isArchived && p.archivedDate) {
                        html += `<div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:8px;padding:12px;margin-bottom:16px;">
                            <span style="color:#e53e3e;font-weight:600;">Archived on:</span> ${p.archivedDate}
                        </div>`;
                    }

                    html += `<div style="margin-bottom:16px;">
                        <div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Description</div>
                        <div style="font-size:14px;color:#1f2937;background:#f8f9fa;border-radius:8px;padding:12px;border:1px solid #e5e7eb;">${p.description || 'No description provided.'}</div>
                    </div>`;

                    if (p.filePath) {
                        html += `<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px;">
                            <span style="font-weight:600;color:#1e40af;">&#128206; File attached:</span> ${p.filePath.split('/').pop()}
                        </div>`;
                        const downloadBtn = document.getElementById('viewDownloadBtn');
                        downloadBtn.href = '/AdminPolicy/DownloadPolicyFile?policyId=' + dbId;
                        downloadBtn.style.display = 'inline-flex';
                    }

                    document.getElementById('viewModalBody').innerHTML = html;
                } else {
                    document.getElementById('viewModalBody').innerHTML = '<div style="text-align:center;padding:40px;color:#e53e3e;">Policy not found.</div>';
                }
            })
            .catch(() => {
                document.getElementById('viewModalBody').innerHTML = '<div style="text-align:center;padding:40px;color:#e53e3e;">Error loading policy details.</div>';
            });
        }

        function closeViewModal() {
            document.getElementById('viewModal').classList.remove('active');
        }

        function openAssignModal(id, title) {
            currentPolicyId = id;
            currentPolicyDbId = parseInt(id.replace('POL-', ''));
            openAssignModalByDbId(currentPolicyDbId, title);
        }

        function openAssignModalByDbId(dbId, title) {
            currentPolicyDbId = dbId;
            currentPolicyId = dbId ? ('POL-' + String(dbId).padStart(3, '0')) : null;
            document.getElementById('assignModalTitle').textContent = 'Assign Policy: ' + title;
            document.querySelectorAll('#employeeList input, #supplierList input').forEach(cb => cb.checked = false);
            resetAssignmentIndicators();
            loadAssignmentStatus();
            document.getElementById('assignModal').classList.add('active');
        }

        function closeAssignModal() {
            document.getElementById('assignModal').classList.remove('active');
            currentPolicyId = null;
            currentPolicyDbId = null;
        }

        async function assignPolicy() {
            const selectedEmployees = Array.from(document.querySelectorAll('#employeeList input:checked')).map(cb => parseInt(cb.value));
            const selectedSuppliers = Array.from(document.querySelectorAll('#supplierList input:checked')).map(cb => parseInt(cb.value));

            if (selectedEmployees.length === 0 && selectedSuppliers.length === 0) {
                await window.showAppMessage('Please select at least one employee or supplier who is not already assigned.', 'Validation');
                return;
            }

            showLoading('Assigning policy & sending notification emails...');
            fetch('/AdminPolicy/AssignPolicy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    policyId: currentPolicyDbId,
                    employeeIds: selectedEmployees,
                    supplierIds: selectedSuppliers
                })
            })
            .then(res => res.json())
            .then(async result => {
                hideLoading();
                if (result.success) {
                    await window.showAppMessage(result.message || 'Policy assigned successfully!', 'Success');
                    closeAssignModal();
                    location.reload();
                } else {
                    await window.showAppMessage(result.message || 'Failed to assign policy', 'Error');
                }
            })
            .catch(async () => { hideLoading(); await window.showAppMessage('Error assigning policy', 'Error'); });
        }

        function resetAssignmentIndicators() {
            document.querySelectorAll('#employeeList .checkbox-item, #supplierList .checkbox-item').forEach(item => {
                const checkbox = item.querySelector('input[type="checkbox"]');
                const badge = item.querySelector('.already-badge');
                if (checkbox) {
                    checkbox.checked = false;
                    checkbox.disabled = false;
                }
                item.classList.remove('already-assigned');
                if (badge) badge.style.display = 'none';
            });
            document.getElementById('assignStatusNote').textContent = 'Select users to assign. Recipients with an existing assignment are marked and disabled.';
        }

        function markAlreadyAssigned(listSelector, assignedIds) {
            const assignedSet = new Set((assignedIds || []).map(id => parseInt(id)));
            let markedCount = 0;
            document.querySelectorAll(`${listSelector} .checkbox-item`).forEach(item => {
                const checkbox = item.querySelector('input[type="checkbox"]');
                const badge = item.querySelector('.already-badge');
                const recipientId = parseInt(checkbox.value);
                const isAssigned = assignedSet.has(recipientId);

                checkbox.disabled = isAssigned;
                checkbox.checked = false;
                item.classList.toggle('already-assigned', isAssigned);
                if (badge) badge.style.display = isAssigned ? 'inline-flex' : 'none';
                if (isAssigned) markedCount++;
            });
            return markedCount;
        }

        function loadAssignmentStatus() {
            if (!currentPolicyDbId) return;

            fetch('/AdminPolicy/GetPolicyAssignmentStatus?policyId=' + currentPolicyDbId)
                .then(res => res.json())
                .then(result => {
                    if (!result.success) return;

                    const employeeMarked = markAlreadyAssigned('#employeeList', result.assignedEmployeeIds);
                    const supplierMarked = markAlreadyAssigned('#supplierList', result.assignedSupplierIds);
                    document.getElementById('assignStatusNote').textContent =
                        `${employeeMarked} employee(s) and ${supplierMarked} supplier(s) already received this policy and cannot be selected again.`;
                })
                .catch(() => {
                    document.getElementById('assignStatusNote').textContent = 'Unable to load existing assignment markers.';
                });
        }

        function filterPolicies() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const category = document.getElementById('categoryFilter').value;
            const status = document.getElementById('statusFilter').value;

            document.querySelectorAll('tbody tr').forEach(row => {
                const tds = row.querySelectorAll('td');
                if (tds.length < 4) return;

                const title = tds[1].textContent.toLowerCase();
                const rowCategory = tds[2].textContent.trim();
                const statusBadge = tds[3].querySelector('.status-badge');
                const rowStatus = statusBadge ? statusBadge.textContent.trim() : tds[3].textContent.trim();

                const matchesSearch = !search || title.includes(search);
                const matchesCategory = !category || rowCategory === category;
                const matchesStatus = !status || rowStatus === status;

                row.style.display = (matchesSearch && matchesCategory && matchesStatus) ? '' : 'none';
            });
        }

        // Close modals when clicking outside
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.remove('active');
                }
            });
        });
    </script>
}
