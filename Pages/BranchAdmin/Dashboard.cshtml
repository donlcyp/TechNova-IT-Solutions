@page
@model TechNova_IT_Solutions.Pages.BranchAdmin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            min-height: 100vh;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px 20px;
            transition: transform 0.2s, box-shadow 0.2s;
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: auto 1fr;
            gap: 0 12px;
            align-items: start;
        }

        a.card {
            text-decoration: none;
            color: inherit;
            cursor: pointer;
        }

        a.card:hover {
            border-color: #c7d2fe;
            box-shadow: 0 4px 16px rgba(99, 102, 241, 0.08);
        }

        .card-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            grid-row: 1 / 3;
        }

        .card-icon svg {
            width: 22px;
            height: 22px;
        }

        .card-icon.blue {
            color: #1e40af;
        }

        .card-icon.green {
            color: #48bb78;
        }

        .card-icon.purple {
            color: #9f7aea;
        }

        .card-icon.orange {
            color: #f6ad55;
        }

        .card-icon.red {
            color: #fc8181;
        }

        .card-icon.teal {
            color: #38b2ac;
        }

        .card-value {
            font-size: 26px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 2px;
            line-height: 1;
            min-height: 30px;
            display: flex;
            align-items: center;
        }

        .card-label {
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
            line-height: 1.35;
            min-height: 38px;
        }

        /* Two Column Layout */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }

        .section-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 26px;
            box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
            overflow: hidden;
            min-width: 0;
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            row-gap: 10px;
        }

        .section-title-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
        }

        .section-title-icon svg {
            width: 18px;
            height: 18px;
        }

        /* Compliance Overview */
        .compliance-percentage {
            text-align: center;
            margin-bottom: 24px;
            padding: 20px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            border-radius: 10px;
            color: white;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .compliance-percentage h2 {
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 4px;
            line-height: 1.05;
        }

        .compliance-percentage p {
            font-size: 14px;
            opacity: 0.9;
            line-height: 1.3;
            max-width: 22ch;
        }

        .policy-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-height: 400px;
            overflow-y: auto;
            padding-right: 4px;
        }

        .policy-list::-webkit-scrollbar {
            width: 6px;
        }

        .policy-list::-webkit-scrollbar-track {
            background: #f3f4f6;
            border-radius: 10px;
        }

        .policy-list::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }

        .policy-list::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .policy-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: #f3f4f6;
            border-radius: 8px;
            transition: background 0.2s;
            gap: 12px;
        }

        .policy-item > div {
            min-width: 0;
            flex: 1;
            overflow: hidden;
        }

        .policy-item:hover {
            background: #e5e7eb;
        }

        .policy-name {
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .policy-date {
            font-size: 12px;
            color: #6b7280;
            white-space: nowrap;
        }

        .policy-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            background: rgba(72, 187, 120, 0.1);
            color: #48bb78;
            white-space: nowrap;
            flex-shrink: 0;
        }

        /* Procurement Overview Table */
        .procurement-table {
            width: 100%;
            border-collapse: collapse;
        }

        .procurement-table thead {
            background: #f3f4f6;
        }

        .procurement-table th {
            text-align: left;
            padding: 12px 16px;
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            border-bottom: 2px solid #e5e7eb;
        }

        .procurement-table td {
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
            color: #1f2937;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }

        .procurement-table tbody tr:hover {
            background: #f3f4f6;
        }

        .table-scroll {
            width: 100%;
            max-height: 400px;
            overflow-x: auto;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            margin-top: 4px;
        }

        .table-scroll::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        .table-scroll::-webkit-scrollbar-track {
            background: #f3f4f6;
            border-radius: 10px;
        }

        .table-scroll::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }

        .table-scroll::-webkit-scrollbar-thumb:hover {
            background: #a0aec0;
        }

        .table-scroll .procurement-table {
            min-width: 500px;
        }

        .supplier-name {
            font-weight: 600;
            color: #1e40af;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Mobile scroll hint */
        @@media (max-width: 768px) {
            .table-scroll {
                position: relative;
            }

            .table-scroll::after {
                content: '← Scroll →';
                position: absolute;
                bottom: 8px;
                right: 8px;
                background: rgba(30, 64, 175, 0.9);
                color: white;
                padding: 4px 10px;
                border-radius: 6px;
                font-size: 10px;
                font-weight: 600;
                pointer-events: none;
                opacity: 0;
                animation: fadeInOut 3s ease-in-out;
                animation-delay: 0.5s;
            }

            @@keyframes fadeInOut {
                0% { opacity: 0; }
                20% { opacity: 1; }
                80% { opacity: 1; }
                100% { opacity: 0; }
            }

            .procurement-table td {
                max-width: 150px;
            }
        }

        /* Recent Activities */
        .activity-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .activity-item {
            display: flex;
            gap: 16px;
            padding: 16px;
            background: #f3f4f6;
            border-radius: 10px;
            transition: background 0.2s;
        }

        .activity-content {
            min-width: 0;
        }

        .activity-item:hover {
            background: #e5e7eb;
        }

        .activity-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .activity-icon svg {
            width: 20px;
            height: 20px;
        }

        .activity-icon.user {
            background: rgba(30, 64, 175, 0.1);
            color: #1e40af;
        }

        .activity-icon.policy {
            background: rgba(159, 122, 234, 0.1);
            color: #9f7aea;
        }

        .activity-icon.procurement {
            background: rgba(246, 173, 85, 0.1);
            color: #f6ad55;
        }

        .activity-content {
            flex: 1;
        }

        .activity-title {
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .activity-description {
            font-size: 13px;
            color: #6b7280;
        }

        .activity-time {
            font-size: 12px;
            color: #6b7280;
            white-space: nowrap;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 20px;
                margin-bottom: 24px;
            }

            .summary-cards {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }

            .content-wrapper {
                padding: 20px;
            }

            .summary-cards {
                grid-template-columns: repeat(2, 1fr);
                gap: 16px;
            }

            .card {
                padding: 14px 16px;
            }

            .card-value {
                font-size: 22px;
            }

            .card-label {
                font-size: 13px;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 18px;
                margin-bottom: 20px;
            }

            .section-card {
                padding: 20px;
            }

            .section-title {
                font-size: 18px;
            }

            .table-scroll {
                max-height: 350px;
            }

            .policy-list {
                max-height: 350px;
            }
        }

        @@media (max-width: 768px) {
            .dashboard-grid {
                gap: 16px;
                margin-bottom: 18px;
            }

            .section-card {
                padding: 18px;
            }

            .section-title {
                font-size: 17px;
            }
        }

        @@media (max-width: 576px) {
            .summary-cards {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .card {
                padding: 12px 16px;
                grid-template-columns: auto 1fr;
            }

            .card-icon {
                width: 32px;
                height: 32px;
            }

            .card-icon svg {
                width: 18px;
                height: 18px;
            }

            .card-value {
                font-size: 20px;
            }

            .card-label {
                font-size: 12px;
            }

            .content-wrapper {
                padding: 16px;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 14px;
                margin-bottom: 16px;
            }

            .section-card {
                padding: 16px;
            }

            .section-title {
                font-size: 16px;
                margin-bottom: 14px;
            }

            .section-title-icon {
                width: 28px;
                height: 28px;
            }

            .section-title-icon svg {
                width: 16px;
                height: 16px;
            }

            .compliance-percentage h2 {
                font-size: 32px;
            }

            .compliance-percentage {
                padding: 14px;
                margin-bottom: 16px;
            }

            .compliance-percentage p {
                max-width: none;
                font-size: 13px;
            }

            .policy-item {
                flex-direction: column;
                align-items: flex-start;
                padding: 12px;
                gap: 8px;
            }

            .policy-name {
                font-size: 13px;
                white-space: normal;
            }

            .policy-date {
                font-size: 11px;
            }

            .policy-badge {
                font-size: 10px;
                padding: 3px 8px;
            }

            .procurement-table th,
            .procurement-table td {
                padding: 10px 12px;
                font-size: 12px;
            }

            .procurement-table th {
                font-size: 10px;
            }

            .table-scroll {
                max-height: 300px;
            }

            .policy-list {
                max-height: 300px;
            }

            .activity-item {
                flex-direction: row;
                align-items: flex-start;
                padding: 12px;
                gap: 12px;
            }

            .activity-icon {
                width: 36px;
                height: 36px;
            }

            .activity-icon svg {
                width: 18px;
                height: 18px;
            }

            .activity-title {
                font-size: 13px;
            }

            .activity-description {
                font-size: 12px;
            }

            .activity-time {
                font-size: 11px;
                white-space: nowrap;
                margin-top: 4px;
                display: block;
            }
        }

        @@media (max-width: 480px) {
            .dashboard-grid {
                gap: 14px;
                margin-bottom: 16px;
            }

            .section-card {
                padding: 14px;
            }

            .section-title {
                font-size: 15px;
                gap: 8px;
            }

            .section-title-icon {
                width: 26px;
                height: 26px;
            }

            .section-title-icon svg {
                width: 14px;
                height: 14px;
            }

            .compliance-percentage {
                padding: 12px;
                margin-bottom: 14px;
                border-radius: 8px;
            }

            .compliance-percentage h2 {
                font-size: 28px;
            }

            .compliance-percentage p {
                font-size: 12px;
            }

            .policy-list {
                gap: 10px;
                max-height: 280px;
            }

            .policy-item {
                padding: 10px 12px;
                gap: 6px;
            }

            .policy-name {
                font-size: 12px;
            }

            .policy-date {
                font-size: 10px;
            }

            .policy-badge {
                font-size: 9px;
                padding: 3px 7px;
            }

            .table-scroll {
                border-radius: 8px;
                max-height: 280px;
            }

            .table-scroll .procurement-table {
                min-width: 420px;
            }

            .procurement-table th {
                padding: 8px 10px;
                font-size: 9px;
            }

            .procurement-table td {
                padding: 8px 10px;
                font-size: 11px;
                max-width: 120px;
            }
        }

        @@media (max-width: 400px) {
            .content-wrapper {
                padding: 10px;
            }

            .dashboard-grid {
                grid-template-columns: 1fr;
                gap: 12px;
                margin-bottom: 14px;
            }

            .section-card {
                padding: 12px;
                border-radius: 10px;
            }

            .compliance-percentage h2 {
                font-size: 26px;
            }

            .compliance-percentage {
                padding: 10px;
                margin-bottom: 12px;
            }

            .card-value {
                font-size: 18px;
            }

            .summary-cards {
                gap: 10px;
            }

            .section-title {
                font-size: 14px;
                margin-bottom: 12px;
            }

            .table-scroll .procurement-table {
                min-width: 380px;
            }

            .procurement-table th {
                padding: 7px 8px;
                font-size: 9px;
            }

            .procurement-table td {
                padding: 7px 8px;
                font-size: 11px;
                max-width: 100px;
            }

            .policy-item {
                padding: 8px 10px;
            }

            .policy-name {
                font-size: 12px;
            }

            .policy-date {
                font-size: 10px;
            }
        }

        @@media (max-width: 360px) {
            .content-wrapper {
                padding: 8px;
            }

            .dashboard-grid {
                gap: 10px;
                margin-bottom: 12px;
            }

            .section-card {
                padding: 10px;
                border-radius: 8px;
            }

            .section-title {
                font-size: 13px;
                margin-bottom: 10px;
            }

            .compliance-percentage h2 {
                font-size: 24px;
            }

            .table-scroll .procurement-table {
                min-width: 340px;
            }
        }

        @@media (max-width: 320px) {
            .dashboard-grid {
                gap: 8px;
                margin-bottom: 10px;
            }

            .section-card {
                padding: 8px;
                border-radius: 6px;
            }

            .section-title {
                font-size: 12px;
                margin-bottom: 8px;
            }

            .compliance-percentage h2 {
                font-size: 22px;
            }

            .card-value {
                font-size: 16px;
            }
        }
    </style>
}

    @await Html.PartialAsync("_BranchAdminSidebar", "Dashboard")

    <!-- Main Content -->
    <div class="main-content flex-grow-1">
        @await Html.PartialAsync("_BranchAdminTopBar", (Title: "Dashboard", Description: "System Overview"))

        <!-- Content Wrapper -->
        <div class="content-wrapper">
        <!-- Top Summary Cards -->
        <div class="summary-cards">
            <a href="/Admin/UserManagement" class="card">
                    <div class="card-icon blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                <div class="card-value">@Model.TotalUsers</div>
                <div class="card-label">Total Users</div>
            </a>

            <a href="/Admin/Reports" class="card">
                    <div class="card-icon green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                    </div>
                <div class="card-value">@Model.ActivePolicies</div>
                <div class="card-label">Active Policies</div>
            </a>

            <a href="/Admin/Reports" class="card">
                    <div class="card-icon red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                    </div>
                <div class="card-value">@Model.PendingCompliance</div>
                <div class="card-label">Pending Compliance</div>
            </a>

            <a href="/Admin/SupplierManagement" class="card">
                    <div class="card-icon purple">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                <div class="card-value">@Model.TotalSuppliers</div>
                <div class="card-label">Total Suppliers</div>
            </a>

            <a href="/Admin/Procurement" class="card">
                    <div class="card-icon orange">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                            <line x1="1" y1="10" x2="23" y2="10"></line>
                        </svg>
                    </div>
                <div class="card-value">@Model.RecentProcurements</div>
                <div class="card-label">Recent Procurements</div>
            </a>

            <a href="/Admin/AuditLogs" class="card">
                    <div class="card-icon teal">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                    </div>
                <div class="card-value">@Model.AuditLogsToday</div>
                <div class="card-label">Audit Logs Today</div>
            </a>
        </div>

        <!-- Two Column Section -->
        <div class="dashboard-grid">
            <!-- Compliance Overview -->
            <div class="section-card">
                <div class="section-title">
                    <div class="section-title-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                        </svg>
                    </div>
                    Compliance Overview
                </div>

                <div class="compliance-percentage">
                    <h2>@Model.CompliancePercentage%</h2>
                    <p>Overall Compliance Rate</p>
                </div>

                <div class="policy-list">
                    @foreach (var policy in Model.RecentPolicies)
                    {
                        <div class="policy-item">
                            <div>
                                <div class="policy-name">@policy.Name</div>
                                <div class="policy-date">Assigned on @policy.AssignedDate.ToString("MMM dd, yyyy")</div>
                            </div>
                            <span class="policy-badge">Active</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Procurement Overview -->
            <div class="section-card">
                <div class="section-title">
                    <div class="section-title-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                            <line x1="1" y1="10" x2="23" y2="10"></line>
                        </svg>
                    </div>
                    Procurement Overview
                </div>

                <div class="table-scroll">
                    <table class="procurement-table">
                        <thead>
                            <tr>
                                <th>Supplier</th>
                                <th>Item</th>
                                <th>Date</th>
                                <th>Linked Policy</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var procurement in Model.RecentProcurementsData)
                            {
                                <tr>
                                    <td class="supplier-name">@procurement.Supplier</td>
                                    <td>@procurement.Item</td>
                                    <td>@procurement.Date.ToString("MMM dd")</td>
                                    <td>@procurement.LinkedPolicy</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Recent Activities -->
        <div class="section-card">
            <div class="section-title">
                <div class="section-title-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                </div>
                Recent Activities
            </div>

            <div class="activity-list">
                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="activity-item">
                        <div class="activity-icon @activity.IconClass">
                            @Html.Raw(activity.IconSvg)
                        </div>
                        <div class="activity-content">
                            <div class="activity-title">@activity.Title</div>
                            <div class="activity-description">@activity.Description</div>
                        </div>
                        <div class="activity-time">@activity.Time</div>
                    </div>
                }
            </div>
        </div>
        </div>
    </div>

@section Scripts {
    <script>
        // Mobile detection for dynamic adjustments
        if (window.innerWidth <= 768) {
            console.log('Mobile view initialized');
        }
    </script>
}
