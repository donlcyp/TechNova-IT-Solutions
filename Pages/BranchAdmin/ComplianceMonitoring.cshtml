@page
@model TechNova_IT_Solutions.Pages.BranchAdmin.ComplianceMonitoringModel
@{
    ViewData["Title"] = "Compliance Monitoring";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            min-height: 100vh;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 18px 20px;
            transition: transform 0.2s;
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: auto auto;
            gap: 0 12px;
            align-items: center;
        }

        .card-icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            grid-row: 1 / 3;
            overflow: hidden;
        }

        .card-icon svg {
            width: 28px;
            height: 28px;
        }

        .card-icon.blue {
            color: #1e40af;
        }

        .card-icon.green {
            color: #16a34a;
        }

        .card-icon.red {
            color: #dc2626;
        }

        .card-icon.purple {
            color: #7c3aed;
        }

        .card-value {
            font-size: 28px;
            font-weight: 700;
            color: #1f2937;
        }

        .card-label {
            font-size: 13px;
            color: #6b7280;
            font-weight: 500;
        }

        .card-trend {
            font-size: 12px;
            color: #48bb78;
        }

        /* Filter Section */
        .filter-section {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 24px;
        }

        .filter-row {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .filter-group label {
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
        }

        .filter-group select,
        .filter-group input {
            padding: 8px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            font-size: 14px;
            min-width: 150px;
        }

        /* Table Section */
        .table-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 24px;
        }

        .section-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
            font-weight: 700;
            color: #1f2937;
        }

        .section-title-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
            flex-shrink: 0;
        }

        .section-title-icon svg {
            width: 18px;
            height: 18px;
        }

        .filter-section {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .search-box {
            flex: 1;
            min-width: 260px;
            position: relative;
        }

        .search-box input {
            width: 100%;
            padding: 10px 14px 10px 40px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
        }

        .search-box input:focus {
            outline: none;
            border-color: #1e40af;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 18px;
            height: 18px;
            color: #6b7280;
        }

        .filter-group {
            display: flex;
            flex-direction: row;
            gap: 12px;
            flex-wrap: wrap;
        }

        .filter-group select {
            padding: 10px 14px;
            background: #f8f9fa;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
            cursor: pointer;
        }

        .filter-group select:focus {
            outline: none;
            border-color: #1e40af;
        }

        .table-header {
            padding: 20px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
        }

        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 800px;
        }

        thead {
            background: #f3f4f6;
        }

        th {
            padding: 12px 16px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            border-bottom: 1px solid #e5e7eb;
        }

        td {
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
            color: #1f2937;
        }

        tbody tr:hover {
            background: #f3f4f6;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-badge.compliant {
            color: #16a34a;
        }

        .status-badge.not-compliant {
            color: #dc2626;
        }

        .status-compliant {
            color: #48bb78;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            width: 90%;
            max-width: 600px;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            padding: 24px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: #1f2937;
        }

        .btn-close {
            background: none;
            border: none;
            font-size: 24px;
            color: #6b7280;
            cursor: pointer;
        }

        .btn-close:hover {
            color: #1f2937;
        }

        .modal-body {
            padding: 24px;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #e5e7eb;
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            font-weight: 600;
            color: #6b7280;
        }

        .detail-value {
            color: #1f2937;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .filter-section {
                flex-direction: column;
                align-items: stretch;
            }

            .search-box {
                min-width: 100%;
            }
        }

        /* Tab Switch */
        .tab-switch { display: flex; gap: 8px; margin-bottom: 16px; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 6px; width: fit-content; }
        .tab-btn { padding: 8px 22px; border-radius: 7px; border: none; background: transparent; color: #6b7280; font-size: 14px; font-weight: 600; cursor: pointer; transition: all .2s; display: flex; align-items: center; gap: 8px; }
        .tab-btn svg { width: 16px; height: 16px; }
        .tab-btn.active { background: #1e40af; color: #fff; }
        .tab-btn:not(.active):hover { background: #f3f4f6; color: #1f2937; }
        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }

            .content-wrapper {
                padding: 20px;
            }

            .summary-cards {
                grid-template-columns: repeat(2, 1fr);
            }

            .filter-group {
                width: 100%;
            }

            .filter-group select {
                width: 100%;
            }
        }

        @@media (max-width: 768px) {
            .filter-group select {
                min-width: auto;
                width: 100%;
            }
        }

        @@media (max-width: 576px) {
            .summary-cards {
                grid-template-columns: 1fr;
            }

            .card-value {
                font-size: 22px;
            }

            .section-card {
                padding: 16px;
            }

            th, td {
                padding: 8px 10px;
            }

            table {
                font-size: 12px;
            }

            .section-title {
                font-size: 16px;
            }

            .modal-content {
                width: 95%;
            }

            .detail-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@await Html.PartialAsync("_BranchAdminSidebar", "ComplianceMonitoring")

    <!-- Main Content -->
    <div class="main-content">
        @await Html.PartialAsync("_BranchAdminTopBar", (Title: "Compliance Monitoring", Description: "Monitor and track compliance status"))

        <div class="content-wrapper">
            <!-- Summary Cards -->
            <div class="summary-cards">
            <div class="card">
                    <div class="card-icon blue">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                        </svg>
                    </div>
                <div class="card-value">@Model.TotalPoliciesAssigned</div>
                <div class="card-label">Total Policies Assigned</div>
            </div>

            <div class="card">
                    <div class="card-icon green">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                    </div>
                <div class="card-value">@Model.EmployeesCompliant</div>
                <div class="card-label">Employees Compliant</div>
            </div>

            <div class="card">
                    <div class="card-icon red">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="15" y1="9" x2="9" y2="15"></line>
                            <line x1="9" y1="9" x2="15" y2="15"></line>
                        </svg>
                    </div>
                <div class="card-value">@Model.EmployeesNotCompliant</div>
                <div class="card-label">Employees Not Compliant</div>
            </div>

            <div class="card">
                    <div class="card-icon purple">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                <div class="card-value">@Model.SuppliersCompliant</div>
                <div class="card-label">Suppliers Compliant</div>
            </div>
        </div>

        <!-- Tab Switch -->
        <div class="tab-switch">
            <button class="tab-btn active" id="tabEmployee" onclick="switchTab('employee')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Employee Compliance
            </button>
            <button class="tab-btn" id="tabSupplier" onclick="switchTab('supplier')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Supplier Compliance
            </button>
        </div>

        <!-- Employee Compliance Section -->
        <div class="tab-panel active" id="panelEmployee">
        <div class="section-card">
            <div class="section-header">
                <div class="section-title">
                    <div class="section-title-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                    Employee Compliance
                </div>
            </div>

            <div class="filter-section">
                <div class="search-box">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                    <input type="text" placeholder="Search by employee name..." />
                </div>
                <div class="filter-group">
                    <select>
                        <option>All Departments</option>
                        <option>IT</option>
                        <option>Finance</option>
                        <option>HR</option>
                        <option>Operations</option>
                    </select>
                    <select>
                        <option>All Policies</option>
                        <option>Data Privacy</option>
                        <option>Cybersecurity</option>
                        <option>Code of Conduct</option>
                    </select>
                    <select>
                        <option>All Status</option>
                        <option>Compliant</option>
                        <option>Not Compliant</option>
                    </select>
                </div>
            </div>

            <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Employee Name</th>
                        <th>Assigned Policy</th>
                        <th>Date Assigned</th>
                        <th>Compliance Status</th>
                        <th>Acknowledged Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.EmployeeCompliance)
                    {
                        <tr onclick="showEmployeeDetail('@emp.Name', '@emp.AssignedPolicy', '@emp.DateAssigned.ToString("MMM dd, yyyy")', '@emp.ComplianceStatus', '@emp.AcknowledgedDate?.ToString("MMM dd, yyyy")')">
                            <td>@emp.Name</td>
                            <td>@emp.AssignedPolicy</td>
                            <td>@emp.DateAssigned.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="status-badge @(emp.ComplianceStatus == "Compliant" ? "compliant" : "not-compliant")">
                                    @emp.ComplianceStatus
                                </span>
                            </td>
                            <td>@(emp.AcknowledgedDate?.ToString("MMM dd, yyyy") ?? "Not Acknowledged")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
        </div><!-- end panelEmployee -->

        <!-- Supplier Compliance Section -->
        <div class="tab-panel" id="panelSupplier">
        <div class="section-card">
            <div class="section-header">
                <div class="section-title">
                    <div class="section-title-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    Supplier Compliance
                </div>
            </div>

            <div class="filter-section">
                <div class="search-box">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                    <input type="text" placeholder="Search by supplier name..." />
                </div>
                <div class="filter-group">
                    <select>
                        <option>All Policies</option>
                        <option>Supplier Code of Conduct</option>
                        <option>Environmental Policy</option>
                        <option>Quality Standards</option>
                    </select>
                    <select>
                        <option>All Status</option>
                        <option>Compliant</option>
                        <option>Not Compliant</option>
                    </select>
                </div>
            </div>

            <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Supplier Name</th>
                        <th>Assigned Policy</th>
                        <th>Compliance Status</th>
                        <th>Date Assigned</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in Model.SupplierCompliance)
                    {
                        <tr onclick="showSupplierDetail('@supplier.Name', '@supplier.AssignedPolicy', '@supplier.ComplianceStatus', '@supplier.DateAssigned.ToString("MMM dd, yyyy")')">
                            <td>@supplier.Name</td>
                            <td>@supplier.AssignedPolicy</td>
                            <td>
                                <span class="status-badge @(supplier.ComplianceStatus == "Compliant" ? "compliant" : "not-compliant")">
                                    @supplier.ComplianceStatus
                                </span>
                            </td>
                            <td>@supplier.DateAssigned.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
        </div><!-- end panelSupplier -->
    </div>

    <!-- Detail Modal -->
    <div class="modal" id="detailModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle">Compliance Details</h2>
                <button class="btn-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Dynamic content will be inserted here -->
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('panel' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
            document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
        }

        function showEmployeeDetail(name, policy, dateAssigned, status, acknowledgedDate) {
            const modal = document.getElementById('detailModal');
            const modalBody = document.getElementById('modalBody');
            
            modalBody.innerHTML = `
                <div class="detail-row">
                    <span class="detail-label">Employee Name:</span>
                    <span class="detail-value">${name}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Assigned Policy:</span>
                    <span class="detail-value">${policy}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Date Assigned:</span>
                    <span class="detail-value">${dateAssigned}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Compliance Status:</span>
                    <span class="detail-value">${status}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Acknowledged Date:</span>
                    <span class="detail-value">${acknowledgedDate}</span>
                </div>
            `;
            
            modal.classList.add('active');
        }

        function showSupplierDetail(name, policy, status, dateAssigned) {
            const modal = document.getElementById('detailModal');
            const modalBody = document.getElementById('modalBody');
            
            modalBody.innerHTML = `
                <div class="detail-row">
                    <span class="detail-label">Supplier Name:</span>
                    <span class="detail-value">${name}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Assigned Policy:</span>
                    <span class="detail-value">${policy}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Compliance Status:</span>
                    <span class="detail-value">${status}</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Date Assigned:</span>
                    <span class="detail-value">${dateAssigned}</span>
                </div>
            `;
            
            modal.classList.add('active');
        }

        function closeModal() {
            document.getElementById('detailModal').classList.remove('active');
        }

        // Close modal when clicking outside
        document.getElementById('detailModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });
    </script>
}
