@page
@model TechNova_IT_Solutions.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Employee Sign In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechNova</title>    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
        <style>
        html {
            margin: 0 !important;
            padding: 0 !important;
            width: 100%;
            height: 100%;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            min-height: 100vh;
            width: 100%;
            overflow-x: hidden;
            margin: 0 !important;
            padding: 0 !important;
        }

        .login-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 100vh;
            width: 100%;
            margin: 0 !important;
            padding: 0 !important;
        }

        .left-panel {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
            color: white;
            padding: 80px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 60%);
            animation: floatBg 8s ease-in-out infinite;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -20%;
            right: -20%;
            width: 60%;
            height: 60%;
            background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
            animation: floatBg2 10s ease-in-out infinite;
        }

        @@keyframes floatBg {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(30px, 20px); }
        }

        @@keyframes floatBg2 {
            0%, 100% { transform: translate(0, 0); }
            50% { transform: translate(-20px, -30px); }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeInLeft {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .main-content {
            position: relative;
            z-index: 1;
        }

        .logo-section {
            margin-bottom: 32px;
            animation: fadeInUp 0.8s ease-out;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo-icon {
            width: 64px;
            height: 64px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 28px;
            color: white;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            border: 2px solid rgba(255, 255, 255, 0.2);
        }

        .company-name {
            font-size: 24px;
            font-weight: 700;
            opacity: 0.98;
            letter-spacing: -0.5px;
        }

        .main-content h2 {
            font-size: 48px;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 28px;
            animation: fadeInLeft 0.8s ease-out;
        }

        .main-content > p {
            font-size: 18px;
            opacity: 0.9;
            line-height: 1.7;
            max-width: 520px;
            animation: fadeInUp 0.8s ease-out 0.3s both;
        }

        .footer-links {
            display: flex;
            gap: 24px;
            margin-top: auto;
            padding-top: 60px;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
            animation: fadeInUp 0.8s ease-out 0.6s both;
        }

        .footer-links a {
            color: white;
            text-decoration: none;
            font-size: 14px;
            opacity: 0.9;
        }

        .footer-links a:hover {
            opacity: 1;
            text-decoration: underline;
        }

        .right-panel {
            background: #ffffff;
            color: #1f2937;
            padding: 60px 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow-y: auto;
        }

        .form-container {
            max-width: 440px;
            width: 100%;
        }

        .form-container h2 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .form-container > p {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 40px;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-group label {
            display: block;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 8px;
            color: #1f2937;
        }

        .input-wrapper {
            position: relative;
        }

        .form-group input[type="email"],
        .form-group input[type="password"],
        .form-group input[type="text"] {
            width: 100%;
            padding: 14px 48px 14px 16px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            color: #1f2937;
            font-size: 14px;
            transition: border-color 0.2s;
        }

        .form-group input:focus {
            outline: none;
            border-color: #1e40af;
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #6b7280;
            cursor: pointer;
            padding: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .toggle-password:hover {
            color: #1f2937;
        }

        .toggle-password svg {
            width: 20px;
            height: 20px;
        }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            gap: 12px;
        }

        .checkbox-wrapper {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .checkbox-wrapper input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .checkbox-wrapper label {
            font-size: 14px;
            cursor: pointer;
            color: #1f2937;
        }

        .form-options a {
            color: #1e40af;
            text-decoration: none;
            font-size: 14px;
            white-space: nowrap;
        }

        .form-options a:hover {
            text-decoration: underline;
        }

        .btn-signin {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .login-type-toggle {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin: 14px 0 26px;
        }

        .login-type-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            background: #ffffff;
            color: #111827;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: border-color 0.2s, background 0.2s;
        }

        .login-type-btn.active {
            border-color: #1e40af;
            background: rgba(30, 64, 175, 0.06);
        }

        .login-type-btn:hover {
            border-color: #cbd5e1;
            background: #f8fafc;
        }

        .btn-signin:hover {
            opacity: 0.9;
        }

        .info-box {
            margin-top: 32px;
            background: #f3f4f6;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 20px;
            display: flex;
            gap: 12px;
        }

        .info-icon {
            color: #1e40af;
            flex-shrink: 0;
        }

        .info-icon svg {
            width: 20px;
            height: 20px;
        }

        .info-content h4 {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 6px;
            color: #1f2937;
        }

        .info-content p {
            font-size: 13px;
            color: #6b7280;
            line-height: 1.5;
        }

        .error-message {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .error-icon {
            flex-shrink: 0;
        }

        .error-icon svg {
            width: 20px;
            height: 20px;
        }

        .field-validation-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .input-validation-error {
            border-color: #ef4444 !important;
        }

        .validation-summary-errors {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 20px;
        }

        .validation-summary-errors li {
            margin: 4px 0;
        }

        /* Tablet styles */
        @@media (max-width: 1024px) {
            .login-container {
                grid-template-columns: 1fr;
                min-height: 100vh;
                display: block;
            }

            .left-panel {
                min-height: 100vh;
            }

            .right-panel {
                min-height: 100vh;
                padding: 60px 40px;
            }

            .main-content h2 {
                font-size: 36px;
            }
        }

        /* Mobile styles */
        @@media (max-width: 640px) {
            body {
                overflow-y: auto;
                overflow-x: hidden;
            }

            .login-container {
                display: block;
            }

            .left-panel {
                min-height: 100vh;
                padding: 40px 24px;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .logo-section {
                margin-bottom: 40px;
            }

            .logo-icon {
                width: 56px;
                height: 56px;
                font-size: 24px;
            }

            .company-name {
                font-size: 20px;
            }

            .main-content h2 {
                font-size: 32px;
                margin-bottom: 20px;
            }

            .main-content > p {
                font-size: 16px;
                margin-bottom: 0;
            }

            .footer-links {
                padding-top: 40px;
                justify-content: center;
            }

            .right-panel {
                min-height: 100vh;
                padding: 40px 24px;
                display: flex;
                align-items: center;
            }

            .form-container {
                width: 100%;
            }

            .form-container h2 {
                font-size: 28px;
            }

            .form-options {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            .info-box {
                flex-direction: row;
            }

            .login-type-toggle {
                grid-template-columns: 1fr;
            }
        }

        /* Small mobile styles */
        @@media (max-width: 375px) {
            .left-panel {
                padding: 32px 20px;
            }

            .right-panel {
                padding: 32px 20px;
            }

            .main-content h2 {
                font-size: 28px;
            }

            .main-content > p {
                font-size: 15px;
            }

            .form-container h2 {
                font-size: 24px;
            }

            .form-group input[type="email"],
            .form-group input[type="password"],
            .form-group input[type="text"] {
                padding: 12px 40px 12px 12px;
                font-size: 16px;
            }
        }

        /* Smooth scroll behavior */
        html {
            scroll-behavior: smooth;
        }

        /* Decorative elements */
        .decorative-shapes {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 0;
            pointer-events: none;
        }

        .shape {
            position: absolute;
            opacity: 0.1;
        }

        .shape-circle {
            width: 300px;
            height: 300px;
            border: 2px solid white;
            border-radius: 50%;
            top: -100px;
            right: -100px;
            animation: float 6s ease-in-out infinite;
        }

        .shape-square {
            width: 150px;
            height: 150px;
            border: 2px solid white;
            bottom: 100px;
            left: -50px;
            transform: rotate(45deg);
            animation: rotate 20s linear infinite;
        }

        .shape-line {
            width: 200px;
            height: 2px;
            background: white;
            top: 30%;
            right: -100px;
            animation: slideIn 8s ease-in-out infinite;
        }

        .grid-pattern {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            opacity: 0.3;
        }

        .tech-icon {
            position: absolute;
            opacity: 0.08;
        }

        .icon-code {
            top: 15%;
            left: 10%;
            animation: pulse 4s ease-in-out infinite;
        }

        .icon-shield {
            bottom: 25%;
            right: 8%;
            animation: pulse 4s ease-in-out 1s infinite;
        }

        .icon-network {
            top: 60%;
            left: 5%;
            animation: pulse 4s ease-in-out 2s infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-20px) scale(1.05); }
        }

        @@keyframes rotate {
            0% { transform: rotate(45deg); }
            100% { transform: rotate(405deg); }
        }

        @@keyframes slideIn {
            0%, 100% { transform: translateX(0); opacity: 0.1; }
            50% { transform: translateX(-50px); opacity: 0.2; }
        }

        @@keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.08; }
            50% { transform: scale(1.1); opacity: 0.12; }
        }

        /* ── Contact Admin Modal ── */
        .ca-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,0.55);
            backdrop-filter: blur(4px);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }
        .ca-overlay.open { display: flex; }
        .ca-modal {
            background: #fff;
            border-radius: 16px;
            width: 90%;
            max-width: 460px;
            box-shadow: 0 24px 60px rgba(15,23,42,0.18);
            overflow: hidden;
            animation: caSlideUp .25s ease;
        }
        @@keyframes caSlideUp {
            from { opacity:0; transform:translateY(24px); }
            to   { opacity:1; transform:translateY(0); }
        }
        .ca-header {
            background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
            padding: 24px 28px 20px;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .ca-header-icon {
            width: 44px; height: 44px;
            background: rgba(255,255,255,0.18);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .ca-header h3 { margin:0; font-size:17px; font-weight:700; }
        .ca-header p  { margin:4px 0 0; font-size:13px; opacity:.8; }
        .ca-body {
            padding: 24px 28px;
        }
        .ca-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 16px;
            margin-bottom: 12px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }
        .ca-card-icon {
            width: 36px; height: 36px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .ca-card-icon.blue  { background:#eff6ff; color:#1d4ed8; }
        .ca-card-icon.green { background:#f0fdf4; color:#16a34a; }
        .ca-card-icon.amber { background:#fffbeb; color:#d97706; }
        .ca-card-label { font-size:11px; font-weight:600; color:#94a3b8; text-transform:uppercase; letter-spacing:.5px; margin-bottom:2px; }
        .ca-card-value { font-size:14px; font-weight:600; color:#1e293b; }
        .ca-card-value a { color:#1d4ed8; text-decoration:none; }
        .ca-card-value a:hover { text-decoration:underline; }
        .ca-hint {
            font-size:12px; color:#64748b; background:#f1f5f9;
            border-radius:8px; padding:10px 14px; margin-top:4px;
            display:flex; gap:8px; align-items:flex-start;
        }
        .ca-footer {
            padding: 16px 28px 24px;
            display: flex;
            justify-content: flex-end;
        }
        .ca-close-btn {
            background: #1e3a8a;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 24px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
        }
        .ca-close-btn:hover { background: #1d4ed8; }

        /* ── Supplier Wrong-Portal Modal ── */
        .sp-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,23,42,0.55);
            backdrop-filter: blur(4px);
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }
        .sp-overlay.open { display: flex; }
        .sp-modal {
            background: #fff;
            border-radius: 16px;
            width: 90%;
            max-width: 460px;
            box-shadow: 0 24px 60px rgba(15,23,42,0.18);
            overflow: hidden;
            animation: caSlideUp .25s ease;
        }
        .sp-header {
            background: #1e40af;
            padding: 24px 28px 20px;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .sp-header-icon {
            width: 44px; height: 44px;
            background: rgba(255,255,255,0.18);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .sp-header h3 { margin:0; font-size:17px; font-weight:700; }
        .sp-header p  { margin:4px 0 0; font-size:13px; opacity:.85; }
        .sp-body { padding: 24px 28px; }
        .sp-body p { font-size:14px; color:#334155; line-height:1.6; margin:0 0 16px; }
        .sp-redirect-card {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #eff6ff;
            border: 1px solid #93c5fd;
            border-radius: 10px;
            padding: 14px 16px;
        }
        .sp-redirect-card-icon {
            width: 38px; height: 38px;
            background: #dbeafe;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            color: #1e40af;
        }
        .sp-redirect-card-text { font-size:13px; color:#1e3a8a; font-weight:600; }
        .sp-redirect-card-sub  { font-size:12px; color:#1e40af; margin-top:2px; }
        .sp-footer {
            padding: 16px 28px 24px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }
        .sp-close-btn {
            background: #f1f5f9;
            color: #475569;
            border: none;
            border-radius: 8px;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
        }
        .sp-close-btn:hover { background: #e2e8f0; }
        .sp-go-btn {
            background: #1e40af;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 22px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .sp-go-btn:hover { background: #1e3a8a; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="left-panel">
            <!-- Decorative Design Elements -->
            <div class="decorative-shapes">
                <div class="grid-pattern"></div>
                <div class="shape shape-circle"></div>
                <div class="shape shape-square"></div>
                <div class="shape shape-line"></div>
                
                <!-- Tech Icons -->
                <svg class="tech-icon icon-code" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <polyline points="16 18 22 12 16 6"></polyline>
                    <polyline points="8 6 2 12 8 18"></polyline>
                </svg>
                
                <svg class="tech-icon icon-shield" width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                
                <svg class="tech-icon icon-network" width="55" height="55" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
            </div>

            <div class="main-content">
                <div class="logo-section">
                    <img src="/images/logo2.png" alt="TechNova Logo" class="logo-icon" />
                    <div class="company-name">TechNova IT Solutions</div>
                </div>
                <h2>Welcome to TechNova<br />The Consulting and Software Services Company</h2>
                <p>Greetings! We are a leading technology consulting and software development company dedicated to delivering innovative solutions that drive business transformation.</p>
            </div>

            <div class="footer-links">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Contact IT</a>
            </div>
        </div>

        <div class="right-panel" id="login-form">
            <div class="form-container">
                <h2>Company Sign In</h2>
                <p>Use the credentials provided by your administrator</p>

                <div class="login-type-toggle" aria-label="Choose login type">
                    <a class="login-type-btn active" href="/Account/Login">Employee</a>
                    <a class="login-type-btn" href="/Supplier/Login">Supplier</a>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="error-message">
                        <div class="error-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="15" y1="9" x2="9" y2="15"></line>
                                <line x1="9" y1="9" x2="15" y2="15"></line>
                            </svg>
                        </div>
                        <div>@Model.ErrorMessage</div>
                    </div>
                }

                <form method="post" novalidate autocomplete="on" id="loginForm">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                    <div class="form-group">
                        <label asp-for="Email">Company Email</label>
                        <input asp-for="Email" type="email" placeholder="j.cruz@company.com" autocomplete="username" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password">Password</label>
                        <div class="input-wrapper">
                            <input asp-for="Password" type="password" id="passwordField" placeholder="Enter your password" autocomplete="current-password" />
                            <button type="button" class="toggle-password" onclick="togglePassword()" id="toggleBtn" aria-label="Toggle password visibility">
                                <svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path id="eyePath" d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle id="eyeCircle" cx="12" cy="12" r="3"></circle>
                                    <line id="eyeSlash" x1="1" y1="1" x2="23" y2="23" style="display: none;"></line>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <div class="form-options">
                        <div class="checkbox-wrapper">
                            <input asp-for="RememberMe" type="checkbox" />
                            <label asp-for="RememberMe">Remember me</label>
                        </div>
                        <a href="#" onclick="openContactModal(); return false;">Contact Admin</a>
                    </div>

                    <button type="submit" class="btn-signin">Sign In</button>
                </form>

                <div class="info-box">
                    <div class="info-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    </div>
                    <div class="info-content">
                        <h4>Need Access?</h4>
                        <p>Contact your IT administrator to receive your login credentials. All employee accounts are created and managed by the admin team.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // On page load, restore remembered email from cookie
        window.addEventListener('DOMContentLoaded', function() {
            var remembered = getCookie('TechNova_RememberEmail');
            if (remembered) {
                document.getElementById('Email').value = remembered;
                document.getElementById('RememberMe').checked = true;
            }
        });

        // Save or clear remember-me cookie on form submit
        document.addEventListener('DOMContentLoaded', function() {
            var form = document.getElementById('loginForm');
            if (form) {
                form.addEventListener('submit', function() {
                    var cb = document.getElementById('RememberMe');
                    var email = document.getElementById('Email').value;
                    if (cb && cb.checked && email) {
                        setCookie('TechNova_RememberEmail', email, 30);
                    } else {
                        eraseCookie('TechNova_RememberEmail');
                    }
                });
            }
        });

        function setCookie(name, value, days) {
            var d = new Date();
            d.setTime(d.getTime() + (days * 24 * 60 * 60 * 1000));
            document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
        }
        function getCookie(name) {
            var v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
            return v ? decodeURIComponent(v.pop()) : '';
        }
        function eraseCookie(name) {
            document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;SameSite=Lax';
        }

        function togglePassword() {
            const passwordInput = document.getElementById('passwordField');
            const eyePath = document.getElementById('eyePath');
            const eyeCircle = document.getElementById('eyeCircle');
            const eyeSlash = document.getElementById('eyeSlash');
            const isPassword = passwordInput.getAttribute('type') === 'password';

            if (isPassword) {
                passwordInput.setAttribute('type', 'text');
                eyePath.setAttribute('d', 'M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24');
                eyeCircle.style.display = 'none';
                eyeSlash.style.display = 'block';
            } else {
                passwordInput.setAttribute('type', 'password');
                eyePath.setAttribute('d', 'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z');
                eyeCircle.style.display = 'block';
                eyeSlash.style.display = 'none';
            }
        }
    </script>
    
    <!-- Supplier Wrong-Portal Modal -->
    <div class="sp-overlay" id="supplierPortalOverlay" onclick="handleSupplierOverlayClick(event)">
        <div class="sp-modal" role="dialog" aria-modal="true" aria-labelledby="spModalTitle">
            <div class="sp-header">
                <div class="sp-header-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </div>
                <div>
                    <h3 id="spModalTitle">Wrong Login Portal</h3>
                    <p>Your account is not registered as an employee</p>
                </div>
            </div>
            <div class="sp-body">
                <p>The email and password you entered belong to a <strong>Supplier account</strong>. This portal is for TechNova employees only.</p>
                <p>To access your supplier dashboard, please sign in through the <strong>Supplier Portal</strong> instead.</p>
                <div class="sp-redirect-card">
                    <div class="sp-redirect-card-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                    </div>
                    <div>
                        <div class="sp-redirect-card-text">Supplier Portal</div>
                        <div class="sp-redirect-card-sub">technova.com/Supplier/Login</div>
                    </div>
                </div>
            </div>
            <div class="sp-footer">
                <button class="sp-close-btn" onclick="closeSupplierModal()">Cancel</button>
                <a class="sp-go-btn" href="/Supplier/Login">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                    Go to Supplier Login
                </a>
            </div>
        </div>
    </div>

    <script>
        function openSupplierModal()  { document.getElementById('supplierPortalOverlay').classList.add('open'); }
        function closeSupplierModal() { document.getElementById('supplierPortalOverlay').classList.remove('open'); }
        function handleSupplierOverlayClick(e) { if (e.target === document.getElementById('supplierPortalOverlay')) closeSupplierModal(); }
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') { closeContactModal(); closeSupplierModal(); } });

        @if (Model.ShowSupplierModal)
        {
            <text>window.addEventListener('DOMContentLoaded', function() { openSupplierModal(); });</text>
        }
    </script>

    <!-- Contact Admin Modal -->
    <div class="ca-overlay" id="contactAdminOverlay" onclick="handleOverlayClick(event)">
        <div class="ca-modal" role="dialog" aria-modal="true" aria-labelledby="caModalTitle">
            <div class="ca-header">
                <div class="ca-header-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.64 3.48 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.64a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
                    </svg>
                </div>
                <div>
                    <h3 id="caModalTitle">Contact IT Administrator</h3>
                    <p>Reach out for account access or login issues</p>
                </div>
            </div>
            <div class="ca-body">
                <!-- Super Admin -->
                <div class="ca-card">
                    <div class="ca-card-icon blue">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="ca-card-label">Super Administrator</div>
                        <div class="ca-card-value" style="font-size:13px;color:#475569;margin-bottom:2px;">@Model.SuperAdminName</div>
                        <div class="ca-card-value"><a href="mailto:@Model.SuperAdminEmail">@Model.SuperAdminEmail</a></div>
                    </div>
                </div>
                <!-- System Admin -->
                <div class="ca-card">
                    <div class="ca-card-icon green">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                        </svg>
                    </div>
                    <div>
                        <div class="ca-card-label">System Administrator</div>
                        <div class="ca-card-value" style="font-size:13px;color:#475569;margin-bottom:2px;">@Model.SysAdminName</div>
                        <div class="ca-card-value"><a href="mailto:@Model.SysAdminEmail">@Model.SysAdminEmail</a></div>
                    </div>
                </div>
                <!-- Phone -->
                <div class="ca-card">
                    <div class="ca-card-icon amber">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.64 3.48 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.64a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="ca-card-label">Phone / Helpdesk</div>
                        <div class="ca-card-value"><a href="tel:+18007832668">+1 800-TECHNOVA</a></div>
                    </div>
                </div>
                <!-- Hours -->
                <div class="ca-card">
                    <div class="ca-card-icon" style="background:#f0fdf4;color:#16a34a;width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                        </svg>
                    </div>
                    <div>
                        <div class="ca-card-label">Support Hours</div>
                        <div class="ca-card-value">Monday – Friday &nbsp;|&nbsp; 8:00 AM – 6:00 PM</div>
                    </div>
                </div>
                <div class="ca-hint">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                    <span>Your account and credentials are managed by the IT admin team. Please include your full name and department when reaching out.</span>
                </div>
            </div>
            <div class="ca-footer">
                <button class="ca-close-btn" onclick="closeContactModal()">Close</button>
            </div>
        </div>
    </div>

    <script>
        function openContactModal()  { document.getElementById('contactAdminOverlay').classList.add('open'); }
        function closeContactModal() { document.getElementById('contactAdminOverlay').classList.remove('open'); }
        function handleOverlayClick(e) { if (e.target === document.getElementById('contactAdminOverlay')) closeContactModal(); }
    </script>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
</body>
</html>
