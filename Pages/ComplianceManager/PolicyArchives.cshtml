@page
@model TechNova_IT_Solutions.Pages.ComplianceManager.PolicyArchivesModel
@{
    ViewData["Title"] = "Policy Archives";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            min-height: 100vh;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 32px;
        }

        .summary-card {
            background: #ffffff;
            padding: 24px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            transition: all 0.3s;
        }

        .summary-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(30, 64, 175, 0.2);
            border-color: #1e40af;
        }

        .summary-card h3 {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 12px;
            font-weight: 500;
        }

        .summary-card .value {
            font-size: 32px;
            font-weight: bold;
            color: #1f2937;
        }

        .summary-card.gradient-1 .value {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .summary-card.gradient-2 .value {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .summary-card.gradient-3 .value {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Archive Section */
        .archive-section {
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            padding: 24px;
        }

        .archive-section h2 {
            font-size: 18px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .archive-section h2 svg {
            width: 20px;
            height: 20px;
            color: #6366f1;
        }

        /* Filters */
        .filters {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .search-input {
            flex: 1;
            min-width: 200px;
            padding: 10px 16px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            color: #1f2937;
            background: #f9fafb;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .search-input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .filter-select {
            padding: 10px 16px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            color: #1f2937;
            background: #f9fafb;
            cursor: pointer;
            min-width: 180px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .filter-select:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .filter-btn {
            padding: 10px 20px;
            background: #6366f1;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.2s;
        }

        .filter-btn:hover {
            background: #4f46e5;
        }

        .clear-btn {
            padding: 10px 20px;
            background: #f3f4f6;
            color: #6b7280;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .clear-btn:hover {
            background: #e5e7eb;
            color: #1f2937;
        }

        /* Table */
        .table-container {
            overflow-x: auto;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            background: #f9fafb;
            padding: 12px 16px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #e5e7eb;
        }

        .data-table td {
            padding: 14px 16px;
            font-size: 14px;
            color: #374151;
            border-bottom: 1px solid #f3f4f6;
        }

        .data-table tbody tr {
            transition: background 0.15s;
        }

        .data-table tbody tr:hover {
            background: #f9fafb;
        }

        .policy-title {
            font-weight: 600;
            color: #1f2937;
        }

        .policy-description {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 2px;
            max-width: 300px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .category-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            background: #ede9fe;
            color: #6366f1;
        }

        .archived-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            background: #fef3c7;
            color: #92400e;
        }

        .archived-badge svg {
            width: 12px;
            height: 12px;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #9ca3af;
        }

        .empty-state svg {
            width: 64px;
            height: 64px;
            margin-bottom: 16px;
            color: #d1d5db;
        }

        .empty-state h3 {
            font-size: 18px;
            font-weight: 600;
            color: #6b7280;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 14px;
        }

        /* Results Count */
        .results-count {
            font-size: 13px;
            color: #9ca3af;
            margin-bottom: 16px;
        }

        .results-count strong {
            color: #6b7280;
        }

        /* Responsive */
        @@media (max-width: 1024px) {
            .main-content {
                margin-left: 0;
            }

            .summary-cards {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }
        }

        @@media (max-width: 768px) {
            .content-wrapper {
                padding: 16px;
            }

            .summary-cards {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .summary-card {
                padding: 16px;
            }

            .summary-card .value {
                font-size: 24px;
            }

            .filters {
                flex-direction: column;
            }

            .search-input,
            .filter-select {
                min-width: 100%;
            }

            .data-table th {
                padding: 8px;
                font-size: 10px;
            }

            .data-table td {
                padding: 10px 8px;
                font-size: 12px;
            }

            .policy-description {
                max-width: 160px;
            }
        }

        @@media (max-width: 480px) {
            .content-wrapper {
                padding: 10px;
            }

            .archive-section {
                padding: 16px;
            }

            .data-table th {
                padding: 7px;
                font-size: 9px;
            }

            .data-table td {
                padding: 7px;
                font-size: 11px;
            }
        }
    </style>
}

    @await Html.PartialAsync("_ComplianceManagerSidebar", "PolicyArchives")

    <!-- Main Content -->
    <main class="main-content flex-grow-1">
        @await Html.PartialAsync("_ComplianceManagerTopBar", (Title: "Policy Archives", Description: "View and search archived compliance policies"))

        <div class="content-wrapper">

            <!-- Summary Cards -->
            <div class="summary-cards">
                <div class="summary-card gradient-1">
                    <h3>Total Archived Policies</h3>
                    <div class="value">@Model.TotalArchived</div>
                </div>
                <div class="summary-card gradient-2">
                    <h3>Archived This Month</h3>
                    <div class="value">@Model.ArchivedThisMonth</div>
                </div>
                <div class="summary-card gradient-3">
                    <h3>Categories</h3>
                    <div class="value">@Model.TotalCategories</div>
                </div>
                <div class="summary-card gradient-1">
                    <h3>External Policy Imports</h3>
                    <div class="value">@Model.ExternalImportsCount</div>
                </div>
            </div>

            <!-- Archive Table Section -->
            <div class="archive-section">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="21 8 21 21 3 21 3 8"></polyline>
                        <rect x="1" y="3" width="22" height="5"></rect>
                        <line x1="10" y1="12" x2="14" y2="12"></line>
                    </svg>
                    Archived Policies
                </h2>
                <div style="margin-bottom: 12px;">
                    <a href="/ComplianceManager/ExternalPolicyReferences" class="filter-btn" style="display: inline-block; text-decoration: none;">Open External Policy API</a>
                </div>

                <!-- Filters -->
                <form method="get" class="filters">
                    <input type="text" name="SearchTerm" class="search-input" id="archiveSearch"
                           placeholder="Search by title, description, or category..."
                           value="@Model.SearchTerm" />
                    <select name="CategoryFilter" class="filter-select" id="categoryFilter">
                        <option value="all">All Categories</option>
                        @{
                            var categories = Model.ArchivedPolicies
                                .Select(p => p.Category)
                                .Where(c => c != "Uncategorized")
                                .Distinct()
                                .OrderBy(c => c);
                        }
                        @foreach (var cat in categories)
                        {
                            <option value="@cat" selected="@(Model.CategoryFilter == cat)">@cat</option>
                        }
                    </select>
                    <button type="submit" class="filter-btn">Search</button>
                    <a href="/ComplianceManager/PolicyArchives" class="clear-btn">Clear</a>
                </form>

                <div class="results-count">
                    Showing <strong>@Model.ArchivedPolicies.Count</strong> archived
                    @(Model.ArchivedPolicies.Count == 1 ? "policy" : "policies")
                    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                    {
                        <span>matching "<strong>@Model.SearchTerm</strong>"</span>
                    }
                </div>

                @if (Model.ArchivedPolicies.Any())
                {
                    <div class="table-container">
                        <table class="data-table" id="archiveTable">
                            <thead>
                                <tr>
                                    <th>Policy Title</th>
                                    <th>Category</th>
                                    <th>Uploaded By</th>
                                    <th>Date Uploaded</th>
                                    <th>Archived Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var policy in Model.ArchivedPolicies)
                                {
                                    <tr>
                                        <td>
                                            <div class="policy-title">@policy.PolicyTitle</div>
                                            <div class="policy-description" title="@policy.Description">@policy.Description</div>
                                        </td>
                                        <td><span class="category-badge">@policy.Category</span></td>
                                        <td>@policy.UploadedBy</td>
                                        <td>@policy.DateUploaded</td>
                                        <td>@policy.ArchivedDate</td>
                                        <td>
                                            <span class="archived-badge">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="21 8 21 21 3 21 3 8"></polyline>
                                                    <rect x="1" y="3" width="22" height="5"></rect>
                                                </svg>
                                                Archived
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="21 8 21 21 3 21 3 8"></polyline>
                            <rect x="1" y="3" width="22" height="5"></rect>
                            <line x1="10" y1="12" x2="14" y2="12"></line>
                        </svg>
                        <h3>No Archived Policies Found</h3>
                        <p>
                            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || (!string.IsNullOrWhiteSpace(Model.CategoryFilter) && Model.CategoryFilter != "all"))
                            {
                                <span>No policies match your search criteria. Try adjusting your filters.</span>
                            }
                            else
                            {
                                <span>There are no archived policies at this time.</span>
                            }
                        </p>
                    </div>
                }
            </div>

            <!-- External Policy Imports Section -->
            <div class="archive-section" style="margin-top: 20px;">
                <h2>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="17 8 12 3 7 8"></polyline>
                        <line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                    External Policy Imports
                </h2>

                @if (Model.ExternalPolicyImports.Any())
                {
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Import ID</th>
                                    <th>Policy Title</th>
                                    <th>Category</th>
                                    <th>Source</th>
                                    <th>Document #</th>
                                    <th>Status</th>
                                    <th>Imported At</th>
                                    <th>Reviewed At</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.ExternalPolicyImports)
                                {
                                    <tr>
                                        <td>#@row.ImportId</td>
                                        <td>
                                            <div class="policy-title">@row.PolicyTitle</div>
                                        </td>
                                        <td><span class="category-badge">@row.Category</span></td>
                                        <td>@row.SourceApi</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.DocumentNumber) ? "N/A" : row.DocumentNumber)</td>
                                        <td>@row.ReviewStatus</td>
                                        <td>@row.ImportedAt.ToString("MMM dd, yyyy")</td>
                                        <td>@(row.ReviewedAt.HasValue ? row.ReviewedAt.Value.ToString("MMM dd, yyyy") : "N/A")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state" style="padding: 30px 20px;">
                        <h3>No External Policy Imports Yet</h3>
                        <p>Use the External Policy API page to queue and review imported policies.</p>
                    </div>
                }
            </div>
        </div>
    </main>

@section Scripts {
    <script>
        // Client-side table filtering for instant search
        document.getElementById('archiveSearch').addEventListener('keyup', function () {
            filterArchiveTable();
        });

        document.getElementById('categoryFilter').addEventListener('change', function () {
            filterArchiveTable();
        });

        function filterArchiveTable() {
            const searchTerm = document.getElementById('archiveSearch').value.toLowerCase();
            const categoryFilter = document.getElementById('categoryFilter').value.toLowerCase();
            const table = document.getElementById('archiveTable');
            if (!table) return;

            const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');

            for (let row of rows) {
                const title = row.cells[0].textContent.toLowerCase();
                const category = row.cells[1].textContent.toLowerCase().trim();

                const matchesSearch = !searchTerm || title.includes(searchTerm);
                const matchesCategory = !categoryFilter || categoryFilter === 'all' || category.includes(categoryFilter.toLowerCase());

                row.style.display = (matchesSearch && matchesCategory) ? '' : 'none';
            }
        }
    </script>
}
