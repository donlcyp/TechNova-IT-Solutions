@page
@model TechNova_IT_Solutions.Pages.ComplianceManager.ComplianceReportsModel
@{
    ViewData["Title"] = "Compliance Reports";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f8f9fa;
        color: #1f2937;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .main-content {
        margin-left: 260px;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .reports-shell { padding: 24px; }
    .report-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
    .report-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap; }
    .meta { color: #4b5563; font-size: 0.9rem; margin-top: 6px; }
    .filters { display: grid; grid-template-columns: repeat(4, minmax(150px, 1fr)); gap: 12px; align-items: end; }
    .filters label { font-size: 0.85rem; color: #374151; display: block; margin-bottom: 6px; }
    .filters input, .filters select { width: 100%; border: 1px solid #d1d5db; border-radius: 8px; padding: 8px 10px; }
    .kpis { display: grid; grid-template-columns: repeat(5, minmax(120px, 1fr)); gap: 12px; margin-top: 12px; }
    .kpi { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 12px; }
    .kpi .label { font-size: 0.8rem; color: #64748b; }
    .kpi .value { font-size: 1.3rem; font-weight: 700; color: #0f172a; }
    .actions { display: flex; gap: 8px; }
    .actions .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        white-space: nowrap;
    }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #e5e7eb; padding: 10px 8px; text-align: left; font-size: 0.9rem; }
    .status { padding: 4px 8px; border-radius: 999px; font-size: 0.8rem; }
    .status.compliant { background: transparent; color: #166534; }
    .status.pending { background: transparent; color: #92400e; }
    .status.non-compliant { background: transparent; color: #991b1b; }
    @@media (max-width: 900px) {
        .filters { grid-template-columns: 1fr 1fr; }
        .kpis { grid-template-columns: 1fr 1fr; }
    }

    @@media (max-width: 576px) {
        .reports-shell { padding: 14px; }
        .report-card { padding: 12px; }
        .filters { grid-template-columns: 1fr; gap: 10px; }
        .actions { display: grid; grid-template-columns: 1fr 1fr; width: 100%; }
        .actions .btn { width: 100%; padding: 10px 8px; font-size: .85rem; }
        .kpis { grid-template-columns: 1fr 1fr; gap: 10px; }
        .kpi { padding: 10px; }
        .kpi .value { font-size: 1.8rem; line-height: 1; }
    }

    @@media (max-width: 380px) {
        .actions { grid-template-columns: 1fr; }
        .kpis { grid-template-columns: 1fr; }
    }

    @@media (max-width: 991px) {
        .main-content {
            margin-left: 0;
        }
    }
</style>

@await Html.PartialAsync("_ComplianceManagerSidebar", "ComplianceReports")

<main class="main-content">
    @await Html.PartialAsync("_ComplianceManagerTopBar", (Title: "Compliance Reports", Description: "Summary metrics + detailed report records"))

    <div class="reports-shell">
        <div class="report-card">
            <form method="get" class="filters">
                <div>
                    <label for="reportType">Report Type</label>
                    <select id="reportType" name="reportType">
                        @if (Model.ReportType == "employee")
                        {
                            <option value="employee" selected>Employee Compliance</option>
                        }
                        else
                        {
                            <option value="employee">Employee Compliance</option>
                        }
                        @if (Model.ReportType == "supplier")
                        {
                            <option value="supplier" selected>Supplier Compliance</option>
                        }
                        else
                        {
                            <option value="supplier">Supplier Compliance</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="dateFrom">From Date</label>
                    <input id="dateFrom" type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <label for="dateTo">To Date</label>
                    <input id="dateTo" type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="actions">
                    <button type="submit" class="btn btn-primary">Generate</button>
                    <a class="btn btn-secondary"
                       asp-page-handler="ExportCsv"
                       asp-route-reportType="@Model.ReportType"
                       asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                       asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")">
                        Export CSV
                    </a>
                </div>
            </form>
        </div>

        <div class="report-card">
            <div class="report-header">
                <div>
                    <h3>@(Model.ReportType == "supplier" ? "Supplier Compliance Report" : "Employee Compliance Report")</h3>
                    <div class="meta">Period: @Model.DateFrom?.ToString("MMM dd, yyyy") to @Model.DateTo?.ToString("MMM dd, yyyy")</div>
                    <div class="meta">Generated by: @Model.GeneratedByName (@Model.GeneratedByRole) on @Model.GeneratedOn.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</div>
                </div>
            </div>

            <div class="kpis">
                <div class="kpi"><div class="label">Total Policies</div><div class="value">@Model.TotalPolicies</div></div>
                <div class="kpi"><div class="label">Total Employees</div><div class="value">@Model.TotalEmployees</div></div>
                <div class="kpi"><div class="label">Records</div><div class="value">@Model.TotalRecords</div></div>
                <div class="kpi"><div class="label">Compliant</div><div class="value">@Model.CompliantCount</div></div>
                <div class="kpi"><div class="label">Compliance %</div><div class="value">@($"{Model.ComplianceRate}%")</div></div>
            </div>
        </div>

        <div class="report-card table-wrap">
            @if (Model.ReportType == "supplier")
            {
                <table>
                    <thead>
                        <tr>
                            <th>Supplier</th>
                            <th>Contact Person</th>
                            <th>Policy</th>
                            <th>Status</th>
                            <th>Date Assigned</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.SupplierRows)
                        {
                            var statusCss = row.Status.ToLowerInvariant();
                            <tr>
                                <td>@row.SupplierName</td>
                                <td>@row.ContactPerson</td>
                                <td>@row.AssignedPolicy</td>
                                <td><span class="status @statusCss">@row.Status</span></td>
                                <td>@row.DateAssigned?.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Policy</th>
                            <th>Status</th>
                            <th>Date Assigned</th>
                            <th>Acknowledged Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.EmployeeRows)
                        {
                            var statusCss = row.Status.ToLowerInvariant();
                            <tr>
                                <td>@row.EmployeeName</td>
                                <td>@row.Department</td>
                                <td>@row.AssignedPolicy</td>
                                <td><span class="status @statusCss">@row.Status</span></td>
                                <td>@row.DateAssigned?.ToString("MMM dd, yyyy")</td>
                                <td>@(row.AcknowledgedDate.HasValue ? row.AcknowledgedDate.Value.ToString("MMM dd, yyyy") : "N/A")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</main>
