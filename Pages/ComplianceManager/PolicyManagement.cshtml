@page
@model TechNova_IT_Solutions.Pages.ComplianceManager.CMPolicyManagementModel
@{
    ViewData["Title"] = "Policy Management";
}

@section Styles {
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif; background: #f8f9fa; color: #1f2937; display: flex; min-height: 100vh; }
        .main-content { margin-left: 260px; flex: 1; overflow-y: auto; }
        .content-wrapper { padding: 24px; max-width: 1400px; margin: 0 auto; }

        /* Buttons */
        .btn-primary { padding: 12px 24px; background: linear-gradient(135deg,#1e40af 0%,#1e3a8a 100%); border: none; border-radius: 8px; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: opacity .2s; }
        .btn-primary:hover { opacity: .9; }
        .btn-primary svg { width: 18px; height: 18px; }
        .btn-secondary { padding: 10px 20px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #6b7280; font-size: 14px; font-weight: 600; cursor: pointer; transition: all .2s; }
        .btn-secondary:hover { border-color: #1e40af; color: #1e40af; }
        .btn-action { padding: 6px 12px; border: 1px solid #e5e7eb; border-radius: 6px; background: #f8f9fa; color: #6b7280; font-size: 12px; cursor: pointer; transition: all .2s; }
        .btn-action:hover { border-color: #1e40af; color: #1e40af; }
        .add-policy-btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 20px; background: linear-gradient(135deg,#1e40af 0%,#1e3a8a 100%); color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
        .add-policy-btn svg { width: 18px; height: 18px; }

        /* Filter */
        .filter-section { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; margin-bottom: 24px; display: flex; gap: 16px; flex-wrap: wrap; }
        .search-box { flex: 1; min-width: 250px; position: relative; }
        .search-box input { width: 100%; padding: 10px 14px 10px 40px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #1f2937; font-size: 14px; }
        .search-box input:focus { outline: none; border-color: #1e40af; }
        .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #6b7280; width: 18px; height: 18px; }
        .filter-group { display: flex; gap: 12px; }
        .filter-toolbar { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
        .filter-controls { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; flex: 1; min-width: 0; }
        select { padding: 10px 14px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #1f2937; font-size: 14px; cursor: pointer; }
        select:focus { outline: none; border-color: #1e40af; }

        /* Table */
        .table-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; margin-bottom: 32px; }
        .table-scroll { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .table-scroll table { min-width: 1000px; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: center; padding: 12px 16px; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; border-bottom: 2px solid #e5e7eb; }
        td { text-align: center; vertical-align: middle; padding: 14px 16px; border-bottom: 1px solid #e5e7eb; font-size: 14px; color: #1f2937; }
        td:nth-child(2) { text-align: left; }
        tbody tr { transition: background .2s; }
        tbody tr:hover { background: #f3f4f6; }
        .status-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; border: 1.5px solid; background: transparent; }
        .status-badge::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
        .status-badge.active, .status-badge.approved { color: #16a34a; border-color: #16a34a; }
        .status-badge.archived { color: #dc2626; border-color: #dc2626; }
        .status-badge.pending-review { color: #d97706; border-color: #d97706; }
        .status-badge.pending-update { color: #7c3aed; border-color: #7c3aed; }
        .status-badge.rejected { color: #dc2626; border-color: #dc2626; }
        .actions { display: flex; gap: 6px; justify-content: center; }
        .btn-icon { width: 34px; height: 34px; border-radius: 6px; border: 1px solid; background: transparent; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: all .15s; padding: 0; }
        .btn-icon svg { width: 14px; height: 14px; }
        .btn-icon.view { color: #2563eb; border-color: #93c5fd; } .btn-icon.view:hover { background: #eff6ff; }
        .btn-icon.edit { color: #d97706; border-color: #fcd34d; } .btn-icon.edit:hover { background: #fffbeb; }
        .btn-icon.assign { color: #6366f1; border-color: #a5b4fc; } .btn-icon.assign:hover { background: #eef2ff; }
        .btn-icon.archive { color: #dc2626; border-color: #fca5a5; } .btn-icon.archive:hover { background: #fef2f2; }
        .btn-icon.restore { color: #059669; border-color: #6ee7b7; } .btn-icon.restore:hover { background: #ecfdf5; }

        /* Summary Cards */
        .summary-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 16px; }
        .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px 20px; transition: transform .2s; display: grid; grid-template-columns: auto 1fr; grid-template-rows: auto auto; gap: 0 12px; align-items: center; }

        .card-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; grid-row: 1/3; }
        .card-icon svg { width: 22px; height: 22px; }
        .card-icon.blue { color: #1e40af; }
        .card-icon.green { color: #48bb78; }
        .card-icon.purple { color: #9f7aea; }
        .card-value { font-size: 26px; font-weight: 700; color: #1f2937; margin-bottom: 4px; }
        .card-label { font-size: 14px; color: #6b7280; font-weight: 500; }

        /* Modal */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,.7); z-index: 1000; align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        .modal-content { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
        .modal-header { padding: 24px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
        .modal-header h2 { font-size: 20px; font-weight: 600; color: #1f2937; }
        .btn-close { background: none; border: none; font-size: 24px; color: #6b7280; cursor: pointer; }
        .btn-close:hover { color: #1f2937; }
        .modal-body { padding: 24px; }
        .modal-footer { padding: 24px; border-top: 1px solid #e5e7eb; display: flex; justify-content: flex-end; gap: 12px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-size: 14px; font-weight: 600; color: #1f2937; }
        .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 10px 14px; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; color: #1f2937; font-size: 14px; font-family: inherit; }
        .form-group textarea { min-height: 100px; resize: vertical; }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: #1e40af; }
        .form-group input[type="file"] { padding: 8px; }
        .multi-select { background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; max-height: 200px; overflow-y: auto; }
        .checkbox-item { display: flex; align-items: center; padding: 8px; margin-bottom: 4px; border-radius: 6px; transition: background .2s; }
        .checkbox-item:hover { background: #f3f4f6; }
        .checkbox-item input[type="checkbox"] { width: auto; margin-right: 10px; }
        .checkbox-item label { margin: 0; font-weight: normal; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
        .checkbox-item.already-assigned { background: #f8fafc; border: 1px solid #e2e8f0; }
        .checkbox-item.already-assigned label { color: #64748b; cursor: not-allowed; }
        .already-badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 999px; background: #dbeafe; color: #1e40af; font-size: 11px; font-weight: 600; }
        .assign-status-note { margin-bottom: 14px; padding: 10px 12px; border: 1px solid #bfdbfe; border-radius: 8px; background: #eff6ff; color: #1e3a8a; font-size: 13px; }

        @@media (max-width: 991px) { .main-content { margin-left: 0; } .content-wrapper { padding: 20px; } .filter-section { flex-direction: column; } .search-box { min-width: 100%; } .filter-controls { width: 100%; } }
        @@media (max-width: 768px) { th, td { padding: 12px; } .actions { flex-direction: column; gap: 8px; } .btn-action { width: 100%; text-align: center; } }
        @@media (max-width: 576px) { .summary-cards { grid-template-columns: 1fr; } .filter-toolbar { align-items: stretch; } .filter-controls { width: 100%; } .filter-group { width: 100%; display: grid; grid-template-columns: 1fr 1fr; } .filter-group select { width: 100%; min-width: 0; } .add-policy-btn { width: 100%; } .modal-header,.modal-body,.modal-footer { padding: 16px; } .modal-content { width: 95%; margin: 10px; } }

        /* ── Loading overlay ────────────────── */
        .loading-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,42,.6); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:16px; }
        .loading-overlay.active { display:flex; }
        .loading-spinner { width:48px; height:48px; border:4px solid rgba(255,255,255,.3); border-top:4px solid #fff; border-radius:50%; animation:spin .8s linear infinite; }
        .loading-text { color:#fff; font-size:15px; font-weight:600; text-align:center; max-width:280px; line-height:1.4; }
        @@keyframes spin { to { transform:rotate(360deg); } }
    </style>
}

@await Html.PartialAsync("_ComplianceManagerSidebar", "PolicyManagement")

<!-- Main Content -->
<div class="main-content">
    @await Html.PartialAsync("_ComplianceManagerTopBar", (Title: "Policy Management", Description: "Create, edit, archive and assign compliance policies"))

    <div class="content-wrapper">
        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="card">
                <div class="card-icon blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <div class="card-value">@Model.TotalPolicies</div>
                <div class="card-label">Total Policies</div>
            </div>
            <div class="card">
                <div class="card-icon green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                </div>
                <div class="card-value">@Model.ApprovedPolicies</div>
                <div class="card-label">Approved</div>
            </div>
            <div class="card">
                <div class="card-icon" style="color: #d97706;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <div class="card-value">@Model.PendingReviewPolicies</div>
                <div class="card-label">Pending Review</div>
            </div>
            <div class="card">
                <div class="card-icon purple">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </div>
                <div class="card-value">@Model.PendingUpdatePolicies</div>
                <div class="card-label">Pending Update</div>
            </div>
            <div class="card">
                <div class="card-icon" style="color: #e53e3e;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"></path><path d="M1 3h22v5H1z"></path><path d="M10 12h4"></path></svg>
                </div>
                <div class="card-value">@Model.ArchivedPolicies</div>
                <div class="card-label">Archived</div>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="filter-section filter-toolbar">
            <div class="filter-controls">
                <div class="search-box">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
                    <input type="text" id="searchInput" placeholder="Search by policy title..." oninput="filterPolicies()" />
                </div>
                <div class="filter-group">
                    <select id="categoryFilter" onchange="filterPolicies()">
                        <option value="">All Categories</option>
                        <option>Supplier Management</option>
                        <option>Procurement Policy</option>
                        <option>IT Governance</option>
                        <option>Contract Management</option>
                        <option>Quality Assurance</option>
                        <option>Compliance &amp; Regulatory</option>
                        <option>Code of Conduct</option>
                        <option>Risk Management</option>
                    </select>
                    <select id="statusFilter" onchange="filterPolicies()">
                        <option value="">All Status</option>
                        <option value="Approved">Approved</option>
                        <option value="Pending Review">Pending Review</option>
                        <option value="Pending Update">Pending Update</option>
                        <option value="Rejected">Rejected</option>
                        <option value="Archived">Archived</option>
                    </select>
                </div>
            </div>
            <button onclick="openUploadModal()" class="add-policy-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add Policy
            </button>
        </div>

        <!-- Policies Table -->
        <div class="table-card">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                                <th>Policy ID</th>
                                <th>Policy Title</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Date Uploaded</th>
                                <th>Uploaded By</th>
                                <th>Actions</th>
                            </tr>
                    </thead>
                    <tbody>
                        @foreach (var policy in Model.Policies)
                        {
                            var badgeClass = policy.ReviewStatus switch
                            {
                                "PendingReview" => "pending-review",
                                "PendingUpdate" => "pending-update",
                                "Approved" => "approved",
                                "Rejected" => "rejected",
                                "Archived" => "archived",
                                _ => "approved"
                            };
                            var statusLabel = policy.ReviewStatus switch
                            {
                                "PendingReview" => "Pending Review",
                                "PendingUpdate" => "Pending Update",
                                _ => policy.ReviewStatus
                            };
                            <tr>
                                <td>@policy.PolicyId</td>
                                <td>@policy.Title</td>
                                <td>@policy.Category</td>
                                <td><span class="status-badge @badgeClass">@statusLabel</span></td>
                                <td>@policy.DateUploaded.ToString("MMM dd, yyyy")</td>
                                <td>@policy.UploadedBy</td>
                                <td>
                                    <div class="actions">
                                        <button class="btn-icon view" onclick="viewPolicy(@policy.RawId)" title="View">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                        @if (policy.ReviewStatus == "Approved" && policy.IsBranchPolicy)
                                        {
                                            <button class="btn-icon edit" onclick="editPolicy('@policy.PolicyId', '@policy.Title', '@policy.Category', '@policy.Status', this)" data-description="@Html.Encode(policy.Description)" title="Edit (requires re-approval)">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            <button class="btn-icon assign" onclick="openAssignModal('@policy.PolicyId', '@policy.Title')" title="Assign">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                                            </button>
                                            <button class="btn-icon archive" onclick="archivePolicy(@policy.RawId, '@policy.Title')" title="Archive">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
                                            </button>
                                        }
                                        else if (policy.ReviewStatus == "Approved" && !policy.IsBranchPolicy)
                                        {
                                            <button class="btn-icon assign" onclick="openAssignModal('@policy.PolicyId', '@policy.Title')" title="Assign">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                                            </button>
                                        }
                                        else if (policy.ReviewStatus == "Archived" && policy.IsBranchPolicy)
                                        {
                                            <button class="btn-icon restore" onclick="restorePolicy(@policy.RawId, '@policy.Title')" title="Restore (resubmits for review)">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.17"/></svg>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Upload / Edit Policy Modal -->
<div class="modal" id="uploadModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="uploadModalTitle">Upload New Policy</h2>
            <button class="btn-close" onclick="closeUploadModal()">&times;</button>
        </div>
        <div class="modal-body">
            <form id="policyForm">
                <div class="form-group">
                    <label for="policyTitle">Policy Title</label>
                    <input type="text" id="policyTitle" placeholder="Enter policy title" required />
                </div>
                <div class="form-group">
                    <label for="policyDescription">Description</label>
                    <textarea id="policyDescription" placeholder="Enter policy description" required></textarea>
                </div>
                <div class="form-group">
                    <label for="policyCategory">Category</label>
                    <select id="policyCategory" required>
                        <option value="">Select category</option>
                        <option value="Supplier Management">Supplier Management</option>
                        <option value="Procurement Policy">Procurement Policy</option>
                        <option value="IT Governance">IT Governance</option>
                        <option value="Contract Management">Contract Management</option>
                        <option value="Quality Assurance">Quality Assurance</option>
                        <option value="Compliance &amp; Regulatory">Compliance &amp; Regulatory</option>
                        <option value="Code of Conduct">Code of Conduct</option>
                        <option value="Risk Management">Risk Management</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="policyFile">Upload File</label>
                    <input type="file" id="policyFile" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.png,.jpg,.jpeg" />
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeUploadModal()">Cancel</button>
            <button class="btn-primary" onclick="savePolicy()">Save Policy</button>
        </div>
    </div>
</div>

<!-- Assign Policy Modal -->
<div class="modal" id="assignModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="assignModalTitle">Assign Policy</h2>
            <button class="btn-close" onclick="closeAssignModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div id="assignStatusNote" class="assign-status-note">Select users to assign. Recipients with an existing assignment are marked and disabled.</div>
            <div class="form-group">
                <label>Assign to Employees</label>
                <div class="multi-select" id="employeeList">
                    @foreach (var emp in Model.Employees)
                    {
                        <div class="checkbox-item">
                            <input type="checkbox" id="emp_@emp.Id" value="@emp.Id" />
                            <label for="emp_@emp.Id"><span class="recipient-name">@emp.Name</span><span class="already-badge" style="display:none;">Already assigned</span></label>
                        </div>
                    }
                </div>
            </div>
            <div class="form-group">
                <label>Assign to Suppliers</label>
                <div class="multi-select" id="supplierList">
                    @foreach (var supplier in Model.Suppliers)
                    {
                        <div class="checkbox-item">
                            <input type="checkbox" id="sup_@supplier.Id" value="@supplier.Id" />
                            <label for="sup_@supplier.Id"><span class="recipient-name">@supplier.Name</span><span class="already-badge" style="display:none;">Already assigned</span></label>
                        </div>
                    }
                </div>
            </div>
            <div class="form-group">
                <label for="assignDate">Assign Date</label>
                <input type="date" id="assignDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeAssignModal()">Cancel</button>
            <button class="btn-primary" onclick="assignPolicy()">Assign Policy</button>
        </div>
    </div>
</div>

<!-- View Policy Modal -->
<div class="modal" id="viewModal">
    <div class="modal-content" style="max-width: 700px;">
        <div class="modal-header">
            <h2 id="viewModalTitle">Policy Details</h2>
            <button class="btn-close" onclick="closeViewModal()">&times;</button>
        </div>
        <div class="modal-body" id="viewModalBody">
            <div style="text-align: center; padding: 40px;">Loading...</div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeViewModal()">Close</button>
            <a id="viewDownloadBtn" href="#" target="_blank" class="btn-primary" style="display: none; text-decoration: none; padding: 10px 20px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                View / Download File
            </a>
        </div>
    </div>
</div>

<!-- ── Loading Overlay ── -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <div class="loading-text" id="loadingText">Processing...</div>
</div>

@section Scripts {
<script>
    // All AJAX endpoints now go through ComplianceManagerPolicy controller
    const API = '/ComplianceManagerPolicy';
    let currentPolicyId = null;
    let currentPolicyDbId = null;

    function showLoading(msg = 'Processing...') { document.getElementById('loadingText').textContent = msg; document.getElementById('loadingOverlay').classList.add('active'); }
    function hideLoading() { document.getElementById('loadingOverlay').classList.remove('active'); }

    /* ── Upload / Edit ─────────────────────────────── */
    function openUploadModal() {
        document.getElementById('uploadModalTitle').textContent = 'Upload New Policy';
        document.getElementById('policyForm').reset();
        currentPolicyId = null;
        currentPolicyDbId = null;
        document.getElementById('uploadModal').classList.add('active');
    }
    function closeUploadModal() { document.getElementById('uploadModal').classList.remove('active'); currentPolicyId = null; currentPolicyDbId = null; }

    function editPolicy(id, title, category, status, btn) {
        currentPolicyId = id;
        currentPolicyDbId = parseInt(id.replace('POL-', ''));
        document.getElementById('uploadModalTitle').textContent = 'Edit Policy (requires re-approval)';
        document.getElementById('policyTitle').value = title;
        document.getElementById('policyDescription').value = btn ? (btn.dataset.description || '') : '';
        document.getElementById('policyCategory').value = category;
        document.getElementById('uploadModal').classList.add('active');
    }

    async function savePolicy() {
        const title = document.getElementById('policyTitle').value.trim();
        const description = document.getElementById('policyDescription').value.trim();
        const category = document.getElementById('policyCategory').value;
        const fileInput = document.getElementById('policyFile');

        if (!title || !category) { await window.showAppMessage('Please fill in all required fields', 'Validation'); return; }

        const formData = new FormData();
        formData.append('policyTitle', title);
        formData.append('description', description);
        formData.append('category', category);
        formData.append('status', 'Active');
        if (fileInput.files.length > 0) formData.append('policyFile', fileInput.files[0]);
        if (currentPolicyDbId) formData.append('policyId', currentPolicyDbId);

        const isEdit = !!currentPolicyDbId;
        const loadMsg = isEdit ? 'Submitting policy update for review...' : 'Creating policy & submitting for review...';
        showLoading(loadMsg);
        fetch(API + '/UploadPolicy', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(async result => {
                hideLoading();
                if (result.success) { await window.showAppMessage(result.message || (isEdit ? 'Policy update submitted for Chief Compliance Manager review.' : 'Policy created and submitted for Chief Compliance Manager review.'), 'Success'); closeUploadModal(); location.reload(); }
                else { await window.showAppMessage(result.message || 'Failed to save policy', 'Error'); }
            })
            .catch(async () => { hideLoading(); await window.showAppMessage('Error saving policy', 'Error'); });
    }

    /* ── View ──────────────────────────────────────── */
    function viewPolicy(dbId) {
        document.getElementById('viewModalBody').innerHTML = '<div style="text-align:center;padding:40px;">Loading...</div>';
        document.getElementById('viewDownloadBtn').style.display = 'none';
        document.getElementById('viewModal').classList.add('active');

        fetch(API + '/GetPolicyDetail?policyId=' + dbId)
            .then(r => r.json())
            .then(result => {
                if (!result.success) { document.getElementById('viewModalBody').innerHTML = '<div style="text-align:center;padding:40px;color:#e53e3e;">Policy not found.</div>'; return; }
                const p = result.policy;
                document.getElementById('viewModalTitle').textContent = p.policyTitle;
                let statusColor = p.isArchived ? '#e53e3e' : '#48bb78';
                let statusText = p.isArchived ? 'Archived' : 'Active';
                let html = `<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                    <div><div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Policy ID</div><div style="font-size:14px;color:#1f2937;">POL-${String(p.policyId).padStart(3,'0')}</div></div>
                    <div><div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Category</div><div style="font-size:14px;color:#1f2937;">${p.category||'N/A'}</div></div>
                    <div><div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Status</div><div><span style="color:${statusColor};font-weight:600;font-size:14px;">${statusText}</span></div></div>
                    <div><div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Date Uploaded</div><div style="font-size:14px;color:#1f2937;">${p.dateUploaded||'N/A'}</div></div>
                    <div><div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Uploaded By</div><div style="font-size:14px;color:#1f2937;">${p.uploadedBy}</div></div>
                    <div><div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Assigned To</div><div style="font-size:14px;color:#1f2937;">${p.assignedEmployees} employee(s), ${p.assignedSuppliers} supplier(s)</div></div>
                </div>`;
                if (p.isArchived && p.archivedDate) html += `<div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:8px;padding:12px;margin-bottom:16px;"><span style="color:#e53e3e;font-weight:600;">Archived on:</span> ${p.archivedDate}</div>`;
                html += `<div style="margin-bottom:16px;"><div style="font-size:12px;color:#6b7280;font-weight:600;text-transform:uppercase;margin-bottom:4px;">Description</div><div style="font-size:14px;color:#1f2937;background:#f8f9fa;border-radius:8px;padding:12px;border:1px solid #e5e7eb;">${p.description||'No description provided.'}</div></div>`;
                if (p.filePath) {
                    html += `<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px;"><span style="font-weight:600;color:#1e40af;">&#128206; File attached:</span> ${p.filePath.split('/').pop()}</div>`;
                    const btn = document.getElementById('viewDownloadBtn');
                    btn.href = '/AdminPolicy/DownloadPolicyFile?policyId=' + dbId;
                    btn.style.display = 'inline-flex';
                }
                document.getElementById('viewModalBody').innerHTML = html;
            })
            .catch(() => { document.getElementById('viewModalBody').innerHTML = '<div style="text-align:center;padding:40px;color:#e53e3e;">Error loading policy details.</div>'; });
    }
    function closeViewModal() { document.getElementById('viewModal').classList.remove('active'); }

    /* ── Archive / Restore ──────────────────────────── */
    async function archivePolicy(dbId, title) {
        const ok = await window.showAppConfirm('Archive "' + title + '"? It can be restored later.');
        if (!ok) return;
        fetch(API + '/ArchivePolicy?policyId=' + dbId, { method: 'POST' }).then(r => r.json())
            .then(async res => { if (res.success) location.reload(); else await window.showAppMessage(res.message || 'Failed', 'Error'); })
            .catch(async () => await window.showAppMessage('Error archiving policy', 'Error'));
    }

    async function restorePolicy(dbId, title) {
        const ok = await window.showAppConfirm('Restore "' + title + '" back to active?');
        if (!ok) return;
        fetch(API + '/RestorePolicy?policyId=' + dbId, { method: 'POST' }).then(r => r.json())
            .then(async res => { if (res.success) location.reload(); else await window.showAppMessage(res.message || 'Failed', 'Error'); })
            .catch(async () => await window.showAppMessage('Error restoring policy', 'Error'));
    }

    /* ── Assign ────────────────────────────────────── */
    function openAssignModal(id, title) { currentPolicyId = id; currentPolicyDbId = parseInt(id.replace('POL-', '')); openAssignModalByDbId(currentPolicyDbId, title); }
    function openAssignModalByDbId(dbId, title) {
        currentPolicyDbId = dbId;
        currentPolicyId = dbId ? ('POL-' + String(dbId).padStart(3, '0')) : null;
        document.getElementById('assignModalTitle').textContent = 'Assign Policy: ' + title;
        document.querySelectorAll('#employeeList input, #supplierList input').forEach(cb => cb.checked = false);
        resetAssignmentIndicators();
        loadAssignmentStatus();
        document.getElementById('assignModal').classList.add('active');
    }
    function closeAssignModal() { document.getElementById('assignModal').classList.remove('active'); currentPolicyId = null; currentPolicyDbId = null; }

    async function assignPolicy() {
        const emps = Array.from(document.querySelectorAll('#employeeList input:checked')).map(cb => parseInt(cb.value));
        const sups = Array.from(document.querySelectorAll('#supplierList input:checked')).map(cb => parseInt(cb.value));
        if (!emps.length && !sups.length) { await window.showAppMessage('Select at least one employee or supplier.', 'Validation'); return; }

        showLoading('Assigning policy & sending notification emails...');
        fetch(API + '/AssignPolicy', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ policyId: currentPolicyDbId, employeeIds: emps, supplierIds: sups }) })
            .then(r => r.json())
            .then(async res => { hideLoading(); if (res.success) { await window.showAppMessage(res.message || 'Assigned!', 'Success'); closeAssignModal(); location.reload(); } else { await window.showAppMessage(res.message, 'Error'); } })
            .catch(async () => { hideLoading(); await window.showAppMessage('Error assigning policy', 'Error'); });
    }

    function resetAssignmentIndicators() {
        document.querySelectorAll('#employeeList .checkbox-item, #supplierList .checkbox-item').forEach(item => {
            const cb = item.querySelector('input[type="checkbox"]');
            const badge = item.querySelector('.already-badge');
            if (cb) { cb.checked = false; cb.disabled = false; }
            item.classList.remove('already-assigned');
            if (badge) badge.style.display = 'none';
        });
        document.getElementById('assignStatusNote').textContent = 'Select users to assign. Recipients with an existing assignment are marked and disabled.';
    }

    function markAlreadyAssigned(sel, ids) {
        const set = new Set((ids || []).map(id => parseInt(id)));
        let count = 0;
        document.querySelectorAll(`${sel} .checkbox-item`).forEach(item => {
            const cb = item.querySelector('input[type="checkbox"]');
            const badge = item.querySelector('.already-badge');
            const rid = parseInt(cb.value);
            const assigned = set.has(rid);
            cb.disabled = assigned; cb.checked = false;
            item.classList.toggle('already-assigned', assigned);
            if (badge) badge.style.display = assigned ? 'inline-flex' : 'none';
            if (assigned) count++;
        });
        return count;
    }

    function loadAssignmentStatus() {
        if (!currentPolicyDbId) return;
        fetch(API + '/GetPolicyAssignmentStatus?policyId=' + currentPolicyDbId).then(r => r.json())
            .then(res => { if (!res.success) return; const e = markAlreadyAssigned('#employeeList', res.assignedEmployeeIds); const s = markAlreadyAssigned('#supplierList', res.assignedSupplierIds); document.getElementById('assignStatusNote').textContent = `${e} employee(s) and ${s} supplier(s) already assigned.`; })
            .catch(() => document.getElementById('assignStatusNote').textContent = 'Unable to load existing assignments.');
    }

    /* ── Filter ────────────────────────────────────── */
    function filterPolicies() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const category = document.getElementById('categoryFilter').value;
        const status = document.getElementById('statusFilter').value;
        document.querySelectorAll('tbody tr').forEach(row => {
            const tds = row.querySelectorAll('td');
            if (tds.length < 4) return;
            const title = tds[1].textContent.toLowerCase();
            const rowCat = tds[2].textContent.trim();
            const badge = tds[3].querySelector('.status-badge');
            const rowStat = badge ? badge.textContent.trim() : tds[3].textContent.trim();
            row.style.display = ((!search || title.includes(search)) && (!category || rowCat === category) && (!status || rowStat === status)) ? '' : 'none';
        });
    }

    /* ── Close modals on backdrop click ────────────── */
    document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('active'); }));
</script>
}
