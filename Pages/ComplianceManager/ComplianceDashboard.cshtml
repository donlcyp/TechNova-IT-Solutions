@page
@model TechNova_IT_Solutions.Pages.ComplianceManager.ComplianceDashboardModel
@{
    ViewData["Title"] = "Compliance Dashboard";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            min-height: 100vh;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
        }

        /* Summary Cards */
        .summary-cards {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin-bottom: 32px;
        }

        .summary-card {
            background: #ffffff;
            padding: 24px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            display: flex;
            flex-direction: column;
            min-height: 140px;
        }

        .summary-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(30, 64, 175, 0.2);
            border-color: #1e40af;
        }

        .summary-card h3 {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 12px;
            font-weight: 500;
            min-height: 40px;
            line-height: 1.35;
        }

        .summary-card .value {
            font-size: 32px;
            font-weight: bold;
            color: #1f2937;
            line-height: 1;
            margin-top: auto;
        }

        .summary-card.gradient-1 .value {
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .summary-card.gradient-2 .value {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .summary-card.gradient-3 .value {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .summary-card.gradient-4 .value {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .summary-card.gradient-5 .value {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Two Column Layout */
        .two-column-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }

        .column-card {
            background: #ffffff;
            padding: 24px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            overflow: hidden;
            min-width: 0;
        }

        .column-card h2 {
            font-size: 20px;
            margin-bottom: 20px;
            color: #1f2937;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .view-all-link {
            font-size: 14px;
            color: #1e40af;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .view-all-link:hover {
            color: #1e3a8a;
        }

        /* Filters */
        .filters {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .search-input, .filter-select {
            padding: 10px 14px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            color: #1f2937;
            font-size: 14px;
        }

        .search-input {
            flex: 1;
            min-width: 200px;
        }

        .filter-select {
            min-width: 150px;
        }

        .search-input::placeholder {
            color: #6b7280;
        }

        .search-input:focus, .filter-select:focus {
            outline: none;
            border-color: #1e40af;
        }

        .table-container {
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            border-radius: 10px;
        }

        .table-container .data-table {
            min-width: 600px;
        }

        /* Tables */
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table thead {
            background: #f3f4f6;
        }

        .data-table th {
            padding: 14px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            border-bottom: 1px solid #e5e7eb;
        }

        .data-table td {
            padding: 14px;
            font-size: 14px;
            color: #1f2937;
            border-bottom: 1px solid #e5e7eb;
        }

        .data-table tbody tr:hover {
            background: rgba(30, 64, 175, 0.05);
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
            white-space: nowrap;
            display: inline-block;
        }

        .status-compliant {
            color: #10b981;
        }

        .status-not-compliant {
            color: #ef4444;
        }

        /* Bottom Section */
        .bottom-section {
            background: #ffffff;
            padding: 24px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
        }

        .bottom-section h2 {
            font-size: 20px;
            margin-bottom: 20px;
            color: #1f2937;
        }

        .recent-list {
            list-style: none;
        }

        .recent-item {
            padding: 16px;
            background: #f9fafb;
            border-radius: 8px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .recent-item:last-child {
            margin-bottom: 0;
        }

        .recent-info h4 {
            font-size: 14px;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .recent-info p {
            font-size: 13px;
            color: #6b7280;
        }

        .recent-date {
            font-size: 13px;
            color: #9ca3af;
        }

        .type-badge {
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
            margin-left: 12px;
        }

        .type-employee {
            color: #1e40af;
        }

        .type-supplier {
            color: #f59e0b;
        }

        /* Archives Section */
        .archives-section {
            background: #ffffff;
            padding: 24px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            margin-top: 24px;
        }

        .archives-section h2 {
            font-size: 20px;
            margin-bottom: 20px;
            color: #1f2937;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .archives-section h2 .section-icon {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .archives-section h2 .section-icon svg {
            width: 20px;
            height: 20px;
            color: #6366f1;
        }

        .archive-table .category-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 500;
            background: #ede9fe;
            color: #6366f1;
        }

        .archive-table .archived-date {
            color: #92400e;
            font-weight: 500;
        }

        .empty-archives {
            text-align: center;
            padding: 40px 20px;
            color: #9ca3af;
        }

        .empty-archives svg {
            width: 48px;
            height: 48px;
            margin-bottom: 12px;
            color: #d1d5db;
        }

        .empty-archives p {
            font-size: 14px;
        }

        @@media (max-width: 1024px) {
            .two-column-layout {
                grid-template-columns: 1fr;
            }

            .summary-cards {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }

            .content-wrapper {
                padding: 20px;
            }

            .summary-cards {
                grid-template-columns: repeat(2, 1fr);
            }

            .filters {
                gap: 10px;
            }

            .filter-select {
                min-width: 0;
                flex: 1;
            }

            .search-input {
                min-width: 0;
                flex: 1 1 100%;
            }
        }

        @@media (max-width: 576px) {
            .content-wrapper {
                padding: 16px;
            }

            .summary-cards {
                grid-template-columns: 1fr;
                gap: 14px;
                margin-bottom: 20px;
            }

            .column-card {
                padding: 16px;
            }

            .column-card h2 {
                font-size: 16px;
                margin-bottom: 14px;
                flex-direction: column;
                align-items: flex-start;
                gap: 8px;
            }

            .filters {
                flex-direction: column;
                align-items: stretch;
            }

            .search-input,
            .filter-select {
                width: 100%;
            }

            .table-container .data-table {
                min-width: 550px;
            }

            .summary-card {
                padding: 18px;
            }

            .summary-card .value {
                font-size: 26px;
            }

            .summary-card h3 {
                font-size: 13px;
                margin-bottom: 8px;
            }

            .data-table th {
                padding: 10px;
                font-size: 11px;
            }

            .data-table td {
                padding: 10px;
                font-size: 13px;
            }

            .bottom-section {
                padding: 16px;
            }

            .bottom-section h2 {
                font-size: 16px;
            }

            .recent-item {
                padding: 12px;
                flex-direction: column;
                gap: 8px;
                align-items: flex-start;
            }

            .recent-info h4 {
                font-size: 13px;
            }

            .recent-info p {
                font-size: 12px;
            }

            .recent-date {
                font-size: 12px;
            }
        }

        @@media (max-width: 480px) {
            .two-column-layout {
                gap: 14px;
                margin-bottom: 20px;
            }

            .column-card {
                padding: 14px;
            }

            .column-card h2 {
                font-size: 15px;
                margin-bottom: 12px;
            }

            .view-all-link {
                font-size: 12px;
            }

            .search-input, .filter-select {
                padding: 8px 12px;
                font-size: 13px;
            }

            .filters {
                margin-bottom: 14px;
                gap: 8px;
            }

            .table-container .data-table {
                min-width: 480px;
            }

            .data-table th {
                padding: 8px;
                font-size: 10px;
            }

            .data-table td {
                padding: 8px;
                font-size: 12px;
            }

            .summary-card {
                padding: 16px;
            }

            .summary-card .value {
                font-size: 24px;
            }

            .bottom-section {
                padding: 14px;
            }

            .bottom-section h2 {
                font-size: 15px;
                margin-bottom: 14px;
            }
        }

        @@media (max-width: 400px) {
            .content-wrapper {
                padding: 10px;
            }

            .summary-cards {
                gap: 10px;
                margin-bottom: 16px;
            }

            .summary-card {
                padding: 14px;
                border-radius: 10px;
            }

            .summary-card .value {
                font-size: 22px;
            }

            .summary-card h3 {
                font-size: 12px;
                margin-bottom: 6px;
            }

            .two-column-layout {
                gap: 12px;
                margin-bottom: 16px;
            }

            .column-card {
                padding: 12px;
                border-radius: 10px;
            }

            .column-card h2 {
                font-size: 14px;
                margin-bottom: 10px;
            }

            .table-container .data-table {
                min-width: 420px;
            }

            .data-table th {
                padding: 7px;
                font-size: 9px;
            }

            .data-table td {
                padding: 7px;
                font-size: 11px;
            }

            .status-badge {
                font-size: 10px;
                padding: 3px 8px;
            }

            .bottom-section {
                padding: 12px;
                border-radius: 10px;
            }

            .bottom-section h2 {
                font-size: 14px;
                margin-bottom: 12px;
            }

            .recent-item {
                padding: 10px;
                margin-bottom: 8px;
            }

            .recent-info h4 {
                font-size: 12px;
            }

            .recent-info p {
                font-size: 11px;
            }

            .recent-date {
                font-size: 11px;
            }

            .type-badge {
                font-size: 10px;
                padding: 3px 8px;
            }
        }

        @@media (max-width: 360px) {
            .content-wrapper {
                padding: 8px;
            }

            .column-card {
                padding: 10px;
                border-radius: 8px;
            }

            .column-card h2 {
                font-size: 13px;
            }

            .table-container .data-table {
                min-width: 380px;
            }

            .summary-card {
                padding: 12px;
            }

            .summary-card .value {
                font-size: 20px;
            }

            .bottom-section {
                padding: 10px;
                border-radius: 8px;
            }
        }
    </style>
}

    @await Html.PartialAsync("_ComplianceManagerSidebar", "ComplianceDashboard")

    <!-- Main Content -->
    <main class="main-content flex-grow-1">
        @await Html.PartialAsync("_ComplianceManagerTopBar", (Title: "Compliance Dashboard", Description: "Overview of compliance metrics"))

        <div class="content-wrapper">

        <!-- Summary Cards -->
        <div class="summary-cards">
            <a href="/ComplianceManager/PolicyReview" class="summary-card gradient-1">
                <h3>Total Policies Assigned</h3>
                <div class="value">@Model.TotalPoliciesAssigned</div>
            </a>
            <a href="/ComplianceManager/EmployeeCompliance" class="summary-card gradient-2">
                <h3>Employees Compliant</h3>
                <div class="value">@Model.EmployeesCompliant</div>
            </a>
            <a href="/ComplianceManager/EmployeeCompliance" class="summary-card gradient-3">
                <h3>Employees Not Compliant</h3>
                <div class="value">@Model.EmployeesNotCompliant</div>
            </a>
            <a href="/ComplianceManager/SupplierCompliance" class="summary-card gradient-4">
                <h3>Suppliers Compliant</h3>
                <div class="value">@Model.SuppliersCompliant</div>
            </a>
            <a href="/ComplianceManager/PolicyArchives" class="summary-card gradient-5">
                <h3>Archived Policies</h3>
                <div class="value">@Model.TotalArchivedPolicies</div>
            </a>
        </div>

        <!-- Two Column Layout -->
        <div class="two-column-layout">
            <!-- Left Column: Employee Compliance -->
            <div class="column-card">
                <h2>
                    <span>Employee Compliance Overview</span>
                    <a href="/ComplianceManager/EmployeeCompliance" class="view-all-link">
                        View All <i class="fas fa-arrow-right"></i>
                    </a>
                </h2>
                <div class="filters">
                    <input type="text" class="search-input" id="employeeSearch" placeholder="Search employees...">
                    <select class="filter-select" id="departmentFilter">
                        <option value="">All Departments</option>
                        <option value="IT">IT</option>
                        <option value="HR">HR</option>
                        <option value="Finance">Finance</option>
                        <option value="Legal">Legal</option>
                        <option value="Operations">Operations</option>
                        <option value="Sales">Sales</option>
                    </select>
                    <select class="filter-select" id="employeeStatusFilter">
                        <option value="">All Status</option>
                        <option value="Compliant">Compliant</option>
                        <option value="Not Compliant">Not Compliant</option>
                    </select>
                </div>
                <div class="table-container">
                    <table class="data-table" id="employeeTable">
                        <thead>
                            <tr>
                                <th>Employee Name</th>
                                <th>Department</th>
                                <th>Assigned Policy</th>
                                <th>Status</th>
                                <th>Acknowledged Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var employee in Model.EmployeeCompliance)
                            {
                                <tr>
                                    <td>@employee.EmployeeName</td>
                                    <td>@employee.Department</td>
                                    <td>@employee.AssignedPolicy</td>
                                    <td>
                                        <span class="status-badge @(employee.ComplianceStatus == "Compliant" ? "status-compliant" : "status-not-compliant")">
                                            @employee.ComplianceStatus
                                        </span>
                                    </td>
                                    <td>@employee.AcknowledgedDate</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right Column: Supplier Compliance -->
            <div class="column-card">
                <h2>
                    <span>Supplier Compliance Overview</span>
                    <a href="/ComplianceManager/SupplierCompliance" class="view-all-link">
                        View All <i class="fas fa-arrow-right"></i>
                    </a>
                </h2>
                <div class="filters">
                    <input type="text" class="search-input" id="supplierSearch" placeholder="Search suppliers...">
                    <select class="filter-select" id="supplierStatusFilter">
                        <option value="">All Status</option>
                        <option value="Compliant">Compliant</option>
                        <option value="Not Compliant">Not Compliant</option>
                    </select>
                </div>
                <div class="table-container">
                    <table class="data-table" id="supplierTable">
                        <thead>
                            <tr>
                                <th>Supplier Name</th>
                                <th>Assigned Policy</th>
                                <th>Status</th>
                                <th>Assigned Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var supplier in Model.SupplierCompliance)
                            {
                                <tr>
                                    <td>@supplier.SupplierName</td>
                                    <td>@supplier.AssignedPolicy</td>
                                    <td>
                                        <span class="status-badge @(supplier.ComplianceStatus == "Compliant" ? "status-compliant" : "status-not-compliant")">
                                            @supplier.ComplianceStatus
                                        </span>
                                    </td>
                                    <td>@supplier.VerifiedDate</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Bottom Section: Recently Assigned Policies -->
        <div class="bottom-section">
            <h2>Recently Assigned Policies</h2>
            <ul class="recent-list">
                @foreach (var recent in Model.RecentlyAssigned)
                {
                    <li class="recent-item">
                        <div class="recent-info">
                            <h4>@recent.PolicyName <span class="type-badge @(recent.Type == "Employee" ? "type-employee" : "type-supplier")">@recent.Type</span></h4>
                            <p>Assigned to: @recent.AssignedTo</p>
                        </div>
                        <span class="recent-date">@recent.DateAssigned</span>
                    </li>
                }
            </ul>
        </div>

        <!-- Policy Archives Section -->
        <div class="archives-section">
            <h2>
                <span class="section-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="21 8 21 21 3 21 3 8"></polyline>
                        <rect x="1" y="3" width="22" height="5"></rect>
                        <line x1="10" y1="12" x2="14" y2="12"></line>
                    </svg>
                    Policy Archives
                </span>
                <a href="/ComplianceManager/PolicyArchives" class="view-all-link">
                    View All <i class="fas fa-arrow-right"></i>
                </a>
            </h2>

            @if (Model.RecentlyArchivedPolicies.Any())
            {
                <div class="table-container">
                    <table class="data-table archive-table" id="archiveTable">
                        <thead>
                            <tr>
                                <th>Policy Title</th>
                                <th>Category</th>
                                <th>Uploaded By</th>
                                <th>Date Uploaded</th>
                                <th>Archived Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var policy in Model.RecentlyArchivedPolicies)
                            {
                                <tr>
                                    <td>@policy.PolicyTitle</td>
                                    <td><span class="category-badge">@policy.Category</span></td>
                                    <td>@policy.UploadedBy</td>
                                    <td>@policy.DateUploaded</td>
                                    <td class="archived-date">@policy.ArchivedDate</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-archives">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="21 8 21 21 3 21 3 8"></polyline>
                        <rect x="1" y="3" width="22" height="5"></rect>
                        <line x1="10" y1="12" x2="14" y2="12"></line>
                    </svg>
                    <p>No archived policies yet.</p>
                </div>
            }
        </div>
        </div>
    </main>

@section Scripts {
    <script>
        // Employee Table Filtering
        function filterEmployeeTable() {
            const searchTerm = document.getElementById('employeeSearch').value.toLowerCase();
            const deptFilter = document.getElementById('departmentFilter').value.toLowerCase();
            const statusFilter = document.getElementById('employeeStatusFilter').value.toLowerCase();
            const table = document.getElementById('employeeTable');
            const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');

            for (let row of rows) {
                const name = row.cells[0].textContent.toLowerCase();
                const dept = row.cells[1].textContent.toLowerCase();
                const status = row.cells[3].textContent.toLowerCase();

                const matchesSearch = name.includes(searchTerm);
                const matchesDept = !deptFilter || dept === deptFilter;
                const matchesStatus = !statusFilter || status.includes(statusFilter);

                row.style.display = (matchesSearch && matchesDept && matchesStatus) ? '' : 'none';
            }
        }

        // Supplier Table Filtering
        function filterSupplierTable() {
            const searchTerm = document.getElementById('supplierSearch').value.toLowerCase();
            const statusFilter = document.getElementById('supplierStatusFilter').value.toLowerCase();
            const table = document.getElementById('supplierTable');
            const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');

            for (let row of rows) {
                const name = row.cells[0].textContent.toLowerCase();
                const status = row.cells[2].textContent.toLowerCase();

                const matchesSearch = name.includes(searchTerm);
                const matchesStatus = !statusFilter || status.includes(statusFilter);

                row.style.display = (matchesSearch && matchesStatus) ? '' : 'none';
            }
        }

        // Event Listeners
        document.getElementById('employeeSearch').addEventListener('keyup', filterEmployeeTable);
        document.getElementById('departmentFilter').addEventListener('change', filterEmployeeTable);
        document.getElementById('employeeStatusFilter').addEventListener('change', filterEmployeeTable);
        document.getElementById('supplierSearch').addEventListener('keyup', filterSupplierTable);
        document.getElementById('supplierStatusFilter').addEventListener('change', filterSupplierTable);
    </script>
}
