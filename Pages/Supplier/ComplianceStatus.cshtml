@page
@model TechNova_IT_Solutions.Pages.Supplier.ComplianceStatusModel
@{
    ViewData["Title"] = "Compliance Status";
    Layout = "_Layout";
}

@section Styles {
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            min-height: 100vh;
        }

        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .section-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 28px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            color: white;
        }

        .section-title-icon svg {
            width: 18px;
            height: 18px;
        }

        .policy-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .policy-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background: #f3f4f6;
            border-radius: 8px;
            transition: background 0.2s;
            gap: 16px;
        }

        .policy-item:hover {
            background: #e5e7eb;
        }

        .policy-name {
            font-size: 14px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .policy-meta {
            font-size: 12px;
            color: #6b7280;
        }

        .policy-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            white-space: nowrap;
        }

        .policy-badge.compliant {
            background: rgba(72, 187, 120, 0.1);
            color: #48bb78;
        }

        .policy-badge.pending {
            background: rgba(246, 173, 85, 0.12);
            color: #d97706;
        }

        .policy-badge.noncompliant {
            background: rgba(252, 129, 129, 0.12);
            color: #dc2626;
        }

        @@media (max-width: 991px) {
            .main-content {
                margin-left: 0;
            }
        }

        @@media (max-width: 576px) {
            .section-card {
                padding: 18px;
            }

            .policy-item {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

@await Html.PartialAsync("_SupplierSidebar", "ComplianceStatus")

<div class="main-content flex-grow-1">
    @await Html.PartialAsync("_SupplierTopBar", (Title: "Compliance Status", Description: "View your current compliance status for all assigned policies"))

    <div class="content-wrapper">
        <div class="section-card">
            <div class="section-title">
                <div class="section-title-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>
                Status by Policy
            </div>

            <div class="policy-list">
                @if (Model.Policies.Any())
                {
                    @foreach (var policy in Model.Policies)
                    {
                        var badgeClass = policy.Status == "Compliant" ? "compliant" : (policy.Status == "Non-Compliant" ? "noncompliant" : "pending");
                        <div class="policy-item">
                            <div>
                                <div class="policy-name">@policy.PolicyTitle</div>
                                <div class="policy-meta">Assigned on @policy.AssignedDate.ToString("MMM dd, yyyy")</div>
                            </div>
                            <span class="policy-badge @badgeClass">@policy.Status</span>
                        </div>
                    }
                }
                else
                {
                    <div class="policy-item">
                        <div>
                            <div class="policy-name">No policies currently assigned.</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
