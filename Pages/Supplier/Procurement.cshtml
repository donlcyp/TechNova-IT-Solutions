@page
@model TechNova_IT_Solutions.Pages.Supplier.ProcurementModel
@{
    ViewData["Title"] = "Procurement Requests";
    Layout = "_Layout";
}

@section Styles {
    <style>
        .main-content {
            margin-left: 260px;
            flex: 1;
            overflow-y: auto;
        }

        .content-wrapper {
            padding: 24px;
            max-width: 1260px;
            margin: 0 auto;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
            margin-bottom: 20px;
        }

        .summary-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 18px 20px;
        }

        .summary-label {
            color: #6b7280;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 8px;
            font-weight: 700;
        }

        .summary-value {
            color: #1f2937;
            font-size: 28px;
            font-weight: 700;
            line-height: 1;
        }

        .section-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 14px;
            color: #1f2937;
            letter-spacing: 0.2px;
        }

        .section-subtitle {
            color: #64748b;
            font-size: 14px;
            margin-bottom: 14px;
        }

        .stock-alerts {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 12px;
        }

        .stock-alert {
            border-radius: 10px;
            padding: 10px 12px;
            border: 1px solid #e5e7eb;
            font-size: 13px;
            font-weight: 600;
        }

        .stock-alert.low {
            color: #92400e;
            background: #fffbeb;
            border-color: #fcd34d;
        }

        .stock-alert.out {
            color: #991b1b;
            background: #fef2f2;
            border-color: #fca5a5;
        }

        .section-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 10px;
            margin-bottom: 12px;
        }

        .form-input {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            padding: 10px;
            font-size: 14px;
            background: #ffffff;
        }

        .form-input:focus {
            outline: none;
            border-color: #1e40af;
            box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.12);
        }

        .btn {
            border: none;
            border-radius: 8px;
            padding: 10px 12px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.2s ease;
        }

        .btn:hover {
            transform: translateY(-1px);
        }

        .btn-primary { background: #1e40af; color: #fff; }
        .btn-success { background: #16a34a; color: #fff; }
        .btn-danger { background: #dc2626; color: #fff; }
        .btn-light { background: #eef2ff; color: #1e40af; border: 1px solid #c7d2fe; }

        .table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 760px;
        }

        th, td {
            text-align: left;
            border-top: 1px solid #e5e7eb;
            padding: 10px;
            font-size: 14px;
            color: #1f2937;
            vertical-align: top;
        }

        thead th {
            color: #64748b;
            text-transform: uppercase;
            font-size: 12px;
            background: #f8fafc;
            border-top: none;
            font-weight: 700;
        }

        .empty-row {
            color: #64748b;
            text-align: center;
            padding: 22px 10px;
            font-style: italic;
            background: #fcfdff;
        }

        .status-pill {
            display: inline-block;
            padding: 0;
            border-radius: 0;
            font-size: 12px;
            font-weight: 700;
            background: transparent;
        }

        .status-available {
            color: #166534;
        }

        .status-low {
            color: #92400e;
        }

        .status-out {
            color: #991b1b;
        }

        .status-submitted { color: #d97706; }
        .status-supplierapproved { color: #16a34a; }
        .status-late { color: #dc2626; }
        .status-supplierrejected { color: #dc2626; }
        .status-shipped { color: #2563eb; }
        .status-received, .status-closed { color: #047857; }

        .response-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

        .modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.5);
            z-index: 1100;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .modal.active {
            display: flex;
        }

        .modal-card {
            width: 100%;
            max-width: 540px;
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 20px 48px rgba(15, 23, 42, 0.2);
            overflow: hidden;
        }

        .modal-header {
            padding: 16px 18px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-title {
            font-size: 18px;
            font-weight: 700;
            color: #0f172a;
        }

        .modal-close {
            border: none;
            background: #f1f5f9;
            color: #334155;
            width: 34px;
            height: 34px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 18px;
        }

        .modal-body {
            padding: 18px;
            display: grid;
            gap: 12px;
        }

        .modal-footer {
            border-top: 1px solid #e5e7eb;
            padding: 14px 18px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .action-group {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .toast-wrap {
            position: fixed;
            right: 18px;
            bottom: 18px;
            z-index: 1200;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .toast {
            min-width: 260px;
            max-width: 360px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-left: 4px solid #1e40af;
            border-radius: 10px;
            padding: 10px 12px;
            color: #0f172a;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
            font-size: 14px;
            font-weight: 600;
        }

        .toast.error {
            border-left-color: #dc2626;
        }

        .toast.success {
            border-left-color: #16a34a;
        }

        @@media (max-width: 991px) {
            .main-content { margin-left: 0; }
            .summary-grid { grid-template-columns: 1fr; }
            .stock-alerts { grid-template-columns: 1fr; }
            .form-grid { grid-template-columns: 1fr; }
            .response-grid { grid-template-columns: 1fr; }
            .section-title { font-size: 20px; }
            .content-wrapper { padding: 16px; }
        }
    .loading-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,42,.6); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:16px; }
    .loading-overlay.active { display:flex; }
    .loading-spinner { width:48px; height:48px; border:4px solid rgba(255,255,255,.3); border-top:4px solid #fff; border-radius:50%; animation:spin .8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
}

<div class="loading-overlay" id="loadingOverlay"><div class="loading-spinner"></div><div id="loadingText" style="color:#fff;font-size:16px;font-weight:500;">Processing...</div></div>
@await Html.PartialAsync("_SupplierSidebar", "Procurement")

<div class="main-content">
    @await Html.PartialAsync("_SupplierTopBar", (Title: "Procurement Requests", Description: "Manage inventory and respond to procurement steps"))

    <div class="content-wrapper">
        <div class="summary-grid">
            <div class="summary-card">
                <div class="summary-label">Pending Requests</div>
                <div class="summary-value" id="pendingCount">0</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Approved Requests</div>
                <div class="summary-value" id="approvedCount">0</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Inventory Items</div>
                <div class="summary-value" id="inventoryCount">0</div>
            </div>
        </div>

        <div class="section-card">
            <div class="section-head">
                <div class="section-title">Procurement Requests</div>
                <div class="section-subtitle">Respond to submitted requests with approval + ship date, or reject with a reason.</div>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Status</th>
                            <th>Response Deadline</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="procurementRows"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

