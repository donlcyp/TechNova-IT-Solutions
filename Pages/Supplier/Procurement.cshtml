<div id="toastWrap" class="toast-wrap"></div>

    @section Scripts {
    <script>
        function showLoading(msg) { document.getElementById('loadingText').textContent = msg || 'Processing...'; document.getElementById('loadingOverlay').classList.add('active'); }
        function hideLoading() { document.getElementById('loadingOverlay').classList.remove('active'); }

        const modalFocusState = {
            itemModal: null,
            stockModal: null
        };

        function setModalState(modalId, isOpen) {
            const modal = document.getElementById(modalId);
            if (!modal) return;

            if (isOpen) {
                modal.classList.add('active');
                modal.setAttribute('aria-hidden', 'false');
                modal.removeAttribute('inert');
                return;
            }

            // Move focus out of modal before hiding it to avoid aria-hidden focus violations
            if (modal.contains(document.activeElement)) {
                document.activeElement.blur();
            }

            modal.classList.remove('active');
            modal.setAttribute('aria-hidden', 'true');
            modal.setAttribute('inert', '');

            const returnTarget = modalFocusState[modalId];
            if (returnTarget && typeof returnTarget.focus === 'function') {
                returnTarget.focus();
            }
            modalFocusState[modalId] = null;
        }

        function showToast(message, type = 'success') {
            const wrap = document.getElementById('toastWrap');
            const el = document.createElement('div');
            el.className = `toast ${type}`;
            el.textContent = message;
            wrap.appendChild(el);
            setTimeout(() => {
                el.remove();
            }, 2800);
        }

        function openItemModal() {
            modalFocusState.itemModal = document.activeElement;
            setModalState('itemModal', true);
            document.getElementById('itemName').focus();
        }

        function closeItemModal() {
            setModalState('itemModal', false);
        }

        let selectedStockItemId = 0;
        function openStockModal(itemId, itemName) {
            modalFocusState.stockModal = document.activeElement;
            selectedStockItemId = itemId;
            document.getElementById('stockItemName').value = itemName;
            document.getElementById('addStockQty').value = '';
            setModalState('stockModal', true);
            document.getElementById('addStockQty').focus();
        }

        function closeStockModal() {
            setModalState('stockModal', false);
            selectedStockItemId = 0;
        }

        async function saveAddedStock() {
            const addQty = parseInt(document.getElementById('addStockQty').value || '0');
            if (!selectedStockItemId || addQty <= 0) {
                showToast('Please enter a valid stock quantity.', 'error');
                return;
            }

            const _t = setTimeout(() => showLoading('Adding stock...'), 300);
            try {
                const res = await fetch('/Supplier/AddInventoryStock', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        supplierItemId: selectedStockItemId,
                        addQuantity: addQty
                    })
                });
                const json = await res.json();
                clearTimeout(_t); hideLoading();
                if (!json.success) {
                    showToast(json.message || 'Failed to add stock', 'error');
                    return;
                }

                closeStockModal();
                showToast('Stock added successfully.', 'success');
                await loadInventory();
            } catch { clearTimeout(_t); hideLoading(); showToast('Error adding stock', 'error'); }
        }

        async function loadInventory() {
            try {
                const res = await fetch('/Supplier/GetInventory');
                const json = await res.json();
                if (!json.success) return;
                document.getElementById('inventoryCount').textContent = json.items.length;
            } catch { /* silent — inventory count is non-critical */ }
        }

        async function saveItem() {
            const itemName = document.getElementById('itemName').value.trim();
            const category = document.getElementById('itemCategory').value.trim();
            const unitPrice = parseFloat(document.getElementById('itemUnitPrice').value || '0');
            const currencyCode = (document.getElementById('itemCurrencyCode').value || '').trim().toUpperCase();
            const quantity = parseInt(document.getElementById('itemQuantity').value || '0');
            const supplierItemId = parseInt(document.getElementById('itemName').dataset.supplierItemId || '0');
            if (!itemName) { showToast('Item name is required', 'error'); return; }
            if (!Number.isFinite(unitPrice) || unitPrice <= 0) { showToast('Unit price must be greater than zero', 'error'); return; }
            if (currencyCode.length !== 3) { showToast('Currency must be a 3-letter code', 'error'); return; }

            const _t = setTimeout(() => showLoading('Saving inventory item...'), 300);
            try {
                const res = await fetch('/Supplier/UpsertInventoryItem', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        supplierItemId: supplierItemId > 0 ? supplierItemId : 0,
                        itemName,
                        category,
                        unitPrice,
                        currencyCode,
                        quantityAvailable: quantity
                    })
                });

                const json = await res.json();
                clearTimeout(_t); hideLoading();
                if (!json.success) { showToast(json.message || 'Save failed', 'error'); return; }
                document.getElementById('itemName').value = '';
                document.getElementById('itemCategory').value = '';
                document.getElementById('itemUnitPrice').value = '';
                document.getElementById('itemCurrencyCode').value = 'PHP';
                document.getElementById('itemQuantity').value = '';
                closeItemModal();
                showToast('Inventory item saved', 'success');
                await loadInventory();
            } catch { clearTimeout(_t); hideLoading(); showToast('Error saving inventory item', 'error'); }
        }

        function openEditPriceModal(supplierItemId, itemName, category, quantityAvailable, unitPrice, currencyCode) {
            openItemModal();
            document.querySelector('#itemModal .modal-title').textContent = 'Edit Unit Price';
            document.getElementById('itemName').value = itemName || '';
            document.getElementById('itemCategory').value = category || '';
            document.getElementById('itemUnitPrice').value = Number(unitPrice || 0).toFixed(2);
            document.getElementById('itemCurrencyCode').value = (currencyCode || 'PHP').toUpperCase();
            document.getElementById('itemQuantity').value = quantityAvailable ?? 0;

            document.getElementById('itemName').dataset.supplierItemId = supplierItemId;
            document.getElementById('itemName').readOnly = true;
            document.getElementById('itemCategory').disabled = true;
            document.getElementById('itemQuantity').readOnly = true;
        }

        async function loadProcurements() {
            try {
            const res = await fetch('/Supplier/GetProcurementRequests');
            const json = await res.json();
            if (!json.success) return;
            const tbody = document.getElementById('procurementRows');
            tbody.innerHTML = '';
            const requests = json.requests || [];

            const pending = requests.filter(r => r.status === 'Submitted').length;
            const approved = requests.filter(r => r.status === 'SupplierApproved' || r.status === 'Late').length;
            document.getElementById('pendingCount').textContent = pending;
            document.getElementById('approvedCount').textContent = approved;

            if (!requests.length) {
                tbody.innerHTML = '<tr><td colspan="6" class="empty-row">No procurement requests yet.</td></tr>';
                return;
            }

            requests.forEach(req => {
                const canRespond = req.status === 'Submitted';
                const canReportDelay = req.status === 'SupplierApproved' || req.status === 'Late';
                const todayIso = new Date().toISOString().split('T')[0];
                const minRevisedIso = req.supplierCommitShipDate
                    ? new Date(new Date(req.supplierCommitShipDate).getTime() + 86400000).toISOString().split('T')[0]
                    : todayIso;
                const deadline = req.supplierResponseDeadline ? new Date(req.supplierResponseDeadline).toLocaleDateString() : '';
                const rejectReason = req.rejectionReason ? `<div style="font-size:12px;color:#dc2626;">Reason: ${req.rejectionReason}</div>` : '';
                const delayReason = req.delayReason ? `<div style="font-size:12px;color:#b91c1c;">Delay: ${req.delayReason}</div>` : '';
                const revisedDelivery = req.revisedDeliveryDate ? `<div style="font-size:12px;color:#334155;">Revised delivery: ${new Date(req.revisedDeliveryDate).toLocaleDateString()}</div>` : '';
                tbody.innerHTML += `
                    <tr>
                        <td>PROC-${String(req.procurementId).padStart(3, '0')}</td>
                        <td>${req.itemName || ''}</td>
                        <td>${req.quantity || 0}</td>
                        <td>
                            <span class="status-pill status-${(req.status || '').toLowerCase()}">${req.status || ''}</span>
                            ${rejectReason}
                            ${delayReason}
                            ${revisedDelivery}
                        </td>
                        <td>${deadline}</td>
                        <td>
                            ${canRespond ? `
                            <div class="response-grid">
                                <input type="date" class="form-input" id="ship-${req.procurementId}" min="${todayIso}" value="${todayIso}">
                                <button class="btn btn-success" type="button" onclick="respondApprove(${req.procurementId})">Approve</button>
                                <input class="form-input" id="reason-${req.procurementId}" placeholder="Reject reason (required)">
                                <button class="btn btn-danger" type="button" onclick="respondReject(${req.procurementId})">Reject</button>
                            </div>` : canReportDelay ? `
                            <div class="response-grid">
                                <input type="date" class="form-input" id="revised-${req.procurementId}" min="${minRevisedIso}" value="${req.revisedDeliveryDate ? new Date(req.revisedDeliveryDate).toISOString().split('T')[0] : ''}">
                                <button class="btn btn-danger" type="button" onclick="reportDelay(${req.procurementId})">Report Delay</button>
                                <input class="form-input" id="delay-${req.procurementId}" placeholder="Delay reason (required)" value="${(req.delayReason || '').replace(/"/g, '&quot;')}">
                                <span style="color:#6b7280;font-size:12px;align-self:center;">Required when late.</span>
                            </div>` : `<span style="color:#6b7280;">No action</span>`}
                        </td>
                    </tr>`;
            });
            } catch { /* silent — procurement list is refreshed on next user action */ }
        }

        async function respondApprove(procurementId) {
            const shipDateInput = document.getElementById(`ship-${procurementId}`);
            const shipDate = shipDateInput?.value;
            if (!shipDate) { showToast('Ship date is required', 'error'); return; }
            if (shipDateInput?.min && shipDate < shipDateInput.min) {
                showToast('Ship date cannot be earlier than today.', 'error');
                return;
            }

            const _t = setTimeout(() => showLoading('Approving procurement request...'), 300);
            try {
                const res = await fetch('/Supplier/RespondToProcurement', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        procurementId,
                        approve: true,
                        supplierCommitShipDate: `${shipDate}T00:00:00`
                    })
                });

                let json = null;
                try {
                    json = await res.json();
                } catch {
                    json = null;
                }

                clearTimeout(_t); hideLoading();
                if (!res.ok || !json?.success) {
                    showToast(json?.message || 'Failed to approve request. Please refresh and try again.', 'error');
                    return;
                }

                showToast('Request approved', 'success');
                await loadProcurements();
            } catch {
                clearTimeout(_t); hideLoading();
                showToast('Network error while approving request.', 'error');
            }
        }

        async function respondReject(procurementId) {
            const reason = document.getElementById(`reason-${procurementId}`).value.trim();
            if (!reason) { showToast('Reject reason is required', 'error'); return; }
            const _t = setTimeout(() => showLoading('Rejecting request...'), 300);
            try {
                const res = await fetch('/Supplier/RespondToProcurement', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        procurementId,
                        approve: false,
                        rejectionReason: reason
                    })
                });
                const json = await res.json();
                clearTimeout(_t); hideLoading();
                if (!json.success) { showToast(json.message || 'Failed', 'error'); return; }
                showToast('Request rejected', 'success');
                await loadProcurements();
            } catch { clearTimeout(_t); hideLoading(); showToast('Network error while rejecting request.', 'error'); }
        }

        async function reportDelay(procurementId) {
            const delayReason = document.getElementById(`delay-${procurementId}`).value.trim();
            const revisedInput = document.getElementById(`revised-${procurementId}`);
            const revisedDeliveryDate = revisedInput.value;

            if (!delayReason) { showToast('Delay reason is required', 'error'); return; }
            if (!revisedDeliveryDate) { showToast('Revised delivery date is required', 'error'); return; }
            if (revisedInput.min && revisedDeliveryDate < revisedInput.min) {
                showToast('Revised delivery must be after the original committed ship date and not in the past.', 'error');
                return;
            }

            const _t = setTimeout(() => showLoading('Reporting delay...'), 300);
            try {
                const res = await fetch('/Supplier/ReportDelay', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        procurementId,
                        delayReason,
                        revisedDeliveryDate
                    })
                });
                const json = await res.json();
                clearTimeout(_t); hideLoading();
                if (!json.success) { showToast(json.message || 'Failed to report delay', 'error'); return; }
                showToast('Delay reported and escalated', 'success');
                await loadProcurements();
            } catch { clearTimeout(_t); hideLoading(); showToast('Network error while reporting delay.', 'error'); }
        }

        document.addEventListener('DOMContentLoaded', async function () {
            setModalState('itemModal', false);

            await loadInventory();
            await loadProcurements();

            document.getElementById('itemModal').addEventListener('click', function (e) {
                if (e.target === this) closeItemModal();
            });
        });

        function resetItemModalState() {
            document.querySelector('#itemModal .modal-title').textContent = 'Add Inventory Item';
            const itemNameInput = document.getElementById('itemName');
            itemNameInput.dataset.supplierItemId = '';
            itemNameInput.readOnly = false;
            document.getElementById('itemCategory').disabled = false;
            document.getElementById('itemQuantity').readOnly = false;
        }

        const _originalOpenItemModal = openItemModal;
        openItemModal = function() {
            resetItemModalState();
            _originalOpenItemModal();
        };

        const _originalCloseItemModal = closeItemModal;
        closeItemModal = function() {
            resetItemModalState();
            _originalCloseItemModal();
        };
    </script>
}
