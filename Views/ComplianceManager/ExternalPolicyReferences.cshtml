        <a href="/Account/Logout" class="logout-btn" title="Logout" onclick="return confirm('Are you sure you want to logout?');">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            <span class="logout-text">Logout</span>
        </a>
    </div>
    }

    <!-- ==================== MAIN CONTENT ==================== -->
    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div class="page-title-area">
                <h1>External Policy References</h1>
                <p>Federal regulations mapped to TechNova's compliance policy areas</p>
            </div>
            <div class="account-section">
                <div class="account-info">
                    <h4>@userName</h4>
                    <p>@(userRole == "Admin" ? "Administrator" : "Compliance Officer")</p>
                </div>
                <div class="account-avatar">@initials</div>
            </div>
        </div>

        <div class="content-wrapper">
            <!-- API Status Bar -->
            <div class="api-status-bar">
                <div class="api-info">
                    <span class="api-dot"></span>
                    <span class="api-text">Connected to Federal Register API</span>
                </div>
                <span class="api-source">Source: federalregister.gov/api/v1</span>
            </div>

            <!-- Stats Row -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon" style="background: #eff6ff; color: #1e40af;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">@(Model?.Count ?? 0)</div>
                        <div class="stat-label">Total References</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #f0fdf4; color: #15803d;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">@grouped.Count</div>
                        <div class="stat-label">Categories Found</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #fef3c7; color: #d97706;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">7</div>
                        <div class="stat-label">TechNova Policies Mapped</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: #f3e8ff; color: #7c3aed;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                    </div>
                    <div class="stat-info">
                        <div class="stat-value">Live</div>
                        <div class="stat-label">API Status</div>
                    </div>
                </div>
            </div>

            <!-- Filter Section -->
            <div class="filter-section">
                <div class="filter-label">Filter by Policy Category</div>
                <div class="filter-tabs">
                    <button class="filter-tab active" onclick="filterCategory('all', this)">
                        All Categories <span class="tab-count">@(Model?.Count ?? 0)</span>
                    </button>
                    @foreach (var group in grouped)
                    {
                        var icon = icons.ContainsKey(group.Key) ? icons[group.Key] : "📄";
                        <button class="filter-tab" onclick="filterCategory('@group.Key.Replace("'", "\\'")', this)">
                            @icon @group.Key <span class="tab-count">@group.Count()</span>
                        </button>
                    }
                </div>
            </div>

            <!-- Category Sections -->
            @if (Model != null && Model.Any())
            {
                foreach (var group in grouped)
                {
                    var icon = icons.ContainsKey(group.Key) ? icons[group.Key] : "📄";
                    var color = colorMap.ContainsKey(group.Key) ? colorMap[group.Key] : "#6b7280";

                    <div class="category-section" data-category="@group.Key">
                        <div class="category-header">
                            <div class="category-icon-box" style="background: @(color)15;">
                                <span>@icon</span>
                            </div>
                            <div class="category-title-area">
                                <div class="category-title">@group.Key</div>
                                <div class="category-subtitle">Federal regulations related to this policy area</div>
                            </div>
                            <span class="category-count-badge" style="background: @(color)15; color: @color;">
                                @group.Count() reference@(group.Count() != 1 ? "s" : "")
                            </span>
                        </div>
                        <div class="category-body">
                            @foreach (var policy in group)
                            {
                                <div class="policy-card">
                                    <div class="policy-card-header">
                                        <div class="policy-title">@policy.PolicyTitle</div>
                                        <span class="policy-type-badge" style="background: @(color)15; color: @color;">
                                            @group.Key.Split(' ')[0]
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(policy.Description))
                                    {
                                        <div class="policy-description">@policy.Description</div>
                                    }
                                    <div class="policy-footer">
                                        @if (!string.IsNullOrEmpty(policy.DocumentNumber))
                                        {
                                            <span class="doc-number-chip">@policy.DocumentNumber</span>
                                        }
                                        <span class="meta-chip">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                                            <strong>@policy.SourceApi</strong>
                                        </span>
                                        @if (policy.DateUploaded.HasValue)
                                        {
                                            <span class="meta-chip">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                                @policy.DateUploaded.Value.ToString("MMM dd, yyyy")
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(policy.ExternalUrl))
                                        {
                                            <a href="@policy.ExternalUrl" target="_blank" class="view-link">
                                                View Full Document
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                    <h3>No External Policy References Found</h3>
                    <p>The Federal Register API may be temporarily unavailable. Please try again later.</p>
                </div>
            }
        </div>
    </main>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('pageSidebar');
            sidebar.classList.toggle('collapsed');
            localStorage.setItem('apiPageSidebarCollapsed', sidebar.classList.contains('collapsed'));
        }

        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('pageSidebar');
            if (localStorage.getItem('apiPageSidebarCollapsed') === 'true') {
                sidebar.classList.add('collapsed');
            }
        });

        function filterCategory(cat, btn) {
            document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');

            document.querySelectorAll('.category-section').forEach(section => {
                section.style.display = (cat === 'all' || section.dataset.category === cat) ? '' : 'none';
            });
        }
    </script>
</body>
</html>
