@model List<TechNova_IT_Solutions.Models.ExternalPolicyData>
@{
    Layout = null;
    ViewData["Title"] = "External Policy References";
    var category = ViewBag.Category as string ?? "all";
    var userRole = ViewBag.UserRole as string ?? "ComplianceManager";
    var userName = Context.Session.GetString("UserName") ?? "User";
    var nameParts = userName.Split(' ');
    var initials = nameParts.Length >= 2
        ? $"{nameParts[0][0]}{nameParts[1][0]}"
        : userName.Length >= 2 ? userName.Substring(0, 2).ToUpper() : userName[0].ToString().ToUpper();

    var grouped = Model?.GroupBy(p => p.Category)
        .OrderBy(g => g.Key)
        .ToList() ?? new List<IGrouping<string, TechNova_IT_Solutions.Models.ExternalPolicyData>>();

    var icons = new Dictionary<string, string>
    {
        ["Information Security Policy"]     = "🔐",
        ["Data Privacy Policy"]             = "🗄️",
        ["Acceptable Use of IT Resources"]  = "💻",
        ["Employee Code of Conduct"]        = "🧑‍💼",
        ["Procurement Policy"]              = "🛒",
        ["Supplier Compliance Policy"]      = "🏢",
        ["Document Retention Policy"]       = "📁"
    };

    var colorMap = new Dictionary<string, string>
    {
        ["Information Security Policy"]     = "#dc2626",
        ["Data Privacy Policy"]             = "#7c3aed",
        ["Acceptable Use of IT Resources"]  = "#0284c7",
        ["Employee Code of Conduct"]        = "#059669",
        ["Procurement Policy"]              = "#d97706",
        ["Supplier Compliance Policy"]      = "#0891b2",
        ["Document Retention Policy"]       = "#6366f1"
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - TechNova IT Solutions</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f8f9fa;
            color: #1f2937;
            display: flex;
            min-height: 100vh;
        }

        /* ==================== SIDEBAR ==================== */
        .sidebar {
            width: 260px;
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            transition: width 0.3s ease;
            z-index: 50;
        }
        .sidebar.collapsed { width: 70px; }
        .logo {
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 8px;
        }
        .logo-text { font-size: 18px; font-weight: 700; color: #1e40af; white-space: nowrap; }
        .sidebar.collapsed .logo-text { display: none; }
        .logo-image { height: 45px; width: auto; object-fit: contain; }
        .sidebar.collapsed .logo-image { height: 32px; }
        .toggle-btn {
            background: #f3f4f6; border: none; color: #6b7280;
            padding: 12px; margin: 8px 16px; border-radius: 8px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: all 0.3s;
        }
        .toggle-btn svg { width: 24px; height: 24px; }
        .toggle-btn:hover { background: #e5e7eb; color: #1e40af; }
        .nav-menu { flex: 1; padding: 8px 0; overflow-y: auto; }
        .nav-item {
            padding: 14px 24px; color: #6b7280; text-decoration: none;
            display: flex; align-items: center; gap: 12px;
            transition: all 0.3s; font-size: 14px; font-weight: 500; white-space: nowrap;
        }
        .nav-item:hover { background: rgba(30, 64, 175, 0.1); color: #1e40af; }
        .nav-item.active {
            background: linear-gradient(90deg, rgba(30, 64, 175, 0.15) 0%, transparent 100%);
            color: #1e40af; border-left: 3px solid #1e40af;
        }
        .nav-item svg { width: 24px; height: 24px; min-width: 24px; }
        .logout-btn {
            padding: 16px 24px; border-top: 1px solid #e5e7eb;
            display: flex; align-items: center; gap: 12px;
            color: #ef4444; text-decoration: none; transition: all 0.3s;
            margin-top: auto; white-space: nowrap; font-size: 15px; font-weight: 500;
        }
        .logout-btn:hover { background: rgba(239, 68, 68, 0.1); }
        .logout-btn svg { width: 24px; height: 24px; min-width: 24px; }
        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .logout-text { display: none; }
        .sidebar.collapsed .logo { justify-content: center; }
        .sidebar.collapsed .nav-item { justify-content: center; padding: 12px; }
        .sidebar.collapsed .logout-btn { justify-content: center; padding: 16px; }
        body:has(.sidebar.collapsed) .main-content { margin-left: 70px !important; }

        /* ==================== TOP BAR ==================== */
        .top-bar {
            background: #ffffff; border-bottom: 1px solid #e5e7eb;
            padding: 24px 32px; display: flex; justify-content: space-between;
            align-items: center; position: sticky; top: 0; z-index: 10;
        }
        .top-bar .page-title-area { display: flex; flex-direction: column; gap: 2px; }
        .top-bar .page-title-area h1 { font-size: 32px; font-weight: 700; color: #1f2937; margin: 0; line-height: 1.2; }
        .top-bar .page-title-area p { color: #6b7280; font-size: 15px; margin: 0; }
        .account-section { display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
        .account-info { text-align: right; display: flex; flex-direction: column; gap: 2px; }
        .account-info h4 { font-size: 14px; font-weight: 600; color: #1f2937; margin: 0; }
        .account-info p { font-size: 13px; color: #6b7280; margin: 0; }
        .account-avatar {
            width: 44px; height: 44px; border-radius: 12px;
            background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%);
            display: flex; align-items: center; justify-content: center;
            font-weight: 600; font-size: 18px; color: white; flex-shrink: 0;
        }

        /* ==================== MAIN CONTENT ==================== */
        .main-content { margin-left: 260px; flex: 1; overflow-y: auto; }
        .content-wrapper { padding: 32px; }

        /* ==================== STATS ROW ==================== */
        .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
        .stat-card {
            background: #ffffff; border-radius: 12px; padding: 24px;
            border: 1px solid #e5e7eb; display: flex; align-items: center; gap: 16px;
        }
        .stat-icon {
            width: 52px; height: 52px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .stat-icon svg { width: 26px; height: 26px; }
        .stat-info { display: flex; flex-direction: column; }
        .stat-value { font-size: 28px; font-weight: 700; color: #1f2937; line-height: 1.2; }
        .stat-label { font-size: 13px; color: #6b7280; font-weight: 500; margin-top: 2px; }

        /* ==================== API STATUS ==================== */
        .api-status-bar {
            background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px;
            padding: 16px 24px; margin-bottom: 24px;
            display: flex; align-items: center; justify-content: space-between;
        }
        .api-info { display: flex; align-items: center; gap: 12px; }
        .api-dot { width: 10px; height: 10px; background: #10b981; border-radius: 50%; animation: pulse 2s infinite; }
        @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .api-text { font-size: 14px; color: #374151; font-weight: 500; }
        .api-source { font-size: 12px; color: #6b7280; background: #f3f4f6; padding: 4px 12px; border-radius: 6px; }

        /* ==================== FILTER TABS ==================== */
        .filter-section {
            background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px;
            padding: 20px 24px; margin-bottom: 24px;
        }
        .filter-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
        .filter-tabs { display: flex; flex-wrap: wrap; gap: 8px; }
        .filter-tab {
            padding: 8px 18px; border-radius: 8px; border: 1px solid #e5e7eb;
            background: #ffffff; color: #6b7280; font-size: 13px; font-weight: 500;
            cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
        }
        .filter-tab:hover { border-color: #1e40af; color: #1e40af; background: #eff6ff; }
        .filter-tab.active { background: #1e40af; color: white; border-color: #1e40af; }
        .filter-tab .tab-count {
            background: rgba(255,255,255,0.2); padding: 1px 8px; border-radius: 10px;
            font-size: 11px; font-weight: 600;
        }
        .filter-tab.active .tab-count { background: rgba(255,255,255,0.3); }

        /* ==================== CATEGORY SECTIONS ==================== */
        .category-section {
            background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px;
            margin-bottom: 24px; overflow: hidden;
        }
        .category-header {
            display: flex; align-items: center; gap: 14px;
            padding: 20px 24px; border-bottom: 1px solid #e5e7eb;
        }
        .category-icon-box {
            width: 44px; height: 44px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; flex-shrink: 0;
        }
        .category-title-area { flex: 1; }
        .category-title { font-size: 18px; font-weight: 700; color: #1f2937; }
        .category-subtitle { font-size: 13px; color: #6b7280; margin-top: 2px; }
        .category-count-badge {
            padding: 4px 14px; border-radius: 20px;
            font-size: 12px; font-weight: 600; flex-shrink: 0;
        }
        .category-body { padding: 16px 24px; }

        /* ==================== POLICY CARDS ==================== */
        .policy-card {
            background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px;
            padding: 20px; margin-bottom: 12px; transition: all 0.2s;
        }
        .policy-card:hover { border-color: #93c5fd; box-shadow: 0 2px 8px rgba(30, 64, 175, 0.08); transform: translateY(-1px); }
        .policy-card:last-child { margin-bottom: 0; }
        .policy-card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
        .policy-title { font-size: 15px; font-weight: 600; color: #1f2937; line-height: 1.5; flex: 1; }
        .policy-type-badge {
            padding: 3px 10px; border-radius: 6px; font-size: 11px;
            font-weight: 600; white-space: nowrap; flex-shrink: 0;
        }
        .policy-description {
            color: #6b7280; font-size: 14px; line-height: 1.7; margin-bottom: 14px;
            display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
        }
        .policy-footer {
            display: flex; flex-wrap: wrap; align-items: center; gap: 12px;
            padding-top: 14px; border-top: 1px solid #e5e7eb;
        }
        .meta-chip {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 12px; color: #6b7280; background: #f3f4f6;
            padding: 4px 10px; border-radius: 6px;
        }
        .meta-chip svg { width: 14px; height: 14px; }
        .meta-chip strong { color: #374151; }
        .doc-number-chip {
            font-family: 'Courier New', monospace; background: #e0e7ff;
            color: #3730a3; padding: 4px 10px; border-radius: 6px;
            font-size: 12px; font-weight: 600;
        }
        .view-link {
            display: inline-flex; align-items: center; gap: 5px;
            color: #1e40af; text-decoration: none; font-size: 13px;
            font-weight: 600; margin-left: auto; transition: color 0.2s;
        }
        .view-link:hover { color: #1d4ed8; text-decoration: underline; }
        .view-link svg { width: 14px; height: 14px; }

        /* ==================== EMPTY STATE ==================== */
        .empty-state {
            text-align: center; padding: 60px 20px;
            background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px;
        }
        .empty-state svg { width: 64px; height: 64px; color: #d1d5db; margin-bottom: 16px; }
        .empty-state h3 { font-size: 18px; color: #374151; margin-bottom: 8px; }
        .empty-state p { font-size: 14px; color: #9ca3af; }
    </style>
</head>
